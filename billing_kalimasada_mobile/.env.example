# Salin ke `.env` (wajib ada agar bisa di-build — file ini di-daftarkan sebagai asset di pubspec).
# Tanpa slash di akhir. App memanggil API Node billing, bukan koneksi SQL langsung dari HP.

# URL server billing (prioritas pembacaan: API_URL, lalu BILLING_API_URL, lalu API_BASE_URL)
API_URL=http://38.253.240.243:30196

# Jika debug lewat IP/LAN, isi tenant karena server tidak menerima subdomain.
# Contoh dari URL web `http://192.168.166.197:4555/login?tenant=skynet`:
# API_URL=http://192.168.166.197:4555
# API_TENANT=skynet
#
# Jika pakai domain tenant, cukup gunakan origin tanpa `/login`:
# API_URL=https://skynet.kalimasada-app.com

# Produksi lebih aman dengan HTTPS + domain, mis.:
# API_URL=https://billing.kalimasada.example

# Pembaruan APK: app memeriksa GET {API_URL}/api/mobile-adapter/app-update/manifest terlebih dahulu.
# Admin mengunggah manifest.json + APK ke server (lihat public/mobile-app/manifest.example.json di repo billing).
