# Salin ke `.env` (wajib ada agar bisa di-build — file ini di-daftarkan sebagai asset di pubspec).
# Tanpa slash di akhir. App memanggil API Node billing, bukan koneksi SQL langsung dari HP.

# Hub API mobile unified (prioritas: API_URL, lalu BILLING_API_URL, lalu API_BASE_URL)
API_URL=https://mobile.kalimasada-app.com

# Satu APK untuk semua tenant: pilih tenant di layar login (disimpan di perangkat).
# Baris di bawah hanya fallback bila belum pernah login / belum pilih tenant:
# API_TENANT=default
#
# Contoh debug lewat IP/LAN (sama seperti web /login?tenant=skynet):
# API_URL=http://192.168.166.197:4555
# API_TENANT=default
#
# Jangan pakai manage.kalimasada-app.com sebagai API_URL — itu portal Super Admin.
# Jangan hardcode subdomain tenant sebagai API_URL untuk APK unified.

# Pembaruan APK: app memeriksa GET {API_URL}/api/mobile-adapter/app-update/manifest terlebih dahulu.
# Admin mengunggah manifest.json + APK ke server (lihat public/mobile-app/manifest.example.json di repo billing).
