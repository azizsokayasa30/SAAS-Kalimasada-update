# Salin ke .env dan sesuaikan. File .env tidak di-commit (lihat .gitignore).

# ========== Server bind ==========
# Port proses Node (override settings.json server_port jika di-set)
# Contoh produksi LAN:
# PORT=3003
PORT=4555

# Port khusus halaman isolir untuk walled garden Mikrotik.
# Pelanggan isolir diarahkan ke http://IP_SERVER:8899/isolir.
ISOLIR_PORT=8899

# IP LAN server billing yang terlihat oleh Mikrotik.
# Isi jika PUBLIC_APP_BASE_URL memakai domain/tunnel agar generator script punya to-addresses yang valid.
# ISOLIR_BILLING_SERVER_IP=192.168.8.89

# ========== URL publik (LAN / hostname / domain) — patokan untuk Android & link eksternal ==========
# Cara 1 (disarankan): satu baris URL lengkap, tanpa slash di akhir
# Contoh billing + portal pelanggan di LAN yang sama:
# PUBLIC_APP_BASE_URL=http://192.168.166.196:3003
# Contoh HTTPS:
# PUBLIC_APP_BASE_URL=https://billing.domain.com
PUBLIC_APP_BASE_URL=

# Alias opsional (sama artinya dengan PUBLIC_APP_BASE_URL)
PUBLIC_API_BASE_URL=

# Cara 2: jika PUBLIC_APP_BASE_URL kosong, susun dari scheme + host + port:
PUBLIC_APP_SCHEME=http
# Contoh LAN: PUBLIC_APP_HOST=192.168.166.196  dan  PUBLIC_APP_PORT=3003
PUBLIC_APP_HOST=
PUBLIC_APP_PORT=

# Prioritas: PUBLIC_APP_BASE_URL / PUBLIC_API_BASE_URL dulu;
# jika kosong, dipakai PUBLIC_APP_* + fallback server_host & server_port dari settings.json.

# ========== RADIUS SQLite (satu file dengan modul sql FreeRADIUS) ==========
# Jika billing dan FreeRADIUS di server yang sama, set ke path penuh file .db yang dipakai FR
# (cek mods-enabled/sql, sqlite { filename = ... }). Kosongkan jika pakai default data/radius.db di folder proyek.
# RADIUS_SQLITE_PATH=/var/lib/freeradius/radius.db

# Salinan clients.conf yang bisa dibaca user PM2 (opsional; default: data/clients.conf.mirror)
# Buat dengan: npm run radius:mirror-clients
# RADIUS_CLIENTS_CONF_MIRROR=/home/user/internet-express/data/clients.conf.mirror

# ========== RAM / Node (produksi pakai PM2) ==========
# Batas heap diatur di ecosystem.config.cjs (node_args --max-old-space-size).
# Jangan mengandalkan .env untuk NODE_OPTIONS max-old-space-size — harus saat proses Node dimulai (PM2).
# Di VPS sempit: pastikan hanya satu proses `node app.js` (PM2), tutup Cursor/IDE di server produksi.

# ========== Portal pelanggan (React, /customer-app/) ==========
# Setelah clone / deploy: jalankan sekali dari akar repo: npm run build:customer-portal
# Akses produksi (satu proses dengan billing): http://PUBLIC_APP_HOST:PORT/customer-app/
#
# Saat pengembangan portal React (npm run dev di customer-portal-web ATAU npm run dev:customer-portal
# dari akar repo), proxy /api ke billing mengikuti urutan (nilai di .env repo menimpa .env di folder portal):
#   1) VITE_PROXY_TARGET (di customer-portal-web/.env* atau di .env repo ini)
#   2) PUBLIC_APP_BASE_URL / PUBLIC_API_BASE_URL
#   3) PUBLIC_APP_SCHEME + PUBLIC_APP_HOST + PUBLIC_APP_PORT (atau PORT)
#   4) http://127.0.0.1:$PORT (default PORT di atas = 4555)
# Buka di browser untuk edit UI portal React: http://localhost:5173/customer-app/  (bukan port backend)
# Dua port saat dev: 5173 = Vite (UI), PORT di bawah = Express billing (API). Vite memproksi /api ke PORT itu.
# Contoh jika billing jalan di mesin lain:
# VITE_PROXY_TARGET=http://192.168.166.196:3003

# ========== Foto penyelesaian tugas teknisi (instalasi / gangguan) ==========
# Pindah ke disk/partisi lain jika root penuh (buat folder & chmod tulis dulu):
# FIELD_COMPLETION_UPLOAD_DIR=/mnt/data/field-completion
# Simpan foto job selesai (hari) sebelum dihapus otomatis:
# FIELD_COMPLETION_COMPLETED_RETENTION_DAYS=5
# Mode darurat (disk penuh): FIELD_COMPLETION_COMPLETED_RETENTION_DAYS_AGGRESSIVE=1
# FIELD_COMPLETION_ORPHAN_HOURS=48
# FIELD_COMPLETION_MAX_MB=3
# FIELD_COMPLETION_MIN_FREE_MB=80

# ========== Lain (contoh) ==========
# NODE_ENV=production
# SESSION_SECRET=ganti-dengan-string-acak-panjang
