{
  "name": "gembok-bill",
  "version": "2.1.0",
  "description": "Sistem Manajemen ISP Terintegrasi dengan WhatsApp Gateway untuk GenieACS, Mikrotik PPPoE, dan Hotspot Management",
  "main": "app.js",
  "scripts": {
    "start": "set NODE_ENV=development && node app.js",
    "dev": "set NODE_ENV=development && nodemon app.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --only billing-kalimasada --update-env",
    "pm2:restart": "pm2 restart billing-kalimasada --update-env",
    "pm2:stop": "pm2 stop billing-kalimasada",
    "pm2:delete": "pm2 delete billing-kalimasada",
    "pm2:kill": "pm2 kill",
    "pm2:save": "pm2 save",
    "pm2:logs": "pm2 logs billing-kalimasada",
    "doctor:process": "node scripts/doctor-process.js",
    "radius:check": "node scripts/radius-consistency-check.js",
    "radius:prep-verify": "bash scripts/verify-radius-manager-prep.sh",
    "radius:optimize-sqlite": "node scripts/optimize-radius-sqlite.js",
    "radius:optimize-freeradius": "bash scripts/optimize-freeradius-mass-auth.sh",
    "radius:fix-contention": "node scripts/fix-radius-sqlite-contention.js --yes",
    "radius:fix-production": "bash scripts/fix-radius-production.sh",
    "radius:health": "bash scripts/check-radius-mikrotik-health.sh",
    "radius:apply-fr-fix": "bash scripts/apply-freeradius-sqlite-fix.sh",
    "radius:migrate-mysql": "bash scripts/migrate-freeradius-sqlite-to-mysql.sh",
    "radius:mirror-clients": "bash scripts/mirror-radius-clients-conf.sh",
    "deploy:full-server": "sudo bash scripts/deploy-full-server.sh",
    "deploy:freeradius": "sudo bash scripts/install-freeradius-billing.sh",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "echo \"No build process required\"",
    "build:customer-portal": "cd customer-portal-web && npm install && npm run build",
    "dev:customer-portal": "npm --prefix customer-portal-web run dev",
    "setup": "npm install && node scripts/init-database.js",
    "platform:init": "node scripts/init-platform-saas.js",
    "prepare": "node scripts/git-hooks-install.js",
    "postpull": "bash scripts/post-git-pull.sh",
    "clean:onu-fallback": "node scripts/delete-fallback-onu-devices.js",
    "clean:onu-fallback:dry": "node scripts/delete-fallback-onu-devices.js --dry-run",
    "odp:purge-demo": "node scripts/purge-demo-odp-seed.js",
    "odp:purge-demo:dry": "node scripts/purge-demo-odp-seed.js --dry-run",
    "collectors:purge-demo": "node scripts/purge-demo-collectors-seed.js",
    "collectors:purge-demo:dry": "node scripts/purge-demo-collectors-seed.js --dry-run",
    "purge:demo-seed": "node scripts/purge-demo-seed-data.js",
    "purge:demo-seed:dry": "node scripts/purge-demo-seed-data.js --dry-run",
    "cleanup:field-photos": "node scripts/cleanup-field-completion-images.js",
    "cleanup:field-photos:aggressive": "node scripts/cleanup-field-completion-images.js --aggressive"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.21",
    "axios": "^1.6.7",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "compression": "^1.8.1",
    "connect-sqlite3": "^0.9.15",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "form-data": "^4.0.0",
    "geolib": "^3.3.4",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "midtrans-client": "^1.4.3",
    "multer": "^2.0.1",
    "mysql2": "^3.9.7",
    "net-snmp": "^3.26.3",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "node-routeros": "^1.6.9",
    "nodemailer": "^7.0.10",
    "pino": "^8.11.0",
    "puppeteer": "^24.31.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^5.1.7",
    "ssh2": "^1.17.0",
    "supertest": "^7.1.4",
    "turf": "^3.0.14",
    "winston": "^3.8.2",
    "xendit-node": "^7.0.0"
  },
  "devDependencies": {
    "ejs-lint": "^2.0.1",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "keywords": [
    "isp",
    "billing",
    "whatsapp",
    "genieacs",
    "mikrotik",
    "pppoe",
    "hotspot",
    "nodejs",
    "express"
  ],
  "author": "JINOM-HOMENET Team",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/alijayanet/gembok-bill.git"
  },
  "bugs": {
    "url": "https://github.com/alijayanet/gembok-bill/issues"
  },
  "homepage": "https://github.com/alijayanet/gembok-bill#readme"
}
