<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { active, adminName }) %>
<main class="km-main">
  <div class="km-topbar">
    <div>
      <h2>Reverse Proxy</h2>
      <p class="km-subtitle">Kelola domain <code><%= config.base_domain %></code> dan routing subdomain tenant</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <form method="POST" action="/management/settings/reverse-proxy/sync" class="d-inline">
        <button type="submit" class="btn btn-km-primary btn-sm" <%= !status.nginx_installed ? 'disabled' : '' %>>
          <i class="bi bi-arrow-repeat"></i> Sync Tenant
        </button>
      </form>
      <form method="POST" action="/management/settings/reverse-proxy/reload" class="d-inline">
        <button type="submit" class="btn btn-outline-secondary btn-sm" <%= !status.nginx_installed ? 'disabled' : '' %>>
          <i class="bi bi-arrow-clockwise"></i> Reload
        </button>
      </form>
    </div>
  </div>

  <%- include('../settings/_nav', { settingsSection }) %>

  <% if (flash && flash.success) { %>
    <div class="alert alert-success">
      <% if (flash.success === 'synced') { %>
        Nginx diperbarui — <strong><%= flash.count || config.tenant_subdomains.length %></strong> subdomain tenant aktif.
      <% } %>
      <% if (flash.success === 'subdomain_added') { %>Subdomain <code><%= flash.sub %>.<%= config.base_domain %></code> ditambahkan.<% } %>
      <% if (flash.success === 'subdomain_removed') { %>Subdomain manual dihapus.<% } %>
      <% if (flash.success === 'proxy_added') { %>Proxy <code><%= flash.host %></code> ditambahkan.<% } %>
      <% if (flash.success === 'proxy_removed') { %>Proxy eksternal dihapus.<% } %>
      <% if (flash.success === 'saved' || flash.success === 'applied') { %>Pengaturan disimpan dan diterapkan.<% } %>
      <% if (flash.success === 'reloaded') { %>Nginx berhasil di-reload.<% } %>
      <% if (flash.success === 'test_ok') { %>Test konfigurasi nginx -t berhasil.<% } %>
    </div>
  <% } %>

  <% if (flash && flash.error === 'ssl_missing') { %>
    <div class="alert alert-danger">
      <strong>SSL belum tersedia.</strong> Jalankan certbot di server, lalu aktifkan SSL lagi.
    </div>
  <% } else if (flash && flash.error) { %>
    <div class="alert alert-danger"><%= flash.error %></div>
  <% } %>

  <% if (typeof diagnostics !== 'undefined' && diagnostics.issues && diagnostics.issues.length) { %>
    <div class="alert alert-warning">
      <strong>Perlu perbaikan:</strong>
      <ul class="mb-0 mt-2"><% diagnostics.issues.forEach(function(issue) { %><li><%= issue %></li><% }); %></ul>
    </div>
  <% } %>

  <% if (!status.nginx_installed) { %>
    <div class="alert alert-warning mb-4">
      <strong>Nginx belum terinstall.</strong> Jalankan:
      <code>sudo bash /var/www/billing-kalimasada/scripts/setup-nginx-proxy.sh</code>
    </div>
  <% } %>

  <div class="row g-3 mb-4">
    <div class="col-md-4 col-6">
      <div class="km-stat">
        <div class="label">Status Nginx</div>
        <div class="value fs-6">
          <% if (!status.nginx_installed) { %>
            <span class="badge bg-secondary">Belum install</span>
          <% } else if (status.nginx_active) { %>
            <span class="badge bg-success">Aktif</span>
          <% } else { %>
            <span class="badge bg-warning text-dark">Tidak aktif</span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="col-md-4 col-6">
      <div class="km-stat">
        <div class="label">Tenant di Proxy</div>
        <div class="value"><%= (config.tenant_subdomains || []).length %></div>
      </div>
    </div>
    <div class="col-md-4 col-12">
      <div class="km-stat">
        <div class="label">Upstream</div>
        <div class="value fs-6"><code><%= config.upstream_host %>:<%= config.upstream_port %></code></div>
      </div>
    </div>
  </div>

  <div class="km-card mb-4">
    <h5 class="mb-3"><i class="bi bi-buildings me-1"></i> Tenant</h5>
    <% if (typeof tenantProxyRows !== 'undefined' && tenantProxyRows.length) { %>
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0">
        <thead>
          <tr><th>Tenant</th><th>URL</th><th>Status</th></tr>
        </thead>
        <tbody>
          <% tenantProxyRows.forEach(function(t) { %>
            <tr>
              <td><%= t.name %></td>
              <td>
                <a href="<%= t.url %>" target="_blank" rel="noopener" class="text-decoration-none" style="color: var(--accent)">
                  <%= t.hostname %>
                </a>
              </td>
              <td>
                <% if (t.proxyActive) { %>
                  <span class="badge bg-success">Aktif</span>
                <% } else { %>
                  <span class="badge bg-secondary">Pending</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <p class="km-subtitle small mb-0">Belum ada tenant. Tambahkan tenant lalu klik Sync.</p>
    <% } %>
  </div>

  <div class="km-card mb-4">
    <h5 class="mb-3"><i class="bi bi-hdd-network me-1"></i> Proxy ke Server Lain</h5>
    <% if (typeof customProxies !== 'undefined' && customProxies.length) { %>
    <div class="table-responsive mb-3">
      <table class="table table-sm table-hover mb-0">
        <thead>
          <tr><th>Domain</th><th>Target</th><th></th></tr>
        </thead>
        <tbody>
          <% customProxies.forEach(function(p) { %>
            <tr>
              <td><code><%= p.hostname %></code></td>
              <td><code><%= p.upstream_host %>:<%= p.upstream_port %></code></td>
              <td class="text-end">
                <form method="POST" action="/management/settings/reverse-proxy/proxies/remove" class="d-inline"
                      onsubmit="return confirm('Hapus proxy <%= p.hostname %>?');">
                  <input type="hidden" name="proxy_id" value="<%= p.id %>">
                  <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-2">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
    <form method="POST" action="/management/settings/reverse-proxy/proxies/add" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small mb-1">Subdomain</label>
        <div class="input-group input-group-sm">
          <input type="text" name="hostname" class="form-control" placeholder="bna" required>
          <span class="input-group-text">.<%= config.base_domain %></span>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label small mb-1">Target (IP:port)</label>
        <div class="input-group input-group-sm">
          <input type="text" name="upstream_host" class="form-control" placeholder="192.168.1.10" required>
          <span class="input-group-text">:</span>
          <input type="number" name="upstream_port" class="form-control" value="3003" min="1" max="65535" required style="max-width:5rem;">
        </div>
      </div>
      <div class="col-md-3">
        <label class="form-label small mb-1">Label <span class="text-muted">(opsional)</span></label>
        <input type="text" name="label" class="form-control form-control-sm" placeholder="Cabang BNA">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary btn-sm w-100" <%= !status.nginx_installed ? 'disabled' : '' %>>
          <i class="bi bi-plus-lg"></i> Tambah
        </button>
      </div>
    </form>
  </div>

  <div class="km-card">
    <h5 class="mb-3"><i class="bi bi-gear me-1"></i> Pengaturan</h5>
    <form method="POST" action="/management/settings/reverse-proxy/save">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Domain Utama</label>
          <input type="text" name="base_domain" class="form-control form-control-sm" value="<%= config.base_domain %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Subdomain Management</label>
          <input type="text" name="central_subdomain" class="form-control form-control-sm" value="<%= config.central_subdomain %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Upstream Host</label>
          <input type="text" name="upstream_host" class="form-control form-control-sm" value="<%= config.upstream_host %>" required>
        </div>
        <div class="col-md-2">
          <label class="form-label">Port</label>
          <input type="number" name="upstream_port" class="form-control form-control-sm" value="<%= config.upstream_port %>" min="1" max="65535" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">IP Server (LAN)</label>
          <input type="text" name="server_ip" class="form-control form-control-sm" value="<%= config.server_ip %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">IP Publik (DNS)</label>
          <input type="text" name="public_ip" class="form-control form-control-sm" value="<%= config.public_ip || '' %>">
        </div>
        <div class="col-12">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" name="ssl_enabled" id="ssl_enabled" <%= config.ssl_enabled ? 'checked' : '' %>>
            <label class="form-check-label" for="ssl_enabled">Aktifkan HTTPS (SSL)</label>
          </div>
          <% if (typeof sslStatus !== 'undefined' && !sslStatus.ok) { %>
            <div class="form-text text-warning small"><%= sslStatus.error %></div>
          <% } %>
        </div>
      </div>

      <details class="mt-3">
        <summary class="small text-muted" style="cursor:pointer;">Pengaturan lanjutan</summary>
        <div class="row g-3 mt-1">
          <div class="col-md-3">
            <label class="form-label">Listen Port</label>
            <input type="number" name="listen_port" class="form-control form-control-sm" value="<%= config.listen_port %>" min="1" max="65535">
          </div>
          <div class="col-md-9">
            <label class="form-label">Domain Tambahan</label>
            <input type="text" name="custom_hosts" class="form-control form-control-sm"
                   value="<%= (config.custom_hosts || []).join(', ') %>" placeholder="billing.example.com">
          </div>
          <div class="col-12">
            <label class="form-label">Subdomain Manual</label>
            <textarea name="manual_subdomains" class="form-control form-control-sm" rows="2"
                      placeholder="staging, demo"><%= (config.manual_subdomains || []).join('\n') %></textarea>
          </div>
          <div class="col-md-6 ssl-fields" style="<%= config.ssl_enabled ? '' : 'display:none' %>">
            <label class="form-label">SSL Certificate</label>
            <input type="text" name="ssl_cert_path" class="form-control form-control-sm" value="<%= config.ssl_cert_path %>">
          </div>
          <div class="col-md-6 ssl-fields" style="<%= config.ssl_enabled ? '' : 'display:none' %>">
            <label class="form-label">SSL Private Key</label>
            <input type="text" name="ssl_key_path" class="form-control form-control-sm" value="<%= config.ssl_key_path %>">
          </div>
        </div>
      </details>

      <input type="hidden" name="auto_sync_on_tenant_change" value="on">
      <div class="d-flex gap-2 mt-4 flex-wrap">
        <button type="submit" class="btn btn-km-primary btn-sm" <%= !status.nginx_installed ? 'disabled' : '' %>>
          <i class="bi bi-check-lg"></i> Simpan & Terapkan
        </button>
        <button type="submit" formaction="/management/settings/reverse-proxy/test" class="btn btn-outline-info btn-sm" <%= !status.nginx_installed ? 'disabled' : '' %>>
          Test nginx -t
        </button>
        <a href="/management/settings/reverse-proxy/preview" target="_blank" class="btn btn-outline-secondary btn-sm">Preview config</a>
      </div>
      <% if (config.last_apply_message) { %>
        <p class="small mt-3 mb-0 <%= config.last_apply_ok ? 'text-success' : 'text-danger' %>">
          <%= config.last_apply_message %>
        </p>
      <% } %>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
<script>
document.getElementById('ssl_enabled')?.addEventListener('change', function() {
  document.querySelectorAll('.ssl-fields').forEach(function(el) {
    el.style.display = this.checked ? '' : 'none';
  }.bind(this));
});
</script>
