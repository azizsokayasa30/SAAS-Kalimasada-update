<!DOCTYPE html>
<html lang="id">
<head>
  <script>
    (function(){
      try {
        var stored = localStorage.getItem('kalimasada_theme');
        var theme = (stored === 'dark' || stored === 'light') ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch(e) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Kalimasada Management Portal</title>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme-system.css?v=6">
  <link rel="stylesheet" href="/css/management-login.css?v=2">
</head>
<body class="km-login-page">

  <main class="km-login-shell">

    <!-- Hero: branding + motivasi -->
    <section class="km-login-hero" aria-label="Branding Kalimasada">
      <div class="km-login-eyebrow">
        <i class="bi bi-layers-fill"></i>
        Portal Management Multi-Tenant
      </div>

      <div class="km-login-brand">
        <div class="km-login-brand-logo">
          <img src="/img/logo.svg" alt="Logo Kalimasada" onerror="this.style.display='none'">
        </div>
        <div>
          <p class="km-login-company">PT Kalimasada Inti Sarana</p>
          <p class="km-login-product">Kalimasada Management Portal</p>
        </div>
      </div>

      <h1>Membangun ISP andal dimulai dari manajemen yang kuat.</h1>
      <p>Platform dedicated untuk mengelola seluruh tenant billing Kalimasada dari satu pusat kendali.</p>

      <div class="km-login-motivation">
        <div class="km-motivation-card">
          <i class="bi bi-diagram-3-fill"></i>
          <div>
            <strong>Manajemen terpusat</strong>
            <span>Satu dashboard untuk tenant, reverse proxy, dan mobile app.</span>
          </div>
        </div>
        <div class="km-motivation-card">
          <i class="bi bi-lightning-charge-fill"></i>
          <div>
            <strong>Keputusan lebih cepat</strong>
            <span>Data terstruktur membuat operasional ISP lebih responsif.</span>
          </div>
        </div>
        <div class="km-motivation-card">
          <i class="bi bi-graph-up-arrow"></i>
          <div>
            <strong>Skala dengan percaya diri</strong>
            <span>Multi-tenant yang rapi, siap tumbuh bersama jaringan Anda.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Login card -->
    <section aria-label="Form login">
      <div class="km-login-card">
        <div class="km-login-card-inner">

          <div class="km-login-card-brand">
            <div class="km-login-brand-logo">
              <img src="/img/logo.svg" alt="Logo Kalimasada" onerror="this.style.display='none'">
            </div>
            <div>
              <p class="km-login-card-title">Kalimasada Management</p>
              <p class="km-login-card-subtitle">Portal Super Admin</p>
            </div>
          </div>

          <div class="km-login-heading">
            <h2>Selamat datang</h2>
            <p>Masuk ke portal management untuk mengelola seluruh tenant SaaS Kalimasada.</p>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger py-2" role="alert"><%= error %></div>
          <% } %>
          <% if (success) { %>
            <div class="alert alert-success py-2" role="alert"><%= success %></div>
          <% } %>

          <form method="POST" action="/management/login" class="km-login-form">
            <div class="mb-3">
              <label class="form-label" for="email">Email</label>
              <div class="km-input-wrap">
                <i class="bi bi-envelope-fill"></i>
                <input type="email" id="email" name="email" class="form-control"
                  placeholder="management@kalimasada" required autofocus autocomplete="email">
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label" for="password">Password</label>
              <div class="km-input-wrap">
                <i class="bi bi-lock-fill"></i>
                <input type="password" id="password" name="password" class="form-control"
                  placeholder="••••••••" required autocomplete="current-password">
              </div>
            </div>
            <button type="submit" class="km-btn-login">
              <i class="bi bi-box-arrow-in-right"></i>
              Masuk Portal
            </button>
            <button type="button" class="km-login-theme-btn" id="globalThemeToggle" title="Ganti tema">
              <i class="bi bi-moon-fill" id="themeToggleIcon"></i>
              <span id="themeToggleLabel">Tema Terang</span>
            </button>
          </form>

          <p class="km-login-footer">
            Dedicated Platform · PT Kalimasada Inti Sarana · Shared DB Multi-Tenant
          </p>

        </div>
      </div>
    </section>

  </main>

  <script src="/js/theme-switcher.js?v=1"></script>
</body>
</html>
