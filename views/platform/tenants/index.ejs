<%
const summary = {
  customers: { total: 0, active: 0, inactive: 0, new: 0 },
  invoices: { total: 0, paid: 0, unpaid: 0, isolir: 0 },
};
tenants.forEach(function(t) {
  const c = t.usage?.customers || {};
  const inv = t.usage?.invoices || {};
  summary.customers.total += Number(c.total) || 0;
  summary.customers.active += Number(c.active) || 0;
  summary.customers.inactive += Number(c.inactive) || 0;
  summary.customers.new += Number(c.new) || 0;
  summary.invoices.total += Number(inv.total) || 0;
  summary.invoices.paid += Number(inv.paid) || 0;
  summary.invoices.unpaid += Number(inv.unpaid) || 0;
  summary.invoices.isolir += Number(inv.isolir) || 0;
});
%>
<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { active: 'tenants', adminName }) %>
<main class="km-main">
  <div class="km-topbar">
    <div>
      <h2>Kelola Tenant</h2>
      <p class="km-subtitle">Kelola unit operasional billing Kalimasada</p>
    </div>
  </div>

  <% if (flash && flash.success === 'deleted') { %>
    <div class="alert alert-success">Tenant berhasil dihapus.</div>
  <% } %>
  <% if (flash && flash.success === 'restored') { %>
    <div class="alert alert-success">
      Restore selesai — <%= flash.created || 0 %> dibuat, <%= flash.updated || 0 %> diperbarui, <%= flash.skipped || 0 %> dilewati.
      <% if (flash.warn) { %><span class="d-block small mt-1"><%= flash.warn %></span><% } %>
    </div>
  <% } %>
  <% if (flash && flash.success === 'imported') { %>
    <div class="alert alert-success">
      Import Excel selesai — <%= flash.created || 0 %> dibuat, <%= flash.updated || 0 %> diperbarui, <%= flash.skipped || 0 %> dilewati.
      <% if (flash.warn) { %><span class="d-block small mt-1"><%= flash.warn %></span><% } %>
    </div>
  <% } %>
  <% if (flash && flash.error) { %>
    <div class="alert alert-danger"><%= flash.error %></div>
  <% } %>

  <%
    const statsFilters = typeof filters !== 'undefined' && filters ? filters : {};
    const selectedMonth = statsFilters.month != null ? statsFilters.month : (new Date().getMonth() + 1);
    const selectedYear = statsFilters.year != null ? Number(statsFilters.year) : new Date().getFullYear();
    const periodLabel = statsFilters.label || '';
    const monthNamesId = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    const cyFilter = new Date().getFullYear();
  %>
  <div class="km-card km-card--toolbar mb-3">
    <form method="GET" action="/management/tenants" class="km-tenant-toolbar">
      <div class="km-tenant-toolbar__filters">
        <select name="month" class="form-select form-select-sm" aria-label="Bulan" title="Bulan">
          <option value="all" <%= String(selectedMonth) === 'all' ? 'selected' : '' %>>Satu tahun</option>
          <% for (let m = 1; m <= 12; m++) { %>
            <option value="<%= m %>" <%= String(selectedMonth) === String(m) ? 'selected' : '' %>><%= monthNamesId[m - 1] %></option>
          <% } %>
        </select>
        <select name="year" class="form-select form-select-sm" aria-label="Tahun" title="Tahun">
          <% for (let y = cyFilter - 3; y <= cyFilter + 1; y++) { %>
            <option value="<%= y %>" <%= selectedYear === y ? 'selected' : '' %>><%= y %></option>
          <% } %>
        </select>
        <button type="submit" class="btn btn-km-primary btn-sm" title="Filter statistik">
          <i class="bi bi-funnel"></i><span class="km-tenant-toolbar__btn-text"> Filter</span>
        </button>
        <% if (periodLabel) { %>
          <span class="km-tenant-toolbar__period"><%= periodLabel %></span>
        <% } %>
      </div>
      <div class="km-tenant-toolbar__actions">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#backupRestoreModal" title="Backup &amp; Restore">
          <i class="bi bi-cloud-arrow-up"></i><span class="km-tenant-toolbar__btn-text"> Backup</span>
        </button>
        <a href="/management/tenants/new" class="btn btn-km-primary btn-sm" title="Tambah Tenant">
          <i class="bi bi-plus-lg"></i><span class="km-tenant-toolbar__btn-text"> Tambah</span>
        </a>
      </div>
    </form>
  </div>

  <div class="km-card km-card--flush">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 km-tenant-table">
        <thead>
          <tr class="km-tenant-table__head-main">
            <th rowspan="2" class="km-tenant-table__sticky-col">ID</th>
            <th rowspan="2">Nama Tenant</th>
            <th rowspan="2">Subdomain</th>
            <th rowspan="2">Owner</th>
            <th colspan="4" class="km-th-group km-th-group--customers">Pelanggan</th>
            <th colspan="4" class="km-th-group km-th-group--invoices">Tagihan <span class="fw-normal" style="opacity:.75;font-size:.75em">(<%= periodLabel %>)</span></th>
            <th rowspan="2" class="text-end km-tenant-table__actions-col">Aksi</th>
          </tr>
          <tr class="km-tenant-table__head-sub">
            <th class="km-metric-th">Total</th>
            <th class="km-metric-th">Aktif</th>
            <th class="km-metric-th">Nonaktif</th>
            <th class="km-metric-th km-th-group--customers-end">Baru</th>
            <th class="km-metric-th">Total</th>
            <th class="km-metric-th">Lunas</th>
            <th class="km-metric-th">Belum Lunas</th>
            <th class="km-metric-th km-th-group--invoices-end">Isolir</th>
          </tr>
        </thead>
        <tbody>
          <% if (!tenants.length) { %>
            <tr><td colspan="13" class="text-center py-4" style="color: var(--text-muted)">Belum ada tenant. Klik "Tambah Tenant" untuk memulai.</td></tr>
          <% } %>
          <% tenants.forEach(function(t) {
            const c = t.usage.customers || {};
            const inv = t.usage.invoices || {};
          %>
            <tr>
              <td class="km-tenant-table__sticky-col">#<%= t.id %></td>
              <td class="fw-semibold"><%= t.name %></td>
              <td><code><%= t.subdomain %></code></td>
              <td>
                <div><%= t.owner_name %></div>
                <small style="color: var(--text-muted)"><%= t.owner_email %></small>
              </td>
              <td class="km-metric-cell km-metric-cell--num"><%= c.total || 0 %></td>
              <td class="km-metric-cell km-metric-cell--num km-metric-cell--success"><%= c.active || 0 %></td>
              <td class="km-metric-cell km-metric-cell--num km-metric-cell--muted"><%= c.inactive || 0 %></td>
              <td class="km-metric-cell km-metric-cell--num km-metric-cell--accent km-th-group--customers-end"><%= c.new || 0 %></td>
              <td class="km-metric-cell km-metric-cell--money"><%= formatRupiah(inv.total) %></td>
              <td class="km-metric-cell km-metric-cell--money km-metric-cell--success"><%= formatRupiah(inv.paid) %></td>
              <td class="km-metric-cell km-metric-cell--money km-metric-cell--warning"><%= formatRupiah(inv.unpaid) %></td>
              <td class="km-metric-cell km-metric-cell--money km-metric-cell--danger km-th-group--invoices-end"><%= formatRupiah(inv.isolir) %></td>
              <td class="text-end">
                <div class="km-actions">
                  <a href="/management/tenants/<%= t.id %>" class="btn btn-sm btn-outline-secondary" title="Detail"><i class="bi bi-eye"></i></a>
                  <a href="/management/tenants/<%= t.id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                  <button type="button" class="btn btn-sm btn-outline-danger" title="Hapus"
                    data-bs-toggle="modal" data-bs-target="#deleteModal-<%= t.id %>"><i class="bi bi-trash"></i></button>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (tenants.length) { %>
  <section class="km-report-summary" aria-label="Ringkasan keseluruhan tenant">
    <div class="km-report-summary__header">
      <div>
        <h5 class="km-report-summary__title">Ringkasan Keseluruhan</h5>
        <p class="km-report-summary__subtitle">Total agregat dari <%= tenants.length %> tenant aktif · periode <%= periodLabel %></p>
      </div>
      <span class="km-report-summary__badge"><%= tenants.length %> tenant</span>
    </div>

    <div class="table-responsive">
      <table class="table mb-0 km-report-summary__table">
        <thead>
          <tr>
            <th colspan="4" class="km-report-summary__label-col">Pelanggan</th>
            <th colspan="4" class="km-report-summary__label-col">Tagihan</th>
          </tr>
          <tr class="km-report-summary__subhead">
            <th>Total</th>
            <th>Aktif</th>
            <th>Nonaktif</th>
            <th>Baru</th>
            <th>Total</th>
            <th>Lunas</th>
            <th>Belum Lunas</th>
            <th>Isolir</th>
          </tr>
        </thead>
        <tbody>
          <tr class="km-report-summary__total-row">
            <td class="km-metric-cell km-metric-cell--num"><%= summary.customers.total %></td>
            <td class="km-metric-cell km-metric-cell--num km-metric-cell--success"><%= summary.customers.active %></td>
            <td class="km-metric-cell km-metric-cell--num km-metric-cell--muted"><%= summary.customers.inactive %></td>
            <td class="km-metric-cell km-metric-cell--num km-metric-cell--accent"><%= summary.customers.new %></td>
            <td class="km-metric-cell km-metric-cell--money"><%= formatRupiah(summary.invoices.total) %></td>
            <td class="km-metric-cell km-metric-cell--money km-metric-cell--success"><%= formatRupiah(summary.invoices.paid) %></td>
            <td class="km-metric-cell km-metric-cell--money km-metric-cell--warning"><%= formatRupiah(summary.invoices.unpaid) %></td>
            <td class="km-metric-cell km-metric-cell--money km-metric-cell--danger"><%= formatRupiah(summary.invoices.isolir) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
  <% } %>
</main>

<%- include('_backup-restore', { backups }) %>

<% tenants.forEach(function(t) { %>
  <div class="modal fade km-modal" id="deleteModal-<%= t.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <form method="POST" action="/management/tenants/<%= t.id %>/delete" class="modal-content">
        <input type="hidden" name="redirect" value="list">
        <div class="modal-header">
          <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-1"></i> Hapus Tenant</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
        </div>
        <div class="modal-body">
          <p class="mb-2">Anda akan menghapus tenant berikut:</p>
          <ul class="mb-3">
            <li><strong><%= t.name %></strong></li>
            <li>Subdomain: <code><%= t.subdomain %></code></li>
            <li>Owner: <%= t.owner_email %></li>
          </ul>
          <p class="mb-0" style="color: var(--badge-warning-text); background: var(--badge-warning-bg); padding: 0.65rem 0.85rem; border-radius: 8px; font-size: 0.9rem;">
            Soft delete — data bisnis tenant tetap di database tetapi tenant tidak bisa diakses.
          </p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-danger">Ya, Hapus Tenant</button>
        </div>
      </form>
    </div>
  </div>
<% }); %>

<%- include('../partials/footer') %>
