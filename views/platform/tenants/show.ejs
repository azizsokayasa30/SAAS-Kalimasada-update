<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { active: 'tenants', adminName }) %>
<main class="km-main">
  <div class="km-topbar">
    <div>
      <h2><%= tenant.name %></h2>
      <p class="km-subtitle">
        <code><%= tenantHostname %></code>
        · <a href="<%= tenantLoginUrl %>" target="_blank" rel="noopener"><%= tenantLoginUrl %></a>
      </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/management/tenants" class="btn btn-outline-secondary btn-sm">← Daftar</a>
      <a href="/management/tenants/<%= tenant.id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
      <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal">Hapus</button>
    </div>
  </div>

  <% if (flash && flash.success) { %>
    <div class="alert alert-success">
      <% if (flash.success === 'created') { %>Tenant berhasil dibuat. Subdomain otomatis diaktifkan di reverse proxy.<% } %>
      <% if (flash.success === 'updated') { %>Perubahan tenant disimpan. Reverse proxy diperbarui.<% } %>
      <% if (flash.success === 'credentials') { %>Username &amp; password admin tenant berhasil diperbarui.<% } %>
    </div>
  <% } %>
  <% if (flash && flash.nginx_warn) { %>
    <div class="alert alert-warning">
      <strong>Reverse proxy:</strong> <%= flash.nginx_warn %>
      <a href="/management/settings/reverse-proxy" class="alert-link">Buka halaman Reverse Proxy</a> untuk aktivasi manual.
    </div>
  <% } %>
  <% if (flash && flash.error) { %><div class="alert alert-danger"><%= flash.error %></div><% } %>

  <div class="row g-3 mb-4">
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Pelanggan Total</div><div class="value"><%= usage.customers.total || 0 %></div></div></div>
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Pelanggan Aktif</div><div class="value text-success"><%= usage.customers.active || 0 %></div></div></div>
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Nonaktif</div><div class="value text-muted"><%= usage.customers.inactive || 0 %></div></div></div>
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Baru Bulan Ini</div><div class="value" style="color: var(--accent)"><%= usage.customers.new || 0 %></div></div></div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Tagihan Total</div><div class="value"><%= formatRupiah(usage.invoices.total) %></div></div></div>
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Lunas</div><div class="value text-success"><%= formatRupiah(usage.invoices.paid) %></div></div></div>
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Belum Lunas</div><div class="value text-warning"><%= formatRupiah(usage.invoices.unpaid) %></div></div></div>
    <div class="col-md-3 col-6"><div class="km-stat"><div class="label">Isolir</div><div class="value text-danger"><%= formatRupiah(usage.invoices.isolir) %></div></div></div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-4 col-6"><div class="km-stat"><div class="label">Router / NAS</div><div class="value"><%= usage.routers || 0 %></div></div></div>
  </div>

  <div class="row g-3">
    <div class="col-lg-6">
      <div class="km-card h-100">
        <h5 class="mb-3">Informasi Tenant</h5>
        <table class="table table-sm mb-0">
          <tr><td>Owner</td><td><%= tenant.owner_name %></td></tr>
          <tr><td>Email</td><td><%= tenant.owner_email %></td></tr>
          <tr><td>WhatsApp</td><td><%= tenant.owner_phone %></td></tr>
          <tr><td>Provisioned</td><td><%= tenant.provisioned_at || '-' %></td></tr>
        </table>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="km-card h-100">
        <h5 class="mb-3">Kredensial Admin Tenant</h5>
        <p class="km-subtitle small">URL produksi memakai subdomain tenant. Untuk akses via IP/LAN, gunakan URL pengembangan.</p>
        <table class="table table-sm mb-0">
          <tr><td>Domain Tenant</td><td><code><%= tenantHostname %></code></td></tr>
          <tr><td>URL Login</td><td><a href="<%= tenantLoginUrl %>" target="_blank" rel="noopener"><code><%= tenantLoginUrl %></code></a></td></tr>
          <tr><td>URL Dev (IP/LAN)</td><td><a href="<%= tenantDevLoginUrl %>" target="_blank" rel="noopener"><code><%= tenantDevLoginUrl %></code></a></td></tr>
          <tr>
            <td>Username</td>
            <td>
              <code id="tenantAdminUser"><%= tenant.settings.admin_username %></code>
              <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 ms-1" onclick="navigator.clipboard.writeText(document.getElementById('tenantAdminUser').textContent.trim())">Salin</button>
              <button type="button" class="btn btn-outline-primary btn-sm py-0 px-1 ms-1" data-bs-toggle="modal" data-bs-target="#credentialsModal"><i class="bi bi-pencil"></i> Ubah</button>
            </td>
          </tr>
          <tr>
            <td>Password</td>
            <td>
              <code id="tenantAdminPass"><%= tenant.settings.admin_password %></code>
              <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 ms-1" onclick="navigator.clipboard.writeText(document.getElementById('tenantAdminPass').textContent.trim())">Salin</button>
              <button type="button" class="btn btn-outline-primary btn-sm py-0 px-1 ms-1" data-bs-toggle="modal" data-bs-target="#credentialsModal"><i class="bi bi-pencil"></i> Ubah</button>
            </td>
          </tr>
        </table>
      </div>
    </div>
    <div class="col-12">
      <div class="km-card">
        <h5 class="mb-3">Log Provisioning</h5>
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead><tr><th>Step</th><th>Status</th><th>Waktu</th><th>Error</th></tr></thead>
            <tbody>
              <% if (!logs.length) { %><tr><td colspan="4" style="color: var(--text-muted)">Tidak ada log.</td></tr><% } %>
              <% logs.forEach(function(l) { %>
                <tr>
                  <td><%= l.step %></td>
                  <td><%= l.status %></td>
                  <td><%= l.completed_at || l.started_at || '-' %></td>
                  <td class="small" style="color: var(--color-danger)"><%= l.error_message || '' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<div class="modal fade km-modal" id="credentialsModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form method="POST" action="/management/tenants/<%= tenant.id %>/credentials" class="modal-content" autocomplete="off">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-key me-1"></i> Ubah Kredensial Admin Tenant</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="km-subtitle small mb-3">
          Kredensial ini dipakai admin <strong><%= tenant.name %></strong> untuk login di
          <a href="<%= tenantLoginUrl %>" target="_blank" rel="noopener"><%= tenantHostname %></a>.
          Perubahan langsung berlaku.
        </p>
        <div class="mb-3">
          <label class="form-label">Username</label>
          <input type="text" name="admin_username" class="form-control"
                 value="<%= tenant.settings.admin_username %>"
                 pattern="[a-zA-Z0-9._-]+" required
                 placeholder="admin">
          <small class="text-muted">Hanya huruf, angka, titik, strip, dan underscore.</small>
        </div>
        <div class="mb-2">
          <label class="form-label">Password Baru</label>
          <div class="input-group">
            <input type="password" name="admin_password" id="credPassword" class="form-control"
                   minlength="4" placeholder="Kosongkan bila tidak diubah">
            <button type="button" class="btn btn-outline-secondary" id="toggleCredPassword" tabindex="-1">
              <i class="bi bi-eye"></i>
            </button>
          </div>
          <small class="text-muted">Minimal 4 karakter. Biarkan kosong untuk mempertahankan password lama.</small>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Simpan</button>
      </div>
    </form>
  </div>
</div>

<div class="modal fade km-modal" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form method="POST" action="/management/tenants/<%= tenant.id %>/delete" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-1"></i> Hapus Tenant</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-2" style="color: var(--badge-warning-text); background: var(--badge-warning-bg); padding: 0.65rem 0.85rem; border-radius: 8px; font-size: 0.9rem;">
          Soft delete — tenant ditandai deleted dan tidak bisa diakses.
        </p>
        <p class="mb-0">Yakin hapus <strong><%= tenant.name %></strong>?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="submit" class="btn btn-danger">Hapus Tenant</button>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    var toggle = document.getElementById('toggleCredPassword');
    var input = document.getElementById('credPassword');
    if (toggle && input) {
      toggle.addEventListener('click', function () {
        var isPw = input.type === 'password';
        input.type = isPw ? 'text' : 'password';
        var icon = toggle.querySelector('i');
        if (icon) icon.className = isPw ? 'bi bi-eye-slash' : 'bi bi-eye';
      });
    }
  })();
</script>

<%- include('../partials/footer') %>
