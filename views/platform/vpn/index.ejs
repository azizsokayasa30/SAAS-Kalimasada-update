<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { active, adminName }) %>
<main class="km-main">
  <div class="km-topbar">
    <div>
      <h2>VPN Server</h2>
      <p class="km-subtitle">WireGuard (RouterOS v7) &amp; L2TP/IPsec (RouterOS v6) — script VPS &amp; MikroTik</p>
    </div>
  </div>

  <%- include('_nav', { vpnSection }) %>

  <% if (flash && flash.success === 'saved') { %><div class="alert alert-success">Pengaturan VPN berhasil disimpan.</div><% } %>
  <% if (flash && flash.success === 'keys') { %><div class="alert alert-success">Keypair WireGuard berhasil digenerate.</div><% } %>
  <% if (flash && flash.success === 'psk') { %><div class="alert alert-success">IPsec PSK berhasil digenerate.</div><% } %>
  <% if (flash && flash.error) { %><div class="alert alert-danger"><%= flash.error %></div><% } %>

  <form method="POST" action="/management/vpn" class="km-settings-form">
    <div class="km-card mb-4">
      <h5 class="mb-3">Umum</h5>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Public Endpoint (IP / hostname VPS)</label>
          <input type="text" name="public_endpoint" class="form-control" required
                 value="<%= server.public_endpoint || '' %>" placeholder="31.97.51.19">
        </div>
        <div class="col-md-3">
          <label class="form-label">WAN Interface (NAT)</label>
          <input type="text" name="wan_interface" class="form-control"
                 value="<%= server.wan_interface || 'eth0' %>" placeholder="eth0">
        </div>
        <div class="col-md-3">
          <label class="form-label">Tunnel Address Server</label>
          <input type="text" name="tunnel_address" class="form-control"
                 value="<%= server.tunnel_address || '10.10.0.1/24' %>" placeholder="10.10.0.1/24">
        </div>
        <div class="col-md-6">
          <label class="form-label">Network Subnet</label>
          <input type="text" name="network_subnet" class="form-control"
                 value="<%= server.network_subnet || '10.10.0.0/24' %>" placeholder="10.10.0.0/24">
          <small class="text-muted">Pool Tunnel IP bersama untuk WireGuard dan L2TP.</small>
        </div>
      </div>
    </div>

    <div class="km-card mb-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h5 class="mb-0">WireGuard <span class="badge <%= wgReady ? 'bg-success' : 'bg-secondary' %>"><%= wgReady ? 'Siap' : 'Belum siap' %></span></h5>
      </div>
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label">Listen Port</label>
          <input type="number" name="listen_port" class="form-control" min="1" max="65535"
                 value="<%= server.listen_port || 51820 %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Interface Name</label>
          <input type="text" name="interface_name" class="form-control"
                 value="<%= server.interface_name || 'wg0' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Server Public Key</label>
          <input type="text" name="server_public_key" class="form-control font-monospace"
                 value="<%= server.server_public_key || '' %>" placeholder="Base64 public key" autocomplete="off">
        </div>
        <div class="col-md-6">
          <label class="form-label">Server Private Key</label>
          <div class="input-group">
            <input type="password" name="server_private_key" id="serverPrivateKey" class="form-control font-monospace"
                   value="" placeholder="<%= server.server_private_key ? '•••• tersimpan — isi untuk mengganti' : 'Private key WireGuard' %>" autocomplete="off">
            <button type="button" class="btn btn-outline-secondary" id="togglePrivKey" title="Tampilkan / sembunyikan">
              <i class="bi bi-eye"></i>
            </button>
          </div>
          <small class="text-muted">Kosongkan untuk mempertahankan private key yang sudah tersimpan.</small>
        </div>
      </div>
      <div class="mt-3">
        <button type="submit" formaction="/management/vpn/generate-keys" formmethod="POST"
                class="btn btn-outline-primary btn-sm" onclick="return confirm('Generate keypair WireGuard baru? Key lama akan diganti.')">
          <i class="bi bi-key me-1"></i> Generate Keypair WireGuard
        </button>
      </div>
    </div>

    <div class="km-card mb-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h5 class="mb-0">L2TP/IPsec <span class="badge <%= l2tpReady ? 'bg-success' : 'bg-secondary' %>"><%= l2tpReady ? 'Siap' : 'Belum siap' %></span></h5>
      </div>
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label">IPsec PSK (shared secret)</label>
          <div class="input-group">
            <input type="password" name="ipsec_psk" id="ipsecPsk" class="form-control font-monospace"
                   value="" placeholder="<%= server.ipsec_psk ? '•••• tersimpan — isi untuk mengganti' : 'Shared secret IPsec' %>" autocomplete="off">
            <button type="button" class="btn btn-outline-secondary" id="toggleIpsecPsk" title="Tampilkan / sembunyikan">
              <i class="bi bi-eye"></i>
            </button>
          </div>
          <small class="text-muted">Kosongkan untuk mempertahankan PSK yang sudah tersimpan. Dipakai semua client L2TP.</small>
        </div>
        <div class="col-md-4">
          <label class="form-label">Status L2TP</label>
          <select name="l2tp_enabled" class="form-select">
            <option value="1" <%= Number(server.l2tp_enabled) !== 0 ? 'selected' : '' %>>Aktif</option>
            <option value="0" <%= Number(server.l2tp_enabled) === 0 ? 'selected' : '' %>>Nonaktif</option>
          </select>
        </div>
      </div>
      <div class="mt-3">
        <button type="submit" formaction="/management/vpn/generate-ipsec-psk" formmethod="POST"
                class="btn btn-outline-primary btn-sm" onclick="return confirm('Generate IPsec PSK baru? Client L2TP perlu update secret.')">
          <i class="bi bi-key me-1"></i> Generate IPsec PSK
        </button>
      </div>
    </div>

    <div class="mb-4 d-flex justify-content-end">
      <button type="submit" class="btn btn-km-primary px-4">
        <i class="bi bi-check-lg me-1"></i> Simpan Pengaturan
      </button>
    </div>
  </form>

  <div class="row g-4">
    <div class="col-lg-6">
      <div class="km-card h-100">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <div>
            <h5 class="mb-1">Script Setup VPS — WireGuard</h5>
            <p class="text-muted small mb-0"><%= (wgPeers || []).filter(function(p){ return p.is_active; }).length %> peer aktif.</p>
          </div>
          <a href="/management/vpn/vps-script" class="btn btn-sm btn-km-primary">
            <i class="bi bi-download me-1"></i> Download .sh
          </a>
        </div>
        <pre class="bg-dark text-light p-3 rounded small mb-0" style="max-height: 280px; overflow: auto;"><code><%= vpsScript %></code></pre>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="km-card h-100">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <div>
            <h5 class="mb-1">Script Setup VPS — L2TP/IPsec</h5>
            <p class="text-muted small mb-0"><%= (l2tpPeers || []).filter(function(p){ return p.is_active; }).length %> peer aktif.</p>
          </div>
          <a href="/management/vpn/vps-l2tp-script" class="btn btn-sm btn-km-primary">
            <i class="bi bi-download me-1"></i> Download .sh
          </a>
        </div>
        <pre class="bg-dark text-light p-3 rounded small mb-0" style="max-height: 280px; overflow: auto;"><code><%= vpsL2tpScript %></code></pre>
      </div>
    </div>
  </div>

  <p class="small text-muted mt-3 mb-0">
    Script MikroTik per perangkat tersedia di menu <a href="/management/vpn/devices">Perangkat</a>.
  </p>
</main>

<script>
(function () {
  function bindToggle(btnId, inputId) {
    var btn = document.getElementById(btnId);
    var input = document.getElementById(inputId);
    if (!btn || !input) return;
    btn.addEventListener('click', function () {
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      btn.innerHTML = show ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
    });
  }
  bindToggle('togglePrivKey', 'serverPrivateKey');
  bindToggle('toggleIpsecPsk', 'ipsecPsk');
})();
</script>

<%- include('../partials/footer') %>
