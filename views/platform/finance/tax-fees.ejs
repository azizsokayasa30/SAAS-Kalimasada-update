<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { active, adminName }) %>
<main class="km-main">
  <div class="km-topbar">
    <div>
      <h2>Pajak &amp; Fee Management</h2>
      <p class="km-subtitle">Pengaturan rate global BHP USO, management fee, dan rekap per tenant</p>
    </div>
  </div>

  <%- include('_nav', { financeSection }) %>

  <% if (flash && flash.success === 'saved') { %><div class="alert alert-success">Pengaturan fee berhasil disimpan.</div><% } %>
  <% if (flash && flash.success === 'restored') { %><div class="alert alert-success">Backup finance berhasil di-restore.</div><% } %>
  <% if (flash && flash.error) { %><div class="alert alert-danger"><%= flash.error %></div><% } %>

  <form method="POST" action="/management/finance/tax-fees" class="km-card mb-4">
    <h5 class="mb-3">Pengaturan Rate Global</h5>
    <div class="row g-3">
      <div class="col-md-3">
        <label class="form-label">BHP USO (%)</label>
        <input type="number" step="0.01" name="bhp_uso_rate" class="form-control" value="<%= settings.bhp_uso_rate %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">Default PPN (%)</label>
        <input type="number" step="0.01" name="default_tax_rate" class="form-control" value="<%= settings.default_tax_rate %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">Management Fee Type</label>
        <select name="management_fee_type" class="form-select">
          <option value="percent" <%= settings.management_fee_type === 'percent' ? 'selected' : '' %>>Persen (%)</option>
          <option value="fixed" <%= settings.management_fee_type === 'fixed' ? 'selected' : '' %>>Nominal Tetap (Rp)</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Management Fee Value</label>
        <input type="number" step="0.01" name="management_fee_value" class="form-control" value="<%= settings.management_fee_value %>" required>
      </div>
    </div>
    <div class="mt-3 text-end">
      <button type="submit" class="btn btn-km-primary"><i class="bi bi-check-lg me-1"></i> Simpan Pengaturan</button>
    </div>
  </form>

  <div class="km-card mb-3">
    <form method="GET" class="row g-2 align-items-end">
      <div class="col-md-2">
        <label class="form-label small">Tahun</label>
        <% const cy = new Date().getFullYear(); %>
        <select name="year" class="form-select form-select-sm">
          <% for (let y = cy - 3; y <= cy + 1; y++) { %>
            <option value="<%= y %>" <%= Number(year) === y ? 'selected' : '' %>><%= y %></option>
          <% } %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-km-primary btn-sm">Filter</button>
      </div>
    </form>
  </div>

  <div class="km-card km-card--flush">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 km-tenant-table">
        <thead>
          <tr>
            <th>Bulan</th>
            <th>Tenant</th>
            <th class="text-end">Transaksi</th>
            <th class="text-end">Gross</th>
            <th class="text-end">PPN</th>
            <th class="text-end">BHP USO</th>
            <th class="text-end">Mgmt Fee</th>
            <th class="text-end">Net</th>
          </tr>
        </thead>
        <tbody>
          <% if (!breakdown.length) { %>
            <tr><td colspan="8" class="text-center py-4" style="color: var(--text-muted)">Tidak ada data pada tahun ini.</td></tr>
          <% } %>
          <% breakdown.forEach(function(row) { %>
            <tr>
              <td><%= row.period_month %></td>
              <td><%= row.tenant_name %></td>
              <td class="text-end"><%= row.transaction_count %></td>
              <td class="text-end"><%= formatRupiah(row.gross) %></td>
              <td class="text-end"><%= formatRupiah(row.tax) %></td>
              <td class="text-end"><%= formatRupiah(row.bhp_uso_amount) %></td>
              <td class="text-end"><%= formatRupiah(row.management_fee_amount) %></td>
              <td class="text-end fw-semibold"><%= formatRupiah(row.net) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('_backup-restore') %>
</main>
<%- include('../partials/footer') %>
