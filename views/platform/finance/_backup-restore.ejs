<% const returnPath = typeof financeReturnTo !== 'undefined' ? financeReturnTo : '/management/finance/payments'; %>
<div class="km-card km-master-backup-card mt-4" id="backup-restore">
  <div class="km-master-backup-card__head">
    <div>
      <h3 class="km-master-backup-card__title"><i class="bi bi-cloud-arrow-up me-2"></i>Backup &amp; Restore Finance</h3>
      <p class="km-subtitle mb-0">Cadangkan invoice rekap, pengaturan fee, catatan pemasukan/pengeluaran, dan kategori platform</p>
    </div>
    <a href="/management/finance/backup/download?return_to=<%= encodeURIComponent(returnPath) %>" class="btn btn-km-primary btn-sm px-3">
      <i class="bi bi-download me-1"></i> Backup Sekarang
    </a>
  </div>
  <div class="row g-4 km-master-backup-card__body">
    <div class="col-lg-5">
      <div class="km-form-section km-form-section--flat h-100">
        <h6 class="km-form-section__title mb-2"><i class="bi bi-arrow-counterclockwise me-1"></i> Restore dari File</h6>
        <p class="text-muted small mb-3">Unggah file JSON backup untuk mengembalikan data finance platform.</p>
        <form method="POST" action="/management/finance/backup/restore" enctype="multipart/form-data">
          <input type="hidden" name="return_to" value="<%= returnPath %>">
          <div class="mb-3">
            <input type="file" name="backup_file" class="form-control form-control-sm" accept=".json,application/json" required>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Mode restore</label>
            <select name="mode" class="form-select form-select-sm">
              <option value="replace">Ganti semua (hapus data finance lalu restore)</option>
              <option value="merge">Gabung (tambah/perbarui dari backup)</option>
            </select>
          </div>
          <button type="submit" class="btn btn-outline-primary btn-sm px-3" onclick="return confirm('Restore akan mengubah data finance platform. Cadangan otomatis dibuat sebelum restore. Lanjutkan?')">
            <i class="bi bi-upload me-1"></i> Restore
          </button>
        </form>
      </div>
    </div>
    <div class="col-lg-7">
      <h6 class="km-form-section__title mb-2"><i class="bi bi-clock-history me-1"></i> Riwayat Backup Server</h6>
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0 km-tenant-table">
          <thead>
            <tr>
              <th>File</th>
              <th>Ukuran</th>
              <th>Tanggal</th>
              <th class="text-end">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (!backups || !backups.length) { %>
              <tr><td colspan="4" class="text-center py-3 text-muted">Belum ada backup tersimpan di server.</td></tr>
            <% } %>
            <% (backups || []).forEach(function(b) { %>
              <tr>
                <td><code class="small"><%= b.filename %></code></td>
                <td class="text-muted small"><%= (b.size / 1024).toFixed(1) %> KB</td>
                <td class="text-muted small"><%= new Date(b.created_at).toLocaleString('id-ID') %></td>
                <td class="text-end">
                  <a href="/management/finance/backup/file/<%= encodeURIComponent(b.filename) %>" class="btn btn-sm btn-outline-secondary" title="Unduh">
                    <i class="bi bi-download"></i>
                  </a>
                  <form method="POST" action="/management/finance/backup/restore/<%= encodeURIComponent(b.filename) %>" class="d-inline">
                    <input type="hidden" name="return_to" value="<%= returnPath %>">
                    <input type="hidden" name="mode" value="replace">
                    <button type="submit" class="btn btn-sm btn-outline-success" title="Restore" onclick="return confirm('Restore dari <%= b.filename %>? Cadangan otomatis dibuat sebelum restore.')">
                      <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
