<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { active, adminName }) %>
<main class="km-main">
  <div class="km-topbar">
    <div>
      <h2>Catatan Pengeluaran</h2>
      <p class="km-subtitle">Pengeluaran operasional platform Kalimasada</p>
    </div>
    <button type="button" class="btn btn-km-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
      <i class="bi bi-plus-lg me-1"></i> Tambah Pengeluaran
    </button>
  </div>

  <%- include('_nav', { financeSection }) %>

  <% if (flash && flash.success === 'created') { %><div class="alert alert-success">Pengeluaran berhasil ditambahkan.</div><% } %>
  <% if (flash && flash.success === 'updated') { %><div class="alert alert-success">Pengeluaran berhasil diperbarui.</div><% } %>
  <% if (flash && flash.success === 'deleted') { %><div class="alert alert-success">Pengeluaran dihapus.</div><% } %>
  <% if (flash && flash.success === 'restored') { %><div class="alert alert-success">Backup finance berhasil di-restore.</div><% } %>
  <% if (flash && flash.error) { %><div class="alert alert-danger"><%= flash.error %></div><% } %>

  <div class="km-card mb-3">
    <form method="GET" class="row g-2 align-items-end">
      <div class="col-md-2">
        <label class="form-label small">Bulan</label>
        <select name="month" class="form-select form-select-sm">
          <% for (let m = 1; m <= 12; m++) { %>
            <option value="<%= m %>" <%= Number(filters.month) === m ? 'selected' : '' %>><%= m %></option>
          <% } %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small">Tahun</label>
        <% const cy = new Date().getFullYear(); %>
        <select name="year" class="form-select form-select-sm">
          <% for (let y = cy - 3; y <= cy + 1; y++) { %>
            <option value="<%= y %>" <%= Number(filters.year) === y ? 'selected' : '' %>><%= y %></option>
          <% } %>
        </select>
      </div>
      <div class="col-md-2"><button type="submit" class="btn btn-km-primary btn-sm">Filter</button></div>
    </form>
  </div>

  <div class="km-card km-card--flush">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 km-tenant-table">
        <thead>
          <tr><th>Tanggal</th><th>Deskripsi</th><th>Kategori</th><th class="text-end">Jumlah</th><th>Metode</th><th>Catatan</th><th class="text-end">Aksi</th></tr>
        </thead>
        <tbody>
          <% if (!expenses.length) { %>
            <tr><td colspan="7" class="text-center py-4" style="color: var(--text-muted)">Belum ada catatan pengeluaran.</td></tr>
          <% } %>
          <% expenses.forEach(function(exp) { %>
            <tr>
              <td><%= new Date(exp.transaction_date).toLocaleDateString('id-ID') %></td>
              <td><%= exp.description %></td>
              <td><span class="badge bg-danger-subtle text-danger"><%= exp.category %></span></td>
              <td class="text-end fw-semibold text-danger"><%= formatRupiah(exp.amount) %></td>
              <td><%= exp.payment_method || '-' %></td>
              <td class="small"><%= exp.notes || '-' %></td>
              <td class="text-end">
                <button type="button" class="btn btn-outline-primary btn-sm py-0" data-bs-toggle="modal" data-bs-target="#editExpense<%= exp.id %>">Edit</button>
                <form method="POST" action="/management/finance/expenses/<%= exp.id %>/delete" class="d-inline" onsubmit="return confirm('Hapus catatan ini?')">
                  <button type="submit" class="btn btn-outline-danger btn-sm py-0">Hapus</button>
                </form>
              </td>
            </tr>
            <div class="modal fade" id="editExpense<%= exp.id %>" tabindex="-1">
              <div class="modal-dialog">
                <form method="POST" action="/management/finance/expenses/<%= exp.id %>" class="modal-content">
                  <div class="modal-header"><h5 class="modal-title">Edit Pengeluaran</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                  <div class="modal-body">
                    <div class="mb-2"><label class="form-label">Deskripsi</label><input name="description" class="form-control" value="<%= exp.description %>" required></div>
                    <div class="mb-2"><label class="form-label">Jumlah</label><input name="amount" type="number" class="form-control" value="<%= exp.amount %>" required></div>
                    <div class="mb-2"><label class="form-label">Kategori</label>
                      <select name="category" class="form-select">
                        <% categories.forEach(function(c) { %>
                          <option value="<%= c.name %>" <%= exp.category === c.name ? 'selected' : '' %>><%= c.name %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="mb-2"><label class="form-label">Tanggal</label><input name="transaction_date" type="date" class="form-control" value="<%= String(exp.transaction_date).slice(0,10) %>" required></div>
                    <div class="mb-2"><label class="form-label">Metode</label><input name="payment_method" class="form-control" value="<%= exp.payment_method || '' %>"></div>
                    <div class="mb-2"><label class="form-label">Catatan</label><textarea name="notes" class="form-control" rows="2"><%= exp.notes || '' %></textarea></div>
                  </div>
                  <div class="modal-footer"><button type="submit" class="btn btn-km-primary">Simpan</button></div>
                </form>
              </div>
            </div>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('_backup-restore') %>
</main>

<div class="modal fade" id="addExpenseModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/management/finance/expenses" class="modal-content">
      <div class="modal-header"><h5 class="modal-title">Tambah Pengeluaran</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="mb-2"><label class="form-label">Deskripsi</label><input name="description" class="form-control" required></div>
        <div class="mb-2"><label class="form-label">Jumlah</label><input name="amount" type="number" class="form-control" required></div>
        <div class="mb-2"><label class="form-label">Kategori</label>
          <select name="category" class="form-select">
            <% categories.forEach(function(c) { %><option value="<%= c.name %>"><%= c.name %></option><% }); %>
          </select>
        </div>
        <div class="mb-2"><label class="form-label">Tanggal</label><input name="transaction_date" type="date" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>" required></div>
        <div class="mb-2"><label class="form-label">Metode</label><input name="payment_method" class="form-control"></div>
        <div class="mb-2"><label class="form-label">Catatan</label><textarea name="notes" class="form-control" rows="2"></textarea></div>
      </div>
      <div class="modal-footer"><button type="submit" class="btn btn-km-primary">Simpan</button></div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
