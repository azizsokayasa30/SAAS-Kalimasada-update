<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    body { font-family: Arial, sans-serif; font-size: 12px; color: #111; margin: 24px; }
    h1 { font-size: 18px; margin: 0 0 4px; }
    .muted { color: #666; }
    table { width: 100%; border-collapse: collapse; margin-top: 16px; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
    th { background: #f5f5f5; }
    .text-right { text-align: right; }
    .total { font-weight: bold; font-size: 14px; }
    @media print { .no-print { display: none; } }
  </style>
</head>
<body>
  <button class="no-print" onclick="window.print()">Cetak</button>
  <h1><%= company.company_name || 'Kalimasada' %></h1>
  <p class="muted"><%= company.company_address || '' %> · <%= company.contact_email || '' %></p>
  <hr>
  <h2>Invoice Rekap: <%= invoice.invoice_number %></h2>
  <p>
    <strong>Tenant:</strong> <%= invoice.tenant_name %><br>
    <strong>Pemilik:</strong> <%= invoice.owner_name %><br>
    <strong>Periode:</strong> <%= invoice.period_start %> — <%= invoice.period_end %><br>
    <strong>Status:</strong> <%= invoice.status %>
  </p>
  <table>
    <thead><tr><th>Deskripsi</th><th class="text-right">Jumlah</th></tr></thead>
    <tbody>
      <% invoice.items.forEach(function(item) { %>
        <tr><td><%= item.description %></td><td class="text-right"><%= formatRupiah(item.amount) %></td></tr>
      <% }); %>
      <tr class="total">
        <td>Net ke Pemilik Tenant</td>
        <td class="text-right"><%= formatRupiah(invoice.net_amount) %></td>
      </tr>
    </tbody>
  </table>
  <p class="muted" style="margin-top: 24px;">Dokumen ini dibuat otomatis oleh Kalimasada Management Portal.</p>
</body>
</html>
