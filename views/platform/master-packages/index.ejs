<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { active, adminName }) %>
<main class="km-main">
  <div class="km-topbar">
    <div>
      <h2>Master Paket Internet</h2>
      <p class="km-subtitle">Katalog paket untuk semua tenant — tenant hanya bisa memilih, tidak membuat sendiri</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a href="#backup-restore" class="btn btn-outline-secondary btn-sm px-3">
        <i class="bi bi-cloud-arrow-up me-1"></i> Backup &amp; Restore
      </a>
      <button type="button" class="btn btn-km-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#addMasterPackageModal">
        <i class="bi bi-plus-lg me-1"></i> Tambah Paket
      </button>
    </div>
  </div>

  <%- include('../settings/_nav', { settingsSection }) %>

  <% if (flash && flash.success === 'created') { %>
    <div class="alert alert-success">Master paket berhasil ditambahkan.</div>
  <% } %>
  <% if (flash && flash.success === 'updated') { %>
    <div class="alert alert-success">Master paket berhasil diperbarui.</div>
  <% } %>
  <% if (flash && flash.success === 'deleted') { %>
    <div class="alert alert-success">Master paket dinonaktifkan.</div>
  <% } %>
  <% if (flash && flash.success === 'restored') { %>
    <div class="alert alert-success">Backup berhasil di-restore (<%= flash.count || 0 %> paket).</div>
  <% } %>
  <% if (flash && flash.error) { %>
    <div class="alert alert-danger"><%= flash.error %></div>
  <% } %>

  <div class="km-card km-card--flush">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 km-tenant-table">
        <thead>
          <tr>
            <th>Nama</th>
            <th>Kecepatan</th>
            <th>Tipe</th>
            <th class="text-end">Harga</th>
            <th class="text-end">PPN</th>
            <th>Profil PPPoE</th>
            <th>Status</th>
            <th class="text-end">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (!packages.length) { %>
            <tr><td colspan="8" class="text-center py-4" style="color: var(--text-muted)">Belum ada master paket.</td></tr>
          <% } %>
          <% packages.forEach(function(pkg) {
            const billingOnly = pkg.billing_only === 1;
          %>
            <tr class="<%= pkg.is_active ? '' : 'opacity-50' %>">
              <td class="fw-semibold"><%= pkg.name %></td>
              <td><%= pkg.speed %></td>
              <td>
                <% if (billingOnly) { %>
                  <span class="badge bg-info">Billing only</span>
                <% } else { %>
                  <span class="badge bg-primary">PPPoE + IP Statik</span>
                <% } %>
              </td>
              <td class="text-end km-metric-cell--money"><%= formatRupiah(pkg.price) %></td>
              <td class="text-end">
                <% if (!pkg.tax_rate || Number(pkg.tax_rate) === 0) { %>
                  <span class="badge bg-secondary">Nonaktif</span>
                <% } else { %>
                  <%= pkg.tax_rate %>%
                <% } %>
              </td>
              <td><%= billingOnly ? '—' : (pkg.pppoe_profile || 'default') %></td>
              <td>
                <% if (pkg.is_active) { %>
                  <span class="badge bg-success">Aktif</span>
                <% } else { %>
                  <span class="badge bg-secondary">Nonaktif</span>
                <% } %>
              </td>
              <td class="text-end">
                <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editMasterPackageModal-<%= pkg.id %>">
                  <i class="bi bi-pencil"></i>
                </button>
                <% if (pkg.is_active) { %>
                  <form method="POST" action="<%= basePath %>/<%= pkg.id %>/delete" class="d-inline" onsubmit="return confirm('Nonaktifkan paket ini? Tenant yang memilih akan ikut dinonaktifkan.')">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="km-card km-master-backup-card mt-4" id="backup-restore">
    <div class="km-master-backup-card__head">
      <div>
        <h3 class="km-master-backup-card__title"><i class="bi bi-cloud-arrow-up me-2"></i>Backup &amp; Restore</h3>
        <p class="km-subtitle mb-0">Cadangkan katalog master paket dan pemilihan tenant ke file JSON</p>
      </div>
      <a href="<%= basePath %>/backup/download" class="btn btn-km-primary btn-sm px-3">
        <i class="bi bi-download me-1"></i> Backup Sekarang
      </a>
    </div>
    <div class="row g-4 km-master-backup-card__body">
      <div class="col-lg-5">
        <div class="km-form-section km-form-section--flat h-100">
          <h6 class="km-form-section__title mb-2"><i class="bi bi-arrow-counterclockwise me-1"></i> Restore dari File</h6>
          <p class="text-muted small mb-3">Unggah file JSON backup untuk mengembalikan katalog paket.</p>
          <form method="POST" action="<%= basePath %>/backup/restore" enctype="multipart/form-data">
            <div class="mb-3">
              <input type="file" name="backup_file" class="form-control form-control-sm" accept=".json,application/json" required>
            </div>
            <div class="mb-3">
              <label class="form-label small fw-semibold">Mode restore</label>
              <select name="mode" class="form-select form-select-sm">
                <option value="replace">Ganti semua (paket tidak ada di backup dinonaktifkan)</option>
                <option value="merge">Gabung (tambah/perbarui paket dari backup)</option>
              </select>
            </div>
            <button type="submit" class="btn btn-outline-primary btn-sm px-3" onclick="return confirm('Restore akan menimpa data master paket. Cadangan otomatis dibuat sebelum restore. Lanjutkan?')">
              <i class="bi bi-upload me-1"></i> Restore
            </button>
          </form>
        </div>
      </div>
      <div class="col-lg-7">
        <h6 class="km-form-section__title mb-2"><i class="bi bi-clock-history me-1"></i> Riwayat Backup Server</h6>
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0 km-tenant-table">
            <thead>
              <tr>
                <th>File</th>
                <th>Ukuran</th>
                <th>Tanggal</th>
                <th class="text-end">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (!backups || !backups.length) { %>
                <tr><td colspan="4" class="text-center py-3 text-muted">Belum ada backup tersimpan di server.</td></tr>
              <% } %>
              <% (backups || []).forEach(function(b) { %>
                <tr>
                  <td><code class="small"><%= b.filename %></code></td>
                  <td class="text-muted small"><%= (b.size / 1024).toFixed(1) %> KB</td>
                  <td class="text-muted small"><%= new Date(b.created_at).toLocaleString('id-ID') %></td>
                  <td class="text-end">
                    <a href="<%= basePath %>/backup/file/<%= encodeURIComponent(b.filename) %>" class="btn btn-sm btn-outline-secondary" title="Unduh">
                      <i class="bi bi-download"></i>
                    </a>
                    <form method="POST" action="<%= basePath %>/backup/restore/<%= encodeURIComponent(b.filename) %>" class="d-inline">
                      <input type="hidden" name="mode" value="replace">
                      <button type="submit" class="btn btn-sm btn-outline-success" title="Restore" onclick="return confirm('Restore dari <%= b.filename %>? Cadangan otomatis dibuat sebelum restore.')">
                        <i class="bi bi-arrow-counterclockwise"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- Modal Tambah -->
<div class="modal fade km-modal km-package-modal-wrap" id="addMasterPackageModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <form method="POST" action="<%= basePath %>" class="modal-content km-package-modal">
      <%- include('_form-fields', { prefix: 'add', pkg: {} }) %>
    </form>
  </div>
</div>

<% packages.forEach(function(pkg) { %>
<div class="modal fade km-modal km-package-modal-wrap" id="editMasterPackageModal-<%= pkg.id %>" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <form method="POST" action="<%= basePath %>/<%= pkg.id %>" class="modal-content km-package-modal">
      <%- include('_form-fields', { prefix: 'edit-' + pkg.id, pkg: pkg }) %>
    </form>
  </div>
</div>
<% }); %>

<script>
(function () {
  function setPpnState(prefix, enabled) {
    var rateInput = document.getElementById('taxRate-' + prefix);
    var hint = document.querySelector('.km-ppn-hint-' + prefix);
    var priceLabel = document.querySelector('.km-ppn-price-label-' + prefix);
    var ppnBox = document.getElementById('ppnBox-' + prefix);
    if (!rateInput) return;
    rateInput.disabled = !enabled;
    if (ppnBox) ppnBox.classList.toggle('km-ppn-box--off', !enabled);
    if (enabled) {
      if (!rateInput.value || Number(rateInput.value) === 0) rateInput.value = '11';
      if (hint) hint.style.display = 'none';
      if (priceLabel) priceLabel.textContent = 'Harga (sebelum PPN)';
    } else {
      if (hint) hint.style.display = '';
      if (priceLabel) priceLabel.textContent = 'Harga';
    }
  }

  function setBillingOnlyState(prefix, billingOnly) {
    var section = document.getElementById('networkSection-' + prefix);
    var pppoe = document.getElementById('pppoeProfile-' + prefix);
    if (section) section.classList.toggle('km-form-section--dimmed', billingOnly);
    if (section) {
      section.querySelectorAll('input').forEach(function (inp) {
        if (inp.name === 'upload_limit' || inp.name === 'download_limit' || inp.name === 'pppoe_profile') {
          inp.disabled = billingOnly;
        }
      });
    }
    if (pppoe) pppoe.disabled = billingOnly;
  }

  document.querySelectorAll('.km-ppn-switch').forEach(function (sw) {
    var prefix = sw.getAttribute('data-prefix');
    setPpnState(prefix, sw.checked);
    sw.addEventListener('change', function () { setPpnState(prefix, sw.checked); });
  });

  document.querySelectorAll('[id^="billingOnly-"]').forEach(function (cb) {
    var prefix = cb.getAttribute('data-prefix');
    if (!prefix) return;
    setBillingOnlyState(prefix, cb.checked);
    cb.addEventListener('change', function () { setBillingOnlyState(prefix, cb.checked); });
  });

  document.querySelectorAll('form.km-package-modal').forEach(function (form) {
    form.addEventListener('submit', function () {
      form.querySelectorAll('.km-ppn-switch').forEach(function (sw) {
        var prefix = sw.getAttribute('data-prefix');
        var rateInput = document.getElementById('taxRate-' + prefix);
        if (!rateInput) return;
        if (!sw.checked) {
          rateInput.disabled = false;
          rateInput.value = '0';
        } else if (!rateInput.value) {
          rateInput.value = '11';
        }
      });
      form.querySelectorAll('[id^="billingOnly-"]:checked').forEach(function (cb) {
        var section = document.getElementById('networkSection-' + cb.getAttribute('data-prefix'));
        if (section) section.querySelectorAll('input').forEach(function (inp) { inp.disabled = false; });
      });
    });
  });
})();
</script>

<%- include('../partials/footer') %>
