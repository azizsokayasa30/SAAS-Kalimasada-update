<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Login Admin | <%= appSettings.company_header %></title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <%- include('partials/theme-head') %>
    <style>
        :root {
            --bg: #07111f;
            --panel: rgba(255, 255, 255, .94);
            --ink: #0f172a;
            --muted: #64748b;
            --line: rgba(148, 163, 184, .28);
            --primary: #0ea5e9;
            --primary-dark: #0369a1;
            --accent: #22c55e;
            --warning: #f59e0b;
        }

        * { box-sizing: border-box; }

        body {
            position: relative;
            min-height: 100vh;
            margin: 0;
            color: var(--ink) !important;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
            background:
                radial-gradient(circle at top left, rgba(14, 165, 233, .12), transparent 30rem),
                radial-gradient(circle at bottom right, rgba(34, 197, 94, .08), transparent 28rem),
                #0b2235;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background: url('/img/login-smart-work.svg') center / cover no-repeat;
            opacity: .86;
        }

        body::after {
            content: "";
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background:
                linear-gradient(90deg, rgba(7, 17, 31, .08), rgba(7, 17, 31, 0) 52%, rgba(8, 47, 73, .03)),
                radial-gradient(circle at 72% 30%, rgba(14, 165, 233, .03), transparent 24rem);
        }

        .page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(0, 1.05fr) minmax(360px, 440px);
            gap: clamp(24px, 5vw, 72px);
            align-items: center;
            width: min(1120px, 100%);
            margin: 0 auto;
            padding: clamp(22px, 5vw, 56px);
        }

        .hero {
            padding: clamp(10px, 2vw, 18px);
            color: #fff;
            text-shadow: 0 2px 18px rgba(2, 6, 23, .72);
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: 999px;
            background: rgba(255, 255, 255, .08);
            color: rgba(255, 255, 255, .86);
            font-size: .82rem;
            font-weight: 650;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .hero h1 {
            max-width: 720px;
            margin: 24px 0 18px;
            font-size: clamp(2.25rem, 5.6vw, 4.25rem);
            line-height: 1.02;
            font-weight: 750;
            letter-spacing: -.05em;
        }

        .hero p {
            max-width: 620px;
            margin: 0;
            color: rgba(226, 232, 240, .84);
            font-size: clamp(1rem, 2vw, 1.16rem);
            line-height: 1.75;
            font-weight: 400;
        }

        .motivation {
            display: grid;
            gap: 12px;
            max-width: 640px;
            margin-top: 28px;
        }

        .motivation-card {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            padding: 16px;
            border: 1px solid rgba(255, 255, 255, .14);
            border-radius: 20px;
            background: rgba(15, 23, 42, .24);
            box-shadow: 0 14px 34px rgba(0, 0, 0, .12);
            backdrop-filter: blur(14px);
        }

        .motivation-card i {
            display: inline-flex;
            width: 34px;
            height: 34px;
            align-items: center;
            justify-content: center;
            flex: 0 0 34px;
            border-radius: 12px;
            background: rgba(14, 165, 233, .18);
            color: #7dd3fc;
        }

        .motivation-card strong {
            display: block;
            color: #fff;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .motivation-card span {
            color: rgba(226, 232, 240, .78);
            line-height: 1.55;
            font-size: .94rem;
            font-weight: 400;
        }

        .login-card {
            position: relative;
            overflow: hidden;
            width: 100%;
            border: 1px solid rgba(255, 255, 255, .62);
            border-radius: 30px;
            background: var(--panel) !important;
            color: var(--ink) !important;
            box-shadow: 0 28px 80px rgba(2, 6, 23, .38);
        }

        .login-card::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 7px;
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--warning));
        }

        .login-inner {
            padding: clamp(26px, 4vw, 38px);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 13px;
            margin-bottom: 26px;
        }

        .brand-logo {
            width: 58px;
            height: 58px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 18px;
            background: #fff;
            border: 1px solid var(--line);
            box-shadow: 0 12px 28px rgba(15, 23, 42, .08);
        }

        .brand-logo img {
            max-width: 42px;
            max-height: 42px;
            object-fit: contain;
        }

        .brand-title {
            margin: 0;
            color: var(--ink) !important;
            font-size: 1.18rem;
            font-weight: 750;
            letter-spacing: -.035em;
        }

        .brand-subtitle {
            margin: 2px 0 0;
            color: var(--muted) !important;
            font-size: .86rem;
            font-weight: 450;
        }

        .login-heading {
            margin-bottom: 22px;
        }

        .login-heading h2 {
            margin: 0 0 8px;
            color: var(--ink) !important;
            font-size: clamp(1.65rem, 3vw, 2.1rem);
            font-weight: 720;
            letter-spacing: -.04em;
        }

        .login-heading p {
            margin: 0;
            color: var(--muted) !important;
            line-height: 1.6;
            font-weight: 400;
        }

        .form-label {
            color: #334155 !important;
            font-weight: 650;
            font-size: .84rem;
            margin-bottom: 8px;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8 !important;
            z-index: 2;
        }

        .form-control {
            min-height: 52px;
            border-radius: 16px;
            border: 1.5px solid #dbe4ef;
            padding: 13px 16px 13px 45px;
            color: var(--ink) !important;
            background: #fff !important;
            font-weight: 450;
            transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease;
        }

        .form-control::placeholder {
            color: #a8b3c4 !important;
            font-weight: 400;
        }

        .form-control:focus {
            border-color: var(--primary);
            color: var(--ink) !important;
            background: #fff !important;
            box-shadow: 0 0 0 5px rgba(14, 165, 233, .14);
            transform: translateY(-1px);
        }

        .btn-login {
            width: 100%;
            min-height: 54px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 8px;
            border: 0;
            border-radius: 17px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff !important;
            font-weight: 700;
            letter-spacing: -.01em;
            box-shadow: 0 18px 34px rgba(14, 165, 233, .28);
            transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
        }

        .btn-login * {
            color: #fff !important;
        }

        .btn-login:hover {
            color: #fff;
            filter: brightness(1.04);
            transform: translateY(-2px);
            box-shadow: 0 22px 44px rgba(14, 165, 233, .34);
        }

        .btn-login:disabled {
            opacity: .72;
            transform: none;
            box-shadow: none;
        }

        .security-note {
            display: flex;
            gap: 10px;
            margin-top: 18px;
            padding: 13px;
            border-radius: 17px;
            background: #f8fafc !important;
            color: #64748b !important;
            font-size: .86rem;
            line-height: 1.5;
            font-weight: 400;
        }

        .security-note i {
            color: var(--accent) !important;
            margin-top: 1px;
        }

        .security-note span {
            color: #64748b !important;
        }

        .alert {
            border: 0;
            border-radius: 15px;
            font-weight: 700;
        }

        .footer {
            margin-top: 18px;
            color: rgba(226, 232, 240, .72);
            font-size: .86rem;
            text-align: center;
        }

        @media (max-width: 900px) {
            .page {
                grid-template-columns: 1fr;
                gap: 28px;
                padding: 22px 16px;
            }

            .hero {
                text-align: center;
            }

            .hero p,
            .motivation {
                margin-left: auto;
                margin-right: auto;
            }

            .motivation {
                display: none;
            }
        }
    </style>
</head>
<body>
    <main class="page">
        <section class="hero" aria-label="Motivasi kerja">
            <div class="eyebrow">
                <i class="bi bi-lightning-charge-fill"></i>
                Admin Control Center
            </div>
            <h1>Kerja rapi, layanan cepat, pelanggan senang.</h1>
            <p>
                Setiap data yang tertata, setiap tiket yang ditangani, dan setiap pelanggan yang terbantu
                adalah bagian dari layanan internet yang lebih dipercaya.
            </p>

            <div class="motivation">
                <div class="motivation-card">
                    <i class="bi bi-bullseye"></i>
                    <div>
                        <strong>Mulai hari ini dengan fokus.</strong>
                        <span>Prioritaskan yang penting, selesaikan satu per satu, dan biarkan hasil kerja berbicara.</span>
                    </div>
                </div>
                <div class="motivation-card">
                    <i class="bi bi-people-fill"></i>
                    <div>
                        <strong>Layanan baik dimulai dari admin yang sigap.</strong>
                        <span>Kecepatan respon dan ketelitian data adalah kekuatan utama tim operasional.</span>
                    </div>
                </div>
                <div class="motivation-card">
                    <i class="bi bi-graph-up-arrow"></i>
                    <div>
                        <strong>Konsisten hari ini, lebih kuat besok.</strong>
                        <span>Perbaikan kecil yang dilakukan terus-menerus akan membuat sistem semakin matang.</span>
                    </div>
                </div>
            </div>
        </section>

        <section>
            <div class="login-card">
                <div class="login-inner">
                    <div class="brand">
                        <div class="brand-logo">
                            <img src="/img/<%= appSettings.logo_filename %>" alt="Logo <%= appSettings.company_header %>" onerror="this.style.display='none'">
                        </div>
                        <div>
                            <p class="brand-title"><%= appSettings.company_header %></p>
                            <p class="brand-subtitle">Single login khusus admin</p>
                        </div>
                    </div>

                    <div class="login-heading">
                        <h2>Selamat datang kembali</h2>
                        <p>Masuk ke dashboard admin untuk memantau layanan, billing, pelanggan, dan operasional jaringan.</p>
                    </div>

                    <% if (timedOut) { %>
                        <div class="alert alert-warning py-2 small" role="alert">
                            Sesi login berakhir karena tidak ada aktivitas. Silakan login kembali.
                        </div>
                    <% } %>
                    <% if (typeof error === 'string' && error) { %>
                        <div class="alert alert-danger py-2 small" role="alert"><%= error %></div>
                    <% } %>
                    <% if (tenantSlug) { %>
                        <div class="alert alert-info py-2 small" role="alert">
                            Login tenant: <strong><%= tenantSlug %></strong>
                            <% if (typeof directHostAccess !== 'undefined' && directHostAccess) { %>
                            <div class="mt-1 text-muted" style="font-size:0.78rem;">
                                Akses via IP — ganti tenant:
                                <a href="/login?tenant=login">login</a> ·
                                <a href="/login?tenant=default">default</a> ·
                                <a href="/login?tenant=lebakwangi">lebakwangi</a>
                            </div>
                            <% } %>
                        </div>
                    <% } %>

                    <form id="loginForm" autocomplete="on">
                        <input type="hidden" name="role" value="admin">
                        <input type="hidden" id="tenantSlug" name="tenant" value="<%= tenantSlug || '' %>">

                        <div class="mb-3">
                            <label class="form-label" for="username">Username Admin</label>
                            <div class="input-wrap">
                                <i class="bi bi-person"></i>
                                <input type="text" class="form-control" id="username" name="username" placeholder="Masukkan username admin" autocomplete="username" required autofocus>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="password">Password</label>
                            <div class="input-wrap">
                                <i class="bi bi-lock"></i>
                                <input type="password" class="form-control" id="password" name="password" placeholder="Masukkan password" autocomplete="current-password" required>
                            </div>
                        </div>

                        <div id="alertPlaceholder"></div>

                        <button type="submit" class="btn-login" id="btnLogin">
                            <span class="spinner-border spinner-border-sm" style="display: none;" id="loginSpinner" aria-hidden="true"></span>
                            <span id="loginText">Masuk Dashboard</span>
                            <i class="bi bi-arrow-right-circle"></i>
                        </button>
                    </form>

                    <div class="security-note">
                        <i class="bi bi-shield-check"></i>
                        <span>Gunakan akun admin resmi. Untuk teknisi, kolektor, agen, dan pelanggan gunakan aplikasi atau portal masing-masing.</span>
                    </div>
                </div>
            </div>

            <div class="footer">
                <%= appSettings.footer_info %>
            </div>
        </section>
    </main>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        const form = document.getElementById('loginForm');
        const alertPlaceholder = document.getElementById('alertPlaceholder');
        const button = document.getElementById('btnLogin');
        const spinner = document.getElementById('loginSpinner');
        const loginText = document.getElementById('loginText');

        function showAlert(type, message) {
            alertPlaceholder.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show py-2 small" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Tutup"></button>
                </div>
            `;
        }

        function setLoading(isLoading) {
            button.disabled = isLoading;
            spinner.style.display = isLoading ? 'inline-block' : 'none';
            loginText.textContent = isLoading ? 'Memeriksa akun...' : 'Masuk Dashboard';
        }

        form.addEventListener('submit', async (event) => {
            event.preventDefault();
            alertPlaceholder.innerHTML = '';

            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value.trim();

            if (!username || !password) {
                showAlert('danger', 'Username dan password admin wajib diisi.');
                return;
            }

            setLoading(true);

            try {
                const body = new URLSearchParams();
                body.set('role', 'admin');
                body.set('username', username);
                body.set('password', password);
                const tenantSlug = (document.getElementById('tenantSlug')?.value || '').trim();
                if (tenantSlug) body.set('tenant', tenantSlug);

                const loginEndpoint = tenantSlug
                    ? `/login?tenant=${encodeURIComponent(tenantSlug)}`
                    : '/login';

                const response = await fetch(loginEndpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
                    body,
                });
                const data = await response.json().catch(() => ({}));

                if (!response.ok || !data.success) {
                    showAlert('danger', data.message || 'Login gagal. Periksa kembali username dan password.');
                    setLoading(false);
                    return;
                }

                loginText.textContent = 'Berhasil, mengalihkan...';
                window.location.href = data.redirect || '/admin/dashboard';
            } catch (error) {
                showAlert('danger', 'Tidak dapat terhubung ke server. Silakan coba lagi.');
                setLoading(false);
            }
        });
    </script>
</body>
</html>
