<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/hard-reload') %>
  <meta charset="UTF-8">
  <title>Manage RADIUS Clients</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/responsive-admin.css" rel="stylesheet">
  <style>
    body { background: #f5f6fa; }
    .main-content { padding: 32px 24px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  </style>

    <%- include('partials/theme-head') %>
</head>
<body>
<div class="container-fluid">
  <div class="row">
    <%- include('partials/admin-responsive-sidebar', { page: 'setting-radius-clients', settings: settings }) %>
    <main class="col-md-10 ms-sm-auto main-content">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0"><i class="bi bi-router"></i> Manage RADIUS Clients (NAS)</h3>
        <a href="/admin/radius" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Kembali ke Setting RADIUS
        </a>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="bi bi-exclamation-triangle me-2"></i> <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      
      <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show">
          <i class="bi bi-check-circle me-2"></i> <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <div class="alert alert-secondary small mb-4">
        <i class="bi bi-info-circle me-1"></i>
        Daftar NAS menggabungkan <strong>tabel <code>nas</code></strong> (SQLite) dan isi <strong><code>clients.conf</code></strong>.
        Proses billing (PM2) biasanya <strong>tidak bisa membaca</strong> <code>/etc/freeradius/3.0/clients.conf</code> — gunakan salinan <code>data/clients.conf.mirror</code> (perintah <code>npm run radius:mirror-clients</code> di server).
        Simpan perubahan menulis <strong>file asli + nas</strong>. Jika <code>nas</code> kosong, halaman ini mengisi <code>nas</code> dari file yang berhasil dibaca.
      </div>

      <% if (typeof clientsConfDiag !== 'undefined' && clientsConfDiag && !clientsConfDiag.ok && (!clients || clients.length === 0)) { %>
        <div class="alert alert-danger small mb-4">
          <strong>Tidak ada daftar NAS yang terbaca.</strong>
          <pre class="small bg-light p-2 rounded mt-2 mb-0" style="white-space: pre-wrap;"><%= clientsConfDiag.hint || 'Set mirror atau sudoers NOPASSWD untuk sudo -n cat clients.conf.' %></pre>
        </div>
      <% } %>

      <!-- Add Client Button -->
      <div class="card p-3 shadow-sm mb-4">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addClientModal">
          <i class="bi bi-plus-circle"></i> Tambah Client (NAS)
        </button>
      </div>

      <!-- Clients Table -->
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0"><i class="bi bi-list-ul"></i> Daftar RADIUS Clients</h5>
        </div>
        <div class="card-body">
          <% if (clients && clients.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Nama Client</th>
                    <th>IP Address</th>
                    <th>Secret</th>
                    <th>NAS Type</th>
                    <th>Message Auth</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% clients.forEach(function(client) { %>
                    <tr>
                      <td><strong><%= client.name %></strong></td>
                      <td><code><%= client.ipaddr || '-' %></code></td>
                      <td>
                        <code class="secret-text" data-secret="<%= client.secret %>">
                          <%= client.secret ? '••••••••' : '-' %>
                        </code>
                        <button class="btn btn-sm btn-link p-0 ms-2 toggle-secret" title="Tampilkan/Sembunyikan">
                          <i class="bi bi-eye"></i>
                        </button>
                      </td>
                      <td><%= client.nas_type || 'other' %></td>
                      <td>
                        <span class="badge bg-<%= client.require_message_authenticator === 'yes' ? 'success' : 'warning' %>">
                          <%= client.require_message_authenticator || 'no' %>
                        </span>
                      </td>
                      <td>
                        <div class="admin-action-btns">
                          <button type="button" class="btn btn-sm btn-primary edit-client-btn" 
                                  data-name="<%= client.name %>"
                                  data-ipaddr="<%= client.ipaddr %>"
                                  data-secret="<%= client.secret %>"
                                  data-nas-type="<%= client.nas_type %>"
                                  data-msg-auth="<%= client.require_message_authenticator %>"
                                  data-comment="<%= client.comment || '' %>"
                                  title="Ubah data klien RADIUS / NAS"
                                  aria-label="Ubah klien RADIUS">
                            <i class="bi bi-pencil"></i>
                          </button>
                          <button type="button" class="btn btn-sm btn-danger delete-client-btn" 
                                  data-name="<%= client.name %>"
                                  title="Hapus klien RADIUS dari daftar"
                                  aria-label="Hapus klien RADIUS">
                            <i class="bi bi-trash"></i>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="alert alert-info">
              <i class="bi bi-info-circle"></i> Belum ada client yang dikonfigurasi. Klik "Tambah Client (NAS)" untuk menambahkan.
            </div>
          <% } %>
        </div>
      </div>

      <!-- Info Box -->
      <div class="card mt-4 shadow-sm">
        <div class="card-body">
          <h6><i class="bi bi-info-circle"></i> Informasi</h6>
          <ul class="mb-0">
            <li>Client adalah router/NAS (Network Access Server) yang akan mengirim request autentikasi ke FreeRADIUS</li>
            <li>Setiap client harus memiliki IP address dan secret yang unik</li>
            <li><strong>Nama client tidak boleh spasi</strong> — hanya huruf, angka, titik, strip, underscore (contoh: <code>BAKTI_PUSAT</code>)</li>
            <li>IP tidak boleh disertai port (benar: <code>10.10.0.5</code>)</li>
            <li>Secret harus sama dengan yang dikonfigurasi di router Mikrotik</li>
            <li>Setelah menambah/edit/hapus client, FreeRADIUS akan otomatis direstart (hanya jika config valid)</li>
            <li>NAS produksi disimpan di tabel <code>nas</code> SQLite; <code>clients.conf</code> hanya localhost</li>
          </ul>
        </div>
      </div>
    </main>
  </div>
</div>

<!-- Add/Edit Client Modal -->
<div class="modal fade" id="addClientModal" tabindex="-1" aria-labelledby="addClientModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="addClientModalLabel">
          <i class="bi bi-plus-circle"></i> <span id="modalTitle">Tambah Client (NAS)</span>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="clientForm">
        <div class="modal-body">
          <input type="hidden" id="oldName" name="oldName">
          
          <div class="mb-3">
            <label for="clientName" class="form-label">Nama Client *</label>
            <input type="text" class="form-control" id="clientName" name="name" required
                   maxlength="64" pattern="[A-Za-z0-9][A-Za-z0-9._\-]*"
                   title="Hanya huruf, angka, titik, strip, underscore — tanpa spasi"
                   placeholder="misal: mikrotik-router-1" autocomplete="off"
                   inputmode="text" spellcheck="false">
            <small class="form-text text-muted">
              Wajib aman untuk FreeRADIUS: <strong>huruf, angka, <code>.</code> <code>-</code> <code>_</code> saja</strong> (tanpa spasi).
              Contoh valid: <code>BAKTI_PUSAT</code>, <code>RO-KRG_MERDEN</code>.
            </small>
            <div id="clientNameFeedback" class="invalid-feedback d-block" style="display:none!important"></div>
          </div>

          <div class="mb-3">
            <label for="clientIpaddr" class="form-label">IP Address *</label>
            <input type="text" class="form-control" id="clientIpaddr" name="ipaddr" required
                   maxlength="45" pattern="(\d{1,3}\.){3}\d{1,3}|([0-9a-fA-F:]+)"
                   title="IPv4 tanpa port, contoh 10.10.0.5"
                   placeholder="10.10.0.5" autocomplete="off" spellcheck="false">
            <small class="form-text text-muted">IP NAS/tunnel saja — <strong>jangan</strong> sertakan port (salah: <code>10.10.0.5:8728</code>)</small>
            <div id="clientIpFeedback" class="invalid-feedback d-block" style="display:none!important"></div>
          </div>

          <div class="mb-3">
            <label for="clientSecret" class="form-label">Secret *</label>
            <input type="text" class="form-control" id="clientSecret" name="secret" required 
                   placeholder="testing123">
            <small class="form-text text-muted">Shared secret (harus sama dengan yang dikonfigurasi di router)</small>
          </div>

          <div class="mb-3">
            <label for="clientNasType" class="form-label">NAS Type</label>
            <select class="form-select" id="clientNasType" name="nas_type">
              <option value="other" selected>other</option>
              <option value="cisco">cisco</option>
              <option value="juniper">juniper</option>
              <option value="mikrotik">mikrotik</option>
            </select>
          </div>

          <div class="mb-3">
            <label for="clientMsgAuth" class="form-label">Require Message Authenticator</label>
            <select class="form-select" id="clientMsgAuth" name="require_message_authenticator">
              <option value="no" selected>no</option>
              <option value="yes">yes</option>
              <option value="auto">auto</option>
            </select>
            <small class="form-text text-muted">Untuk keamanan, set ke 'yes' jika router mendukung</small>
          </div>

          <div class="mb-3">
            <label for="clientComment" class="form-label">Komentar (Opsional)</label>
            <input type="text" class="form-control" id="clientComment" name="comment" 
                   placeholder="misal: Router utama di cabang A">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function() {
  const modal = $('#addClientModal');
  const form = $('#clientForm');
  let isEditMode = false;

  const NAME_RE = /^[A-Za-z0-9][A-Za-z0-9._-]*$/;
  const IPV4_RE = /^(\d{1,3}\.){3}\d{1,3}$/;
  const IPV4_PORT_RE = /^(\d{1,3}\.){3}\d{1,3}:\d+$/;

  function showFieldError($input, $feedback, msg) {
    $input.addClass('is-invalid').removeClass('is-valid');
    if ($feedback && $feedback.length) {
      $feedback.attr('style', '').text(msg || '').toggle(!!msg);
    }
  }
  function clearFieldError($input, $feedback) {
    $input.removeClass('is-invalid').addClass('is-valid');
    if ($feedback && $feedback.length) {
      $feedback.attr('style', 'display:none!important').text('');
    }
  }

  function validateNameLive() {
    const $el = $('#clientName');
    const $fb = $('#clientNameFeedback');
    let v = $el.val();
    // Blok spasi & karakter ilegal saat mengetik — ganti spasi jadi _
    const filtered = String(v).replace(/\s+/g, '_').replace(/[^A-Za-z0-9._-]/g, '');
    if (filtered !== v) {
      const pos = $el[0].selectionStart;
      $el.val(filtered);
      try { $el[0].setSelectionRange(Math.max(0, pos - (v.length - filtered.length)), Math.max(0, pos - (v.length - filtered.length))); } catch (_) {}
      v = filtered;
    }
    if (!v) {
      showFieldError($el, $fb, 'Nama client wajib diisi');
      return false;
    }
    if (!NAME_RE.test(v)) {
      showFieldError($el, $fb, 'Hanya huruf, angka, titik, strip, underscore — tanpa spasi');
      return false;
    }
    clearFieldError($el, $fb);
    return true;
  }

  function validateIpLive() {
    const $el = $('#clientIpaddr');
    const $fb = $('#clientIpFeedback');
    const v = String($el.val() || '').trim();
    if (!v) {
      showFieldError($el, $fb, 'IP address wajib diisi');
      return false;
    }
    if (IPV4_PORT_RE.test(v)) {
      showFieldError($el, $fb, 'Jangan sertakan port — cukup IP saja (contoh: 10.10.0.5)');
      return false;
    }
    if (IPV4_RE.test(v)) {
      const ok = v.split('.').every(function(p) { const n = parseInt(p, 10); return n >= 0 && n <= 255; });
      if (!ok) {
        showFieldError($el, $fb, 'Oktet IPv4 harus 0–255');
        return false;
      }
      clearFieldError($el, $fb);
      return true;
    }
    if (v.includes(':') && !v.includes('.')) {
      clearFieldError($el, $fb);
      return true;
    }
    showFieldError($el, $fb, 'Format IP tidak valid');
    return false;
  }

  $('#clientName').on('input', validateNameLive);
  $('#clientIpaddr').on('input', validateIpLive);

  // Toggle secret visibility
  $(document).on('click', '.toggle-secret', function() {
    const $secretText = $(this).siblings('.secret-text');
    const $icon = $(this).find('i');
    const secret = $secretText.data('secret');
    
    if ($secretText.text().includes('••••')) {
      $secretText.text(secret);
      $icon.removeClass('bi-eye').addClass('bi-eye-slash');
    } else {
      $secretText.text('••••••••');
      $icon.removeClass('bi-eye-slash').addClass('bi-eye');
    }
  });

  // Edit client button
  $(document).on('click', '.edit-client-btn', function() {
    isEditMode = true;
    const $btn = $(this);
    
    $('#modalTitle').text('Edit Client (NAS)');
    $('#oldName').val($btn.data('name'));
    $('#clientName').val($btn.data('name'));
    $('#clientIpaddr').val($btn.data('ipaddr'));
    $('#clientSecret').val($btn.data('secret'));
    $('#clientNasType').val($btn.data('nas-type') || 'other');
    $('#clientMsgAuth').val($btn.data('msg-auth') || 'no');
    $('#clientComment').val($btn.data('comment') || '');
    validateNameLive();
    validateIpLive();
    
    modal.modal('show');
  });

  // Add new client button
  $('#addClientModal').on('show.bs.modal', function() {
    if (!isEditMode) {
      $('#modalTitle').text('Tambah Client (NAS)');
      form[0].reset();
      $('#oldName').val('');
      $('#clientName, #clientIpaddr').removeClass('is-invalid is-valid');
      $('#clientNameFeedback, #clientIpFeedback').attr('style', 'display:none!important').text('');
    }
    isEditMode = false;
  });

  // Delete client button
  $(document).on('click', '.delete-client-btn', function() {
    const name = $(this).data('name');
    if (confirm(`Yakin ingin menghapus client "${name}"?`)) {
      $.ajax({
        url: '/admin/radius/clients/delete',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ name: name }),
        success: function(response) {
          if (response.success) {
            alert('Client berhasil dihapus' + (response.restart && response.restart.success ? ' dan FreeRADIUS berhasil direstart' : ''));
            location.reload();
          } else {
            alert('Gagal menghapus client: ' + response.message);
          }
        },
        error: function() {
          alert('Error menghapus client');
        }
      });
    }
  });

  // Form submit
  form.on('submit', function(e) {
    e.preventDefault();

    const nameOk = validateNameLive();
    const ipOk = validateIpLive();
    if (!nameOk || !ipOk) {
      alert('Perbaiki nama/IP client sebelum menyimpan. Nama tanpa spasi; IP tanpa port.');
      return;
    }
    
    const formData = {
      name: $('#clientName').val().trim(),
      ipaddr: $('#clientIpaddr').val().trim(),
      secret: $('#clientSecret').val().trim(),
      nas_type: $('#clientNasType').val(),
      require_message_authenticator: $('#clientMsgAuth').val(),
      comment: $('#clientComment').val().trim() || null
    };

    const oldName = $('#oldName').val();
    const url = oldName ? '/admin/radius/clients/edit' : '/admin/radius/clients/add';
    
    if (oldName) {
      formData.oldName = oldName;
    }

    const $submitBtn = form.find('button[type="submit"]');
    $submitBtn.prop('disabled', true);

    $.ajax({
      url: url,
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify(formData),
      success: function(response) {
        $submitBtn.prop('disabled', false);
        if (response.success) {
          modal.modal('hide');
          let msg = response.message || 'Berhasil disimpan';
          if (response.restart && !response.restart.success) {
            msg += '\n\nPeringatan restart: ' + (response.restart.message || '');
          }
          alert(msg);
          location.reload();
        } else {
          alert('Gagal: ' + (response.message || 'unknown'));
        }
      },
      error: function(xhr) {
        $submitBtn.prop('disabled', false);
        const msg = (xhr.responseJSON && xhr.responseJSON.message) || 'Error menyimpan client';
        alert(msg);
      }
    });
  });
});
</script>
</body>
</html>

