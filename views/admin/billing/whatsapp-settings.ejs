            const response = await fetch('/admin/settings/wa-delete', { method: 'POST' });
            const data = await response.json();

            if (data.success) {
                showAlert(data.message || 'Sesi WhatsApp berhasil dihapus.', 'success');
                loadWAStatus();
            } else {
                showAlert(data.error || data.message || 'Gagal hapus sesi WhatsApp', 'danger');
            }
        } catch (error) {
            console.error('Error deleting WhatsApp session:', error);
            showAlert('Error hapus sesi WhatsApp', 'danger');
        }
    }

    function startWAStatusInterval() {
        stopWAStatusInterval();
        waStatusInterval = setInterval(() => {
            if (document.getElementById('baileys_enabled')?.checked) {
                loadWAStatus();
            } else {
                stopWAStatusInterval();
            }
        }, 10000);
    }

    function stopWAStatusInterval() {
        if (waStatusInterval) {
            clearInterval(waStatusInterval);
            waStatusInterval = null;
        }
    }

    // Load templates from server
    async function loadTemplates() {
        try {
