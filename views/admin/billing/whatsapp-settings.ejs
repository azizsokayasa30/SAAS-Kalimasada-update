                    if (toggle) {
                        toggle.checked = templates[key].enabled !== false; // Default to true if not specified
                    }
                });
                updateTemplateStatus();
            }
        } catch (error) {
            console.error('Error loading templates:', error);
            showAlert('Error loading templates', 'danger');
        }
    }

