    async function saveProviderSettings() {
        const payload = collectProviderSettings();
        const button = document.getElementById('btnSaveGatewaySettings');
        const originalHtml = button ? button.innerHTML : '';
        if (button) {
            button.disabled = true;
            button.innerHTML = '<i class="bi bi-hourglass-split"></i> Menyimpan...';
        }
        try {
            const response = await fetch('/admin/billing/whatsapp-settings/gateway', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await response.json();

            if (data.success) {
                applyProviderSettings(data.settings || {});
                showAlert('Pengaturan provider WhatsApp berhasil disimpan!', 'success');
                toggleBaileysContent();
            } else {
                showAlert('Gagal menyimpan provider: ' + (data.message || data.error || 'Unknown error'), 'danger');
            }
        } catch (error) {
            console.error('Error saving provider settings:', error);
            showAlert('Error menyimpan pengaturan provider WhatsApp', 'danger');
        } finally {
            if (button) {
                button.disabled = false;
                button.innerHTML = originalHtml;
            }
        }
    }

    function toggleBaileysContent() {
        const enabled = document.getElementById('baileys_enabled')?.checked;
        const content = document.getElementById('baileysContent');
        const status = document.getElementById('wa-status');
        const qrContainer = document.getElementById('wa-qr-container');

        if (!content) return;

        if (enabled) {
            content.style.display = '';
            loadWAStatus();
            startWAStatusInterval();
        } else {
            content.style.display = 'none';
            if (status) status.innerHTML = '';
            if (qrContainer) qrContainer.classList.add('d-none');
            stopWAStatusInterval();
        }
    }

    async function loadWAStatus() {
        const status = document.getElementById('wa-status');
        const qrContainer = document.getElementById('wa-qr-container');
        const qrImage = document.getElementById('wa-qr');
        const qrDiv = document.getElementById('wa-qr-div');

        if (!status || !qrContainer || !qrDiv) return;

        try {
            const response = await fetch('/admin/settings/wa-status');
            const data = await response.json();

            if (data.connected) {
                const phone = data.phoneNumber ? ` (${data.phoneNumber})` : '';
                const since = data.connectedSince ? `<br><small>Terhubung sejak: ${new Date(data.connectedSince).toLocaleString()}</small>` : '';
                status.innerHTML = `<span class="badge bg-success status-badge"><i class="bi bi-check-circle"></i> Terhubung${phone}${since}</span>`;
                qrContainer.classList.add('d-none');
                qrDiv.innerHTML = '';
                return;
            }

            status.innerHTML = '<span class="badge bg-warning text-dark status-badge"><i class="bi bi-exclamation-triangle"></i> Belum Terhubung</span>';
            qrContainer.classList.add('d-none');
            qrDiv.innerHTML = '';
            if (qrImage) {
                qrImage.setAttribute('src', '#');
                qrImage.style.display = 'none';
            }

            if (data.qr) {
                qrContainer.classList.remove('d-none');
                if (data.qrImage && qrImage) {
                    qrImage.setAttribute('src', data.qrImage);
                    qrImage.style.display = 'block';
                    qrDiv.innerHTML = '';
                    status.insertAdjacentHTML('beforeend', '<div class="text-info small mt-2"><i class="bi bi-info-circle"></i> Scan dari WhatsApp &gt; Perangkat tertaut.</div>');
                    return;
                }

                if (typeof QRCode === 'undefined') {
                    qrDiv.innerHTML = '<div class="alert alert-warning">QR tersedia, tetapi generator QR browser belum termuat. Refresh halaman lalu coba lagi.</div>';
                    return;
                }

                try {
                    new QRCode(qrDiv, {
                        text: data.qr,
                        width: 320,
                        height: 320,
                        colorDark: '#000000',
                        colorLight: '#ffffff',
                        correctLevel: QRCode.CorrectLevel.M || 2
                    });
                    status.insertAdjacentHTML('beforeend', '<div class="text-info small mt-2"><i class="bi bi-info-circle"></i> Scan dari WhatsApp &gt; Perangkat tertaut.</div>');
                } catch (qrError) {
                    console.error('Error rendering QR code:', qrError);
                    qrDiv.innerHTML = '<div class="alert alert-warning">QR tersedia, tetapi gagal dirender di browser. Klik Refresh QR atau refresh halaman.</div>';
                }
            } else if (data.error) {
                status.insertAdjacentHTML('beforeend', `<div class="alert alert-danger mt-2">${data.error}</div>`);
            } else {
                status.insertAdjacentHTML('beforeend', '<div class="alert alert-info mt-2"><i class="bi bi-hourglass-split"></i> Menunggu QR code. Klik Refresh QR jika belum muncul.</div>');
            }
        } catch (error) {
            console.error('Error getting WhatsApp status:', error);
            status.innerHTML = '<span class="badge bg-danger status-badge"><i class="bi bi-x-circle"></i> Gagal memuat status</span>';
            qrContainer.classList.add('d-none');
        }
    }

    async function refreshWAQRCode() {
        if (!document.getElementById('baileys_enabled')?.checked) {
            showAlert('Baileys belum diaktifkan. Centang Enable Baileys terlebih dahulu.', 'warning');
            return;
        }

        const button = document.getElementById('btnRefreshQR');
        const originalHtml = button ? button.innerHTML : '';
        if (button) {
            button.disabled = true;
            button.innerHTML = '<i class="bi bi-hourglass-split"></i> Refreshing...';
        }

        try {
            const response = await fetch('/admin/settings/wa-refresh', { method: 'POST' });
            const data = await response.json();

            if (!data.success) {
                showAlert(data.error || data.message || 'Gagal refresh QR', 'danger');
                return;
            }

            showAlert(data.message || 'Sesi direset, menunggu QR code baru...', 'info');
            loadWAStatus();

            if (waRefreshPolling) clearInterval(waRefreshPolling);
            let attempts = 0;
            waRefreshPolling = setInterval(() => {
                attempts += 1;
                loadWAStatus();
                const hasQr = document.querySelector('#wa-qr[src^="data:image"], #wa-qr-div canvas, #wa-qr-div img');
                if (hasQr || attempts >= 4) {
                    clearInterval(waRefreshPolling);
                    waRefreshPolling = null;
                    if (!hasQr && attempts >= 4) {
                        showAlert('QR belum muncul. Coba refresh sekali lagi atau restart service.', 'warning');
                    }
                }
            }, 10000);
        } catch (error) {
            console.error('Error refreshing QR:', error);
            showAlert('Error refresh QR WhatsApp', 'danger');
        } finally {
            if (button) {
                button.disabled = false;
                button.innerHTML = originalHtml;
            }
        }
    }

