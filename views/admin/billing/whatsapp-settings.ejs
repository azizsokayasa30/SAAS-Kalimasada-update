    function bindBaileysControls() {
        const toggle = document.getElementById('baileys_enabled');
        const activeProvider = document.getElementById('whatsappActiveProvider');
        const saveButton = document.getElementById('btnSaveGatewaySettings');
        const refreshButton = document.getElementById('btnRefreshQR');
        const deleteButton = document.getElementById('btnDeleteSession');

        if (toggle) {
