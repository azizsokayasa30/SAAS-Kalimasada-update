<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Pengeluaran - Admin Portal</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/vendor/boxicons/boxicons.min.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <style>
        .main-content { min-height: 100vh; }
    </style>

    <%- include('../../partials/theme-head') %>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-sidebar') %>
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2"><i class="bi bi-cash-coin"></i> Manajemen Pengeluaran</h1>
                    <div>
                        <a href="/admin/billing/expenses" class="btn btn-outline-secondary me-2">
                            <i class="bi bi-arrow-clockwise"></i> Refresh
                        </a>
                        <button type="button" class="btn btn-outline-success me-2" onclick="exportToCSV()">
                            <i class="bi bi-download"></i> Export CSV
                        </button>
                        <a href="/admin/billing/finance-categories" class="btn btn-outline-info me-2">
                            <i class="bi bi-tags"></i> Kelola Kategori
                        </a>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
                            <i class="bi bi-plus-lg"></i> Tambah Pengeluaran
                        </button>
                    </div>
                </div>

                <!-- Filter Section -->
                <div class="card mb-4">
                    <div class="card-body">
                        <form method="GET" class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label">Bulan</label>
                                <select class="form-select" name="month" id="month_filter">
                                    <% const monthNames = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember']; %>
                                    <% for (let m = 1; m <= 12; m++) { %>
                                        <option value="<%= m %>" <%= Number(month) === m ? 'selected' : '' %>><%= monthNames[m - 1] %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tahun</label>
                                <% const currentYear = new Date().getFullYear(); %>
                                <select class="form-select" name="year" id="year_filter">
                                    <% for (let y = currentYear - 3; y <= currentYear + 1; y++) { %>
                                        <option value="<%= y %>" <%= Number(year) === y ? 'selected' : '' %>><%= y %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i> Filter
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <%- include('../../partials/finance-category-summary', {
                    categorySummary: typeof categorySummary !== 'undefined' ? categorySummary : null,
                    summaryTitle: 'Ringkasan per Kategori Pengeluaran',
                    summaryVariant: 'expense',
                    amountClass: 'text-danger',
                    startDate: typeof startDate !== 'undefined' ? startDate : '',
                    endDate: typeof endDate !== 'undefined' ? endDate : '',
                    transactionBodyId: 'expenseTransactionBody',
                    listTitleId: 'financeTransactionListTitle',
                    listTitleDefault: 'Daftar Pengeluaran'
                }) %>

                <!-- Expenses Table -->
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h5 class="card-title mb-0" id="financeTransactionListTitle">Daftar Pengeluaran</h5>
                        <button type="button" class="btn btn-sm btn-outline-secondary d-none" id="financeCategoryFilterClear">
                            <i class="bi bi-x-lg me-1"></i> Tampilkan Semua
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tanggal</th>
                                        <th>Kategori Pengeluaran</th>
                                        <th>Akun Pengeluaran</th>
                                        <th>Jumlah</th>
                                        <th>Metode Pembayaran</th>
                                        <th>Catatan</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody id="expenseTransactionBody">
                                    <% if (expenses && expenses.length > 0) { %>
                                        <% expenses.forEach(function(expense) { %>
                                            <tr data-id="<%= expense.id %>" data-category="<%= expense.category %>">
                                                <td><%= new Date(expense.expense_date).toLocaleDateString('id-ID') %></td>
                                                <td><span class="badge bg-info"><%= expense.category || '-' %></span></td>
                                                <td><%= expense.account_expenses || '-' %></td>
                                                <td class="text-danger">Rp <%= (expense.amount || 0).toLocaleString('id-ID') %></td>
                                                <td><%= expense.payment_method || '-' %></td>
                                                <td><%= expense.notes || '-' %></td>
                                                <td>
                                                    <div class="admin-action-btns">
                                                        <button type="button" class="btn btn-sm btn-primary" onclick="editExpense('<%= expense.id %>')" title="Ubah catatan pengeluaran" aria-label="Ubah pengeluaran">Edit</button>
                                                        <button type="button" class="btn btn-sm btn-danger" onclick="deleteExpense('<%= expense.id %>')" title="Hapus catatan pengeluaran" aria-label="Hapus pengeluaran">Hapus</button>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                        <tr class="finance-filter-empty d-none">
                                            <td colspan="7" class="text-center text-muted">
                                                Tidak ada pengeluaran untuk kategori ini
                                            </td>
                                        </tr>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">
                                                Tidak ada data pengeluaran
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Add Expense Modal -->
    <div class="modal fade" id="addExpenseModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tambah Pengeluaran</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="addExpenseForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="category" class="form-label">Kategori Pengeluaran *</label>
                            <select class="form-select" id="category" name="category" required>
                                <option value="">Pilih Kategori Pengeluaran</option>
                                <option value="Harga Pokok Penjualan (HPP)">Harga Pokok Penjualan (HPP)</option>
                                <option value="Beban Operasional (OPEX)">Beban Operasional (OPEX)</option>
                                <option value="Beban Lainnya">Beban Lainnya</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="expense_date" class="form-label">Tanggal Pengeluaran *</label>
                            <input type="date" class="form-control" id="expense_date" name="expense_date" required>
                        </div>
                        <div class="mb-3">
                            <label for="amount" class="form-label">Jumlah *</label>
                            <input type="number" class="form-control" id="amount" name="amount" step="0.01" required>
                        </div>
                        <div class="mb-3">
                            <label for="payment_method" class="form-label">Metode Pembayaran</label>
                            <select class="form-select" id="payment_method" name="payment_method">
                                <option value="">Pilih Metode</option>
                                <option value="Cash">Cash</option>
                                <option value="Transfer Bank">Transfer Bank</option>
                                <option value="E-Wallet">E-Wallet</option>
                                <option value="Kartu Kredit">Kartu Kredit</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="notes" class="form-label">Catatan</label>
                            <textarea class="form-control" id="notes" name="notes" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Simpan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Expense Modal -->
    <div class="modal fade" id="editExpenseModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Pengeluaran</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editExpenseForm">
                    <input type="hidden" id="edit_id" name="id">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="edit_category" class="form-label">Kategori Pengeluaran *</label>
                            <select class="form-select" id="edit_category" name="category" required>
                                <option value="">Pilih Kategori Pengeluaran</option>
                                <option value="Harga Pokok Penjualan (HPP)">Harga Pokok Penjualan (HPP)</option>
                                <option value="Beban Operasional (OPEX)">Beban Operasional (OPEX)</option>
                                <option value="Beban Lainnya">Beban Lainnya</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="edit_account_expenses" class="form-label">Akun Pengeluaran *</label>
                            <select class="form-select" id="edit_account_expenses" name="account_expenses" required>
                                <option value="">Pilih kategori pengeluaran terlebih dahulu</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="edit_expense_date" class="form-label">Tanggal Pengeluaran *</label>
                            <input type="date" class="form-control" id="edit_expense_date" name="expense_date" required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_amount" class="form-label">Jumlah *</label>
                            <input type="number" class="form-control" id="edit_amount" name="amount" step="0.01" required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_payment_method" class="form-label">Metode Pembayaran</label>
                            <select class="form-select" id="edit_payment_method" name="payment_method">
                                <option value="">Pilih Metode</option>
                                <option value="Cash">Cash</option>
                                <option value="Transfer Bank">Transfer Bank</option>
                                <option value="E-Wallet">E-Wallet</option>
                                <option value="Kartu Kredit">Kartu Kredit</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="edit_notes" class="form-label">Catatan</label>
                            <textarea class="form-control" id="edit_notes" name="notes" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set default date to today
        document.getElementById('expense_date').value = new Date().toISOString().split('T')[0];

        let accountExpensesOptions = {};

        // Load categories from DB
        async function loadExpenseCategories() {
            try {
                const res = await fetch('/admin/billing/api/finance-categories?type=expense');
                const data = await res.json();
                if (data.success) {
                    const categorySelect = document.getElementById('category');
                    const editCategorySelect = document.getElementById('edit_category');
                    
                    categorySelect.innerHTML = '<option value="">Pilih Kategori Pengeluaran</option>';
                    editCategorySelect.innerHTML = '<option value="">Pilih Kategori Pengeluaran</option>';
                    
                    data.data.forEach(cat => {
                        const opt = `<option value="${cat.name}">${cat.name}</option>`;
                        categorySelect.innerHTML += opt;
                        editCategorySelect.innerHTML += opt;
                        
                        let subs = [];
                        try { subs = JSON.parse(cat.subcategories) || []; } catch(e) {}
                        accountExpensesOptions[cat.name] = subs;
                    });
                }
            } catch(e) {
                console.error("Error loading categories:", e);
            }
        }
        loadExpenseCategories();

        // Function to update account expenses dropdown
        function updateAccountExpenses(categorySelectId, accountSelectId) {
            const categorySelect = document.getElementById(categorySelectId);
            const accountSelect = document.getElementById(accountSelectId);
            
            // Clear existing options
            accountSelect.innerHTML = '<option value="">Pilih Akun Pengeluaran</option>';
            
            const selectedCategory = categorySelect.value;
            if (selectedCategory && accountExpensesOptions[selectedCategory]) {
                accountExpensesOptions[selectedCategory].forEach(option => {
                    const optionElement = document.createElement('option');
                    optionElement.value = option;
                    optionElement.textContent = option;
                    accountSelect.appendChild(optionElement);
                });
            }
        }

        // Add event listener for edit category changes
        document.getElementById('edit_category').addEventListener('change', function() {
            updateAccountExpenses('edit_category', 'edit_account_expenses');
        });

        // Export to CSV function
        function exportToCSV() {
            <% if (expenses && expenses.length > 0) { %>
            const expenses = <%- JSON.stringify(expenses) %>;
            const csvHeaders = ['Tanggal', 'Kategori Pengeluaran', 'Akun Pengeluaran', 'Jumlah', 'Metode Pembayaran', 'Catatan'];
            
            const csvRows = [csvHeaders.join(',')];
            
            expenses.forEach(expense => {
                const row = [
                    `"${new Date(expense.expense_date).toLocaleDateString('id-ID')}"`,
                    `"${expense.category || ''}"`,
                    `"${expense.account_expenses || ''}"`,
                    `"${expense.amount}"`,
                    `"${expense.payment_method || ''}"`,
                    `"${(expense.notes || '').replace(/"/g, '""')}"`
                ];
                csvRows.push(row.join(','));
            });
            
            const csvContent = csvRows.join('\n');
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `pengeluaran-${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
            URL.revokeObjectURL(url);
            <% } else { %>
            alert('Tidak ada data untuk di-export');
            <% } %>
        }

        // Add expense form submission
        document.getElementById('addExpenseForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());
            
            try {
                const response = await fetch('/admin/billing/api/expenses', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    document.getElementById('addExpenseModal').querySelector('.btn-close').click();
                    document.getElementById('addExpenseForm').reset();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('Terjadi kesalahan saat menyimpan data');
            }
        });

        // Edit expense
        function editExpense(id) {
            // Fetch expense data from server
            fetch(`/admin/billing/api/expenses/${id}`)
                .then(response => response.json())
                .then(result => {
                    if (result.success && result.data) {
                        const expense = result.data;
                        document.getElementById('edit_id').value = id;
                        document.getElementById('edit_amount').value = expense.amount || '';
                        document.getElementById('edit_category').value = expense.category || '';
                        
                        // Update account expenses dropdown based on category
                        updateAccountExpenses('edit_category', 'edit_account_expenses');
                        
                        // Set account expenses after a short delay to ensure dropdown is populated
                        setTimeout(() => {
                            document.getElementById('edit_account_expenses').value = expense.account_expenses || '';
                        }, 100);
                        
                        document.getElementById('edit_expense_date').value = expense.expense_date || '';
                        document.getElementById('edit_payment_method').value = expense.payment_method || '';
                        document.getElementById('edit_notes').value = expense.notes || '';
                        
                        new bootstrap.Modal(document.getElementById('editExpenseModal')).show();
                    } else {
                        alert('Gagal memuat data pengeluaran');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Terjadi kesalahan saat memuat data');
                });
        }

        // Edit expense form submission
        document.getElementById('editExpenseForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());
            const id = data.id;
            delete data.id;
            
            try {
                const response = await fetch(`/admin/billing/api/expenses/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    document.getElementById('editExpenseModal').querySelector('.btn-close').click();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('Terjadi kesalahan saat mengupdate data');
            }
        });

        // Delete expense
        async function deleteExpense(id) {
            if (!confirm('Apakah Anda yakin ingin menghapus pengeluaran ini?')) return;
            
            try {
                const response = await fetch(`/admin/billing/api/expenses/${id}`, {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('Terjadi kesalahan saat menghapus data');
            }
        }
    </script>
</body>
</html>

