                showToast('error', 'Validasi', 'Pilih minimal satu wilayah');
                return;
            }
            if (!due_day || isNaN(due_day) || parseInt(due_day, 10) < 1 || parseInt(due_day, 10) > 28) {
                showToast('error', 'Validasi', 'Tanggal jatuh tempo harus antara 1–28');
                return;
            }

            if (!window.confirm(`Update jatuh tempo ke tanggal ${due_day} untuk ${area_ids.length} wilayah terpilih?\n\nTagihan unpaid akan disesuaikan.`)) {
                return;
            }

            const btn = $(this);
            const originalText = btn.html();
            btn.prop('disabled', true).html('<i class="bi bi-arrow-repeat bx-spin me-2"></i>Memproses...');
            showToast('info', 'Memproses', 'Update jatuh tempo per wilayah...', 6000);

            fetch('/admin/billing/service-suspension/bulk-update-due-date-by-areas', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ area_ids, due_day: parseInt(due_day, 10) })
            })
                .then(async (r) => {
                    const data = await r.json().catch(() => ({}));
                    if (!r.ok && !data.message) throw new Error('HTTP ' + r.status);
                    return data;
                })
                .then((data) => {
                    const body = [
                        data.message || '',
                        `Pelanggan: ${data.updated ?? 0}/${data.total ?? 0}`,
                        `Invoice disesuaikan: ${data.invoices_updated ?? 0}`
                    ].filter(Boolean).join('\n');
                    if (data.success) {
                        showToast((data.failed || 0) > 0 ? 'warning' : 'success', 'Jatuh tempo diupdate', body, 12000);
                    } else {
                        showToast('error', 'Gagal', body || data.message || 'Terjadi kesalahan', 12000);
                    }
                })
                .catch((err) => {
                    showToast('error', 'Gagal', err.message || 'Koneksi gagal', 10000);
                })
                .finally(() => {
                    btn.prop('disabled', false).html(originalText);
                });
        });

        $('#btnBulkAutoIsolirByAreas').click(function () {
            const area_ids = getSelectedAreaIds('isolirAreasList');
            const auto_suspension_day = $('#bulkAutoIsolirDay').val();

            if (area_ids.length === 0) {
                showToast('error', 'Validasi', 'Pilih minimal satu wilayah');
                return;
            }
            if (!auto_suspension_day || isNaN(auto_suspension_day) || parseInt(auto_suspension_day, 10) < 1 || parseInt(auto_suspension_day, 10) > 28) {
                showToast('error', 'Validasi', 'Tanggal auto isolir harus antara 1–28');
                return;
            }

            if (!window.confirm(`Set tanggal auto isolir ke tgl ${auto_suspension_day} untuk pelanggan di ${area_ids.length} wilayah terpilih?`)) {
                return;
            }

            const btn = $(this);
            const originalText = btn.html();
            btn.prop('disabled', true).html('<i class="bi bi-arrow-repeat bx-spin me-2"></i>Memproses...');
            showToast('info', 'Memproses', 'Update tanggal auto isolir per wilayah...', 6000);

            fetch('/admin/billing/service-suspension/bulk-update-auto-isolir-by-areas', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ area_ids, auto_suspension_day: parseInt(auto_suspension_day, 10) })
            })
                .then(async (r) => {
                    const data = await r.json().catch(() => ({}));
                    if (!r.ok && !data.message) throw new Error('HTTP ' + r.status);
                    return data;
                })
                .then((data) => {
                    const body = [
                        data.message || '',
                        `Pelanggan: ${data.updated ?? 0}/${data.total ?? 0}`
                    ].filter(Boolean).join('\n');
                    if (data.success) {
                        showToast((data.failed || 0) > 0 ? 'warning' : 'success', 'Auto isolir diupdate', body, 12000);
                        if (data.area_ids && data.area_ids.length) {
