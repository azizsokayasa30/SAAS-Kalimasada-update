            badge.removeClass('bg-success bg-danger').addClass('bg-secondary').text('Saving...');
            $(this).prop('disabled', true);

            fetch('/admin/billing/service-suspension/toggle-feature', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ enabled: isEnabled })
            })
            .then(r => r.json())
            .then(data => {
                if (data && data.success) {
                    showToast('success', 'Berhasil', 'Fitur Auto Isolir ' + (isEnabled ? 'Diaktifkan' : 'Dimatikan'));
                    badge.removeClass('bg-secondary').addClass(isEnabled ? 'bg-success' : 'bg-danger').text(isEnabled ? 'ON' : 'OFF');
                } else {
                    showToast('error', 'Gagal', data.message || 'Gagal mengubah pengaturan');
                    // Revert UI
                    $(this).prop('checked', !isEnabled);
                    badge.removeClass('bg-secondary').addClass(!isEnabled ? 'bg-success' : 'bg-danger').text(!isEnabled ? 'ON' : 'OFF');
                }
            })
            .catch(err => {
                showToast('error', 'Gagal', 'Terjadi kesalahan koneksi');
                // Revert UI
                $(this).prop('checked', !isEnabled);
                badge.removeClass('bg-secondary').addClass(!isEnabled ? 'bg-success' : 'bg-danger').text(!isEnabled ? 'ON' : 'OFF');
            })
            .finally(() => {
                $(this).prop('disabled', false);
            });
        });

    </script>
</body>
</html>

