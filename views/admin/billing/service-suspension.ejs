        function filterSuspendedCustomers() {
            const q = String($('#suspendedSearchInput').val() || '').trim().toLowerCase();
            if (!q) {
                renderSuspendedCustomers(suspendedCustomersCache);
                return;
            }
            const filtered = suspendedCustomersCache.filter(c =>
                String(c.name || '').toLowerCase().includes(q)
            );
            renderSuspendedCustomers(filtered);
        }

