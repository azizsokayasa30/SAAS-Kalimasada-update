                    }
                })
                .catch((err) => {
                    showToast('error', 'Gagal', err.message || 'Koneksi gagal', 10000);
                })
                .finally(() => {
                    btn.prop('disabled', false).html(originalText);
                });
        });

        // Get current isolir profile setting
        function loadCurrentIsolirProfile() {
            fetch('/admin/billing/service-suspension/isolir-profile')
                .then(r => r.json())
                .then(data => {
                    if (data && data.success) {
                        const current = data.isolir_profile || 'isolir';
                        // ensure options exist then update tampilan
                        const sel = document.getElementById('isolirProfileSelect');
                        if (sel && sel.options.length > 0) {
                            // Update tampilan profil aktif tanpa mengubah struktur dropdown
                            for (let i = 0; i < sel.options.length; i++) {
                                const option = sel.options[i];
                                if (option.value === current) {
                                    option.textContent = current + ' (Aktif)';
                                    // Pastikan tetap selected
                                    sel.value = current;
                                } else if (option.textContent.includes(' (Aktif)')) {
                                    option.textContent = option.value;
                                }
                            }
                        }
                        else {
                            loadIsolirProfiles(current);
                        }
                        // tandai siap agar change berikutnya dianggap aksi user
                        isolirSelectReady = true;
                    }
                })
                .catch(() => {});
        }

