        // Restore customer
        function restoreCustomer(username) {
            if (!username || username.trim() === '') {
                showToast('error', 'Error', 'Username tidak valid');
                return;
            }

            if (!confirm(`Yakin ingin restore layanan untuk pelanggan ${username}?`)) return;

            const reason = prompt('Masukkan alasan buka isolir (opsional):', 'Manual restore');
            if (reason === null) return; // user canceled prompt

            // Show loading state
            showToast('info', 'Processing', `Sedang mengaktifkan layanan ${username}...`);

            $.post(`/admin/billing/service-suspension/restore/${username}`, { reason }, function(response) {
                if (response.success) {
                    const r = (response.reason || reason || '').trim();
                    const msg = r ? `Layanan ${username} diaktifkan. Alasan: ${r}` : `Layanan ${username} berhasil diaktifkan`;
                    showToast('success', 'Service Restored', msg);
                    loadStats();
                    loadSuspendedCustomers();
                } else {
                    showToast('error', 'Error', response.message || 'Gagal mengaktifkan layanan');
                }
            }).fail(function(xhr) {
                const response = xhr.responseJSON || {};
                showToast('error', 'Error', response.message || 'Request failed');
            });
        }

        // Initialize
        $(document).ready(function() {
            loadIsolirProfiles();
            loadCurrentIsolirProfile();
            loadStats();
            loadSuspendedCustomers();
        });

        // Load Mikrotik PPPoE profiles with active profile highlighting from settings.json
        // Atau load RADIUS groups jika mode RADIUS
        function loadIsolirProfiles(selected) {
            const sel = document.getElementById('isolirProfileSelect');
            if (!sel) return;
            
            // Check if RADIUS mode
            <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                // In RADIUS mode, isolir profile is always 'isolir' (groupname)
                // Just set the value
                sel.value = 'isolir';
                return;
            <% } %>
            
            // Mikrotik API mode
            sel.innerHTML = '<option>Loading...</option>';

            // Pertama, ambil profil aktif dari settings.json
            fetch('/admin/billing/service-suspension/isolir-profile')
                .then(r => r.json())
                .then(settingsData => {
                    const currentIsolirProfile = (settingsData && settingsData.success) ? settingsData.isolir_profile : 'isolir';

                    // Kemudian load profil dari Mikrotik API
                    return fetch('/admin/mikrotik/profiles/api')
                        .then(r => r.json())
                        .then(data => {
                            const names = Array.from(new Set(((data && data.profiles) || []).map(p => p.name).filter(Boolean)));

                            // Pastikan profil dari settings.json ada di daftar
                            if (currentIsolirProfile && !names.includes(currentIsolirProfile)) {
                                names.unshift(currentIsolirProfile);
                            }

                            sel.innerHTML = '';
                            names.forEach(n => {
                                const opt = document.createElement('option');
                                opt.value = n;

                                // Tandai profil yang sedang aktif dari settings.json
                                if (n === currentIsolirProfile) {
                                    opt.textContent = n + ' (Aktif)';
                                    opt.selected = true;
                                } else {
                                    opt.textContent = n;
                                }

                                sel.appendChild(opt);
                            });

                            // Set selected value jika ada parameter, tapi jangan override profil aktif
                            if (selected && selected !== currentIsolirProfile) {
                                sel.value = selected;
                            }
                        })
                        .catch(err => {
                            console.error('Load isolir profiles error:', err);
                            // Fallback: buat dropdown dengan profil dari settings.json
                            sel.innerHTML = '';
                            const opt = document.createElement('option');
                            opt.value = currentIsolirProfile;
                            opt.textContent = currentIsolirProfile + ' (Aktif)';
                            opt.selected = true;
                            sel.appendChild(opt);
                            showToast('warning', 'Fallback', 'Menggunakan profil dari pengaturan karena gagal load dari Mikrotik');
                        });
                })
                .catch(err => {
                    console.error('Error loading current isolir profile:', err);
                    // Jika gagal load settings, tetap load dari Mikrotik
                    fetch('/admin/mikrotik/profiles/api')
                        .then(r => r.json())
                        .then(data => {
                            const names = Array.from(new Set(((data && data.profiles) || []).map(p => p.name).filter(Boolean)));
                            if (!names.includes('isolir')) names.unshift('isolir');
                            sel.innerHTML = '';
                            names.forEach(n => {
                                const opt = document.createElement('option');
                                opt.value = n;
                                opt.textContent = n;
                                sel.appendChild(opt);
                            });
                            if (selected) sel.value = selected;
                        })
                        .catch(err => {
                            console.error('Load isolir profiles error:', err);
                            sel.innerHTML = '<option value="isolir">isolir</option>';
                            showToast('error', 'Gagal', 'Gagal memuat profile Mikrotik');
                        });
                });
        }

        function getSelectedAreaIds(containerId) {
            const ids = [];
            document.querySelectorAll(`#${containerId} input.area-checkbox:checked`).forEach((el) => {
                const id = parseInt(el.value, 10);
                if (Number.isFinite(id) && id > 0) ids.push(id);
            });
            return ids;
        }

        function renderAreaCheckboxes(areas, containerId, loadingId) {
            const listEl = document.getElementById(containerId);
            const loadingEl = document.getElementById(loadingId);
            if (!listEl) return;

            if (!areas || areas.length === 0) {
                if (loadingEl) loadingEl.textContent = 'Belum ada wilayah terdaftar. Tambahkan di menu Area.';
                listEl.style.display = 'none';
                return;
            }

            if (loadingEl) loadingEl.style.display = 'none';
            listEl.style.display = 'block';
            listEl.innerHTML = areas.map((a) => `
                <div class="form-check">
                    <input class="form-check-input area-checkbox" type="checkbox" value="${a.id}" id="${containerId}_area_${a.id}">
                    <label class="form-check-label" for="${containerId}_area_${a.id}">
                        ${a.nama_area}${a.kode_area ? ` <small class="text-muted">(${a.kode_area})</small>` : ''}
                    </label>
                </div>
            `).join('');
        }

        function loadBillingAreas() {
            fetch('/admin/billing/areas/list')
                .then((r) => r.json())
                .then((data) => {
                    const areas = (data && data.success && data.data) ? data.data : [];
                    renderAreaCheckboxes(areas, 'dueDateAreasList', 'dueDateAreasLoading');
                    renderAreaCheckboxes(areas, 'isolirAreasList', 'isolirAreasLoading');
                    renderAreaCheckboxes(areas, 'summaryAreasList', 'summaryAreasLoading');
                })
                .catch(() => {
                    ['dueDateAreasLoading', 'isolirAreasLoading', 'summaryAreasLoading'].forEach((id) => {
                        const el = document.getElementById(id);
                        if (el) el.textContent = 'Gagal memuat daftar wilayah.';
                    });
                    showToast('error', 'Gagal', 'Tidak dapat memuat daftar wilayah');
                });
        }

        function renderIsolirSummary(data) {
            const resultEl = document.getElementById('isolirSummaryResult');
            const emptyEl = document.getElementById('isolirSummaryEmpty');
            const metaEl = document.getElementById('isolirSummaryByDay');
            const detailEl = document.getElementById('isolirSummaryDetail');
            const metaText = document.getElementById('isolirSummaryMeta');

            if (!data || !data.success) {
                if (resultEl) resultEl.classList.add('d-none');
                if (emptyEl) {
                    emptyEl.classList.remove('d-none');
                    emptyEl.textContent = data && data.message ? data.message : 'Gagal memuat ringkasan.';
                }
                return;
            }

            if (emptyEl) emptyEl.classList.add('d-none');
            if (resultEl) resultEl.classList.remove('d-none');

            const scope = (data.area_ids && data.area_ids.length)
                ? `${data.area_ids.length} wilayah terpilih`
                : 'semua pelanggan';
            if (metaText) {
                metaText.textContent =
                    `Total ${data.total || 0} pelanggan (${scope}). Default global: tgl ${data.global_default_day}.`;
            }

            if (metaEl) {
                const rows = data.by_day || [];
                metaEl.innerHTML = rows.length
                    ? rows.map((r) => `
                        <tr>
                            <td>${r.label}</td>
                            <td class="text-end">${r.count}</td>
                        </tr>
                    `).join('')
                    : '<tr><td colspan="2" class="text-muted">Tidak ada data</td></tr>';
            }

            if (detailEl) {
                const list = data.customers || [];
                detailEl.innerHTML = list.length
                    ? list.map((c) => `
                        <tr>
                            <td>${c.area_name || '-'}</td>
                            <td>${c.name || '-'}</td>
                            <td><code>${c.username || '-'}</code></td>
                            <td><span class="badge bg-warning text-dark">${c.isolir_label}</span></td>
                        </tr>
                    `).join('')
                    : '<tr><td colspan="4" class="text-muted">Tidak ada pelanggan</td></tr>';
            }
        }

        function fetchIsolirSummary(area_ids) {
            const qs = (area_ids && area_ids.length)
                ? `?area_ids=${area_ids.join(',')}`
                : '';
            return fetch(`/admin/billing/service-suspension/isolir-day-summary${qs}`)
                .then((r) => r.json());
        }

