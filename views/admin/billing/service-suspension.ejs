<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Penangguhan/Isolir - Admin Portal</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/boxicons/boxicons.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <style>
        #toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 99999;
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            max-width: min(420px, calc(100vw - 2rem));
            pointer-events: none;
        }

        #toast-container .billing-toast {
            pointer-events: auto;
            min-width: 300px;
            border: none;
            border-radius: 10px;
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
            color: #fff !important;
            background-color: #22c55e !important;
            opacity: 1 !important;
        }

        #toast-container .billing-toast .toast-header {
            background: transparent !important;
            color: #fff !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.25) !important;
            font-weight: 600;
        }

        #toast-container .billing-toast .toast-body {
            background: transparent !important;
            color: #fff !important;
        }

        #toast-container .billing-toast .toast-header i,
        #toast-container .billing-toast .toast-header strong {
            color: #fff !important;
        }

        #toast-container .billing-toast.billing-toast--success {
            background-color: #22c55e !important;
        }

        #toast-container .billing-toast.billing-toast--error {
            background-color: #dc3545 !important;
        }

        #toast-container .billing-toast.billing-toast--warning {
            background-color: #f59e0b !important;
        }

        #toast-container .billing-toast.billing-toast--info {
            background-color: #16a34a !important;
        }

        .suspension-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
        }
        
        .stats-card {
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            transition: transform 0.3s ease;
        }
        
        .stats-card:hover {
            transform: translateY(-5px);
        }
        
        .btn-suspend {
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
            border: none;
            border-radius: 8px;
            color: white;
            transition: all 0.3s ease;
        }
        
        .btn-restore {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            border: none;
            border-radius: 8px;
            color: white;
            transition: all 0.3s ease;
        }
        
        .btn-check {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 8px;
            color: white;
            transition: all 0.3s ease;
        }

        .section-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin: 0 0 1rem;
            padding-bottom: 0.4rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        }

        .action-card .card-body {
            padding: 1.25rem 1rem;
        }

        .action-card i.bi {
            font-size: 2.25rem !important;
        }

        .suspended-card-header {
            display: flex;
            flex-wrap: nowrap;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
        }

        .suspended-card-header h5 {
            flex: 0 1 auto;
            min-width: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .suspended-card-tools {
            display: flex;
            flex-wrap: nowrap;
            align-items: center;
            gap: 0.5rem;
            flex: 0 0 auto;
        }

        .suspended-card-tools .suspended-search {
            width: 220px;
            flex: 0 0 220px;
        }

        .suspended-card-tools #refreshTableBtn {
            flex: 0 0 auto;
            white-space: nowrap;
        }

        @media (max-width: 575.98px) {
            .suspended-card-header {
                flex-wrap: wrap;
            }

            .suspended-card-tools {
                width: 100%;
            }

            .suspended-card-tools .suspended-search {
                flex: 1 1 auto;
                width: auto;
            }
        }
    </style>

    <%- include('../../partials/theme-head') %>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

            <!-- Main content -->
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">
                        <i class="bi bi-shield-x"></i> Penangguhan/Isolir
                    </h1>
                </div>

                <!-- Service Suspension Overview -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="suspension-card p-4">
                            <h4><i class="bi bi-shield-x me-2"></i>Kelola Penangguhan/Isolir</h4>
                            <p class="mb-0">Sistem otomatis untuk menonaktifkan layanan pelanggan yang telat bayar menggunakan profile isolir Mikrotik dan mengaktifkan kembali setelah pembayaran.</p>
                        </div>
                    </div>
                </div>

                <!-- Statistics -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card stats-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-person-check-fill text-primary" style="font-size: 2rem;"></i>
                                <h3 class="text-primary mb-1" id="activeCustomers">-</h3>
                                <p class="text-muted mb-0 small">Pelanggan Aktif</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stats-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-pause-circle-fill text-danger" style="font-size: 2rem;"></i>
                                <h3 class="text-danger mb-1" id="suspendedCustomers">-</h3>
                                <p class="text-muted mb-0 small">Pelanggan Isolir</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stats-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 2rem;"></i>
                                <h3 class="text-warning mb-1" id="overdueInvoices">-</h3>
                                <p class="text-muted mb-0 small">Tagihan Nunggak</p>
                            </div>
                        </div>
                    </div>
                </div>

                <h6 class="section-title"><i class="bi bi-gear me-1"></i> Pengaturan Sistem</h6>
                <div class="row g-3 mb-4">
                    <div class="col-lg-6">
                        <div class="card h-100 border-primary">
                            <div class="card-header bg-primary text-white py-2">
                                <strong><i class="bi bi-power me-2"></i>Status Auto Isolir</strong>
                            </div>
                            <div class="card-body d-flex flex-column justify-content-center text-center py-4">
                                <% const autoSuspensionEnabled = appSettings.auto_suspension_enabled === true || appSettings.auto_suspension_enabled === 'true'; %>
                                <div class="mb-3">
                                    <div class="form-check form-switch d-inline-block fs-3 m-0 p-0">
                                        <input class="form-check-input mx-auto" type="checkbox" role="switch" id="toggleAutoSuspension" <%= autoSuspensionEnabled ? 'checked' : '' %> style="float: none; margin-left: 0; cursor: pointer; width: 3em; height: 1.5em;">
                                    </div>
                                </div>
                                <h4 class="mb-3">
                                    <span class="badge <%= autoSuspensionEnabled ? 'bg-success' : 'bg-danger' %> rounded-pill px-4 py-2" id="autoSuspensionBadge">
                                        <%= autoSuspensionEnabled ? 'AKTIF (ON)' : 'NON-AKTIF (OFF)' %>
                                    </span>
                                </h4>
                                <p class="text-muted small mb-0">Isolir otomatis pukul <strong>10:00</strong> (cek harian), restore pukul <strong>11:00</strong>. Tanggal isolir per pelanggan diatur per wilayah di bawah.</a>.</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center py-2">
                                <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                                    <strong><i class="bi bi-router me-1"></i> Profile Isolir (RADIUS)</strong>
                                <% } else { %>
                                    <strong><i class="bi bi-router me-1"></i> Profile Isolir (Mikrotik)</strong>
                                <% } %>
                                <div>
                                    <% if (typeof authMode !== 'undefined' && authMode !== 'radius') { %>
                                        <button class="btn btn-sm btn-outline-secondary me-1" id="reloadIsolirProfilesBtn" title="Reload Profile">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    <% } %>
                                    <button class="btn btn-sm btn-primary" id="saveIsolirProfileBtn">
                                        <i class="bi bi-floppy-fill me-1"></i>Simpan
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                <label for="isolirProfileSelect" class="form-label">Profile Isolir</label>
                                <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                                    <input type="text" id="isolirProfileSelect" class="form-control" value="isolir" readonly>
                                    <small class="text-muted d-block mt-2">
                                        <i class="bi bi-info-circle"></i> Mode RADIUS memakai groupname <strong>isolir</strong> di <code>radusergroup</code>.
                                    </small>
                                <% } else { %>
                                    <select id="isolirProfileSelect" class="form-select">
                                        <option value="default">Loading...</option>
                                    </select>
                                    <small class="text-muted d-block mt-2">Profil dipakai saat suspend otomatis / manual.</small>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <h6 class="section-title"><i class="bi bi-geo-alt me-1"></i> Penyesuaian per Wilayah</h6>
                <div class="row g-3 mb-4">
                    <div class="col-lg-6">
                        <div class="card border-success h-100">
                            <div class="card-header bg-success text-white py-2">
                                <strong><i class="bi bi-calendar-check me-2"></i>Jatuh Tempo per Wilayah</strong>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-3">Atur tanggal jatuh tempo tagihan (fix date) untuk pelanggan di wilayah tertentu. Tagihan <em>unpaid</em> ikut disesuaikan.</p>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Pilih Wilayah <small class="text-muted">(bisa lebih dari satu)</small></label>
                                    <div id="dueDateAreasLoading" class="text-muted small mb-2">Memuat daftar wilayah...</div>
                                    <div id="dueDateAreasList" class="border rounded p-2" style="max-height: 180px; overflow-y: auto; display: none;"></div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold" for="bulkDueDateDay">Tanggal Jatuh Tempo <small class="text-muted">(1–28)</small></label>
                                    <div class="input-group">
                                        <span class="input-group-text">Tgl</span>
                                        <input type="number" class="form-control" id="bulkDueDateDay" min="1" max="28" value="15" placeholder="Contoh: 15">
                                    </div>
                                </div>
                                <button class="btn btn-success w-100" id="btnBulkDueDateByAreas">
                                    <i class="bi bi-cloud-upload me-2"></i>Update Jatuh Tempo
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="card border-warning h-100">
                            <div class="card-header bg-warning text-dark py-2">
                                <strong><i class="bi bi-shield-x me-2"></i>Auto Isolir per Wilayah</strong>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-3">Tanggal isolir otomatis per pelanggan di wilayah terpilih (terpisah dari jatuh tempo). Pelanggan tanpa setting khusus memakai default global tgl <strong><%= appSettings.auto_suspension_day || '25' %></strong>.</p>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Pilih Wilayah <small class="text-muted">(bisa lebih dari satu)</small></label>
                                    <div id="isolirAreasLoading" class="text-muted small mb-2">Memuat daftar wilayah...</div>
                                    <div id="isolirAreasList" class="border rounded p-2" style="max-height: 180px; overflow-y: auto; display: none;"></div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold" for="bulkAutoIsolirDay">Tanggal Auto Isolir <small class="text-muted">(1–28)</small></label>
                                    <div class="input-group">
                                        <span class="input-group-text">Tgl</span>
                                        <input type="number" class="form-control" id="bulkAutoIsolirDay" min="1" max="28" value="25" placeholder="Contoh: 25">
                                    </div>
                                </div>
                                <button class="btn btn-warning w-100 text-dark mb-2" id="btnBulkAutoIsolirByAreas">
                                    <i class="bi bi-cloud-upload me-2"></i>Update Auto Isolir
                                </button>
                                <button type="button" class="btn btn-outline-dark w-100 btn-sm" id="btnCheckIsolirFromCard">
                                    <i class="bi bi-eye me-1"></i>Cek Tanggal di Wilayah Ini
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card border-secondary">
                            <div class="card-header bg-light py-2 d-flex flex-wrap justify-content-between align-items-center gap-2">
                                <strong><i class="bi bi-table me-2"></i>Cek Tanggal Isolir</strong>
                                <button type="button" class="btn btn-sm btn-secondary" id="btnLoadIsolirSummary">
                                    <i class="bi bi-search me-1"></i>Tampilkan Ringkasan
                                </button>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-3">Lihat tanggal isolir yang tersimpan per pelanggan (<code>auto_suspension_day</code>). Kosongkan filter wilayah = semua pelanggan. Centang wilayah di kartu <em>Auto Isolir</em> lalu klik tampilkan, atau gunakan tombol <em>Cek Tanggal di Wilayah Ini</em>.</p>
                                <div class="mb-3">
                                    <label class="form-label fw-bold small mb-1">Filter wilayah (opsional)</label>
                                    <div id="summaryAreasLoading" class="text-muted small">Memuat...</div>
                                    <div id="summaryAreasList" class="border rounded p-2" style="max-height: 120px; overflow-y: auto; display: none;"></div>
                                </div>
                                <div id="isolirSummaryResult" class="d-none">
                                    <p class="small mb-2" id="isolirSummaryMeta"></p>
                                    <div class="table-responsive mb-3">
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Tanggal Isolir</th>
                                                    <th class="text-end">Jumlah Pelanggan</th>
                                                </tr>
                                            </thead>
                                            <tbody id="isolirSummaryByDay"></tbody>
                                        </table>
                                    </div>
                                    <details>
                                        <summary class="small fw-semibold mb-2" style="cursor:pointer;">Detail per wilayah &amp; pelanggan</summary>
                                        <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
                                            <table class="table table-sm table-hover mb-0">
                                                <thead class="table-light sticky-top">
                                                    <tr>
                                                        <th>Wilayah</th>
                                                        <th>Pelanggan</th>
                                                        <th>Username</th>
                                                        <th>Tgl Isolir</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="isolirSummaryDetail"></tbody>
                                            </table>
                                        </div>
                                    </details>
                                </div>
                                <div id="isolirSummaryEmpty" class="text-muted small">Belum ada data ditampilkan.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <h6 class="section-title"><i class="bi bi-lightning me-1"></i> Aksi Manual</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card action-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-search text-warning d-block mb-2"></i>
                                <h6 class="fw-semibold">Cek & Isolir Nunggak</h6>
                                <p class="text-muted small mb-3">Suspend pelanggan yang nunggak / tagihan belum lunas (tanpa menunggu jadwal otomatis).</p>
                                <button class="btn btn-check w-100 btn-sm" id="checkOverdueBtn">
                                    <i class="bi bi-search me-1"></i>Jalankan
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card action-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-check-circle-fill text-success d-block mb-2"></i>
                                <h6 class="fw-semibold">Restore Pelanggan Bayar</h6>
                                <p class="text-muted small mb-3">Aktifkan kembali pelanggan yang tagihannya sudah lunas.</p>
                                <button class="btn btn-restore w-100 btn-sm" id="checkPaidBtn">
                                    <i class="bi bi-check-lg me-1"></i>Jalankan
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card action-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-arrow-clockwise text-primary d-block mb-2"></i>
                                <h6 class="fw-semibold">Refresh Statistik</h6>
                                <p class="text-muted small mb-3">Perbarui angka ringkasan dan tabel isolir di bawah.</p>
                                <button class="btn btn-outline-primary w-100 btn-sm" id="refreshStatsBtn">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Suspended Customers Table -->
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header suspended-card-header">
                                <h5 class="mb-0"><i class="bi bi-circle me-2"></i>Pelanggan Suspended/Terisolir</h5>
                                <div class="suspended-card-tools">
                                    <div class="input-group input-group-sm suspended-search">
                                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                                        <input type="search" class="form-control" id="suspendedSearchInput"
                                            placeholder="Cari nama..." autocomplete="off">
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-primary" id="refreshTableBtn">
                                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-hover" id="suspendedTable">
                                        <thead>
                                            <tr>
                                                <th>Username</th>
                                                <th>Nama</th>
                                                <th>Phone</th>
                                                <th>Paket</th>
                                                <th>Status</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td colspan="6" class="text-center">Loading...</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    
    <script>
        // Toast function
        function showToast(type, title, message, delayMs) {
            const hideMs = delayMs || 5000;
            const toastId = 'toast-' + Date.now();
            const iconMap = {
                success: 'bi bi-check-circle-fill',
                error: 'bi bi-x-lg-circle',
                warning: 'bi bi-circle',
                info: 'bi bi-info-circle-fill'
            };
            const safeMsg = String(message || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');

            const safeType = ['success', 'error', 'warning', 'info'].includes(type) ? type : 'success';
            const safeTitle = String(title || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');

            const toastHtml = `
                <div id="${toastId}" class="toast billing-toast billing-toast--${safeType} show" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="${hideMs}">
                    <div class="toast-header">
                        <i class="${iconMap[safeType] || iconMap.success} me-2"></i>
                        <strong class="me-auto">${safeTitle}</strong>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Tutup"></button>
                    </div>
                    <div class="toast-body" style="white-space: pre-line;">${safeMsg}</div>
                </div>
            `;

            $('#toast-container').append(toastHtml);
            new bootstrap.Toast(document.getElementById(toastId)).show();

            setTimeout(() => {
                $(`#${toastId}`).remove();
            }, hideMs + 1000);
        }

        // Load statistics
        function loadStats() {
            $.get('/admin/billing/api/stats', function(response) {
                const stats = response.data || response;
                $('#activeCustomers').text(stats.active_customers || 0);
            }).fail(() => {
                $('#activeCustomers').text('Error');
            });

            $.get('/admin/billing/api/customers', function(response) {
                const customers = response.customers || response;
                const suspended = customers.filter(c => c.status === 'suspended').length;
                $('#suspendedCustomers').text(suspended);
            }).fail(() => {
                $('#suspendedCustomers').text('Error');
            });

            $.get('/admin/billing/api/overdue', function(overdue) {
                $('#overdueInvoices').text(overdue.length);
            }).fail(() => {
                $('#overdueInvoices').text('Error');
            });
        }

        let suspendedCustomersCache = [];

        function renderSuspendedCustomers(list) {
            const tbody = $('#suspendedTable tbody');
            tbody.empty();

            if (!list || list.length === 0) {
                const q = String($('#suspendedSearchInput').val() || '').trim();
                const emptyMsg = q
                    ? `Tidak ada pelanggan suspended dengan nama "${q.replace(/"/g, '')}"`
                    : 'Tidak ada pelanggan yang suspended';
                tbody.append(`<tr><td colspan="6" class="text-center text-muted">${emptyMsg}</td></tr>`);
                return;
            }

            list.forEach(customer => {
                const username = String(customer.username || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
                const row = `
                    <tr>
                        <td>${customer.username || '-'}</td>
                        <td>${customer.name || '-'}</td>
                        <td>${customer.phone || '-'}</td>
                        <td>${customer.package_name || '-'}</td>
                        <td><span class="badge bg-danger">Suspended</span></td>
                        <td>
