        // View details functions
        function viewODPDetails(odpId) {
            console.log('Viewing ODP details for ID:', odpId);
            
            // Temukan data ODP dari networkData terlebih dahulu
            let odp = networkData.odps?.find(o => o.id == odpId);
            
            if (odp) {
                // Jika ditemukan di networkData, tampilkan langsung
                showODPDetailsModalWithData(odp);
            } else {
                // Jika tidak ditemukan, coba fetch dari server
                fetch(`/admin/odp/${odpId}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.success && data.data) {
                            // Simpan data ke networkData untuk penggunaan berikutnya
                            if (!networkData.odps) {
                                networkData.odps = [];
                            }
                            
                            // Perbarui atau tambahkan data ODP
                            const existingIndex = networkData.odps.findIndex(o => o.id == odpId);
                            if (existingIndex >= 0) {
                                networkData.odps[existingIndex] = data.data;
                            } else {
                                networkData.odps.push(data.data);
                            }
                            
                            // Tampilkan modal
                            showODPDetailsModalWithData(data.data);
                        } else {
                            alert('ODP data not found');
                        }
                    })
