            const ssidHeaders = {
                'Content-Type': 'application/json'
            };
            
            // Add CSRF token if available
            const ssidCsrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
            if (ssidCsrfTokenMeta) {
                ssidHeaders['X-CSRF-TOKEN'] = ssidCsrfTokenMeta.getAttribute('content');
            }
            
            fetch('/admin/genieacs/edit', {
                method: 'POST',
                headers: ssidHeaders,
                body: JSON.stringify({ id: deviceId, ssid: ssidVal })
            }).then(r => r.json()).then(data => {
