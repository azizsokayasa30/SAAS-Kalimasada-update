            });
        }
        
        function savePopupPassword(deviceId) {
            const pwdInput = document.getElementById(`popup-password-${deviceId}`);
            const pwdVal = pwdInput?.value || '';
            
            if (!deviceId || !pwdVal) {
                alert('Device ID atau Password belum diisi');
                return;
            }
            
            const btn = event.target;
            btn.disabled = true;
            const original = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            
            const pwdHeaders = {
                'Content-Type': 'application/json'
            };
            
            // Add CSRF token if available
            const pwdCsrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
            if (pwdCsrfTokenMeta) {
                pwdHeaders['X-CSRF-TOKEN'] = pwdCsrfTokenMeta.getAttribute('content');
            }
            
            fetch('/admin/genieacs/edit', {
                method: 'POST',
                headers: pwdHeaders,
                body: JSON.stringify({ id: deviceId, password: pwdVal })
            }).then(r => r.json()).then(data => {
                if (!data.success) throw new Error(data.message || 'Gagal update Password');
                alert('Password WiFi berhasil dikirim. Perubahan diproses di background.');
                // Clear password field after success
                pwdInput.value = '';
            }).catch(err => {
                console.error(err);
                alert('Gagal menyimpan Password WiFi: ' + err.message);
            }).finally(() => {
                btn.disabled = false;
                btn.innerHTML = original;
            });
        }
        
        function togglePopupPassword(deviceId) {
            const pwdInput = document.getElementById(`popup-password-${deviceId}`);
            const btn = event.target.closest('button');
            const icon = btn.querySelector('i');
            
            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                icon.className = 'fas fa-eye-slash';
            } else {
                pwdInput.type = 'password';
                icon.className = 'fas fa-eye';
            }
        }
    </script>
    
