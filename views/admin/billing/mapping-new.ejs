        // Save ODP changes
        function saveODP() {
            const form = document.getElementById('editODPForm');
            const formData = new FormData(form);
            const odpData = {};
            
            // Convert FormData to object
            for (let [key, value] of formData.entries()) {
                // Konversi nilai numerik
                if (key === 'capacity' || key === 'used_ports' || key === 'latitude' || key === 'longitude' || key === 'parent_odp_id') {
                    odpData[key] = value ? parseFloat(value) : (key === 'used_ports' ? 0 : null);
                } else {
                    odpData[key] = value;
                }
            }
            
            // Validasi required fields
            if (!odpData.name || !odpData.code || !odpData.capacity) {
                alert('Please fill in all required fields');
                return;
            }
            
            // Show loading
            const saveBtn = document.getElementById('saveOdpBtn');
            const originalText = saveBtn.innerHTML;
            saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
            saveBtn.disabled = true;
            
            // Send data to server
            const headers = {
                'Content-Type': 'application/json'
            };
            
            // Add CSRF token if available
            const csrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
            if (csrfTokenMeta) {
                headers['X-CSRF-TOKEN'] = csrfTokenMeta.getAttribute('content');
            }
            
            fetch('/admin/update-odp', {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(odpData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log('ODP data saved to database:', data);
                    
                    // Update the ODP in networkData
                    if (networkData.odps) {
                        const odpIndex = networkData.odps.findIndex(odp => parseInt(odp.id) === parseInt(odpData.id));
                        if (odpIndex !== -1) {
                            networkData.odps[odpIndex] = { ...networkData.odps[odpIndex], ...odpData };
                        } else {
                            // Jika tidak ditemukan, tambahkan sebagai ODP baru
                            networkData.odps.push(odpData);
                        }
                    } else {
                        networkData.odps = [odpData];
                    }
                    
                    // Update the marker on the map
                    updateODPMarkerOnMap(odpData);
                    
                    // Show success message
                    alert('ODP updated successfully in database!');
                    
                    // Close modal
                    const editModal = bootstrap.Modal.getInstance(document.getElementById('editODPModal'));
                    if (editModal) {
                        editModal.hide();
                    }

                    // Refresh full mapping dataset so backbone/cable/customer relations stay in sync.
                    if (typeof loadNetworkData === 'function') {
                        loadNetworkData();
                    }
                } else {
                    console.error('Error saving ODP data:', data.message);
                    alert('Error saving ODP data: ' + (data.message || 'Unknown error'));
                }
            })
            .catch(error => {
                console.error('Network error:', error);
                alert('Network error while saving ODP data. Please try again.');
            })
            .finally(() => {
                // Reset button
                saveBtn.innerHTML = originalText;
                saveBtn.disabled = false;
            });
        }
        
        // Update ODP marker on map
        function updateODPMarkerOnMap(odpData) {
            // Find and update the marker
            odpLayer.eachLayer(function(layer) {
                if (parseInt(layer.options.odpId) === parseInt(odpData.id)) {
                    // Update marker position if coordinates changed
                    if (odpData.latitude && odpData.longitude) {
                        layer.setLatLng([parseFloat(odpData.latitude), parseFloat(odpData.longitude)]);
                    }
                    
                    // Update popup content
                    const popupContent = createODPPopupContent(odpData);
                    layer.setPopupContent(popupContent);
                }
            });
        }
        
        let editCustomerMap = null;
        let editCustomerMarker = null;
        let editCustomerStreetLayer = null;
        let editCustomerSatelliteLayer = null;
        let pendingEditCustomerLatLng = null;

        function syncEditCustomerLatLngFromMap(lat, lng) {
            const latInput = document.getElementById('editCustomerLat');
            const lngInput = document.getElementById('editCustomerLng');
            if (latInput) latInput.value = Number(lat).toFixed(6);
            if (lngInput) lngInput.value = Number(lng).toFixed(6);
        }

        function moveEditCustomerMarker(lat, lng, shouldCenter = true) {
            if (!editCustomerMap || !editCustomerMarker) return;
            editCustomerMarker.setLatLng([lat, lng]);
            if (shouldCenter) {
                editCustomerMap.setView([lat, lng], Math.max(editCustomerMap.getZoom(), 16));
            }
            syncEditCustomerLatLngFromMap(lat, lng);
        }

        async function runEditCustomerMapSearch() {
            const searchInput = document.getElementById('editCustomerMapSearch');
            if (!searchInput) return;
            const query = searchInput.value.trim();
            if (!query) return;

            try {
                const resp = await fetch(`https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(query)}`);
                const results = await resp.json();
                if (!Array.isArray(results) || results.length === 0) {
                    alert('Lokasi tidak ditemukan');
                    return;
                }
                const lat = parseFloat(results[0].lat);
                const lon = parseFloat(results[0].lon);
                moveEditCustomerMarker(lat, lon, true);
            } catch (error) {
                console.error('Map search error:', error);
                alert('Gagal mencari lokasi. Coba lagi.');
            }
        }

        function initEditCustomerMap() {
            const mapContainer = document.getElementById('editCustomerMap');
            if (!mapContainer) return;

            if (!editCustomerMap) {
                editCustomerMap = L.map('editCustomerMap', {
                    zoomControl: false
                }).setView([-6.2, 106.8], 13);

                editCustomerStreetLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 20,
                    attribution: '&copy; OpenStreetMap contributors'
                });
                editCustomerSatelliteLayer = L.tileLayer(
                    'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
                    {
                        maxZoom: 20,
                        attribution: 'Tiles &copy; Esri'
                    }
                );
                editCustomerStreetLayer.addTo(editCustomerMap);

                editCustomerMarker = L.marker([-6.2, 106.8], { draggable: true }).addTo(editCustomerMap);

                editCustomerMap.on('click', function(event) {
                    moveEditCustomerMarker(event.latlng.lat, event.latlng.lng, false);
                });

                editCustomerMarker.on('dragend', function() {
                    const latlng = editCustomerMarker.getLatLng();
                    syncEditCustomerLatLngFromMap(latlng.lat, latlng.lng);
                });

                const searchInput = document.getElementById('editCustomerMapSearch');
                if (searchInput) {
                    searchInput.addEventListener('keydown', async function(event) {
                        if (event.key !== 'Enter') return;
                        event.preventDefault();
                        await runEditCustomerMapSearch();
                    });
                }

                const searchBtn = document.getElementById('editCustomerMapSearchBtn');
                if (searchBtn) {
                    searchBtn.addEventListener('click', async function() {
                        await runEditCustomerMapSearch();
                    });
                }

                const streetBtn = document.getElementById('editCustomerStreetBtn');
                const satelliteBtn = document.getElementById('editCustomerSatelliteBtn');
                const setBaseLayer = (type) => {
                    if (!editCustomerMap || !editCustomerStreetLayer || !editCustomerSatelliteLayer) return;
                    if (type === 'satellite') {
                        if (editCustomerMap.hasLayer(editCustomerStreetLayer)) {
                            editCustomerMap.removeLayer(editCustomerStreetLayer);
                        }
                        if (!editCustomerMap.hasLayer(editCustomerSatelliteLayer)) {
                            editCustomerSatelliteLayer.addTo(editCustomerMap);
                        }
                        streetBtn && streetBtn.classList.remove('active');
                        satelliteBtn && satelliteBtn.classList.add('active');
                    } else {
                        if (editCustomerMap.hasLayer(editCustomerSatelliteLayer)) {
                            editCustomerMap.removeLayer(editCustomerSatelliteLayer);
                        }
                        if (!editCustomerMap.hasLayer(editCustomerStreetLayer)) {
                            editCustomerStreetLayer.addTo(editCustomerMap);
                        }
                        streetBtn && streetBtn.classList.add('active');
                        satelliteBtn && satelliteBtn.classList.remove('active');
                    }
                };

                if (streetBtn) {
                    streetBtn.addEventListener('click', function() {
                        setBaseLayer('street');
                    });
                }
                if (satelliteBtn) {
                    satelliteBtn.addEventListener('click', function() {
                        setBaseLayer('satellite');
                    });
                }
            }

            // Recalculate map size setelah modal fully rendered.
            if (editCustomerMap) {
                editCustomerMap.invalidateSize();
                setTimeout(() => editCustomerMap && editCustomerMap.invalidateSize(), 120);
                setTimeout(() => editCustomerMap && editCustomerMap.invalidateSize(), 300);
            }
        }

