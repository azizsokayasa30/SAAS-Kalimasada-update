        function populateOdpSelectElement(selectEl, selectedId) {
            if (!selectEl) return;
            selectEl.innerHTML = '<option value="">— Pilih ODP —</option>';

            if (!networkData.odps?.length) return;

            const sortedOdps = [...networkData.odps].sort((a, b) => {
                const nameA = String(a.name || '').toLowerCase();
                const nameB = String(b.name || '').toLowerCase();
                return nameA.localeCompare(nameB);
            });

            sortedOdps.forEach((odp) => {
                const option = document.createElement('option');
                option.value = odp.id;
                const prefix = odp.parent_odp_id ? '└─ ' : '';
                const capacity = `${odp.used_ports || 0}/${odp.capacity || 0} port`;
                option.textContent = `${prefix}${odp.name}${odp.code ? ` (${odp.code})` : ''} — ${capacity}`;
                if (String(odp.id) === String(selectedId)) {
                    option.selected = true;
                }
                selectEl.appendChild(option);
            });
        }

