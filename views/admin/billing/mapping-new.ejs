            if (customer?.odp_id) {
                const odp = networkData.odps?.find((o) => String(o.id) === String(customer.odp_id));
                return odp ? `${odp.name}${odp.code ? ` (${odp.code})` : ''}` : `ODP #${customer.odp_id}`;
            }
            return 'Belum dipatch';
        }

