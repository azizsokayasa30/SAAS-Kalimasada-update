        function openAddOdpAt(lat, lng) {
            pendingAddOdpLatLng = { lat, lng };
            cancelAddOdpMode(false);

            clearAddOdpPreviewMarker();
            if (map) {
                addOdpPreviewMarker = L.marker([lat, lng], { icon: createODPIcon(), opacity: 0.9 }).addTo(map);
            }

            document.getElementById('addOdpLat').value = lat;
            document.getElementById('addOdpLng').value = lng;
            document.getElementById('addOdpCoordHint').textContent = `Koordinat: ${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            document.getElementById('addOdpName').value = '';
            document.getElementById('addOdpCapacity').value = 8;
            document.getElementById('addOdpUsedPorts').value = 0;
            document.getElementById('addOdpAddress').value = '';

            const modalEl = document.getElementById('addOdpModal');
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();
        }

        function saveNewOdp() {
            const name = document.getElementById('addOdpName')?.value?.trim();
            const capacity = parseInt(document.getElementById('addOdpCapacity')?.value, 10);
            const usedPorts = parseInt(document.getElementById('addOdpUsedPorts')?.value, 10) || 0;
            const status = 'active';
            const address = document.getElementById('addOdpAddress')?.value?.trim() || '';
            const latitude = parseFloat(document.getElementById('addOdpLat')?.value);
            const longitude = parseFloat(document.getElementById('addOdpLng')?.value);

            if (!name) {
                alert('Nama ODP wajib diisi');
                return;
            }
            if (!Number.isFinite(capacity) || capacity < 1) {
                alert('Jumlah port minimal 1');
                return;
            }
            if (usedPorts > capacity) {
                alert('Port terpakai tidak boleh lebih besar dari jumlah port');
                return;
            }
            if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) {
                alert('Koordinat belum dipilih di peta');
                return;
            }

            const payload = {
                id: 'new',
                name,
                capacity,
                used_ports: usedPorts,
                status,
                address,
                latitude,
                longitude,
                installation_date: new Date().toISOString().split('T')[0]
            };

            const btn = document.getElementById('saveAddOdpBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Menyimpan...';

            const headers = { 'Content-Type': 'application/json' };
            const csrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
            if (csrfTokenMeta) {
                headers['X-CSRF-TOKEN'] = csrfTokenMeta.getAttribute('content');
            }

            fetch('/admin/update-odp', {
                method: 'POST',
                headers,
                body: JSON.stringify(payload)
            })
            .then((response) => response.json())
            .then((data) => {
                if (!data.success) {
                    alert('Gagal menyimpan ODP: ' + (data.message || 'Unknown error'));
                    return;
                }

                const modal = bootstrap.Modal.getInstance(document.getElementById('addOdpModal'));
                if (modal) modal.hide();
                clearAddOdpPreviewMarker();
                cancelAddOdpMode(true);

                alert('ODP berhasil ditambahkan!');
                if (typeof loadNetworkData === 'function') {
                    loadNetworkData({ skipLive: liveDataLoaded });
                }
            })
            .catch((error) => {
                console.error('Error saving new ODP:', error);
                alert('Terjadi kesalahan saat menyimpan ODP');
            })
            .finally(() => {
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
