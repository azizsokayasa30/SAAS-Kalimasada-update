        function patchCustomerToOdp(customerId, odpId, odpName) {
            const customer = networkData.customers?.find((c) => String(c.id) === String(customerId));
            if (!customer) {
                alert('Data pelanggan tidak ditemukan');
                return Promise.resolve(false);
            }

            const normalizedOdpId = (odpId === '' || odpId === null || odpId === undefined)
                ? null
                : parseInt(odpId, 10);

            if (normalizedOdpId && String(normalizedOdpId) === String(customer.odp_id || '')) {
                alert('Pelanggan sudah ter-patch ke ODP ini.');
                return Promise.resolve(false);
            }

            const odpLabel = odpName || networkData.odps?.find((o) => String(o.id) === String(normalizedOdpId))?.name || 'ODP';
            const confirmText = normalizedOdpId
                ? `Patch pelanggan "${customer.name}" ke ODP "${odpLabel}"?\n\nKabel akses akan otomatis dibuat/diupdate.`
                : `Lepas patch ODP untuk pelanggan "${customer.name}"?`;

            if (!confirm(confirmText)) {
                return Promise.resolve(false);
            }

            const payload = {
                id: customer.id,
                odp_id: normalizedOdpId,
                address: customer.address || null,
                latitude: customer.latitude || null,
                longitude: customer.longitude || null
            };

            const headers = { 'Content-Type': 'application/json' };
            const csrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
            if (csrfTokenMeta) {
                headers['X-CSRF-TOKEN'] = csrfTokenMeta.getAttribute('content');
            }

            return fetch('/admin/update-customer', {
                method: 'POST',
                headers,
                body: JSON.stringify(payload)
            })
            .then((response) => response.json())
            .then((data) => {
                if (!data.success) {
                    alert('Gagal patch ODP: ' + (data.message || 'Unknown error'));
                    return false;
                }

                const matchedOdp = networkData.odps?.find((o) => String(o.id) === String(normalizedOdpId));
                customer.odp_id = normalizedOdpId;
                customer.odp_name = matchedOdp?.name || (normalizedOdpId ? odpLabel : null);

                updateCustomerMarkerOnMap(customer);

                const popupOdpEl = document.getElementById(`customer-popup-odp-${customer.id}`);
                if (popupOdpEl) {
                    popupOdpEl.textContent = getCustomerOdpLabel(customer);
                }

                cancelOdpPickMode();

                const selectModalEl = document.getElementById('selectCustomerOdpModal');
                const selectModal = bootstrap.Modal.getInstance(selectModalEl);
                if (selectModal) {
                    selectModal.hide();
                }

                if (typeof loadNetworkData === 'function') {
                    loadNetworkData();
                }

                alert(normalizedOdpId
                    ? `Pelanggan berhasil di-patch ke ODP "${customer.odp_name}".`
                    : 'Patch ODP pelanggan berhasil dilepas.');
                return true;
            })
            .catch((error) => {
                console.error('Network error patching ODP:', error);
                alert('Terjadi kesalahan jaringan saat patch ODP.');
                return false;
            });
        }

        function patchOdpParent(childOdpId, parentOdpId, parentName) {
            const childOdp = networkData.odps?.find((o) => String(o.id) === String(childOdpId));
            if (!childOdp) {
                alert('Data ODP tidak ditemukan');
                return Promise.resolve(false);
            }

            const normalizedParentId = parseInt(parentOdpId, 10);
            if (!Number.isInteger(normalizedParentId) || normalizedParentId <= 0) {
                alert('Parent ODP tidak valid');
                return Promise.resolve(false);
            }

            if (String(normalizedParentId) === String(childOdpId)) {
                alert('ODP tidak bisa dijadikan parent dirinya sendiri.');
                return Promise.resolve(false);
            }

            if (String(normalizedParentId) === String(childOdp.parent_odp_id || '')) {
                alert('ODP ini sudah terhubung ke parent tersebut.');
                return Promise.resolve(false);
            }

            const parentLabel = parentName
                || networkData.odps?.find((o) => String(o.id) === String(normalizedParentId))?.name
                || 'ODP';
            const confirmText = `Sambungkan ODP "${childOdp.name}" ke parent ODP "${parentLabel}"?\n\nKabel backbone akan otomatis dibuat/diupdate.`;

            if (!confirm(confirmText)) {
                return Promise.resolve(false);
            }

            const payload = {
                id: childOdpId,
                parent_odp_id: normalizedParentId
            };

            const headers = { 'Content-Type': 'application/json' };
            const csrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
            if (csrfTokenMeta) {
                headers['X-CSRF-TOKEN'] = csrfTokenMeta.getAttribute('content');
            }

            return fetch('/admin/update-odp', {
                method: 'POST',
                headers,
                body: JSON.stringify(payload)
            })
            .then((response) => response.json())
            .then((data) => {
                if (!data.success) {
                    alert('Gagal sambung parent ODP: ' + (data.message || 'Unknown error'));
                    return false;
                }

                childOdp.parent_odp_id = normalizedParentId;
                cancelOdpPickMode();

                if (typeof loadNetworkData === 'function') {
                    loadNetworkData();
                }

                alert(`ODP "${childOdp.name}" berhasil disambung ke parent "${parentLabel}".`);
                return true;
            })
            .catch((error) => {
                console.error('Network error patching parent ODP:', error);
                alert('Terjadi kesalahan jaringan saat sambung parent ODP.');
                return false;
            });
        }

