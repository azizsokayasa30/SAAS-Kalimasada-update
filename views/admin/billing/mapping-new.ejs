        // Load network data from API (core first, then live enrichment)
        async function loadNetworkData(options = {}) {
            const loadingEl = document.getElementById('loading');
            const loadingText = loadingEl?.querySelector('.mt-2');
            const liveBadge = document.getElementById('liveSyncBadge');
            const liveText = document.getElementById('liveSyncText');
            const skipLive = options.skipLive === true;

            try {
                if (loadingText) loadingText.textContent = 'Memuat peta & infrastruktur...';
                if (loadingEl) loadingEl.style.display = 'block';

                const coreResponse = await fetch(mappingApiUrl('core'));
                const coreResult = await coreResponse.json();

                if (!coreResult.success) {
                    throw new Error(coreResult.error || 'Failed to load core mapping data');
                }

                networkData = coreResult.data;
                rebuildCustomerIndex();
                renderCoreNetworkData();

                if (loadingEl) loadingEl.style.display = 'none';

                if (skipLive) {
                    return;
                }

                if (liveBadge) liveBadge.classList.remove('d-none');
                if (liveText) liveText.textContent = 'Memuat status PPPoE...';

                const liveResponse = await fetch(mappingApiUrl('live'));
                const liveResult = await liveResponse.json();

                if (liveResult.success) {
                    mergeLiveNetworkData(liveResult.data);
                    renderLiveNetworkData();
                    liveDataLoaded = true;
                    if (liveText) {
                        liveText.textContent = liveResult.cached
                            ? 'Status PPPoE (cache)'
                            : `Status PPPoE (${liveResult.ms || 0} ms)`;
                    }
                    setTimeout(() => {
                        if (liveBadge) liveBadge.classList.add('d-none');
                    }, 2500);
                } else if (liveText) {
                    liveText.textContent = 'Status PPPoE gagal dimuat';
                }
            } catch (error) {
                console.error('? Error loading network data:', error);
                if (loadingEl) {
                    loadingEl.innerHTML = `
                        <div class="text-center text-danger">
                            <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
                            <div>Gagal memuat data jaringan</div>
                            <small>${error.message}</small>
                        </div>
                    `;
                }
                if (liveBadge) liveBadge.classList.add('d-none');
            }
        }

        function rebuildCustomerIndex() {
            customerById = new Map();
            (networkData.customers || []).forEach((customer) => {
                customerById.set(String(customer.id), customer);
            });
        }

        function mergeLiveNetworkData(liveData) {
            if (!liveData) return;

            if (Array.isArray(liveData.customers)) {
                const liveById = new Map(liveData.customers.map((c) => [String(c.id), c]));
                networkData.customers = (networkData.customers || []).map((customer) => {
                    const updated = liveById.get(String(customer.id));
                    if (!updated) return customer;
                    return {
                        ...customer,
                        pppoe_active: updated.pppoe_active,
                        network_down: updated.network_down,
                        down_reason: updated.down_reason,
                        pppoe_uptime_display: updated.pppoe_uptime_display
                    };
                });
                rebuildCustomerIndex();
            }

            if (liveData.statistics && networkData.statistics) {
                networkData.statistics = {
                    ...networkData.statistics,
                    ...liveData.statistics
                };
            }
        }

        function renderCoreNetworkData() {
            renderNetworkData({ includeOnu: false, refreshCables: true, animate: false });
        }

        function renderLiveNetworkData() {
            if (customerLayer) customerLayer.clearLayers();
            if (networkData.customers?.length > 0) {
                renderCustomers(networkData.customers);
            }
            if (cableLayer) cableLayer.clearLayers();
            if (networkData.cables?.length > 0) {
                renderCables(networkData.cables);
            }
            updateStatistics();
            scheduleDataFlowAnimations();
        }
        
        // Render all network data
        function renderNetworkData(options = {}) {
            const refreshCables = options.refreshCables !== false;
            const animate = options.animate !== false;

            try {
                console.log('?? Rendering network data...');
                
                clearLayers();
                
                if (networkData.customers?.length > 0) {
                    renderCustomers(networkData.customers);
                }
                
                if (networkData.odps?.length > 0) {
                    renderODPs(networkData.odps);
                }
                
                if (refreshCables && networkData.cables?.length > 0) {
                    renderCables(networkData.cables);
                }
                
                if (networkData.backboneCables?.length > 0) {
                    renderBackboneCables(networkData.backboneCables);
                }
                
                updateStatistics();
                fitToBounds();

                if (animate) {
                    scheduleDataFlowAnimations();
                }
                
                console.log('? Network data rendered successfully');
                
            } catch (error) {
                console.error('? Error rendering network data:', error);
                throw error;
            }
        }

        // Clear all layers
        function clearLayers() {
            console.log('?? Clearing all layers...');
            
            if (customerLayer) customerLayer.clearLayers();
            if (onuLayer) onuLayer.clearLayers();
            if (odpLayer) odpLayer.clearLayers();
            if (cableLayer) cableLayer.clearLayers();
            if (backboneLayer) backboneLayer.clearLayers();
            
            console.log('? All layers cleared');
        }

        // Render customers
