    <script>
        // Global variables
        let map;
        let networkData = {};
        let showOnlyDownCustomers = false;
        let customerLayer, onuLayer, odpLayer, cableLayer, backboneLayer;
        let odpPickMode = null;
        let odpParentPickMode = null;
        let addOdpMode = false;
        let addOdpPreviewMarker = null;
        let pendingAddOdpLatLng = null;
        let customerById = new Map();
        let liveDataLoaded = false;
        const MAX_FLOW_ANIMATIONS = 40;
        const MAP_VIEW_STORAGE_KEY = 'kalimasada-mapping-map-view';
        const MAPPING_TENANT_SLUG = '<%= typeof tenantSubdomain !== "undefined" ? tenantSubdomain : "" %>';
        function mappingApiUrl(phase) {
            const params = new URLSearchParams({ phase });
            if (MAPPING_TENANT_SLUG) params.set('tenant', MAPPING_TENANT_SLUG);
            return `/admin/api/mapping/new?${params.toString()}`;
        }
        // Auto-refresh dinonaktifkan — muat ulang data lewat refresh browser atau aksi simpan yang memanggil loadNetworkData().

        function getSavedMapView() {
            try {
                const raw = localStorage.getItem(MAP_VIEW_STORAGE_KEY);
                if (!raw) return null;
                const parsed = JSON.parse(raw);
                const lat = Number(parsed.lat);
                const lng = Number(parsed.lng);
                const zoom = Number(parsed.zoom);
                if (!Number.isFinite(lat) || !Number.isFinite(lng) || !Number.isFinite(zoom)) {
                    return null;
                }
                return {
                    lat,
                    lng,
                    zoom: Math.min(Math.max(Math.round(zoom), 1), 19)
                };
            } catch (error) {
                return null;
            }
        }

        function saveMapView() {
            if (!map) return;
            try {
                const center = map.getCenter();
                localStorage.setItem(MAP_VIEW_STORAGE_KEY, JSON.stringify({
                    lat: center.lat,
                    lng: center.lng,
                    zoom: map.getZoom()
                }));
            } catch (error) {
                // Abaikan jika localStorage penuh/tidak tersedia
            }
        }

        function bindMapViewPersistence() {
            if (!map || map._viewPersistenceBound) return;
            map._viewPersistenceBound = true;
            map.on('moveend', saveMapView);
            map.on('zoomend', saveMapView);
        }

        // Initialize map
        function initMap() {
            console.log('??? Initializing map with satellite view as default...');
            
            const defaultLat = <%= typeof defaultMapLat !== 'undefined' && defaultMapLat != null ? Number(defaultMapLat) : -6.2088 %>;
