        function getOdpParentLabel(odp) {
            if (!odp?.parent_odp_id) return '—';
            const parent = networkData.odps?.find((o) => String(o.id) === String(odp.parent_odp_id));
            if (!parent) return `ODP #${odp.parent_odp_id}`;
            return `${parent.name}${parent.code ? ` (${parent.code})` : ''}`;
        }

        function applyOdpPickHighlights(excludeOdpId = null) {
            if (!odpLayer) return;
            odpLayer.eachLayer((layer) => {
                const el = layer.getElement?.();
                if (!el) return;
                const markerEl = el.querySelector('.odp-marker');
                if (!markerEl) return;
                const layerOdpId = layer.options?.odpId;
                markerEl.classList.remove('odp-pick-highlight', 'odp-pick-disabled');
                if (excludeOdpId && String(layerOdpId) === String(excludeOdpId)) {
                    markerEl.classList.add('odp-pick-disabled');
                } else {
                    markerEl.classList.add('odp-pick-highlight');
                }
            });
        }

        function clearOdpPickHighlights() {
            if (!odpLayer) return;
            odpLayer.eachLayer((layer) => {
                const el = layer.getElement?.();
                if (!el) return;
                const markerEl = el.querySelector('.odp-marker');
                if (markerEl) {
                    markerEl.classList.remove('odp-pick-highlight', 'odp-pick-disabled');
                }
            });
        }

