            document.getElementById('selectCustomerOdpName').textContent = customer.name || 'N/A';
            document.getElementById('selectCustomerOdpCurrent').textContent = getCustomerOdpLabel(customer);
            populateOdpSelectElement(document.getElementById('selectCustomerOdpSelect'), customer.odp_id || '');

            const modal = new bootstrap.Modal(document.getElementById('selectCustomerOdpModal'));
            modal.show();
