<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mapping Area Kolektor | <%= appSettings.companyHeader %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">

    <!-- GLOBAL THEME INJECTION -->
    <%- include('../../partials/theme-head') %>

    <style>
        body { background: var(--bg-color, #f1f5f9); font-family: 'Inter', system-ui, sans-serif; }
        .page-wrapper { display: flex; min-height: 100vh; }
        .main-content { flex: 1; padding: 24px; overflow-x: hidden; }
        @media (min-width: 768px) { .main-content { margin-left: 16.666667%; } }

        /* Page Header */
        .page-header {
            background: linear-gradient(135deg, #1d4ed8 0%, #4f46e5 100%);
            border-radius: 16px;
            padding: 28px 32px;
            margin-bottom: 24px;
            color: #fff;
            box-shadow: 0 8px 32px rgba(29,78,216,0.25);
        }
        .page-header h1 { font-size: 1.8rem; font-weight: 700; margin: 0; color: #fff; }
        .page-header p { margin: 6px 0 0; opacity: 0.85; font-size: 0.95rem; color: #fff; }

        /* Card System */
        .content-card {
            background: var(--surface-1, #fff);
            border: 1px solid var(--border-color, #e2e8f0);
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            overflow: hidden;
        }
        .content-card-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border-color, #e2e8f0);
            display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
            background: var(--surface-2, #f8fafc);
        }
        .content-card-title { font-size: 1rem; font-weight: 600; color: var(--text-primary, #0f172a); margin: 0; display: flex; align-items: center; gap: 8px; }

        .area-table th { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted, #64748b); padding: 12px 16px; background: var(--surface-2, #f8fafc); border-bottom: 1px solid var(--border-color, #e2e8f0); white-space: nowrap; }
        .area-table td { padding: 13px 16px; font-size: 0.875rem; color: var(--text-primary, #0f172a); vertical-align: middle; border-bottom: 1px solid var(--border-color, #e2e8f0); }
        .area-table tbody tr:last-child td { border-bottom: none; }
        .area-table tbody tr:hover td { background: rgba(37,99,235,0.03); }

        /* .area-badge style is handled globally in theme-system.css */

        
        /* Modal Info */
        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1050; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
        .modal-overlay.show { display: flex; }
        .modal-box {
            background: var(--surface-1, #fff);
            border-radius: 16px;
            width: 100%; max-width: 600px;
            box-shadow: 0 24px 64px rgba(0,0,0,0.18);
            animation: modalIn 0.2s ease;
            overflow: hidden;
            display: flex; flex-direction: column; max-height: 90vh;
        }
        @keyframes modalIn { from { transform: scale(0.95) translateY(10px); opacity: 0; } to { transform: scale(1) translateY(0); opacity: 1; } }
        .modal-box-header { padding: 20px 24px; border-bottom: 1px solid var(--border-color, #e2e8f0); display: flex; align-items: center; justify-content: space-between; background: var(--surface-2, #f8fafc); }
        .modal-box-title { font-weight: 700; font-size: 1.05rem; color: var(--text-primary, #0f172a); margin: 0; }
        .modal-box-body { padding: 24px; background: var(--surface-1, #fff); overflow-y: auto; }
        .modal-box-footer { padding: 16px 24px; border-top: 1px solid var(--border-color, #e2e8f0); display: flex; justify-content: flex-end; gap: 10px; background: var(--surface-2, #f8fafc); }

        .area-checkbox-list {
            display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
        }
        .area-check-item {
            border: 1px solid var(--border-color);
            padding: 10px 14px;
            border-radius: 8px;
            display: flex; align-items: center; gap: 10px;
            cursor: pointer;
            transition: 0.2s;
            color: var(--text-primary);
        }
        .area-check-item:hover { background: var(--surface-2); }
        .area-check-item.active { border-color: #2563eb; background: rgba(37,99,235,0.05); }
        .area-check-item.area-taken-other {
            cursor: not-allowed;
            pointer-events: none;
            opacity: 0.72;
            background: #334155 !important;
            border-color: #475569 !important;
            color: #94a3b8;
        }
        .area-check-item.area-taken-other:hover { background: #334155 !important; }
        .area-check-item.area-taken-other .area-check-label,
        .area-check-item.area-taken-other .area-check-meta { color: #cbd5e1 !important; }
        .area-check-item.area-taken-other input[type="checkbox"] {
            pointer-events: none;
            opacity: 0.35;
        }
        html[data-theme="light"] .area-check-item.area-taken-other {
            background: #e2e8f0 !important;
            border-color: #cbd5e1 !important;
        }
        html[data-theme="light"] .area-check-item.area-taken-other .area-check-label,
        html[data-theme="light"] .area-check-item.area-taken-other .area-check-meta {
            color: #64748b !important;
        }
        .area-check-meta {
            display: block;
            font-size: 0.7rem;
            margin-top: 2px;
            color: #fbbf24;
            font-weight: 600;
        }
        html[data-theme="light"] .area-check-meta { color: #b45309; }

    </style>
</head>
<body>
<div class="page-wrapper">
    <%- include('../../partials/billing-sidebar', { page: 'collector-areas', settings: appSettings, versionInfo: typeof versionInfo !== 'undefined' ? versionInfo : {} }) %>

    <main class="main-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <h1><i class="bi bi-map me-2"></i>Mapping Area Kolektor</h1>
                    <p>Kelola area pemungutan tagihan yang dibebankan kepada tiap masing-masing kolektor</p>
                </div>
            </div>
        </div>

        <!-- Main Card -->
        <div class="content-card">
            <div class="content-card-header">
                <h2 class="content-card-title"><i class="bi bi-list-ul text-primary"></i> Daftar Kolektor & Areanya</h2>
            </div>

            <!-- Table -->
            <div class="content-card-body">
                <div class="table-responsive">
                    <table class="table area-table mb-0">
                        <thead>
                            <tr>
                                <th style="width:50px">#</th>
                                <th style="width:200px">Nama Kolektor</th>
                                <th>Area Ter-Assign</th>
                                <th style="width:140px; text-align:center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(collectors.length === 0) { %>
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Belum ada kolektor yang aktif.</td>
                                </tr>
                            <% } else { %>
                                <% collectors.forEach(function(col, idx) { %>
                                <tr>
                                    <td class="text-muted"><%= idx + 1 %></td>
                                    <td>
                                        <div class="fw-semibold"><%= col.name %></div>
                                        <div class="text-muted small"><i class="bi bi-telephone-fill mt-1 me-1"></i><%= col.phone %></div>
                                    </td>
                                    <td>
                                        <% if(col.areas && col.areas.length > 0) { %>
                                            <% col.areas.forEach(function(a) { %>
                                                <span class="area-badge"><i class="bi bi-geo-alt-fill me-1"></i><%= a %></span>
                                            <% }); %>
                                        <% } else { %>
                                            <span class="text-muted fst-italic small">Belum ada area</span>
                                        <% } %>
                                    </td>
                                    <td style="text-align:center;">
                                        <button class="btn btn-sm btn-primary" style="border-radius:8px;" onclick="openMappingModal(<%= col.id %>, '<%= col.name %>', <%= JSON.stringify(col.areas||[]) %>)">
                                            <i class="bi bi-gear-fill me-1"></i> Kelola Area
                                        </button>
                                    </td>
                                </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- MODAL MAPPING -->
<div class="modal-overlay" id="modalMapping">
    <div class="modal-box">
        <div class="modal-box-header">
            <h5 class="modal-box-title"><i class="bi bi-map me-2 text-primary"></i>Kelola Area: <span id="colNameLabel" class="text-primary"></span></h5>
            <button type="button" onclick="closeModal()" style="background:transparent;border:none;font-size:1.2rem;color:var(--text-tertiary,#64748b);cursor:pointer;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="modal-box-body">
            <p class="text-muted small mb-3">
                Satu area hanya boleh untuk <strong>satu kolektor</strong>. Area yang sudah dipakai kolektor lain tampil gelap dan tidak bisa dipilih.
            </p>
            <input type="hidden" id="selectedCollectorId">
            <div class="area-checkbox-list" id="areaCheckboxList">
                <% if(areas && areas.length > 0) { %>
                    <% areas.forEach(function(a) { %>
                    <label class="area-check-item" data-area-name="<%= String(a.nama_area || '').replace(/"/g, '&quot;') %>">
                        <input type="checkbox" class="area-checkbox" value="<%= a.nama_area %>">
                        <span>
                            <span class="fw-medium area-check-label" style="color:var(--text-secondary)"><%= a.nama_area %></span>
                            <span class="area-check-meta d-none"></span>
                        </span>
                    </label>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-2 text-muted fst-italic">Belum ada area terdaftar di sistem.</div>
                <% } %>
            </div>
        </div>
        <div class="modal-box-footer">
            <button class="btn btn-light" onclick="closeModal()" style="border-radius:8px;">Batal</button>
            <button class="btn btn-primary fw-semibold" id="btnSaveMapping" onclick="saveMapping()" style="border-radius:8px;">
                <i class="bi bi-check-lg me-1"></i> Simpan
            </button>
        </div>
    </div>
</div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
    /** area name → { collectorId, collectorName } */
    var AREA_ASSIGNMENTS = <%- JSON.stringify(typeof areaAssignmentMap !== 'undefined' ? areaAssignmentMap : {}) %>;

    function normalizeAreaKey(name) {
        return String(name || '').trim().toLowerCase();
    }

    function findAssignment(areaName) {
        if (!areaName) return null;
        if (AREA_ASSIGNMENTS[areaName]) return AREA_ASSIGNMENTS[areaName];
        var key = normalizeAreaKey(areaName);
        for (var k in AREA_ASSIGNMENTS) {
            if (normalizeAreaKey(k) === key) return AREA_ASSIGNMENTS[k];
        }
        return null;
    }

    document.querySelectorAll('.area-checkbox').forEach(function (cb) {
        cb.addEventListener('change', function () {
            var item = this.closest('.area-check-item');
            if (item && item.classList.contains('area-taken-other')) {
                this.checked = false;
                return;
            }
            if (this.checked) item.classList.add('active');
            else item.classList.remove('active');
        });
        cb.addEventListener('click', function (e) {
            if (this.closest('.area-check-item').classList.contains('area-taken-other')) {
                e.preventDefault();
            }
        });
    });

    function openMappingModal(colId, colName, areasArr) {
        var currentId = parseInt(String(colId), 10);
        document.getElementById('selectedCollectorId').value = colId;
        document.getElementById('colNameLabel').textContent = colName;

        var ownedSet = {};
        (areasArr || []).forEach(function (a) {
            ownedSet[normalizeAreaKey(a)] = true;
        });

        document.querySelectorAll('.area-checkbox').forEach(function (cb) {
            var item = cb.closest('.area-check-item');
            var meta = item ? item.querySelector('.area-check-meta') : null;
            var assign = findAssignment(cb.value);
            var takenByOther =
                assign &&
                Number(assign.collectorId) !== currentId &&
                !ownedSet[normalizeAreaKey(cb.value)];

            item.classList.remove('active', 'area-taken-other');
            if (meta) {
                meta.classList.add('d-none');
                meta.textContent = '';
            }

            if (takenByOther) {
                cb.checked = false;
                cb.disabled = true;
                item.classList.add('area-taken-other');
                if (meta) {
                    meta.textContent = 'Sudah: ' + (assign.collectorName || 'kolektor lain');
                    meta.classList.remove('d-none');
                }
            } else {
                cb.disabled = false;
                if (areasArr.includes(cb.value) || ownedSet[normalizeAreaKey(cb.value)]) {
                    cb.checked = true;
                    item.classList.add('active');
                } else {
                    cb.checked = false;
                }
            }
        });

        document.getElementById('modalMapping').classList.add('show');
    }

    function closeModal() {
        document.getElementById('modalMapping').classList.remove('show');
    }

    async function saveMapping() {
        var colId = document.getElementById('selectedCollectorId').value;
        var inputs = document.querySelectorAll('.area-checkbox:checked:not(:disabled)');
        var selectedAreas = Array.from(inputs).map(function (i) { return i.value; });
        
        var btn = document.getElementById('btnSaveMapping');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Menyimpan...';
        
        try {
            var res = await fetch('/admin/billing/collector-areas/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ collector_id: colId, areas: selectedAreas })
            });
            var data = await res.json();
            if(data.success) {
                location.reload();
            } else {
                alert(data.message || 'Gagal menyimpan mapping');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Simpan';
            }
        } catch(e) {
            alert('Kesalahan jaringan');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Simpan';
        }
    }
</script>
</body>
</html>
