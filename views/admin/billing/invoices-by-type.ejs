<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice by Type - Admin Billing</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/boxicons/boxicons.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <style>
        .invoice-type-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
        }
        .invoice-type-monthly {
            background-color: #e3f2fd;
            color: #1976d2;
        }
        .invoice-type-voucher {
            background-color: #f3e5f5;
            color: #7b1fa2;
        }
        .invoice-type-manual {
            background-color: #fff3e0;
            color: #f57c00;
        }
        .filter-tabs .nav-link {
            border: none;
            background: none;
            color: #6c757d;
        }
        .filter-tabs .nav-link.active {
            color: #0d6efd;
            border-bottom: 2px solid #0d6efd;
        }
        .stats-card {
            transition: transform 0.2s;
        }
        .stats-card:hover {
            transform: translateY(-2px);
        }
        .summary-cards-solid .summary-card {
            border-left: 0 !important;
            border-radius: 14px !important;
            overflow: hidden;
        }
        .summary-cards-solid .summary-card .card-body {
            color: #fff !important;
            background: transparent !important;
        }
        .summary-cards-solid .summary-card p,
        .summary-cards-solid .summary-card h3,
        .summary-cards-solid .summary-card i {
            color: #fff !important;
        }
        .summary-cards-solid .summary-card .text-muted {
            color: rgba(255,255,255,0.9) !important;
        }
        .summary-cards-solid > div:nth-child(1) .summary-card { background-image: linear-gradient(135deg, #6366f1, #4f46e5) !important; }
        .summary-cards-solid > div:nth-child(2) .summary-card { background-image: linear-gradient(135deg, #22c55e, #16a34a) !important; }
        .summary-cards-solid > div:nth-child(3) .summary-card { background-image: linear-gradient(135deg, #f59e0b, #d97706) !important; }
        .summary-cards-solid > div:nth-child(4) .summary-card { background-image: linear-gradient(135deg, #06b6d4, #0891b2) !important; }
        .summary-card-nominal {
            font-size: 0.78rem;
            font-weight: 600;
            line-height: 1.2;
            color: rgba(255, 255, 255, 0.92) !important;
        }
        .summary-card-nominal-hint {
            font-size: 0.62rem;
            color: rgba(255, 255, 255, 0.72) !important;
        }
    </style>

    <%- include('../../partials/theme-head') %>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/billing-sidebar', { page: 'invoices-by-type' }) %>

            <!-- Main content -->
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">
                        <i class="bi bi-receipt"></i> Invoice by Type
                    </h1>
                    <div>
                        <a href="/admin/billing/dashboard" class="btn btn-outline-primary">
                            <i class="bi bi-circle"></i> Kembali ke Dashboard
                        </a>
                    </div>
                </div>

                <!-- Month/Year Filter -->
                <form method="GET" action="/admin/billing/invoices-by-type" class="mb-3 d-flex align-items-end gap-2 flex-wrap" id="timeFilterForm">
                    <div>
                        <label class="form-label small fw-bold text-muted mb-1">Bulan</label>
                        <select name="month" class="form-select form-select-sm shadow-sm border-primary" style="width: 150px;" onchange="this.form.submit()">
                            <% const months = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember']; %>
                            <% for(let i=1; i<=12; i++) { %>
                                <option value="<%= i %>" <%= typeof selectedMonth !== 'undefined' && selectedMonth == i ? 'selected' : '' %>><%= months[i-1] %></option>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small fw-bold text-muted mb-1">Tahun</label>
                        <select name="year" class="form-select form-select-sm shadow-sm border-primary" style="width: 100px;" onchange="this.form.submit()">
                            <% const currentY = new Date().getFullYear(); %>
                            <% for(let y=currentY-3; y<=currentY+1; y++) { %>
                                <option value="<%= y %>" <%= typeof selectedYear !== 'undefined' && selectedYear == y ? 'selected' : '' %>><%= y %></option>
                            <% } %>
                        </select>
                    </div>
                </form>

                <%
                    function renderTypeStatsCards(stats, labels) {
                        return [
                            { title: labels.total, value: stats.total_invoices || 0, nominal: stats.total_amount || 0, hint: 'total tagihan', icon: 'bi-receipt' },
                            { title: 'Lunas', value: stats.paid_invoices || 0, nominal: stats.total_revenue || 0, hint: 'sudah dibayar', icon: 'bi-check-circle-fill' },
                            { title: 'Belum Lunas', value: stats.unpaid_invoices || 0, nominal: stats.total_unpaid || 0, hint: 'belum dibayar', icon: 'bi-clock-history' },
                            { title: 'Pendapatan', value: stats.paid_invoices || 0, nominal: stats.total_revenue || 0, hint: 'dari invoice lunas', icon: 'bi-cash-stack' }
                        ];
                    }
                %>

                <!-- Filter Tabs -->
                <ul class="nav nav-tabs filter-tabs mb-4" id="invoiceTypeTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">
                            <i class="bi bi-calendar3"></i> Bulanan (<%= monthlyStats.total_invoices || 0 %>)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="voucher-tab" data-bs-toggle="tab" data-bs-target="#voucher" type="button" role="tab">
                            <i class="bi bi-circle"></i> Voucher (<%= voucherStats.total_invoices || 0 %>)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="manual-tab" data-bs-toggle="tab" data-bs-target="#manual" type="button" role="tab">
                            <i class="bi bi-pencil-fill"></i> Manual (<%= manualStats.total_invoices || 0 %>)
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" id="invoiceTypeTabContent">
                    <!-- Monthly Invoices -->
                    <div class="tab-pane fade show active" id="monthly" role="tabpanel">
                        <% const monthlyCards = renderTypeStatsCards(monthlyStats, { total: 'Total Tagihan' }); %>
                        <div class="row mb-4 g-3 summary-cards-solid">
                            <% monthlyCards.forEach(function(card) { %>
                                <div class="col-md-3 col-12">
                                    <div class="card border-0 shadow-sm h-100 summary-card stats-card" style="border:0 !important; border-radius: 12px;">
                                        <div class="card-body p-3" style="border-radius: 12px;">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <p class="text-muted fw-semibold mb-1" style="font-size:0.75rem;"><%= card.title %></p>
                                                    <h3 class="mb-0 fw-bold mt-2" style="color:#fff !important;"><%= card.value %></h3>
                                                    <div class="summary-card-nominal mt-1">Rp <%= Number(card.nominal || 0).toLocaleString('id-ID') %></div>
                                                    <div class="summary-card-nominal-hint"><%= card.hint %></div>
                                                </div>
                                                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:rgba(255,255,255,0.22);flex-shrink:0;">
                                                    <i class="bi <%= card.icon %>" style="font-size:1.1rem;color:#fff !important;"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title mb-0">Tagihan Bulanan</h5>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Invoice #</th>
                                                <th>Pelanggan</th>
                                                <th>Paket</th>
                                                <th>Jumlah</th>
                                                <th>Status</th>
                                                <th>Jatuh Tempo</th>
                                                <th>Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (monthlyInvoices && monthlyInvoices.length > 0) { %>
                                                <% monthlyInvoices.forEach(function(invoice) { %>
                                                    <tr>
                                                        <td>
                                                            <span class="badge invoice-type-badge invoice-type-monthly">BULANAN</span>
                                                            <br>
                                                            <small class="text-muted"><%= invoice.invoice_number %></small>
                                                        </td>
                                                        <td>
                                                            <strong><%= invoice.customer_name %></strong><br>
                                                            <small class="text-muted"><%= invoice.customer_phone %></small>
                                                        </td>
                                                        <td><%= invoice.package_name %></td>
                                                        <td>Rp <%= invoice.amount.toLocaleString('id-ID') %></td>
                                                        <td>
                                                            <% if (invoice.status === 'paid') { %>
                                                                <span class="badge bg-success">Lunas</span>
                                                            <% } else { %>
                                                                <span class="badge bg-warning text-dark">Belum Lunas</span>
                                                            <% } %>
                                                        </td>
                                                        <td><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></td>
                                                        <td>
                                                            <a href="/admin/billing/invoices/<%= invoice.id %>" class="btn btn-sm btn-outline-primary">
                                                                <i class="bi bi-eye-fill"></i> Lihat
                                                            </a>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="text-center text-muted">Tidak ada tagihan bulanan</td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Voucher Invoices -->
                    <div class="tab-pane fade" id="voucher" role="tabpanel">
                        <% const voucherCards = renderTypeStatsCards(voucherStats, { total: 'Total Voucher' }); %>
                        <div class="row mb-4 g-3 summary-cards-solid">
                            <% voucherCards.forEach(function(card) { %>
                                <div class="col-md-3 col-12">
                                    <div class="card border-0 shadow-sm h-100 summary-card stats-card" style="border:0 !important; border-radius: 12px;">
                                        <div class="card-body p-3" style="border-radius: 12px;">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <p class="text-muted fw-semibold mb-1" style="font-size:0.75rem;"><%= card.title %></p>
                                                    <h3 class="mb-0 fw-bold mt-2" style="color:#fff !important;"><%= card.value %></h3>
                                                    <div class="summary-card-nominal mt-1">Rp <%= Number(card.nominal || 0).toLocaleString('id-ID') %></div>
                                                    <div class="summary-card-nominal-hint"><%= card.hint %></div>
                                                </div>
                                                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:rgba(255,255,255,0.22);flex-shrink:0;">
                                                    <i class="bi <%= card.icon %>" style="font-size:1.1rem;color:#fff !important;"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title mb-0">Tagihan Voucher</h5>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Invoice #</th>
                                                <th>Pelanggan</th>
                                                <th>Paket Voucher</th>
                                                <th>Jumlah</th>
                                                <th>Status</th>
                                                <th>Jatuh Tempo</th>
                                                <th>Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (voucherInvoices && voucherInvoices.length > 0) { %>
                                                <% voucherInvoices.forEach(function(invoice) { %>
                                                    <tr>
                                                        <td>
                                                            <span class="badge invoice-type-badge invoice-type-voucher">VOUCHER</span>
                                                            <br>
                                                            <small class="text-muted"><%= invoice.invoice_number %></small>
                                                        </td>
                                                        <td>
                                                            <strong><%= invoice.customer_name %></strong><br>
                                                            <small class="text-muted"><%= invoice.customer_phone %></small>
                                                        </td>
                                                        <td><%= invoice.package_name %></td>
                                                        <td>Rp <%= invoice.amount.toLocaleString('id-ID') %></td>
                                                        <td>
                                                            <% if (invoice.status === 'paid') { %>
                                                                <span class="badge bg-success">Lunas</span>
                                                            <% } else { %>
                                                                <span class="badge bg-warning text-dark">Belum Lunas</span>
                                                            <% } %>
                                                        </td>
                                                        <td><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></td>
                                                        <td>
                                                            <a href="/admin/billing/invoices/<%= invoice.id %>" class="btn btn-sm btn-outline-primary">
                                                                <i class="bi bi-eye-fill"></i> Lihat
                                                            </a>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="text-center text-muted">Tidak ada tagihan voucher</td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Manual Invoices -->
                    <div class="tab-pane fade" id="manual" role="tabpanel">
                        <% const manualCards = renderTypeStatsCards(manualStats, { total: 'Total Manual' }); %>
                        <div class="row mb-4 g-3 summary-cards-solid">
                            <% manualCards.forEach(function(card) { %>
                                <div class="col-md-3 col-12">
                                    <div class="card border-0 shadow-sm h-100 summary-card stats-card" style="border:0 !important; border-radius: 12px;">
                                        <div class="card-body p-3" style="border-radius: 12px;">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <p class="text-muted fw-semibold mb-1" style="font-size:0.75rem;"><%= card.title %></p>
                                                    <h3 class="mb-0 fw-bold mt-2" style="color:#fff !important;"><%= card.value %></h3>
                                                    <div class="summary-card-nominal mt-1">Rp <%= Number(card.nominal || 0).toLocaleString('id-ID') %></div>
                                                    <div class="summary-card-nominal-hint"><%= card.hint %></div>
                                                </div>
                                                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:rgba(255,255,255,0.22);flex-shrink:0;">
                                                    <i class="bi <%= card.icon %>" style="font-size:1.1rem;color:#fff !important;"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title mb-0">Tagihan Manual</h5>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Invoice #</th>
                                                <th>Pelanggan</th>
                                                <th>Paket</th>
                                                <th>Jumlah</th>
                                                <th>Status</th>
                                                <th>Jatuh Tempo</th>
                                                <th>Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (manualInvoices && manualInvoices.length > 0) { %>
                                                <% manualInvoices.forEach(function(invoice) { %>
                                                    <tr>
                                                        <td>
                                                            <span class="badge invoice-type-badge invoice-type-manual">MANUAL</span>
                                                            <br>
                                                            <small class="text-muted"><%= invoice.invoice_number %></small>
                                                        </td>
                                                        <td>
                                                            <strong><%= invoice.customer_name %></strong><br>
                                                            <small class="text-muted"><%= invoice.customer_phone %></small>
                                                        </td>
                                                        <td><%= invoice.package_name %></td>
                                                        <td>Rp <%= invoice.amount.toLocaleString('id-ID') %></td>
                                                        <td>
                                                            <% if (invoice.status === 'paid') { %>
                                                                <span class="badge bg-success">Lunas</span>
                                                            <% } else { %>
                                                                <span class="badge bg-warning text-dark">Belum Lunas</span>
                                                            <% } %>
                                                        </td>
                                                        <td><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></td>
                                                        <td>
                                                            <a href="/admin/billing/invoices/<%= invoice.id %>" class="btn btn-sm btn-outline-primary">
                                                                <i class="bi bi-eye-fill"></i> Lihat
                                                            </a>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="text-center text-muted">Tidak ada tagihan manual</td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        (function forceSolidSummaryCards() {
            const gradients = [
                'linear-gradient(135deg, #6366f1, #4f46e5)',
                'linear-gradient(135deg, #22c55e, #16a34a)',
                'linear-gradient(135deg, #f59e0b, #d97706)',
                'linear-gradient(135deg, #06b6d4, #0891b2)'
            ];
            document.querySelectorAll('.summary-cards-solid').forEach((row) => {
                row.querySelectorAll('.summary-card').forEach((card, idx) => {
                    const gradient = gradients[idx % gradients.length];
                    card.style.setProperty('background', gradient, 'important');
                    card.style.setProperty('background-image', gradient, 'important');
                    card.style.setProperty('border', '0', 'important');
                    const body = card.querySelector('.card-body');
                    if (body) {
                        body.style.setProperty('background', 'transparent', 'important');
                        body.style.setProperty('color', '#fff', 'important');
                    }
                    card.querySelectorAll('h3, p, i').forEach((el) => {
                        el.style.setProperty('color', '#fff', 'important');
                    });
                });
            });
        })();
    </script>
</body>
</html>

