<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../partials/hard-reload') %>
  <meta charset="UTF-8">
  <title>NAS (RADIUS)</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  
  <link href="/css/theme.css" rel="stylesheet">
  <link href="/css/responsive-admin.css" rel="stylesheet">

    <%- include('../partials/theme-head') %>
</head>
<body>
<div class="container-fluid">
  <div class="row">
    <%- include('../partials/admin-responsive-sidebar', { page: 'routers', settings: settings || {} }) %>
    <main class="col-md-10 ms-sm-auto main-content">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-hdd-network me-2"></i>NAS (RADIUS)</h4>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addRouterModal"><i class="bi bi-plus"></i> Tambah NAS</button>
      </div>
      <div class="card p-3">
        <div class="table-responsive">
          <table class="table table-striped align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Nama</th>
                <th>NAS IP</th>
                <th>NAS Identifier</th>
                <th>Lokasi</th>
                <th>POP</th>
                <th>Port</th>
                <th>User API</th>
                <th>Password API</th>
                <th>GenieACS Server</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% (routers||[]).forEach(function(r,i){ %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= r.name %></td>
                  <td><%= r.nas_ip %></td>
                  <td><%= r.nas_identifier || '' %></td>
                  <td><%= r.location || '' %></td>
                  <td><%= r.pop || '' %></td>
                  <td><%= r.port || 8728 %></td>
                  <td><%= r.user || '' %></td>
                  <td><%= r.password ? '***' : '' %></td>
                  <td>
                    <% if (r.genieacs_server_name) { %>
                      <span class="badge bg-info"><%= r.genieacs_server_name %></span><br>
                      <small class="text-muted"><%= r.genieacs_server_url %></small>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="admin-action-btns">
                      <button type="button" class="btn btn-sm btn-primary" onclick='openEdit(<%- JSON.stringify(r) %>)' title="Ubah data NAS / router" aria-label="Ubah NAS"><i class="bi bi-pencil"></i></button>
                      <button type="button" class="btn btn-sm btn-info" onclick='testRouter(<%= r.id %>)' title="Tes koneksi API MikroTik" aria-label="Tes koneksi MikroTik"><i class="bi bi-activity"></i></button>
                      <button type="button" class="btn btn-sm btn-danger" onclick='deleteRouter(<%= r.id %>)' title="Hapus NAS dari daftar" aria-label="Hapus NAS"><i class="bi bi-trash"></i></button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Add Modal -->
      <div class="modal fade" id="addRouterModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Tambah NAS</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Nama</label>
                <input class="form-control" id="r_name" maxlength="64" pattern="[A-Za-z0-9][A-Za-z0-9._\-]*"
                       title="Hanya huruf, angka, titik, strip, underscore — tanpa spasi"
                       placeholder="Contoh: RO-KRG_MERDEN" autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">Tanpa spasi (contoh <code>BAKTI_PUSAT</code>) — dipakai sebagai nama NAS RADIUS</small>
              </div>
              <div class="mb-3">
                <label class="form-label">NAS IP</label>
                <input class="form-control" id="r_ip" maxlength="45" placeholder="10.10.0.5" autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">IP saja — jangan sertakan port</small>
              </div>
              <div class="mb-3"><label class="form-label">NAS Identifier</label><input class="form-control" id="r_ident" placeholder="RouterA"></div>
              <div class="mb-3"><label class="form-label">Lokasi</label><input class="form-control" id="r_location" placeholder="Gedung/Alamat"></div>
              <div class="mb-3"><label class="form-label">POP</label><input class="form-control" id="r_pop" placeholder="POP-1"></div>
              <div class="mb-3"><label class="form-label">Port</label><input type="number" class="form-control" id="r_port" placeholder="8728" value="8728" min="1" max="65535"></div>
              <div class="mb-3"><label class="form-label">User API</label><input class="form-control" id="r_user" placeholder="admin"></div>
              <div class="mb-3"><label class="form-label">Password API</label><input class="form-control" id="r_password" type="password"></div>
              <div class="mb-3">
                <label class="form-label">GenieACS Server</label>
                <select class="form-control" id="r_genieacs_server_id">
                  <option value="">-- Pilih GenieACS Server (Opsional) --</option>
                  <% (genieacsServers||[]).forEach(function(s){ %>
                    <option value="<%= s.id %>"><%= s.name %> (<%= s.url %>)</option>
                  <% }) %>
                </select>
                <small class="form-text text-muted">Pilih server GenieACS yang digunakan untuk router ini</small>
              </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Batal</button><button class="btn btn-primary" onclick="saveRouter()">Simpan</button></div>
          </div>
        </div>
      </div>

      <!-- Edit Modal -->
      <div class="modal fade" id="editRouterModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Edit NAS</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <input type="hidden" id="e_id">
              <div class="mb-3">
                <label class="form-label">Nama</label>
                <input class="form-control" id="e_name" maxlength="64" pattern="[A-Za-z0-9][A-Za-z0-9._\-]*"
                       title="Hanya huruf, angka, titik, strip, underscore — tanpa spasi"
                       autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">Tanpa spasi — dipakai sebagai nama NAS RADIUS</small>
              </div>
              <div class="mb-3">
                <label class="form-label">NAS IP</label>
                <input class="form-control" id="e_ip" maxlength="45" autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">IP saja — jangan sertakan port</small>
              </div>
              <div class="mb-3"><label class="form-label">NAS Identifier</label><input class="form-control" id="e_ident"></div>
              <div class="mb-3"><label class="form-label">Lokasi</label><input class="form-control" id="e_location"></div>
              <div class="mb-3"><label class="form-label">POP</label><input class="form-control" id="e_pop"></div>
              <div class="mb-3"><label class="form-label">Port</label><input type="number" class="form-control" id="e_port" min="1" max="65535"></div>
              <div class="mb-3"><label class="form-label">User API</label><input class="form-control" id="e_user"></div>
              <div class="mb-3"><label class="form-label">Password API</label><input class="form-control" id="e_password" type="password"></div>
              <div class="mb-3">
                <label class="form-label">GenieACS Server</label>
                <select class="form-control" id="e_genieacs_server_id">
                  <option value="">-- Pilih GenieACS Server (Opsional) --</option>
                  <% (genieacsServers||[]).forEach(function(s){ %>
                    <option value="<%= s.id %>"><%= s.name %> (<%= s.url %>)</option>
                  <% }) %>
                </select>
                <small class="form-text text-muted">Pilih server GenieACS yang digunakan untuk router ini</small>
              </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Batal</button><button class="btn btn-primary" onclick="updateRouter()">Update</button></div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
const NAS_NAME_RE = /^[A-Za-z0-9][A-Za-z0-9._-]*$/;
const NAS_IPV4_RE = /^(\d{1,3}\.){3}\d{1,3}$/;
const NAS_IPV4_PORT_RE = /^(\d{1,3}\.){3}\d{1,3}:\d+$/;

function filterNasNameInput($el) {
  const v = $el.val();
  const filtered = String(v || '').replace(/\s+/g, '_').replace(/[^A-Za-z0-9._-]/g, '');
  if (filtered !== v) $el.val(filtered);
}
function validateNasForm(name, ip) {
  const n = String(name || '').trim();
  const i = String(ip || '').trim();
  if (!n) return 'Nama NAS wajib diisi';
  if (!NAS_NAME_RE.test(n)) return 'Nama NAS tidak boleh spasi/karakter aneh. Contoh: BAKTI_PUSAT';
  if (!i) return 'NAS IP wajib diisi';
  if (NAS_IPV4_PORT_RE.test(i)) return 'NAS IP jangan sertakan port (contoh: 10.10.0.5)';
  if (NAS_IPV4_RE.test(i)) {
    const ok = i.split('.').every(function (p) { const x = parseInt(p, 10); return x >= 0 && x <= 255; });
    if (!ok) return 'Oktet IPv4 harus 0–255';
    return null;
  }
  if (i.includes(':') && !i.includes('.')) return null;
  return 'Format NAS IP tidak valid';
}
$(document).on('input', '#r_name, #e_name', function () { filterNasNameInput($(this)); });

async function saveRouter(){
  filterNasNameInput($('#r_name'));
  const body = { name: $('#r_name').val().trim(), nas_ip: $('#r_ip').val().trim(), nas_identifier: $('#r_ident').val().trim(), location: $('#r_location').val().trim(), pop: $('#r_pop').val().trim(), port: $('#r_port').val(), user: $('#r_user').val(), password: $('#r_password').val(), genieacs_server_id: $('#r_genieacs_server_id').val() || null };
  const err = validateNasForm(body.name, body.nas_ip);
  if (err) { alert(err); return; }
  const res = await fetch('/admin/routers', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)}).then(r=>r.json());
  if(res.success){ location.reload(); } else { alert(res.message||'Gagal simpan'); }
}
function openEdit(r){ 
  $('#e_id').val(r.id); 
  $('#e_name').val(r.name); 
  $('#e_ip').val(r.nas_ip); 
  $('#e_ident').val(r.nas_identifier||''); 
  $('#e_location').val(r.location||''); 
  $('#e_pop').val(r.pop||''); 
  $('#e_port').val(r.port||8728); 
  $('#e_user').val(r.user||''); 
  $('#e_password').val(r.password||''); 
  $('#e_genieacs_server_id').val(r.genieacs_server_id || ''); 
  new bootstrap.Modal(document.getElementById('editRouterModal')).show(); 
}
async function updateRouter(){
  filterNasNameInput($('#e_name'));
  const id=$('#e_id').val(); 
  const body={ name:$('#e_name').val().trim(), nas_ip:$('#e_ip').val().trim(), nas_identifier:$('#e_ident').val(), location: $('#e_location').val(), pop: $('#e_pop').val(), port: $('#e_port').val(), user: $('#e_user').val(), password: $('#e_password').val(), genieacs_server_id: $('#e_genieacs_server_id').val() || null };
  const err = validateNasForm(body.name, body.nas_ip);
  if (err) { alert(err); return; }
  const res = await fetch('/admin/routers/'+id, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)}).then(r=>r.json());
  if(res.success){ location.reload(); } else { alert(res.message||'Gagal update'); }
}
async function deleteRouter(id){ if(!confirm('Hapus NAS ini?')) return; const res=await fetch('/admin/routers/'+id+'/delete',{method:'POST'}).then(r=>r.json()); if(res.success){ location.reload(); } else { alert(res.message||'Gagal hapus'); } }
async function testRouter(id){
  const btn = (typeof event !== 'undefined' && event && event.currentTarget) ? event.currentTarget : null;
  const old = btn ? btn.innerHTML : '';
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; }
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 25000);
  try {
    const res = await fetch('/admin/routers/'+id+'/test', { method: 'POST', signal: controller.signal }).then(r => r.json());
    if (res.success) {
      alert('Connected: '+(res.identity||'OK')+' @ '+(res.host||'')+(res.port? (':'+res.port):''));
    } else {
      alert('Gagal konek API MikroTik:\n'+(res.message||'Unknown')+'\n\nCatatan: tes ini memakai TCP port API (8728), bukan ping ICMP. Pastikan Tunnel IP, service api, dan firewall dari VPS ke MikroTik.');
    }
  } catch (e) {
    const msg = (e && e.name === 'AbortError')
      ? 'Timeout menunggu respons server (25 detik). Cek Tunnel IP / API MikroTik dari VPS.'
      : e.message;
    alert('Error: '+msg);
  } finally {
    clearTimeout(timer);
    if (btn) { btn.disabled = false; btn.innerHTML = old; }
  }
}
</script>
</body>
</html>


