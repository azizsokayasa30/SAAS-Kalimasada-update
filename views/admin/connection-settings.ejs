<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../partials/hard-reload') %>
  <meta charset="UTF-8">
  <title>Setting Mikrotik</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  
  <link href="/css/theme.css" rel="stylesheet">
  <link href="/css/responsive-admin.css" rel="stylesheet">

    <%- include('../partials/theme-head') %>
  <style>
    .wg-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
    @media (max-width: 768px) { .wg-steps { grid-template-columns: 1fr; } }
    .wg-step {
      border: 1px solid var(--border, rgba(148, 163, 184, 0.25));
      border-radius: 0.5rem;
      padding: 0.85rem 1rem;
      background: linear-gradient(135deg, var(--card-bg-start, var(--panel-2)), var(--card-bg-end, var(--panel)));
      color: var(--text, inherit);
    }
    .wg-step .text-muted { color: var(--muted, #94a3b8) !important; }
    .wg-step code {
      color: var(--text, inherit);
      background: transparent;
    }
    .wg-step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.6rem;
      height: 1.6rem;
      border-radius: 50%;
      background: var(--primary, #0d6efd);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 700;
      margin-right: 0.4rem;
    }
    .wg-tunnel-ip { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
  </style>
</head>
<body>
<div class="container-fluid">
  <div class="row">
    <%- include('../partials/admin-responsive-sidebar', { page: 'connection-settings', settings: settings || {} }) %>
    <main class="col-md-10 ms-sm-auto main-content">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-plug me-2"></i>Setting Mikrotik</h4>
      </div>

      <!-- Alur singkat -->
      <div class="card p-3 mb-4">
        <h6 class="mb-3">Cara menambah MikroTik lewat VPN</h6>
        <div class="wg-steps">
          <div class="wg-step">
            <div class="fw-semibold mb-1"><span class="wg-step-num">1</span> Request VPN</div>
            <small class="text-muted">Isi nama router + versi RouterOS. v7 → WireGuard, v6 → L2TP. Perangkat <code><%= tenantPrefix %>-namarouter</code> &amp; Tunnel IP otomatis.</small>
          </div>
          <div class="wg-step">
            <div class="fw-semibold mb-1"><span class="wg-step-num">2</span> Jalankan script</div>
            <small class="text-muted">Download script MikroTik, import/jalankan di router Anda, tunggu status Online.</small>
          </div>
          <div class="wg-step">
            <div class="fw-semibold mb-1"><span class="wg-step-num">3</span> Tambah NAS</div>
            <small class="text-muted">Salin Tunnel IP dari tabel VPN, tempel ke field NAS IP, lalu isi kredensial API.</small>
          </div>
        </div>
      </div>

      <% if (!vpnServerReady) { %>
        <div class="alert alert-warning">
          VPN platform belum siap. Hubungi Kalimasada untuk mengaktifkan WireGuard dan/atau L2TP sebelum request perangkat.
        </div>
      <% } else { %>
        <div class="alert alert-info py-2 small">
          Status server:
          WireGuard <%= typeof wgServerReady !== 'undefined' && wgServerReady ? 'siap' : 'belum siap' %> ·
          L2TP/IPsec <%= typeof l2tpServerReady !== 'undefined' && l2tpServerReady ? 'siap' : 'belum siap' %>.
        </div>
      <% } %>

      <!-- VPN Devices Section -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="bi bi-shield-lock me-1"></i> Perangkat VPN</h5>
        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#requestVpnModal" <%= vpnServerReady ? '' : 'disabled' %>>
          <i class="bi bi-plus"></i> Request VPN
        </button>
      </div>
      <div class="card p-3 mb-4">
        <div class="table-responsive">
          <table class="table table-striped align-middle mb-0" id="wgDevicesTable">
            <thead>
              <tr>
                <th>#</th>
                <th>Nama perangkat</th>
                <th>Protokol</th>
                <th>RouterOS</th>
                <th>Tunnel IP</th>
                <th>Status</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (!(vpnDevices||[]).length) { %>
                <tr id="wgEmptyRow">
                  <td colspan="7" class="text-center text-muted py-4">
                    Belum ada perangkat VPN. Mulai dari langkah 1: Request VPN.
                  </td>
                </tr>
              <% } %>
              <% (vpnDevices||[]).forEach(function(d, i){
                let connBadge = 'bg-secondary';
                if (d.connectionStatus === 'online') connBadge = 'bg-success';
                else if (d.connectionStatus === 'stale') connBadge = 'bg-warning text-dark';
                else if (d.connectionStatus === 'offline') connBadge = 'bg-danger';
                const isL2tp = (d.protocol || 'wireguard') === 'l2tp';
              %>
                <tr data-peer-id="<%= d.id %>">
                  <td><%= i+1 %></td>
                  <td class="fw-semibold"><%= d.name %></td>
                  <td>
                    <% if (isL2tp) { %>
                      <span class="badge bg-warning text-dark">L2TP</span>
                    <% } else { %>
                      <span class="badge bg-primary">WireGuard</span>
                    <% } %>
                  </td>
                  <td><code><%= d.routeros_version || (isL2tp ? 'v6' : 'v7') %></code></td>
                  <td>
                    <code class="wg-tunnel-ip"><%= d.tunnel_ip %></code>
                    <button type="button" class="btn btn-sm btn-outline-secondary ms-1" onclick="copyTunnelIp('<%= d.tunnel_ip %>', this)" title="Salin Tunnel IP">
                      <i class="bi bi-clipboard"></i>
                    </button>
                  </td>
                  <td><span class="badge <%= connBadge %>"><%= d.connectionLabel || '—' %></span></td>
                  <td>
                    <div class="admin-action-btns">
                      <a class="btn btn-sm btn-success" href="/admin/connection-settings/vpn/devices/<%= d.id %>/mikrotik-script" title="Download script MikroTik">
                        <i class="bi bi-download"></i> Script
                      </a>
                      <button type="button" class="btn btn-sm btn-danger" onclick="deleteVpnDevice(<%= d.id %>)" title="Hapus perangkat">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <p class="small text-muted mb-0 mt-3">
          Setelah script dijalankan di MikroTik, salin <strong>Tunnel IP</strong> di atas lalu tempel ke field NAS IP saat menambah NAS.
        </p>
      </div>

      <!-- NAS (Routers) Section -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">NAS (RADIUS)</h5>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addRouterModal"><i class="bi bi-plus"></i> Tambah NAS</button>
      </div>
          <div class="card p-3">
            <div class="table-responsive">
              <table class="table table-striped align-middle">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Nama</th>
                    <th>NAS IP</th>
                    <th>NAS Identifier</th>
                    <th>Lokasi</th>
                    <th>POP</th>
                    <th>Port</th>
                    <th>User API</th>
                    <th>Password API</th>
                    <th>GenieACS Server</th>
                    <th>Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% (routers||[]).forEach(function(r,i){ %>
                    <tr>
                      <td><%= i+1 %></td>
                      <td><%= r.name %></td>
                      <td><%= r.nas_ip %></td>
                      <td><%= r.nas_identifier || '' %></td>
                      <td><%= r.location || '' %></td>
                      <td><%= r.pop || '' %></td>
                      <td><%= r.port || 8728 %></td>
                      <td><%= r.user || '' %></td>
                      <td><%= r.password ? '***' : '' %></td>
                      <td>
                        <% if (r.genieacs_server_name) { %>
                          <span class="badge bg-info"><%= r.genieacs_server_name %></span><br>
                          <small class="text-muted"><%= r.genieacs_server_url %></small>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                      <td>
                        <div class="admin-action-btns">
                          <button type="button" class="btn btn-sm btn-primary" onclick='openEditRouter(<%- JSON.stringify(r) %>)' title="Ubah data NAS / router" aria-label="Ubah NAS"><i class="bi bi-pencil"></i></button>
                          <button type="button" class="btn btn-sm btn-info" onclick='testRouter(<%= r.id %>)' title="Tes koneksi API MikroTik" aria-label="Tes koneksi MikroTik"><i class="bi bi-activity"></i></button>
                          <button type="button" class="btn btn-sm btn-danger" onclick='deleteRouter(<%= r.id %>)' title="Hapus NAS dari daftar" aria-label="Hapus NAS"><i class="bi bi-trash"></i></button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

      <%- include('../partials/isolir-script-generator', {
        settings: settings || {},
        routers: routers || [],
        vpnTunnelIp: typeof vpnTunnelIp !== 'undefined' ? vpnTunnelIp : '',
        isolirPagePort: typeof isolirPagePort !== 'undefined' ? isolirPagePort : '8899'
      }) %>

      <!-- Request VPN Modal -->
      <div class="modal fade" id="requestVpnModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Request VPN</h5>
              <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="alert alert-info py-2 small">
                Nama perangkat final: <strong><%= tenantPrefix %>-{nama-router}</strong>.
                Tunnel IP digenerate otomatis.
                <br>RouterOS <strong>v7</strong> → WireGuard · <strong>v6</strong> → L2TP/IPsec.
              </div>
              <div class="mb-3">
                <label class="form-label">Nama router</label>
                <input class="form-control" id="vpn_router_name" placeholder="POP-A" autocomplete="off">
                <small class="text-muted">Contoh: POP-A → perangkat <code id="vpn_name_preview"><%= tenantPrefix %>-POP-A</code></small>
              </div>
              <div class="mb-3">
                <label class="form-label">Versi RouterOS</label>
                <select class="form-select" id="vpn_routeros_version">
                  <option value="v7" <%= typeof wgServerReady !== 'undefined' && !wgServerReady && typeof l2tpServerReady !== 'undefined' && l2tpServerReady ? '' : 'selected' %>>v7 — WireGuard</option>
                  <option value="v6" <%= typeof wgServerReady !== 'undefined' && !wgServerReady && typeof l2tpServerReady !== 'undefined' && l2tpServerReady ? 'selected' : '' %>>v6 — L2TP/IPsec</option>
                </select>
                <small class="text-muted" id="vpn_protocol_hint">Protokol: WireGuard</small>
              </div>
            </div>
            <div class="modal-footer">
              <button class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button class="btn btn-success" id="btnRequestVpn" onclick="requestVpn()">Buat Perangkat</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Add Router Modal -->
      <div class="modal fade" id="addRouterModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Tambah NAS</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <div class="alert alert-info py-2 small">
                Isi <strong>NAS IP</strong> dengan Tunnel IP dari tabel VPN di atas
                (salin dari kolom Tunnel IP setelah script MikroTik dijalankan).
              </div>
              <div class="mb-3">
                <label class="form-label">Nama</label>
                <input class="form-control" id="r_name" maxlength="64" pattern="[A-Za-z0-9][A-Za-z0-9._\-]*"
                       title="Hanya huruf, angka, titik, strip, underscore — tanpa spasi"
                       placeholder="Contoh: RO-KRG_MERDEN" autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">Nama untuk RADIUS: tanpa spasi (contoh <code>BAKTI_PUSAT</code>)</small>
              </div>
              <div class="mb-3">
                <label class="form-label">NAS IP</label>
                <input class="form-control" id="r_ip" maxlength="45" placeholder="Contoh: 10.10.0.5 (Tunnel IP VPN)" autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">IP saja — jangan sertakan port API</small>
              </div>
              <div class="mb-3"><label class="form-label">NAS Identifier</label><input class="form-control" id="r_ident" placeholder="RouterA"></div>
              <div class="mb-3"><label class="form-label">Lokasi</label><input class="form-control" id="r_location" placeholder="Gedung/Alamat"></div>
              <div class="mb-3"><label class="form-label">POP</label><input class="form-control" id="r_pop" placeholder="POP-1"></div>
              <div class="mb-3"><label class="form-label">Port</label><input type="number" class="form-control" id="r_port" placeholder="8728" value="8728" min="1" max="65535"></div>
              <div class="mb-3"><label class="form-label">User API</label><input class="form-control" id="r_user" placeholder="admin"></div>
              <div class="mb-3"><label class="form-label">Password API</label><input class="form-control" id="r_password" type="password"></div>
              <div class="mb-3">
                <label class="form-label">GenieACS Server</label>
                <select class="form-control" id="r_genieacs_server_id">
                  <option value="">-- Pilih GenieACS Server (Opsional) --</option>
                  <% (genieacsServers||[]).forEach(function(s){ %>
                    <option value="<%= s.id %>"><%= s.name %> (<%= s.url %>)</option>
                  <% }) %>
                </select>
                <small class="form-text text-muted">Pilih server GenieACS yang digunakan untuk router ini</small>
              </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Batal</button><button class="btn btn-primary" onclick="saveRouter()">Simpan</button></div>
          </div>
        </div>
      </div>

      <!-- Edit Router Modal -->
      <div class="modal fade" id="editRouterModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Edit NAS</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <input type="hidden" id="er_id">
              <div class="mb-3">
                <label class="form-label">Nama</label>
                <input class="form-control" id="er_name" maxlength="64" pattern="[A-Za-z0-9][A-Za-z0-9._\-]*"
                       title="Hanya huruf, angka, titik, strip, underscore — tanpa spasi"
                       autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">Nama untuk RADIUS: tanpa spasi</small>
              </div>
              <div class="mb-3">
                <label class="form-label">NAS IP</label>
                <input class="form-control" id="er_ip" maxlength="45" autocomplete="off" spellcheck="false">
                <small class="form-text text-muted">IP saja — jangan sertakan port API</small>
              </div>
              <div class="mb-3"><label class="form-label">NAS Identifier</label><input class="form-control" id="er_ident"></div>
              <div class="mb-3"><label class="form-label">Lokasi</label><input class="form-control" id="er_location"></div>
              <div class="mb-3"><label class="form-label">POP</label><input class="form-control" id="er_pop"></div>
              <div class="mb-3"><label class="form-label">Port</label><input type="number" class="form-control" id="er_port" min="1" max="65535"></div>
              <div class="mb-3"><label class="form-label">User API</label><input class="form-control" id="er_user"></div>
              <div class="mb-3"><label class="form-label">Password API</label><input class="form-control" id="er_password" type="password"></div>
              <div class="mb-3">
                <label class="form-label">GenieACS Server</label>
                <select class="form-control" id="er_genieacs_server_id">
                  <option value="">-- Pilih GenieACS Server (Opsional) --</option>
                  <% (genieacsServers||[]).forEach(function(s){ %>
                    <option value="<%= s.id %>"><%= s.name %> (<%= s.url %>)</option>
                  <% }) %>
                </select>
                <small class="form-text text-muted">Pilih server GenieACS yang digunakan untuk router ini</small>
              </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Batal</button><button class="btn btn-primary" onclick="updateRouter()">Update</button></div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
const TENANT_PREFIX = <%- JSON.stringify(tenantPrefix || 'tenant') %>;

function sanitizeRouterPart(value) {
  return String(value || '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/[^a-zA-Z0-9._-]+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^[-.]+|[-.]+$/g, '');
}

function updateVpnNamePreview() {
  const raw = $('#vpn_router_name').val();
  const part = sanitizeRouterPart(raw) || 'namarouter';
  $('#vpn_name_preview').text(TENANT_PREFIX + '-' + part);
}

function updateVpnProtocolHint() {
  const v = $('#vpn_routeros_version').val();
  $('#vpn_protocol_hint').text(v === 'v6' ? 'Protokol: L2TP/IPsec' : 'Protokol: WireGuard');
}

$('#vpn_router_name').on('input', updateVpnNamePreview);
$('#vpn_routeros_version').on('change', updateVpnProtocolHint);
updateVpnProtocolHint();

async function copyTunnelIp(ip, btn) {
  try {
    await navigator.clipboard.writeText(ip);
    const old = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-check2"></i>';
    setTimeout(function () { btn.innerHTML = old; }, 1200);
  } catch (e) {
    prompt('Salin Tunnel IP ini:', ip);
  }
}

async function requestVpn() {
  const routerName = $('#vpn_router_name').val().trim();
  const routerosVersion = $('#vpn_routeros_version').val();
  if (!routerName) { alert('Nama router wajib diisi'); return; }
  if (!routerosVersion) { alert('Versi RouterOS wajib dipilih'); return; }
  const btn = document.getElementById('btnRequestVpn');
  const old = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Membuat…';
  try {
    const res = await fetch('/admin/connection-settings/vpn/devices', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ router_name: routerName, routeros_version: routerosVersion })
    }).then(function (r) { return r.json(); });
    if (res.success) {
      location.reload();
    } else {
      alert(res.message || 'Gagal membuat perangkat VPN');
    }
  } catch (e) {
    alert('Error: ' + e.message);
  } finally {
    btn.disabled = false;
    btn.innerHTML = old;
  }
}

async function deleteVpnDevice(id) {
  if (!confirm('Hapus perangkat VPN ini?')) return;
  const res = await fetch('/admin/connection-settings/vpn/devices/' + id + '/delete', { method: 'POST' }).then(function (r) { return r.json(); });
  if (res.success) location.reload();
  else alert(res.message || 'Gagal hapus');
}

// Router Functions
const NAS_NAME_RE = /^[A-Za-z0-9][A-Za-z0-9._-]*$/;
const NAS_IPV4_RE = /^(\d{1,3}\.){3}\d{1,3}$/;
const NAS_IPV4_PORT_RE = /^(\d{1,3}\.){3}\d{1,3}:\d+$/;

function filterNasNameInput($el) {
  const v = $el.val();
  const filtered = String(v || '').replace(/\s+/g, '_').replace(/[^A-Za-z0-9._-]/g, '');
  if (filtered !== v) $el.val(filtered);
}

function validateNasForm(name, ip) {
  const n = String(name || '').trim();
  const i = String(ip || '').trim();
  if (!n) return 'Nama NAS wajib diisi';
  if (!NAS_NAME_RE.test(n)) return 'Nama NAS tidak boleh spasi/karakter aneh. Contoh: BAKTI_PUSAT atau RO-KRG_MERDEN';
  if (!i) return 'NAS IP wajib diisi';
  if (NAS_IPV4_PORT_RE.test(i)) return 'NAS IP jangan sertakan port (contoh benar: 10.10.0.5)';
  if (NAS_IPV4_RE.test(i)) {
    const ok = i.split('.').every(function (p) { const x = parseInt(p, 10); return x >= 0 && x <= 255; });
    if (!ok) return 'Oktet IPv4 harus 0–255';
    return null;
  }
  if (i.includes(':') && !i.includes('.')) return null;
  return 'Format NAS IP tidak valid';
}

$(document).on('input', '#r_name, #er_name', function () { filterNasNameInput($(this)); });

async function saveRouter(){
  filterNasNameInput($('#r_name'));
  const body = { name: $('#r_name').val().trim(), nas_ip: $('#r_ip').val().trim(), nas_identifier: $('#r_ident').val().trim(), location: $('#r_location').val().trim(), pop: $('#r_pop').val().trim(), port: $('#r_port').val(), user: $('#r_user').val(), password: $('#r_password').val(), genieacs_server_id: $('#r_genieacs_server_id').val() || null };
  const err = validateNasForm(body.name, body.nas_ip);
  if (err) { alert(err); return; }
  const res = await fetch('/admin/routers', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)}).then(r=>r.json());
  if(res.success){ location.reload(); } else { alert(res.message||'Gagal simpan'); }
}
function openEditRouter(r){ 
  $('#er_id').val(r.id); 
  $('#er_name').val(r.name); 
  $('#er_ip').val(r.nas_ip); 
  $('#er_ident').val(r.nas_identifier||''); 
  $('#er_location').val(r.location||''); 
  $('#er_pop').val(r.pop||''); 
  $('#er_port').val(r.port||8728); 
  $('#er_user').val(r.user||''); 
  $('#er_password').val(r.password||''); 
  $('#er_genieacs_server_id').val(r.genieacs_server_id || ''); 
  new bootstrap.Modal(document.getElementById('editRouterModal')).show(); 
}
async function updateRouter(){
  filterNasNameInput($('#er_name'));
  const id=$('#er_id').val(); 
  const body={ name:$('#er_name').val().trim(), nas_ip:$('#er_ip').val().trim(), nas_identifier:$('#er_ident').val(), location: $('#er_location').val(), pop: $('#er_pop').val(), port: $('#er_port').val(), user: $('#er_user').val(), password: $('#er_password').val(), genieacs_server_id: $('#er_genieacs_server_id').val() || null };
  const err = validateNasForm(body.name, body.nas_ip);
  if (err) { alert(err); return; }
  const res = await fetch('/admin/routers/'+id, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)}).then(r=>r.json());
  if(res.success){ location.reload(); } else { alert(res.message||'Gagal update'); }
}
async function deleteRouter(id){ if(!confirm('Hapus NAS ini?')) return; const res=await fetch('/admin/routers/'+id+'/delete',{method:'POST'}).then(r=>r.json()); if(res.success){ location.reload(); } else { alert(res.message||'Gagal hapus'); } }
async function testRouter(id){
  const btn = (typeof event !== 'undefined' && event && event.currentTarget) ? event.currentTarget : null;
  const old = btn ? btn.innerHTML : '';
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; }
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 25000);
  try {
    const res = await fetch('/admin/routers/'+id+'/test', { method: 'POST', signal: controller.signal }).then(r => r.json());
    if (res.success) {
      alert('Connected: '+(res.identity||'OK')+' @ '+(res.host||'')+(res.port? (':'+res.port):''));
    } else {
      alert('Gagal konek API MikroTik:\n'+(res.message||'Unknown')+'\n\nCatatan: tes ini memakai TCP port API (8728), bukan ping ICMP. Pastikan Tunnel IP, service api, dan firewall dari VPS ke MikroTik.');
    }
  } catch (e) {
    const msg = (e && e.name === 'AbortError')
      ? 'Timeout menunggu respons server (25 detik). Cek Tunnel IP / API MikroTik dari VPS.'
      : e.message;
    alert('Error: '+msg);
  } finally {
    clearTimeout(timer);
    if (btn) { btn.disabled = false; btn.innerHTML = old; }
  }
}
</script>
