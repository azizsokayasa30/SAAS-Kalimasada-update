<%
/*
 * UNIFIED SIDEBAR SHIM
 * billing-sidebar.ejs sekarang hanya redirect ke unified admin-responsive-sidebar.
 * Semua halaman billing & admin kini menggunakan sidebar yang sama.
 * Jangan edit file ini — edit admin-responsive-sidebar.ejs untuk perubahan menu.
 */

// Pastikan variabel 'page' ada, kalau tidak set ke string kosong
if (typeof page === 'undefined') { var page = ''; }
%>
<%- include('./admin-responsive-sidebar', Object.assign(
    { page: page },
    typeof settings !== 'undefined' ? { settings: settings } : {},
    typeof versionInfo !== 'undefined' ? { versionInfo: versionInfo } : {},
    typeof appSettings !== 'undefined' ? { appSettings: appSettings } : {}
)) %>