<!-- Halaman Tab Setting Admin -->
<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/hard-reload') %>
    <meta charset="UTF-8">
    <title>Admin Setting</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        /* Layout & Spacing — warna dihandle oleh kalimasada-theme.css */
        .main-content {
            padding: 32px 24px;
            padding-bottom: 50px;
        }
        .form-section {
            border-radius: 16px;
            padding: 25px;
            margin-bottom: 20px;
            height: 100%;
            box-shadow: var(--km-shadow-sm);
        }
        .qr-container { max-width: 100%; margin: 0 auto; padding: 20px; border-radius: 12px; }
        #wa-qr-container { min-height: 250px; align-items: center; }
        #wa-qr-div {
            padding: 20px;
            border-radius: 10px;
            box-shadow: var(--km-shadow-sm);
            background: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        #wa-qr-div canvas,
        #wa-qr-div img {
            display: block;
            background: #ffffff;
        }
        .command-card { border-radius: 8px; padding: 15px; margin-bottom: 15px; transition: all 0.3s ease; }
        .command-card:hover { box-shadow: var(--km-shadow-md); transform: translateY(-2px); }
        .command-title { font-weight: 600; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
        .command-list { font-size: 0.85rem; line-height: 1.4; }
        .command-list code { padding: 2px 4px; border-radius: 3px; font-size: 0.8rem; }
        .logo-preview { border: 2px dashed var(--km-border); border-radius: 8px; padding: 15px; text-align: center; }
        .logo-preview img { max-width: 100%; height: auto; border-radius: 4px; }
        .logo-preview img[src$=".svg"] { width: auto; height: auto; max-width: 100%; max-height: 120px; }
        .status-badge { font-size: 0.9rem; padding: 8px 12px; }
        .alert-custom { border-radius: 8px; border-left: 4px solid; }
        .alert-warning { border-left-color: #ffc107; }
        .alert-info { border-left-color: #17a2b8; }
        .alert-success { border-left-color: #28a745; }
        .alert-danger { border-left-color: #dc3545; }

        @media (max-width: 767.98px) {
            .main-content { margin-top: 70px !important; padding-top: 10px !important; z-index: 1; }
            .card { z-index: 1; }
            .row.mb-4:first-of-type { margin-top: 10px; }
            .backup-restore-section { margin-top: 20px !important; padding-top: 20px !important; }
            #restartNotif { top: 80px !important; right: 10px !important; left: 10px !important; width: auto !important; }
        }

        .backup-restore-section { margin-top: 40px; padding-top: 30px; scroll-margin-top: 100px; }
        .backup-restore-section .card { position: relative; z-index: 1; }
        .backup-restore-section .card-header { padding-top: 20px; padding-bottom: 15px; }
        .legacy-whatsapp-settings { display: none !important; }
        .settings-group { border: 1px solid #eef2f7; border-radius: 12px; padding: 14px; background: var(--panel-bg, #fff); }
        .settings-group-title { font-weight: 700; font-size: 0.9rem; color: #475569; text-transform: uppercase; letter-spacing: .03em; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #eef2f7; }
        .settings-shortcut { display: block; height: 100%; padding: 14px; border: 1px solid #e9ecef; border-radius: 12px; text-decoration: none; color: inherit; background: var(--panel-bg, #fff); transition: transform .15s ease, box-shadow .15s ease; }
        .settings-shortcut:hover { transform: translateY(-1px); box-shadow: var(--km-shadow-sm, 0 4px 12px rgba(15,23,42,.08)); }
        .settings-shortcut small { color: #64748b; }
    </style>

    <%- include('partials/theme-head') %>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <!-- Include Responsive Admin Sidebar -->
        <%- include('partials/admin-responsive-sidebar', { page: 'setting', settings: settings }) %>
        
        <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
            <h3 class="mb-4">Pengaturan Sistem</h3>
            <div class="alert alert-info alert-custom mb-4">
                <i class="bi bi-whatsapp me-2"></i>
                Toggle notifikasi otomatis WhatsApp sudah dipusatkan di
                <a href="/admin/billing/whatsapp-monitoring" class="alert-link">WhatsApp Monitoring</a>.
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-3 col-sm-6">
                    <a class="settings-shortcut" href="#settingsFields">
                        <strong><i class="bi bi-gear text-primary"></i> Sistem Umum</strong><br>
                        <small>Admin, server, kontak, billing, pajak</small>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a class="settings-shortcut" href="#billingSettingsSection">
                        <strong><i class="bi bi-receipt text-primary"></i> Billing & Pembayaran</strong><br>
                        <small>Rekening bank, tunai, catatan invoice</small>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a class="settings-shortcut" href="/admin/billing/email-settings">
                        <strong><i class="bi bi-envelope-at text-success"></i> Pengaturan Email</strong><br>
                        <small>SMTP, template, test email, broadcast</small>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a class="settings-shortcut" href="/admin/billing/whatsapp-monitoring">
                        <strong><i class="bi bi-whatsapp text-success"></i> Monitoring WhatsApp</strong><br>
                        <small>Toggle notifikasi otomatis dan interval monitor</small>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a class="settings-shortcut" href="#backupRestoreSection">
                        <strong><i class="bi bi-database text-warning"></i> Backup & Logs</strong><br>
                        <small>Backup, restore, dan activity logs</small>
                    </a>
                </div>
            </div>
            
            <div class="row g-3">
                <!-- Kolom 1: Form Settings -->
                <div class="col-lg-6 mb-3">
                    <div class="form-section">
                        <h5 class="mb-3">
                            <i class="bi bi-gear text-primary"></i> Pengaturan Sistem
                        </h5>
                        
                        <!-- Alert Panduan Konfigurasi -->
                        <form id="settingsForm">
                            <div id="settingsFields">
                                <!-- Field dari settings.json akan di-render di sini oleh JS -->
                            </div>
                            <div id="settingsSuccess" class="alert alert-success d-none" role="alert"></div>
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-3">
                                <button type="button" class="btn btn-outline-info me-2" id="testConnectionBtn">
                                    <i class="bi bi-wifi"></i> Test Koneksi
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save"></i> Simpan Perubahan
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Kolom 2: Billing & pembayaran (branding/logo dikelola dari Management) -->
                <div class="col-lg-6 mb-3">
                    <div class="form-section">
                        <!-- Billing & Pembayaran -->
                        <div id="billingSettingsSection">
                            <h5 class="mb-3">
                                <i class="bi bi-receipt text-primary"></i> Billing & Pembayaran
                            </h5>
                            <div id="billingSettingsFields">
                                <!-- Field billing dari settings.json di-render di sini oleh JS -->
                            </div>
                            <div id="billingSettingsSuccess" class="alert alert-success d-none mt-3" role="alert"></div>
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-3">
                                <button type="button" class="btn btn-primary" id="saveSettingsBtnBilling">
                                    <i class="bi bi-save"></i> Simpan Perubahan
                                </button>
                            </div>
                        </div>

                        <!-- QR Notifikasi Penagihan -->
                        <div class="mt-4" id="billingQrSection">
                            <h5 class="mb-3">
                                <i class="bi bi-qr-code text-primary"></i> QR Notifikasi Penagihan
                            </h5>
                            <p class="text-muted small mb-3">
                                Opsional. QR ini dilampirkan saat notifikasi tagihan WhatsApp dikirim ke pelanggan.
                                Jika tidak diunggah, notifikasi hanya berisi teks tanpa gambar QR.
                            </p>
                            <form id="billingQrUploadForm" enctype="multipart/form-data">
                                <div class="mb-3">
                                    <label class="form-label">Upload QR Pembayaran</label>
                                    <input type="file" name="billingQr" accept="image/*" class="form-control" required>
                                    <div class="form-text">Format: PNG, JPG, JPEG, GIF, BMP, WEBP. Maksimal 2MB.</div>
                                </div>
                                <button type="submit" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-upload"></i> Upload QR Penagihan
                                </button>
                            </form>
                            <% const hasBillingQr = typeof settings !== 'undefined' && settings.billing_qr_filename; %>
                            <div class="logo-preview mt-3" id="billingQrPreviewWrap"<%= hasBillingQr ? '' : ' style="display:none"' %>>
                                <label class="form-label">QR Saat Ini:</label>
                                <img id="billingQrPreview" src="<%= hasBillingQr ? '/admin/settings/billing-qr?ts=' + Date.now() : '' %>" alt="QR Penagihan" style="max-width:200px;max-height:200px;">
                                <div class="mt-2 d-flex flex-column gap-2">
                                    <a href="/admin/settings/billing-qr" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary w-100">
                                        Buka QR ukuran penuh
                                    </a>
                                </div>
                            </div>
                            <div id="billingQrEmpty" class="text-muted small mt-3"<%= hasBillingQr ? ' style="display:none"' : '' %>>
                                <i class="bi bi-info-circle"></i> Belum ada QR diunggah.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- WhatsApp settings moved to /admin/billing/whatsapp-monitoring -->
                <div class="col-lg-4 col-md-6 mb-3 legacy-whatsapp-settings" aria-hidden="true">
                    <div class="form-section">
                        <h5 class="mb-3">
                            <i class="bi bi-whatsapp text-success"></i> Wablas WhatsApp Configuration
                        </h5>
                        
                        <!-- Info Alert -->
                        <div class="alert alert-info alert-custom mb-3">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                                <div>
                                    <strong>Konfigurasi Wablas</strong>
                                    <br>
                                    <small>
                                        Konfigurasi Wablas API untuk WhatsApp Gateway. Setelah dikonfigurasi, sistem akan menggunakan Wablas sebagai provider WhatsApp. Jika tidak dikonfigurasi, sistem akan menggunakan Baileys (default).
                                    </small>
                                </div>
                            </div>
                        </div>
                        
                        <form id="wablasForm">
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="wablas_enabled" id="wablas_enabled">
                                    <label class="form-check-label" for="wablas_enabled">
                                        <strong>Enable Wablas</strong>
                                    </label>
                                </div>
                                <div class="form-text">Aktifkan untuk menggunakan Wablas sebagai WhatsApp Gateway</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Wablas API URL</label>
                                <input type="text" class="form-control" name="wablas_api_url" id="wablas_api_url" placeholder="https://bdg.wablas.com">
                                <div class="form-text">URL API Wablas (default: https://bdg.wablas.com)</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Wablas API Key</label>
                                <input type="text" class="form-control" name="wablas_api_key" id="wablas_api_key" placeholder="Your Wablas API Key">
                                <div class="form-text">API Key dari dashboard Wablas</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Wablas Secret Key</label>
                                <input type="password" class="form-control" name="wablas_secret_key" id="wablas_secret_key" placeholder="Your Wablas Secret Key">
                                <div class="form-text">Secret Key dari dashboard Wablas (opsional, jika diperlukan)</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Wablas Device ID</label>
                                <input type="text" class="form-control" name="wablas_device_id" id="wablas_device_id" placeholder="Device ID">
                                <div class="form-text">Device ID dari dashboard Wablas (opsional)</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Webhook Secret</label>
                                <input type="password" class="form-control" name="wablas_webhook_secret" id="wablas_webhook_secret" placeholder="Webhook Secret">
                                <div class="form-text">Secret untuk validasi webhook dari Wablas (opsional, untuk keamanan)</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Min Delay (ms)</label>
                                <input type="number" class="form-control" name="wablas_min_delay" id="wablas_min_delay" placeholder="1000" value="1000">
                                <div class="form-text">Delay minimum antar request dalam millisecond (default: 1000ms)</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Max Retries</label>
                                <input type="number" class="form-control" name="wablas_max_retries" id="wablas_max_retries" placeholder="3" value="3">
                                <div class="form-text">Jumlah maksimal retry jika gagal (default: 3)</div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Retry Delay (ms)</label>
                                <input type="number" class="form-control" name="wablas_retry_delay" id="wablas_retry_delay" placeholder="2000" value="2000">
                                <div class="form-text">Delay antar retry dalam millisecond (default: 2000ms)</div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-outline-info" id="btnTestWablas">
                                    <i class="bi bi-whatsapp"></i> Test Wablas Connection
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save"></i> Simpan Konfigurasi Wablas
                                </button>
                            </div>
                            
                            <div id="wablasTestResult" class="alert mt-3 d-none"></div>
                        </form>

                        <!-- WhatsApp Groups Management -->
                        <div class="mt-4">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-people-fill"></i> WhatsApp Groups Management
                            </h6>

                            <div class="mb-3">
                                <div class="d-flex gap-2">
                                    <button class="btn btn-success btn-sm" id="btnLoadGroups">
                                        <i class="bi bi-arrow-clockwise"></i> Load Groups
                                    </button>
                                    <button class="btn btn-outline-primary btn-sm" id="btnRefreshGroups">
                                        <i class="bi bi-refresh"></i> Refresh
                                    </button>
                                </div>
                            </div>

                            <!-- WhatsApp Groups Status -->
                            <div id="waGroupsStatus" class="mb-3">
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle"></i> Klik "Load Groups" untuk melihat daftar grup WhatsApp yang sudah terkoneksi.
                                </div>
                            </div>

                            <!-- WhatsApp Groups List -->
                            <div id="waGroupsList" class="mb-3" style="display: none;">
                                <div class="card">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0"><i class="bi bi-people-fill"></i> Daftar Grup WhatsApp</h6>
                                        <span class="badge bg-primary" id="groupsCount">0</span>
                                    </div>
                                    <div class="card-body p-0">
                                        <div id="groupsContainer">
                                            <!-- Groups will be loaded here -->
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Group Detail Modal -->
                            <div class="modal fade" id="groupDetailModal" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title"><i class="bi bi-people-fill"></i> Detail Grup WhatsApp</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body" id="groupDetailContent">
                                            <!-- Group detail will be loaded here -->
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                                            <button type="button" class="btn btn-primary" id="btnCopyGroupId">Copy Group ID</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Perintah Admin WhatsApp -->
                        <div class="mt-4">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-info-circle"></i> Perintah Admin WhatsApp
                            </h6>
                            
                            <!-- GenieACS Commands -->
                            <div class="command-card mb-2">
                                <div class="command-title text-success">
                                    <i class="bi bi-hdd-network"></i> GenieACS
                                </div>
                                <div class="command-list">
                                    <ul class="list-unstyled mb-0 small">
                                        <li><code>devices</code> - Daftar perangkat</li>
                                        <li><code>cekall</code> - Cek semua perangkat</li>
                                        <li><code>search [nomor]</code> - Cari perangkat</li>
                                        <li><code>cek [nomor]</code> - Cek status ONU</li>
                                        <li><code>cekstatus [nomor]</code> - Cek status pelanggan</li>
                                        <li><code>admincheck [nomor]</code> - Cek perangkat admin</li>
                                        <li><code>gantissid [nomor] [ssid]</code> - Ubah SSID</li>
                                        <li><code>gantipass [nomor] [pass]</code> - Ubah password</li>
                                        <li><code>reboot [nomor]</code> - Restart ONU</li>
                                        <li><code>factory reset [nomor]</code> - Reset factory</li>
                                        <li><code>refresh</code> - Refresh data perangkat</li>
                                        <li><code>tag [nomor] [tag]</code> - Tambah tag pelanggan</li>
                                        <li><code>untag [nomor] [tag]</code> - Hapus tag</li>
                                        <li><code>tags [nomor]</code> - Lihat tags</li>
                                        <li><code>adminssid [nomor] [ssid]</code> - Admin ubah SSID</li>
                                        <li><code>adminrestart [nomor]</code> - Admin restart ONU</li>
                                        <li><code>adminfactory [nomor]</code> - Admin factory reset</li>
                                        <li><code>confirm admin factory reset [nomor]</code> - Konfirmasi factory reset</li>
                                    </ul>
                                </div>
                            </div>

                            <!-- PPPoE Commands -->
                            <div class="command-card mb-2">
                                <div class="command-title text-primary">
                                    <i class="bi bi-router"></i> PPPoE & Mikrotik
                                </div>
                                <div class="command-list">
                                    <ul class="list-unstyled mb-0 small">
                                        <li><code>interfaces</code> - Daftar interface</li>
                                        <li><code>interface [nama]</code> - Detail interface</li>
                                        <li><code>enableif [nama]</code> - Aktifkan interface</li>
                                        <li><code>disableif [nama]</code> - Nonaktifkan interface</li>
                                        <li><code>ipaddress</code> - Alamat IP</li>
                                        <li><code>routes</code> - Tabel routing</li>
                                        <li><code>dhcp</code> - DHCP leases</li>
                                        <li><code>ping [ip] [count]</code> - Test ping</li>
                                        <li><code>logs [topics] [count]</code> - Log Mikrotik</li>
                                        <li><code>firewall [chain]</code> - Status firewall</li>
                                        <li><code>users</code> - Daftar semua user</li>
                                        <li><code>profiles [type]</code> - Daftar profile</li>
                                        <li><code>identity [nama]</code> - Info router</li>
                                        <li><code>clock</code> - Waktu router</li>
                                        <li><code>resource</code> - Info resource</li>
                                        <li><code>reboot</code> - Restart router</li>
                                        <li><code>confirm restart</code> - Konfirmasi restart</li>
                                        <li><code>addtag [device_id] [nomor]</code> - Tambah tag perangkat</li>
                                    </ul>
                                </div>
                            </div>

                            <!-- Hotspot & PPPoE Management -->
                            <div class="command-card mb-2">
                                <div class="command-title text-warning">
                                    <i class="bi bi-wifi"></i> Hotspot & PPPoE Management
                                </div>
                                <div class="command-list">
                                    <ul class="list-unstyled mb-0 small">
                                        <li><code>vcr [user] [profile] [nomor]</code> - Buat voucher</li>
                                        <li><code>hotspot</code> - User hotspot aktif</li>
                                        <li><code>pppoe</code> - User PPPoE aktif</li>
                                        <li><code>offline</code> - User PPPoE offline</li>
                                        <li><code>addhotspot [user] [pass] [profile]</code> - Tambah user</li>
                                        <li><code>addpppoe [user] [pass] [profile] [ip]</code> - Tambah PPPoE</li>
                                        <li><code>setprofile [user] [profile]</code> - Ubah profile</li>
                                        <li><code>delhotspot [username]</code> - Hapus user hotspot</li>
                                        <li><code>delpppoe [username]</code> - Hapus user PPPoE</li>
                                        <li><code>addpppoe_tag [user] [nomor]</code> - Tambah tag PPPoE</li>
                                        <li><code>member [username] [profile] [nomor]</code> - Tambah member</li>
                                        <li><code>list</code> - Daftar semua user</li>
                                        <li><code>remove [username]</code> - Hapus user (generic)</li>
                                        <li><code>addadmin [nomor]</code> - Tambah nomor admin</li>
                                        <li><code>removeadmin [nomor]</code> - Hapus nomor admin</li>
                                    </ul>
                                </div>
                            </div>

                            <!-- Sistem & Admin -->
                            <div class="command-card mb-2">
                                <div class="command-title text-info">
                                    <i class="bi bi-shield-check"></i> Sistem & Admin
                                </div>
                                <div class="command-list">
                                    <ul class="list-unstyled mb-0 small">
                                        <li><code>otp [nomor]</code> - Kirim OTP</li>
                                        <li><code>status</code> - Status sistem</li>
                                        <li><code>logs</code> - Log aplikasi</li>
                                        <li><code>restart</code> - Restart aplikasi</li>
                                        <li><code>debug resource</code> - Debug resource</li>
                                        <li><code>checkgroup</code> - Cek status group</li>
                                        <li><code>setadmin [nomor]</code> - Set nomor admin</li>
                                        <li><code>settechnician [nomor]</code> - Set nomor teknisi</li>
                                        <li><code>setheader [teks]</code> - Set header pesan</li>
                                        <li><code>setfooter [teks]</code> - Set footer pesan</li>
                                        <li><code>setgenieacs [url] [user] [pass]</code> - Set GenieACS</li>
                                        <li><code>setmikrotik [host] [port] [user] [pass]</code> - Set Mikrotik</li>
                                        <li><code>genieacs stop</code> - Stop GenieACS</li>
                                        <li><code>genieacs start060111</code> - Start GenieACS</li>
                                        <li><code>admin</code> - Menu admin</li>
                                        <li><code>help</code> - Bantuan perintah</li>
                                        <li><code>ya/iya/yes</code> - Konfirmasi ya</li>
