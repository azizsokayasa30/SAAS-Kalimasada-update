<script>
$(function() {
    // Fungsi untuk mendapatkan label yang user-friendly
    function humanizeFieldKey(key) {
        if (!key) return '';
        const leaf = key.includes('.') ? key.slice(key.lastIndexOf('.') + 1) : key;
        return leaf
            .replace(/([a-z])([A-Z])/g, '$1 $2')
            .replace(/_/g, ' ')
            .split(' ')
            .filter(Boolean)
            .map(function(word) {
                const lower = word.toLowerCase();
                if (lower === 'otp') return 'OTP';
                if (lower === 'id') return 'ID';
                if (lower === 'ppn') return 'PPN';
                if (lower === 'url') return 'URL';
                if (lower === 'api') return 'API';
                return lower.charAt(0).toUpperCase() + lower.slice(1);
            })
            .join(' ');
    }

    function getFieldLabel(key) {
        const fieldLabels = {
            'auto_suspension_enabled': 'Isolir Otomatis',
            'auto_suspension_day': 'Tanggal Isolir Otomatis (1-28)',
            'suspension_grace_period_days': 'Grace Period Isolir (Hari, legacy)',
            'default_pppoe_profile': 'Profile PPPoE Default',
            'admins.0': 'Nomor Admin Utama',
            'admins.1': 'Nomor Admin Tambahan 1',
            'admins.2': 'Nomor Admin Tambahan 2',
            'technician_numbers.0': 'Nomor Teknisi 1',
            'technician_numbers.1': 'Nomor Teknisi 2',
            'technician_numbers.2': 'Nomor Teknisi 3',
            'admin_username': 'Username Admin',
            'admin_password': 'Password Admin',
            'admin_session_timeout_minutes': 'Timeout Login Admin (Menit)',
            'pppoe_monitor_enable': 'Monitor PPPoE',
            'pppoe_monitor_interval_minutes': 'Interval Monitor PPPoE (Menit)',
            'whatsapp_keep_alive': 'WhatsApp Keep Alive',
            'whatsapp_restart_on_error': 'Restart WhatsApp on Error',
            'rx_power_warning': 'RX Power Warning (dBm)',
            'rx_power_critical': 'RX Power Critical (dBm)',
            'rx_power_notification_enable': 'Notifikasi RX Power',
            'rx_power_warning_interval_hours': 'Interval Peringatan RX Power (Jam)',
            'company_header': 'Header Perusahaan',
            'app_name': 'Nama Aplikasi',
            'footer_info': 'Info Footer',
            'company_website': 'Website Perusahaan',
            'company_slogan': 'Slogan Perusahaan',
            'company_address': 'Alamat Perusahaan',
            'contact_phone': 'Telepon',
            'contact_email': 'Email',
            'contact_address': 'Alamat Kontak',
            'contact_whatsapp': 'WhatsApp',
            'customerPortalOtp': 'OTP Portal Pelanggan',
            'otp_length': 'Panjang OTP',
            'otp_expiry_minutes': 'Masa Berlaku OTP (Menit)',
            'server_host': 'Host Server',
            'server_port': 'Port Server',
            'technician_group_id': 'Grup WhatsApp Teknisi',
            'payment_bank_name': 'Nama Bank',
            'payment_account_holder': 'Nama Pemilik Rekening',
            'payment_account_number': 'Nomor Rekening',
            'payment_cash_address': 'Alamat Pembayaran Tunai',
            'payment_cash_hours': 'Jam Pembayaran Tunai',
            'invoice_notes': 'Catatan Invoice',
            'trouble_report.enabled': 'Fitur Laporan Gangguan',
            'trouble_report.categories': 'Kategori Laporan',
            'trouble_report.auto_ticket': 'Tiket Otomatis',
            'rxpower_recap_enable': 'Ringkasan RX Power',
            'rxpower_recap_interval_hours': 'Interval Ringkasan RX Power (Jam)',
            'offline_notification_enable': 'Notifikasi Perangkat Offline',
            'offline_notification_interval_hours': 'Interval Notifikasi Offline (Jam)',
            'offline_device_threshold_hours': 'Batas Waktu Offline (Jam)',
            'tax_settings.default_tax_rate': 'Tarif PPN (%)',
            'tax_settings.tax_name': 'Nama Pajak',
            'tax_settings.tax_enabled': 'Aktifkan PPN',
            'tax_settings.tax_inclusive': 'Harga Termasuk PPN'
        };
        return fieldLabels[key] || humanizeFieldKey(key);
    }

    // Field yang tidak perlu ditampilkan di form settings
    // Hanya menyembunyikan field teknis yang tidak perlu diubah di server baru
    const hiddenFields = [
        // Version Info - Tidak perlu diubah manual
        'app_version', 'version_name', 'version_date', 'version_notes', 'build_number',

        // Port server dikelola platform — disembunyikan agar tenant tidak mengubahnya
        'server_port',
        
        // Interval Settings (millisecond format) - hanya tampilkan format jam
        'rx_power_warning_interval', 'rxpower_recap_interval', 'offline_notification_interval',
        
        // Mode Autentikasi - sudah dialihkan ke /admin/radius
        'user_auth_mode',
        
        // Duplicate/Alternative Fields
        'pppoe_notifications.enabled', 'pppoe_notifications.loginNotifications', 
        'pppoe_notifications.logoutNotifications', 'pppoe_notifications.includeOfflineList',
        'pppoe_notifications.maxOfflineListCount', 'pppoe_notifications.monitorInterval',

        // WhatsApp automatic notification controls - dipusatkan di /admin/billing/whatsapp-monitoring
        'whatsapp_system_monitors',
        'pppoe_monitor_enable',
        'pppoe_monitor_interval_minutes',
        'whatsapp_keep_alive',
        'whatsapp_restart_on_error',
        'rx_power_notification_enable',
        'rx_power_warning_interval_hours',
        'rxpower_recap_enable',
        'rxpower_recap_interval_hours',
        'offline_notification_enable',
        'offline_notification_interval_hours',
        'offline_device_threshold_hours',
        
        // GenieACS Settings - Dikelola via /admin/genieacs-setting dan /admin/routers
        'genieacs_url', 'genieacs_username', 'genieacs_password',
        
        // Mikrotik Settings - Dikelola via /admin/routers
        'mikrotik_host', 'mikrotik_port', 'mikrotik_user', 'mikrotik_password', 'main_interface',
        
        // Voucher Cleanup Settings - Dikelola secara internal
        'voucher_cleanup.enabled',
        'voucher_cleanup.expiry_hours',
        'voucher_cleanup.delete_expired_invoices',
        'voucher_cleanup.log_cleanup_actions',
        'voucher_cleanup.cleanup_interval_hours',
        
        // WhatsApp Rate Limit Settings - Dikelola secara internal
        'whatsapp_rate_limit.maxMessagesPerBatch',
        'whatsapp_rate_limit.delayBetweenBatches',
        'whatsapp_rate_limit.delayBetweenMessages',
        'whatsapp_rate_limit.maxRetries',
        'whatsapp_rate_limit.dailyMessageLimit',
        'whatsapp_rate_limit.enabled',
        
        // Billing QR Filename - Dikelola via upload form QR penagihan
        'billing_qr_filename',
        
        // SMTP Settings - Dikelola via /admin/billing/email-settings
        'smtp_host',
        'smtp_port',
        'smtp_secure',
        'smtp_user',
        'smtp_password',
        'smtp_reject_unauthorized',
        'smtp_from_email',
        'smtp_from_name',
        
        // Wablas Settings - Dikelola via form Wablas WhatsApp Configuration
        'wablas_api_url',
        'wablas_enabled',
        'wablas_api_key',
        'wablas_secret_key',
        'wablas_device_id',
        'wablas_webhook_secret',
        'wablas_min_delay',
        'wablas_max_retries',
        'wablas_retry_delay',

        // Meta / Qontak WhatsApp API - dikelola di /admin/billing/whatsapp-settings
        'meta_whatsapp_access_token',
        'meta_whatsapp_app_secret',
        'meta_whatsapp_business_account_id',
        'meta_whatsapp_enabled',
        'meta_whatsapp_graph_api_url',
        'meta_whatsapp_phone_number_id',
        'meta_whatsapp_webhook_verify_token',
        'qontak_whatsapp_access_token',
        'qontak_whatsapp_api_url',
        'qontak_whatsapp_channel_integration_id',
        'qontak_whatsapp_enabled',
        'qontak_whatsapp_namespace',
        'qontak_whatsapp_webhook_secret',

        // Admin tambahan — hanya Nomor Admin Utama di pengaturan umum
        'admins.1',
        'admins.2',

        // Teknisi — dikelola di halaman teknisi / WhatsApp
        'technician_numbers.0',
        'technician_numbers.1',
        'technician_numbers.2',

        // Logo & branding — dikelola dari portal Management
        'logo_filename',
        'company_header',
        'app_name',
        'company_slogan',
        'company_website',
        'footer_info',

        // Isolir & suspension — dikelola di billing / routers / radius
        'isolir_profile',
        'auto_suspension_enabled',
        'auto_suspension_day',
        'suspension_grace_period_days',
        'static_ip_suspension_method',
        'suspension_bandwidth_limit',

        // RADIUS DB — dikelola di /admin/radius
        'radius_database',
        'radius_host',
        'radius_user',
        'radius_password'
    ];
    const hiddenPrefixes = [
        'whatsapp_',
        'whatsapp.',
        'meta_whatsapp_',
        'qontak_whatsapp_',
        'radius_',
        'technician_numbers.',
        'pppoe_notifications',
        'pppoe_monitor_',
        'baileys_',
        'wablas_',
        'rx_power_warning',
        'rx_power_critical',
        'rx_power_notification_',
        'rxpower_recap_',
        'offline_notification_',
        'offline_device_threshold_hours'
    ];

    /** Urutan tetap — hanya field ini di grup Sistem & Billing (sisanya ke grup lain). */
    const systemFieldOrder = [
        'server_host',
        'admin_username',
        'admin_password',
        'admin_session_timeout_minutes',
        'admins.0',
        'technician_group_id'
    ];
    const billingFieldOrder = [
        'payment_bank_name',
        'payment_account_holder',
        'payment_account_number',
        'payment_cash_address',
        'payment_cash_hours',
        'invoice_notes'
    ];
    const companyFieldOrder = [
        'company_header',
        'app_name',
        'company_slogan',
        'company_website',
        'company_address',
        'contact_phone',
        'contact_whatsapp',
        'contact_email',
        'contact_address',
        'footer_info'
    ];
    const portalFieldOrder = [
        'customerPortalOtp',
        'otp_length',
        'otp_expiry_minutes'
    ];
    const taxFieldOrder = [
        'tax_settings.tax_enabled',
        'tax_settings.tax_name',
        'tax_settings.default_tax_rate',
        'tax_settings.tax_inclusive'
    ];
    const troubleFieldOrder = [
        'trouble_report.enabled',
        'trouble_report.categories',
        'trouble_report.auto_ticket'
    ];
    const systemFieldSet = new Set(systemFieldOrder);
    const billingFieldSet = new Set(billingFieldOrder);

    // Keterangan khusus — hanya untuk hint di bawah input, bukan label duplikat
    function getFieldHint(key) {
        const hints = {
            'admin_session_timeout_minutes': 'Default 60 menit. Min 5, maks 1440.',
            'trouble_report.categories': 'Pisahkan dengan koma, contoh: Internet Lambat, WiFi Mati',
            'invoice_notes': 'Tampil di bagian bawah invoice/tagihan',
            'payment_cash_hours': 'Contoh: 08:00 - 16:00'
        };
        return hints[key] || '';
    }
    // Ambil data settings.json
    $.get('/admin/settings/data', function(data) {
        const groups = {
            system: { title: 'Sistem & Akses Admin', icon: 'bi-shield-lock', items: [] },
            company: { title: 'Perusahaan & Kontak', icon: 'bi-building', items: [] },
            billing: { title: 'Billing & Pembayaran', icon: 'bi-receipt', items: [] },
            tax: { title: 'Pajak', icon: 'bi-percent', items: [] },
            portal: { title: 'Portal Pelanggan & OTP', icon: 'bi-phone', items: [] },
            trouble: { title: 'Laporan Gangguan', icon: 'bi-ticket-detailed', items: [] },
            other: { title: 'Lainnya', icon: 'bi-sliders', items: [] }
        };
        const entries = [];

        function escapeHtml(value) {
            return String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function shouldHideField(key) {
            if (hiddenFields.includes(key)) return true;
            if (hiddenPrefixes.some(function(prefix) { return key === prefix || key.startsWith(prefix); })) return true;
            if (key.startsWith('whatsapp_daily_count.')) return true;
            if (key === 'user_auth_mode') return true;
            return false;
        }

        function flattenSetting(key, val) {
            if (shouldHideField(key)) return;
            if (typeof val === 'object' && val !== null) {
                Object.keys(val).forEach(function(subkey) {
                    flattenSetting(key + '.' + subkey, val[subkey]);
                });
                return;
            }
            entries.push({ key: key, val: val });
        }

        function getFieldGroup(key) {
            if (systemFieldSet.has(key)) return 'system';
            if (billingFieldSet.has(key)) return 'billing';
            if (key.startsWith('tax_settings.')) return 'tax';
            if (key.startsWith('trouble_report.')) return 'trouble';
            if (key.includes('otp') || key.includes('Otp') || key.includes('customerPortal')) return 'portal';
            if (key.startsWith('company_') || key.startsWith('contact_') || key === 'app_name' || key === 'footer_info') return 'company';
            return 'other';
        }

        function renderField(entry) {
            const key = entry.key;
            const val = entry.val;
            const fieldLabel = escapeHtml(getFieldLabel(key));
            const fieldHint = escapeHtml(getFieldHint(key));
            const value = escapeHtml(val);
            let fieldHtml = '<div class="mb-3">';
            fieldHtml += '<label class="form-label">' + fieldLabel + '</label>';

            if (typeof val === 'boolean' || val === true || val === false || val === 'true' || val === 'false') {
                const checked = (val === true || val === 'true') ? 'checked' : '';
                fieldHtml += '<div class="form-check">';
                fieldHtml += '<input class="form-check-input" type="checkbox" name="' + escapeHtml(key) + '" id="setting_' + escapeHtml(key) + '" ' + checked + '> ';
                fieldHtml += '<label class="form-check-label" for="setting_' + escapeHtml(key) + '">' + (checked ? 'Aktif' : 'Tidak Aktif') + '</label>';
                fieldHtml += '</div>';
            } else if (key === 'admin_session_timeout_minutes') {
                fieldHtml += '<input type="number" class="form-control" name="' + escapeHtml(key) + '" value="' + value + '" min="5" max="1440" step="1">';
                fieldHtml += '<div class="form-text text-muted">' + fieldHint + '</div>';
            } else if (key === 'suspension_grace_period_days') {
                fieldHtml += '<input type="number" class="form-control" name="' + escapeHtml(key) + '" value="' + value + '" min="1" max="365">';
            } else if (key === 'tax_settings.default_tax_rate') {
                fieldHtml += '<input type="number" class="form-control" name="' + escapeHtml(key) + '" value="' + value + '" step="0.01" min="0" max="100">';
            } else if (key.includes('password') || key.includes('Password')) {
                fieldHtml += '<input type="password" class="form-control" name="' + escapeHtml(key) + '" value="' + value + '" placeholder="Masukkan password">';
            } else if (key === 'invoice_notes') {
                fieldHtml += '<textarea class="form-control" name="' + escapeHtml(key) + '" rows="3">' + value + '</textarea>';
                if (fieldHint) {
                    fieldHtml += '<div class="form-text text-muted">' + fieldHint + '</div>';
                }
            } else {
                fieldHtml += '<input type="text" class="form-control" name="' + escapeHtml(key) + '" value="' + value + '">';
                if (fieldHint) {
                    fieldHtml += '<div class="form-text text-muted">' + fieldHint + '</div>';
                }
            }
            fieldHtml += '</div>';
            return fieldHtml;
        }

        Object.keys(data).forEach(function(key) {
            const dot = key.indexOf('.');
            if (dot > 0) {
                const parentKey = key.slice(0, dot);
                const parentVal = data[parentKey];
                if (parentVal && typeof parentVal === 'object' && !Array.isArray(parentVal)) {
                    return;
                }
            }
            flattenSetting(key, data[key]);
        });

        // Pastikan field billing selalu tampil meski belum pernah disimpan tenant
        billingFieldOrder.forEach(function(key) {
            if (!entries.some(function(e) { return e.key === key; })) {
                entries.push({ key: key, val: data[key] != null ? data[key] : '' });
            }
        });

        entries.sort(function(a, b) {
            const groupA = getFieldGroup(a.key);
            const groupB = getFieldGroup(b.key);
            if (groupA !== groupB) {
                return Object.keys(groups).indexOf(groupA) - Object.keys(groups).indexOf(groupB);
            }
            if (groupA === 'system') {
                return systemFieldOrder.indexOf(a.key) - systemFieldOrder.indexOf(b.key);
            }
            if (groupA === 'billing') {
                return billingFieldOrder.indexOf(a.key) - billingFieldOrder.indexOf(b.key);
            }
            if (groupA === 'company') {
                return companyFieldOrder.indexOf(a.key) - companyFieldOrder.indexOf(b.key);
            }
            if (groupA === 'portal') {
                return portalFieldOrder.indexOf(a.key) - portalFieldOrder.indexOf(b.key);
            }
            if (groupA === 'tax') {
                return taxFieldOrder.indexOf(a.key) - taxFieldOrder.indexOf(b.key);
            }
            if (groupA === 'trouble') {
                return troubleFieldOrder.indexOf(a.key) - troubleFieldOrder.indexOf(b.key);
            }
            return getFieldLabel(a.key).localeCompare(getFieldLabel(b.key), 'id');
        });
        entries.forEach(function(entry) {
            groups[getFieldGroup(entry.key)].items.push(renderField(entry));
        });
        const html = Object.keys(groups).filter(function(groupKey) {
            return groupKey !== 'billing' && groupKey !== 'other';
        }).map(function(groupKey) {
            const group = groups[groupKey];
            if (!group.items.length) return '';
            return '<div class="settings-group mb-4">' +
                '<div class="settings-group-title"><i class="bi ' + group.icon + ' me-1"></i>' + group.title + '</div>' +
                group.items.join('') +
                '</div>';
        }).join('');
        $('#settingsFields').html(html || '<div class="alert alert-info mb-0">Tidak ada pengaturan umum yang perlu ditampilkan.</div>');

        const billingGroup = groups.billing;
        const billingHtml = billingGroup.items.length
            ? billingGroup.items.join('')
            : '<p class="text-muted small mb-0">Tidak ada field billing yang dapat ditampilkan.</p>';
        $('#billingSettingsFields').html(billingHtml);
    });

    function showSettingsSaveMessage(type, message) {
        const alertClass = type === 'success' ? 'alert-success' : (type === 'warning' ? 'alert-warning' : 'alert-danger');
        ['#settingsSuccess', '#billingSettingsSuccess'].forEach(function(selector) {
            const $el = $(selector);
            $el.removeClass('d-none alert-success alert-warning alert-danger')
                .addClass(alertClass)
                .text(message);
        });
        if (type === 'success' || type === 'warning') {
            setTimeout(function() {
                ['#settingsSuccess', '#billingSettingsSuccess'].forEach(function(selector) {
                    $(selector).addClass('d-none').removeClass('alert-warning alert-danger');
                });
            }, 3000);
        } else {
            setTimeout(function() {
                ['#settingsSuccess', '#billingSettingsSuccess'].forEach(function(selector) {
                    $(selector).addClass('d-none').removeClass('alert-warning');
                });
            }, 5000);
        }
    }

    function setSettingsSaveButtonsLoading(loading) {
        const savingHtml = '<i class="bi bi-hourglass-split"></i> Menyimpan...';
        const defaultHtml = '<i class="bi bi-save"></i> Simpan Perubahan';
        $('#settingsForm button[type="submit"], #saveSettingsBtnBilling').each(function() {
            const $btn = $(this);
            if (loading) {
                if (!$btn.data('original-html')) {
                    $btn.data('original-html', $btn.html());
                }
                $btn.prop('disabled', true).html(savingHtml);
            } else {
                $btn.prop('disabled', false).html($btn.data('original-html') || defaultHtml);
            }
        });
    }

    function saveSettingsForm() {
        var formData = {};
        var hasChanges = false;

        $('#settingsForm, #billingSettingsFields').find('input[type=text],input[type=checkbox],input[type=number],input[type=password],textarea').each(function() {
            var name = $(this).attr('name');
            if (!name) return;

            let value;
            if ($(this).attr('type') === 'checkbox') {
                value = $(this).is(':checked');
            } else {
                value = $(this).val();
            }

            formData[name] = value;
            hasChanges = true;
        });

        $('#settingsForm, #billingSettingsFields').find('input[type=radio]:checked').each(function() {
            var name = $(this).attr('name');
            if (!name) return;
            formData[name] = $(this).val();
            hasChanges = true;
        });

        if (!hasChanges || Object.keys(formData).length === 0) {
            showSettingsSaveMessage('warning', 'Tidak ada perubahan untuk disimpan.');
            return;
        }

        setSettingsSaveButtonsLoading(true);

        $.ajax({
            url: '/admin/settings/save',
            method: 'POST',
            data: formData,
            timeout: 10000,
            success: function(res) {
                if (res.success) {
                    showSettingsSaveMessage('success', res.message || 'Pengaturan berhasil disimpan!');
                } else {
                    showSettingsSaveMessage('error', res.error || 'Gagal menyimpan pengaturan!');
                }
            },
            error: function(xhr, status) {
                let errorMsg = 'Gagal menyimpan pengaturan!';
                if (status === 'timeout') {
                    errorMsg = 'Request timeout. Silakan coba lagi.';
                } else if (xhr.responseJSON && xhr.responseJSON.error) {
                    errorMsg = xhr.responseJSON.error;
                } else if (xhr.status === 500) {
                    errorMsg = 'Terjadi kesalahan server. Silakan coba lagi.';
                } else if (xhr.status === 400) {
                    errorMsg = 'Data tidak valid. Silakan periksa input Anda.';
                } else if (xhr.status === 0) {
                    errorMsg = 'Tidak dapat terhubung ke server. Periksa koneksi Anda.';
                }
                showSettingsSaveMessage('error', errorMsg);
            },
            complete: function() {
                setSettingsSaveButtonsLoading(false);
            }
        });
    }

    // Submit form settings
    $('#settingsForm').on('submit', function(e) {
        e.preventDefault();
        saveSettingsForm();
    });

    $('#saveSettingsBtnBilling').on('click', function() {
        saveSettingsForm();
    });
    // WhatsApp QR & Status - Didefinisikan di scope global agar bisa diakses dari semua block
    window.loadWAStatus = function() {
        return $.ajax({
            url: '/admin/settings/wa-status',
            method: 'GET',
            dataType: 'json',
            success: function(res) {
                console.log('WA Status Response:', res); // Debug log
                
                // Update status koneksi
                if (res.connected) {
                    let statusHtml = '<span class="badge bg-success status-badge"><i class="bi bi-check-circle"></i> Terhubung';
                    if (res.phoneNumber) {
                        statusHtml += ` (${res.phoneNumber})`;
                    }
                    if (res.connectedSince) {
                        const connectedDate = new Date(res.connectedSince);
                        statusHtml += `<br><small>Terhubung sejak: ${connectedDate.toLocaleString()}</small>`;
                    }
                    statusHtml += '</span>';
                    $('#wa-status').html(statusHtml);
                    $('#wa-qr-container').addClass('d-none');
                } else {
                    $('#wa-status').html('<span class="badge bg-warning text-dark status-badge"><i class="bi bi-exclamation-triangle"></i> Belum Terhubung</span>');
                    
                    // Tampilkan QR code jika tersedia
                    if (res.qr) {
                        console.log('QR Code received, length:', res.qr.length);
                        $('#wa-qr-container').removeClass('d-none');
                        
                        // Hapus QR lama jika ada
                        $('#wa-qr').attr('src', '').hide();
                        const qrDiv = $('#wa-qr-div');
                        qrDiv.empty().show();
                        
                        // Cek apakah QRCode library sudah ter-load
                        if (typeof QRCode === 'undefined') {
                            console.error('QRCode library tidak ter-load!');
                            qrDiv.html(`
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle"></i> QRCode library tidak ter-load. 
                                    <br>Silakan refresh halaman atau cek koneksi internet.
                                </div>
                            `);
                        } else {
                            try {
                                // Coba buat QR code langsung
                                new QRCode(qrDiv[0], {
                                    text: res.qr,
                                    // QR WhatsApp cukup padat, gunakan ukuran lebih besar supaya mudah dipindai kamera.
                                    width: 320,
                                    height: 320,
                                    colorDark: '#000000',
                                    colorLight: '#ffffff',
                                    correctLevel: QRCode.CorrectLevel.M || 2
                                });
                                console.log('QR Code generated successfully');
                                $('#wa-status').append(`<div class="text-info small mt-2"><i class="bi bi-info-circle"></i> Scan dari WhatsApp > Perangkat tertaut. QR akan berubah otomatis tiap beberapa detik.</div>`);
                            } catch (e) {
                                console.error('Error generating QR code:', e);
                                // Fallback: tampilkan QR sebagai text atau image
                                qrDiv.html(`
                                    <div class="alert alert-info">
                                        <p><strong>QR Code tersedia</strong></p>
                                        <p class="small">Error: ${e.message}</p>
                                        <p class="small">Silakan gunakan tombol "Refresh QR" untuk mencoba lagi.</p>
                                    </div>
                                `);
                            }
                        }
                    } else {
                        console.log('No QR code received from server');
                        $('#wa-qr-container').addClass('d-none');
                        if (res.error) {
                            $('#wa-status').append(`<div class="alert alert-danger mt-2">${res.error}</div>`);
                        } else if (res.status === 'connecting' || res.status === 'qr_code') {
                            // Jika status connecting atau qr_code tapi QR belum ada, tampilkan pesan
                            $('#wa-status').append(`<div class="alert alert-info mt-2">
                                <i class="bi bi-hourglass-split"></i> Menunggu QR code... Silakan refresh dalam beberapa detik.
                            </div>`);
                        }
                    }
                }
            },
            error: function(xhr, status, error) {
                console.error('Error getting WhatsApp status:', error);
                const errorMsg = xhr.responseJSON && xhr.responseJSON.error ? xhr.responseJSON.error : error;
                $('#wa-status').html(`
                    <span class="badge bg-danger status-badge">
                        <i class="bi bi-x-circle"></i> Gagal memuat status
                    </span>
                    <div class="alert alert-danger mt-2">${errorMsg || 'Tidak dapat terhubung ke server'}</div>
                `);
                $('#wa-qr-container').addClass('d-none');
            }
        });
    };
    
    // Load WhatsApp status hanya jika Baileys enabled
    // loadWAStatus() akan dipanggil oleh toggleBaileysContent() saat enabled
    // Jangan panggil loadWAStatus() di sini karena akan dipanggil setelah toggleBaileysContent()
    
    let waRefreshPolling = null;
    $('#btnRefreshQR').on('click', function(e) {
        e.preventDefault();
        // Hanya refresh jika Baileys enabled
        if (!$('#baileys_enabled').is(':checked')) {
            showNotification('warning', 'Baileys belum diaktifkan. Centang "Enable Baileys" terlebih dahulu.');
            return;
        }
        const $btn = $(this);
        const originalHtml = $btn.html();
        $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Refreshing...');

        $.post('/admin/settings/wa-refresh')
            .done(function(resp) {
                showNotification('info', (resp && resp.message) || 'Sesi direset, menunggu QR code baru...');

                // Bersihkan polling lama jika ada
                if (waRefreshPolling) {
                    clearInterval(waRefreshPolling);
                    waRefreshPolling = null;
                }

                let attempts = 0;
                const maxAttempts = 4; // ~40 detik (tiap 10 detik)
                waRefreshPolling = setInterval(function() {
                    attempts += 1;
                    if (typeof window.loadWAStatus === 'function') {
                        window.loadWAStatus();
                    }
                    // Stop polling jika QR sudah muncul di container
                    const hasQrDom = $('#wa-qr-div canvas').length > 0 || $('#wa-qr-div img').length > 0;
                    if (hasQrDom || attempts >= maxAttempts) {
                        clearInterval(waRefreshPolling);
                        waRefreshPolling = null;
                        if (!hasQrDom && attempts >= maxAttempts) {
                            showNotification('warning', 'QR belum muncul. Coba refresh sekali lagi atau restart PM2.');
                        }
                    }
                }, 10000);
            })
            .fail(function(xhr) {
                const msg = (xhr.responseJSON && (xhr.responseJSON.error || xhr.responseJSON.message)) || 'Gagal refresh QR';
                showNotification('danger', msg);
            })
            .always(function() {
                $btn.prop('disabled', false).html(originalHtml);
            });
    });
    $('#btnDeleteSession').on('click', function(e) {
        e.preventDefault();
        // Hanya delete session jika Baileys enabled
        if ($('#baileys_enabled').is(':checked')) {
            if (confirm('Yakin hapus sesi WhatsApp?')) {
                $.post('/admin/settings/wa-delete', function() {
                    if (typeof window.loadWAStatus === 'function') {
                        window.loadWAStatus();
                    } else if (typeof loadWAStatus === 'function') {
                        loadWAStatus();
                    }
                });
            }
        }
    });
    // Auto refresh status tiap 10 detik (hanya jika Baileys enabled)
    let waStatusInterval = null;
    function startWAStatusInterval() {
        // Clear interval lama jika ada
        if (waStatusInterval) {
            clearInterval(waStatusInterval);
            waStatusInterval = null;
        }
        // Start interval baru hanya jika Baileys enabled
        if ($('#baileys_enabled').is(':checked')) {
            waStatusInterval = setInterval(function() {
                if ($('#baileys_enabled').is(':checked')) {
                    loadWAStatus();
                } else {
                    // Stop interval jika Baileys disabled
                    if (waStatusInterval) {
                        clearInterval(waStatusInterval);
                        waStatusInterval = null;
                    }
                }
            }, 10000);
        }
    }
    
    // Handler untuk baileys_enabled sudah ada di bagian Wablas handler
    // yang menangani save, toggle, dan interval
});
</script>
<script>
// Optical Splitter Attenuation Calculator Logic
$(function() {
    // Standar losses
    const fiberLossPerKm = 0.35;
    const connectorLoss = 0.5;
    const spliceLoss = 0.1;

    function calcAttenuation(N) {
        return +(10 * Math.log10(N)).toFixed(2);
    }
    function getTotalLoss() {
        const fiberLength = parseFloat($('#fiberLength').val()) || 0;
        const connectorCount = parseInt($('#connectorCount').val()) || 0;
        const spliceCount = parseInt($('#spliceCount').val()) || 0;
        const margin = parseFloat($('#margin').val()) || 0;
        return +(fiberLength * fiberLossPerKm + connectorCount * connectorLoss + spliceCount * spliceLoss + margin).toFixed(2);
    }
    function updateSplitterCalc() {
        const rxAwal = parseFloat($('#rxAwal').val());
        const ratio = parseInt($('#splitterRatio').val());
        if (isNaN(rxAwal) || isNaN(ratio)) {
            $('#splitterAttenuation').val('');
            $('#rxSetelahSplitter').val('');
            return false;
        }
        const att = calcAttenuation(ratio);
        const totalLoss = getTotalLoss();
        const rxAfter = +(rxAwal - att - totalLoss).toFixed(2);
        $('#splitterAttenuation').val((att + totalLoss).toFixed(2));
        $('#rxSetelahSplitter').val(rxAfter);
        return true;
    }
    function updateSplitterTable() {
        const rxAwal = parseFloat($('#rxAwal').val());
        const fiberLength = parseFloat($('#fiberLength').val()) || 0;
        const connectorCount = parseInt($('#connectorCount').val()) || 0;
        const spliceCount = parseInt($('#spliceCount').val()) || 0;
        const margin = parseFloat($('#margin').val()) || 0;
        const ratios = [2,4,8,16,32,64];
        let html = '';
        ratios.forEach(function(r) {
            const att = calcAttenuation(r);
            const totalLoss = fiberLength * fiberLossPerKm + connectorCount * connectorLoss + spliceCount * spliceLoss + margin;
            let rxAfter = '';
            if (!isNaN(rxAwal)) rxAfter = (rxAwal - att - totalLoss).toFixed(2);
            html += `<tr><td>1:${r}</td><td>${(att + totalLoss).toFixed(2)}</td><td>${rxAfter}</td></tr>`;
        });
        $('#splitterTableBody').html(html);
    }
    // Hide result section by default
    $('#splitterResultSection').hide();
    // Only generate on button click
    $('#generateSplitterResult').on('click', function() {
        const valid = updateSplitterCalc();
        if (valid) {
            updateSplitterTable();
            $('#splitterResultSection').slideDown();
        } else {
            $('#splitterResultSection').slideUp();
        }
    });
});
</script>
<script>
// Fungsi untuk download file
function downloadScript(filename, content) {
    const element = document.createElement('a');
    element.setAttribute('href', 'data:text/plain;charset=utf-8,' + encodeURIComponent(content));
    element.setAttribute('download', filename);
    element.style.display = 'none';
    document.body.appendChild(element);
    element.click();
    document.body.removeChild(element);
}

// VPS & MikroTik Configuration Generator
function generateVpsScript() {
    const vpsIp = $('#vpsPublicIp').val().trim();
    const vpsInterface = $('#vpsInterface').val().trim();
    const wgPort = $('#wgPort').val().trim();
    const vpsLocalIp = $('#vpsLocalIp').val().trim();
    const networkSubnet = $('#networkSubnet').val().trim();
    
    if (!vpsIp || !vpsInterface || !wgPort || !vpsLocalIp || !networkSubnet) {
        alert('Harap isi semua field yang diperlukan');
        return;
    }

    const script = `#!/bin/bash
# ===========================================
# Script Konfigurasi VPS untuk WireGuard
# ===========================================

# Update sistem
echo "Mengupdate sistem..."
sudo apt update && sudo apt upgrade -y

# Install paket yang diperlukan
echo "Menginstall paket yang diperlukan..."
sudo apt install -y wireguard net-tools iputils-ping

# Generate key
echo "Membuat kunci WireGuard..."
umask 077
wg genkey | sudo tee /etc/wireguard/private.key
sudo cat /etc/wireguard/private.key | wg pubkey | sudo tee /etc/wireguard/public.key

# Buat konfigurasi WireGuard
echo "Membuat konfigurasi WireGuard..."
sudo cat > /etc/wireguard/wg0.conf <<EOL
[Interface]
Address = ${vpsLocalIp}/24
SaveConfig = true
ListenPort = ${wgPort}
PrivateKey = $(sudo cat /etc/wireguard/private.key)
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o ${vpsInterface} -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o ${vpsInterface} -j MASQUERADE
EOL

# Aktifkan IP forwarding
echo "Mengaktifkan IP forwarding..."
echo "net.ipv4.ip_forward=1" | sudo tee -a /etc/sysctl.conf
sudo sysctl -p

# Konfigurasi firewall
echo "Mengkonfigurasi firewall..."
sudo ufw allow 22/tcp
sudo ufw allow ${wgPort}/udp

# Konfigurasi NAT untuk WireGuard
sudo sed -i '/^\*filter$/i *nat\n:POSTROUTING ACCEPT [0:0]\n-A POSTROUTING -s ${networkSubnet} -o ${vpsInterface} -j MASQUERADE\nCOMMIT\n' /etc/ufw/before.rules

# Aktifkan firewall
sudo ufw enable

# Start WireGuard
echo "Menjalankan WireGuard..."
sudo systemctl enable --now wg-quick@wg0

echo "\n==========================================="
echo "Konfigurasi VPS selesai!"
echo "Gunakan public key berikut untuk konfigurasi MikroTik:"
sudo cat /etc/wireguard/public.key
echo "\n==========================================="`;

    $('#generatedScript').text(script);
    return script;
}

function generateMikrotikScript() {
    const vpsIp = $('#vpsPublicIp').val().trim();
    const wgPort = $('#wgPort').val().trim();
    const mikrotikLocalIp = $('#mikrotikLocalIp').val().trim();
    const vpsLocalIp = $('#vpsLocalIp').val().trim();
    const networkSubnet = $('#networkSubnet').val().trim();
    
    if (!vpsIp || !wgPort || !mikrotikLocalIp || !vpsLocalIp || !networkSubnet) {
        alert('Harap isi semua field yang diperlukan');
        return;
    }

    const script = `# ===========================================
# Script Konfigurasi MikroTik untuk WireGuard
# ===========================================

# Generate key pair
:local privateKey ""
:local publicKey ""
/interface wireguard keypair \
    private-key=private.key public-key=public.key
:set privateKey [:parse [/file get private.key contents]]
:set publicKey [:parse [/file get public.key contents]]
/file remove public.key private.key

# Buat interface WireGuard
/interface wireguard add \
    name=wg-vps \
    private-key=$privateKey \
    listen-port=${wgPort}

# Tambahkan peer (VPS)
/interface wireguard peers add \
    interface=wg-vps \
    public-key="<MASUKKAN_PUBLIC_KEY_VPS>" \
    allowed-address=${vpsLocalIp}/32 \
    endpoint-address=${vpsIp} \
    endpoint-port=${wgPort}

# Atur IP lokal
/ip address add \
    address=${mikrotikLocalIp}/24 \
    interface=wg-vps

# Tambahkan rute ke VPS
/ip route add \
    dst-address=${vpsLocalIp}/32 \
    gateway=wg-vps

# Tambahkan rute ke jaringan lokal VPS (jika ada)
/ip route add \
    dst-address=${networkSubnet} \
    gateway=wg-vps

# Konfigurasi NAT (jika diperlukan)
/ip firewall nat add \
    chain=srcnat \
    out-interface=wg-vps \
    action=masquerade

# Konfigurasi DHCP Option 43 untuk GenieACS
:local genieAcsUrl "http://${vpsLocalIp}:7547"
:local urlHex [:pick [/tool fetch url="http://text-processing.com/encode/raw/" \
    http-method=post \
    http-data="text=$genieAcsUrl&encode=hex&charset=utf-8" \
    as-value output=user] 1]
:local urlLen [:len $urlHex]
:local option43 "01$[:pick $urlHex 0 2]$[:pick $urlHex 2 $urlLen]"

/ip dhcp-server option add name=opt43 code=43 value="0x$option43"
/ip dhcp-server network set numbers=0 dhcp-option=opt43

:put "==========================================="
:put "Konfigurasi MikroTik selesai!"
:put "Gunakan public key ini di VPS:"
:put $publicKey
:put "\n==========================================="`;

    $('#generatedScript').text(script);
    return script;
}

// Event Listeners
let currentVpsScript = '';
let currentMikrotikScript = '';
    
$('#generateVpsScript').on('click', function() {
    currentVpsScript = generateVpsScript();
    $('#downloadVpsScript').prop('disabled', false);
});
    
$('#generateMikrotikScript').on('click', function() {
    currentMikrotikScript = generateMikrotikScript();
    $('#downloadMikrotikScript').prop('disabled', false);
});
    
$('#downloadVpsScript').on('click', function() {
    if (currentVpsScript) {
        downloadScript('vps-wireguard-setup.sh', currentVpsScript);
    }
});
    
$('#downloadMikrotikScript').on('click', function() {
    if (currentMikrotikScript) {
        downloadScript('mikrotik-wireguard-setup.rsc', currentMikrotikScript);
    }
});
</script>
<script>
