// Wablas Configuration Handler
$(document).ready(function() {
    // Load Wablas settings
    $.get('/admin/settings/data', function(data) {
        if (data.wablas_enabled !== undefined) {
            $('#wablas_enabled').prop('checked', data.wablas_enabled === true || data.wablas_enabled === 'true');
        }
        if (data.wablas_api_url) $('#wablas_api_url').val(data.wablas_api_url);
        if (data.wablas_api_key) $('#wablas_api_key').val(data.wablas_api_key);
        if (data.wablas_secret_key) $('#wablas_secret_key').val(data.wablas_secret_key);
        if (data.wablas_device_id) $('#wablas_device_id').val(data.wablas_device_id);
        if (data.wablas_webhook_secret) $('#wablas_webhook_secret').val(data.wablas_webhook_secret);
        if (data.wablas_min_delay) $('#wablas_min_delay').val(data.wablas_min_delay);
        if (data.wablas_max_retries) $('#wablas_max_retries').val(data.wablas_max_retries);
        if (data.wablas_retry_delay) $('#wablas_retry_delay').val(data.wablas_retry_delay);
    });
    
    // Test Wablas Connection
    $('#btnTestWablas').on('click', function() {
        const btn = $(this);
        const originalText = btn.html();
        btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Testing...');
        
        const wablasData = {
            wablas_enabled: $('#wablas_enabled').is(':checked'),
            wablas_api_url: $('#wablas_api_url').val() || 'https://bdg.wablas.com',
            wablas_api_key: $('#wablas_api_key').val(),
            wablas_secret_key: $('#wablas_secret_key').val(),
            wablas_device_id: $('#wablas_device_id').val(),
            wablas_webhook_secret: $('#wablas_webhook_secret').val(),
            wablas_min_delay: parseInt($('#wablas_min_delay').val()) || 1000,
            wablas_max_retries: parseInt($('#wablas_max_retries').val()) || 3,
            wablas_retry_delay: parseInt($('#wablas_retry_delay').val()) || 2000
        };
        
        // Validate required fields
        if (!wablasData.wablas_api_key) {
            const resultDiv = $('#wablasTestResult');
            resultDiv.removeClass('d-none alert-success alert-info').addClass('alert-danger');
            resultDiv.html('<i class="bi bi-x-circle"></i> <strong>Error:</strong> Harap isi Wablas API Key terlebih dahulu');
            btn.prop('disabled', false).html(originalText);
            return;
        }
        
        // Save temporarily for test
        $.post('/admin/settings/save', wablasData, function(response) {
            if (response.success) {
                // Wait a moment for settings to be saved
                setTimeout(function() {
                    // Test connection
                    $.post('/admin/settings/test-wablas', {}, function(testResponse) {
                        const resultDiv = $('#wablasTestResult');
                        resultDiv.removeClass('d-none');
                        
                        if (testResponse.success) {
                            resultDiv.removeClass('alert-danger alert-info').addClass('alert-success');
                            resultDiv.html('<i class="bi bi-check-circle"></i> <strong>Wablas Connection Successful!</strong> ' + (testResponse.message || 'Wablas API siap digunakan.'));
                        } else {
                            resultDiv.removeClass('alert-success alert-info').addClass('alert-danger');
                            const errorMsg = testResponse.message || testResponse.error || 'Unknown error';
                            resultDiv.html('<i class="bi bi-x-circle"></i> <strong>Wablas Connection Failed:</strong> ' + errorMsg);
                        }
                    }).fail(function(xhr, status, error) {
                        const resultDiv = $('#wablasTestResult');
                        resultDiv.removeClass('d-none alert-success alert-info').addClass('alert-danger');
                        let errorMsg = 'Gagal menguji koneksi Wablas';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMsg = xhr.responseJSON.message;
                        } else if (xhr.responseText) {
                            try {
                                const errorData = JSON.parse(xhr.responseText);
                                errorMsg = errorData.message || errorMsg;
                            } catch (e) {
                                errorMsg = error || errorMsg;
                            }
                        }
                        resultDiv.html('<i class="bi bi-x-circle"></i> <strong>Error:</strong> ' + errorMsg);
                    });
                }, 500);
            } else {
                const resultDiv = $('#wablasTestResult');
                resultDiv.removeClass('d-none alert-success alert-info').addClass('alert-danger');
                resultDiv.html('<i class="bi bi-x-circle"></i> <strong>Error:</strong> ' + (response.message || 'Gagal menyimpan konfigurasi'));
            }
        }).fail(function(xhr, status, error) {
            const resultDiv = $('#wablasTestResult');
            resultDiv.removeClass('d-none alert-success alert-info').addClass('alert-danger');
            let errorMsg = 'Gagal menyimpan konfigurasi Wablas';
            if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMsg = xhr.responseJSON.message;
            }
            resultDiv.html('<i class="bi bi-x-circle"></i> <strong>Error:</strong> ' + errorMsg);
        }).always(function() {
            btn.prop('disabled', false).html(originalText);
        });
    });
    
    // Save Wablas Configuration
    $('#wablasForm').on('submit', function(e) {
        e.preventDefault();
        
        const btn = $(this).find('button[type="submit"]');
        const originalText = btn.html();
        btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Menyimpan...');
        
        const wablasData = {
            wablas_enabled: $('#wablas_enabled').is(':checked'),
            wablas_api_url: $('#wablas_api_url').val() || 'https://bdg.wablas.com',
            wablas_api_key: $('#wablas_api_key').val(),
            wablas_secret_key: $('#wablas_secret_key').val(),
            wablas_device_id: $('#wablas_device_id').val(),
            wablas_webhook_secret: $('#wablas_webhook_secret').val(),
            wablas_min_delay: parseInt($('#wablas_min_delay').val()) || 1000,
            wablas_max_retries: parseInt($('#wablas_max_retries').val()) || 3,
            wablas_retry_delay: parseInt($('#wablas_retry_delay').val()) || 2000
        };
        
        $.post('/admin/settings/save', wablasData, function(response) {
            if (response.success) {
                showNotification('success', 'Konfigurasi Wablas berhasil disimpan! ' + (wablasData.wablas_enabled ? 'Wablas sekarang aktif.' : 'Wablas dinonaktifkan, sistem akan menggunakan Baileys.'));
                // Toggle visibility Baileys section
                toggleBaileysSection();
            } else {
                showNotification('danger', 'Error: ' + (response.message || 'Gagal menyimpan konfigurasi'));
            }
        }).always(function() {
            btn.prop('disabled', false).html(originalText);
        });
    });
    
    // Toggle Baileys section berdasarkan Wablas enabled status
    function toggleBaileysSection() {
        const wablasEnabled = $('#wablas_enabled').is(':checked');
        // Baileys section sekarang ada di dalam kolom Wablas, jadi tetap tampilkan
        // tapi bisa ditambahkan logika lain jika diperlukan
        // if (wablasEnabled) {
        //     $('#baileysSection').hide();
        // } else {
        //     $('#baileysSection').show();
        // }
    }
    
    // Toggle Baileys Content (QR dan Status) berdasarkan Baileys enabled status
    function toggleBaileysContent() {
        const baileysEnabled = $('#baileys_enabled').is(':checked');
        console.log('toggleBaileysContent called, enabled:', baileysEnabled);
        if (baileysEnabled) {
            $('#baileysContent').show();
            console.log('Baileys content shown');
            // Load WhatsApp status jika enabled - gunakan window.loadWAStatus untuk memastikan akses
            if (typeof window.loadWAStatus === 'function') {
                console.log('Calling loadWAStatus...');
                window.loadWAStatus();
            } else if (typeof loadWAStatus === 'function') {
                console.log('Calling loadWAStatus (local scope)...');
                loadWAStatus();
            } else {
                console.error('loadWAStatus function not found! Available functions:', Object.keys(window).filter(k => k.includes('WA')));
                // Coba lagi setelah delay singkat
                setTimeout(function() {
                    if (typeof window.loadWAStatus === 'function') {
                        console.log('loadWAStatus found after delay, calling...');
                        window.loadWAStatus();
                    }
                }, 500);
            }
            // Start auto-refresh interval
            if (typeof startWAStatusInterval === 'function') {
                startWAStatusInterval();
            }
        } else {
            $('#baileysContent').hide();
            // Sembunyikan QR dan status saat disabled
            $('#wa-qr-container').addClass('d-none');
            $('#wa-status').empty();
            // Stop auto-refresh interval
            if (typeof waStatusInterval !== 'undefined' && waStatusInterval) {
                clearInterval(waStatusInterval);
                waStatusInterval = null;
            }
        }
    }
    
    // Save Baileys Enabled Setting
    $('#baileys_enabled').on('change', function() {
        const baileysEnabled = $(this).is(':checked');
        const baileysData = {
            baileys_enabled: baileysEnabled
        };
        
        $.post('/admin/settings/save', baileysData, function(response) {
            if (response.success) {
                showNotification('success', 'Pengaturan Baileys berhasil disimpan! ' + (baileysEnabled ? 'Baileys sekarang aktif.' : 'Baileys dinonaktifkan.'));
                toggleBaileysContent();
            } else {
                showNotification('danger', 'Error: ' + (response.message || 'Gagal menyimpan konfigurasi'));
                // Revert checkbox jika gagal
                $('#baileys_enabled').prop('checked', !baileysEnabled);
            }
        }).fail(function() {
            showNotification('danger', 'Error: Gagal menyimpan konfigurasi Baileys');
            // Revert checkbox jika gagal
            $('#baileys_enabled').prop('checked', !baileysEnabled);
        });
    });
    
    // Toggle saat checkbox Wablas diubah
    $('#wablas_enabled').on('change', function() {
        toggleBaileysSection();
    });
    
    // Load Baileys enabled setting saat page load
    $.get('/admin/settings/data', function(data) {
        if (data.baileys_enabled !== undefined) {
            $('#baileys_enabled').prop('checked', data.baileys_enabled === true || data.baileys_enabled === 'true');
        } else {
            // Default: disabled jika setting belum ada
            $('#baileys_enabled').prop('checked', false);
        }
        toggleBaileysContent();
    });
    
    // Set initial state saat page load
    $(document).ready(function() {
        toggleBaileysSection();
    });
});

</script>

