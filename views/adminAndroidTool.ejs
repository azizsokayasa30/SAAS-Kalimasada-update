<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/hard-reload') %>
    <meta charset="UTF-8">
    <title>Tool Android — Build Mobile</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        .main-content { padding: 28px 24px 48px; }
        .tool-card {
            border-radius: 14px;
            border: 1px solid var(--km-border, #e2e8f0);
            background: var(--panel-bg, #fff);
            box-shadow: var(--km-shadow-sm, 0 2px 8px rgba(15,23,42,.06));
            padding: 22px;
            margin-bottom: 20px;
        }
        .tool-card h5 { font-weight: 700; margin-bottom: 14px; }
        .log-console {
            background: #0f172a;
            color: #e2e8f0;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 12px;
            line-height: 1.45;
            border-radius: 10px;
            padding: 14px;
            max-height: 340px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .build-status-headline {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .build-status-headline.is-running { color: #1d4ed8; }
        .build-status-headline.is-success { color: #166534; }
        .build-status-headline.is-failed { color: #b91c1c; }
        .build-status-headline.is-idle { color: #64748b; }
        .build-progress-wrap { margin-bottom: 10px; }
        .build-progress-wrap .progress {
            height: 22px;
            border-radius: 11px;
            background: #e2e8f0;
            overflow: hidden;
        }
        .build-progress-wrap .progress-bar {
            font-size: 12px;
            font-weight: 700;
            transition: width 0.6s ease;
        }
        .build-progress-meta {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            font-size: 12px;
            color: #64748b;
            margin-top: 6px;
        }
        .build-spinner {
            width: 1rem;
            height: 1rem;
            border: 2px solid #93c5fd;
            border-top-color: #1d4ed8;
            border-radius: 50%;
            animation: build-spin 0.8s linear infinite;
        }
        @keyframes build-spin { to { transform: rotate(360deg); } }
        .apk-list { font-size: 13px; }
        .apk-list li { margin-bottom: 8px; display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
        .apk-list .apk-meta { flex: 1; min-width: 180px; }
        #buildDownloadRow { margin-top: 10px; }
    </style>
    <%- include('partials/theme-head') %>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <%- include('partials/admin-responsive-sidebar', { page: 'android-tool', settings: settings }) %>
        <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/admin/settings">Pengaturan</a></li>
                    <li class="breadcrumb-item active">Tool Android</li>
                </ol>
            </nav>
            <div class="mb-4">
                <h3 class="mb-1"><i class="bi bi-phone me-2 text-success"></i>Tool Android</h3>
                <p class="text-muted mb-0">Sesuaikan <code>.env</code>, versi, nama aplikasi, lalu build APK release ke <code>public/mobile-app/</code>.</p>
            </div>

            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Flutter SDK</strong> default: <code id="defaultFlutterPathHint">public/mobile-app/flutter-sdk/bin/flutter</code>
                (satu folder dengan APK OTA). Setelah build sukses, <code>manifest.json</code> dan APK di
                <code id="apkPublishDirHint">public/mobile-app/</code> diperbarui — pengguna app bisa update langsung dari dalam aplikasi.
                <span id="keystoreOkHint" class="d-none"><br><i class="bi bi-shield-check text-success me-1"></i>Keystore produksi aktif di <code>public/mobile-app/keystore/kalimasada.jks</code> — dipakai otomatis setiap build.</span>
            </div>
            <div id="keystoreAlert" class="alert alert-danger d-none mb-3"></div>

            <form id="androidToolForm">
                <div class="row g-3">
                    <div class="col-lg-6">
                        <div class="tool-card">
                            <h5><i class="bi bi-wifi text-primary me-2"></i>API & Environment</h5>
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="apiUrl">API_URL (.env)</label>
                                <input type="url" class="form-control" id="apiUrl" name="api_url" placeholder="http://103.132.40.18:30196" required>
                                <div class="form-text">Tanpa slash di akhir. Disalin ke API_URL, BILLING_API_URL, dan API_BASE_URL di <code>billing_kalimasada_mobile/.env</code>.</div>
                            </div>
                            <div class="mb-0">
                                <label class="form-label fw-semibold" for="flutterPath">Path Flutter SDK</label>
                                <input type="text" class="form-control" id="flutterPath" name="flutter_path" placeholder="public/mobile-app/flutter-sdk/bin/flutter">
                                <div class="form-text" id="flutterDetectHint">—</div>
                                <div class="form-text">Default di folder OTA (<code>public/mobile-app/flutter-sdk/</code>). Instalasi: lihat <code>public/mobile-app/FLUTTER-SDK-INSTALL.md</code> (hapus folder lama dulu jika clone gagal).</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="tool-card">
                            <h5><i class="bi bi-app-indicator text-success me-2"></i>Aplikasi & Versi</h5>
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="appName">Nama aplikasi (launcher)</label>
                                <input type="text" class="form-control" id="appName" name="app_name" maxlength="40" required>
                                <div class="form-text">Diubah di <code>AndroidManifest.xml</code> (<code>android:label</code>).</div>
                            </div>
                            <div class="row g-2">
                                <div class="col-7">
                                    <label class="form-label fw-semibold" for="versionName">Versi (nama)</label>
                                    <input type="text" class="form-control" id="versionName" name="version_name" placeholder="5.9.3" required>
                                </div>
                                <div class="col-5">
                                    <label class="form-label fw-semibold" for="versionCode">Build (+)</label>
                                    <input type="number" class="form-control" id="versionCode" name="version_code" min="1" step="1" required>
                                    <div class="form-text" id="versionCodeHint">Min. build untuk update OTA</div>
                                </div>
                            </div>
                            <div class="form-text mt-1">Disimpan ke <code>pubspec.yaml</code> sebagai <code>version: nama+build</code>.</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="tool-card">
                            <h5><i class="bi bi-cloud-upload text-warning me-2"></i>Publikasi & Catatan Rilis</h5>
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="releaseNotes">Catatan rilis</label>
                                <textarea class="form-control" id="releaseNotes" name="release_notes" rows="3" placeholder="Perbaikan bug, fitur baru…"></textarea>
                                <div class="form-text">Masuk ke <code>public/mobile-app/manifest.json</code> untuk auto-update di app.</div>
                            </div>
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="forceUpdate" name="force_update">
                                <label class="form-check-label" for="forceUpdate">Paksa update (force_update)</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    <button type="submit" class="btn btn-primary" id="btnSaveConfig">
                        <i class="bi bi-save me-1"></i>Simpan konfigurasi
                    </button>
                    <button type="button" class="btn btn-success" id="btnBuildApk">
                        <i class="bi bi-hammer me-1"></i>Build APK Release
                    </button>
                    <button type="button" class="btn btn-outline-danger" id="btnCancelBuild" disabled>
                        <i class="bi bi-x-circle me-1"></i>Batalkan build
                    </button>
                </div>
            </form>

            <div class="tool-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0"><i class="bi bi-terminal me-2"></i>Log build</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnClearLogView">Bersihkan tampilan</button>
                </div>

                <div id="buildProgressPanel" class="build-progress-wrap mb-3">
                    <div id="buildStatusHeadline" class="build-status-headline is-idle">
                        <i class="bi bi-hourglass-split"></i>
                        <span id="buildStatusText">Siap build aplikasi</span>
                    </div>
                    <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                        <div id="buildProgressBar" class="progress-bar bg-secondary" style="width:0%">0%</div>
                    </div>
                    <div class="build-progress-meta">
                        <span id="buildProgressPhase">Menunggu perintah build</span>
                        <span id="buildProgressEta">—</span>
                    </div>
                    <div id="buildDownloadRow" class="d-none">
                        <a id="btnDownloadLatestApk" class="btn btn-success btn-sm" href="#" download>
                            <i class="bi bi-download me-1"></i>Unduh APK hasil build
                        </a>
                        <span id="buildDownloadSize" class="text-muted small ms-2"></span>
                    </div>
                </div>

                <div id="buildLog" class="log-console text-muted">Belum ada log build.</div>
            </div>

            <div class="tool-card">
                <h5><i class="bi bi-archive me-2"></i>APK di server</h5>
                <ul id="apkList" class="apk-list mb-0 text-muted"><li>Memuat…</li></ul>
            </div>
        </main>
    </div>
</div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    var pollTimer = null;
    var tickTimer = null;
    var lastProgressPct = 0;
    var LS_BUILD_DURATION = 'android_build_duration_ms';
    var DEFAULT_BUILD_MS = 8 * 60 * 1000;

    function el(id) { return document.getElementById(id); }

    function formatDuration(ms) {
        var sec = Math.max(15, Math.round(ms / 1000));
        if (sec < 60) return sec + ' detik';
        var min = Math.max(1, Math.round(sec / 60));
        return min + ' menit';
    }

    function getStoredBuildDuration() {
        var n = parseInt(localStorage.getItem(LS_BUILD_DURATION) || '0', 10);
        return n > 60000 ? n : DEFAULT_BUILD_MS;
    }

    function storeBuildDuration(startedAt, finishedAt) {
        if (!startedAt || !finishedAt) return;
        var ms = new Date(finishedAt).getTime() - new Date(startedAt).getTime();
        if (ms > 60000 && ms < 60 * 60 * 1000) {
            localStorage.setItem(LS_BUILD_DURATION, String(ms));
        }
    }

    function calcProgressFromLogs(logs) {
        if (!logs || !logs.length) return { pct: 0, phase: 'Memulai…' };
        var text = logs.map(function (e) { return e.line || ''; }).join('\n');
        var pct = 3;
        var phase = 'Menyiapkan build';

        if (text.indexOf('flutter pub get') !== -1) { pct = 8; phase = 'flutter pub get'; }
        if (text.indexOf('Resolving dependencies') !== -1) { pct = 10; phase = 'Resolving dependencies'; }
        if (text.indexOf('Downloading packages') !== -1) { pct = 14; phase = 'Mengunduh paket'; }
        if (text.indexOf('Changed') !== -1 && text.indexOf('dependencies') !== -1) { pct = 18; phase = 'Dependensi siap'; }
        if (text.indexOf('flutter build apk') !== -1) { pct = 22; phase = 'flutter build apk --release'; }
        if (text.indexOf('Android SDK') !== -1) { pct = 26; phase = 'Menyiapkan Android SDK'; }
        if (text.indexOf('Running Gradle') !== -1) { pct = 35; phase = 'Gradle assembleRelease'; }

        var gradlePct = null;
        for (var i = logs.length - 1; i >= 0; i--) {
            var line = logs[i].line || '';
            if (line.indexOf('[') === -1) continue;
            var m = line.match(/(\d{1,3})%/);
            if (m) { gradlePct = Math.min(100, parseInt(m[1], 10)); break; }
        }
        if (gradlePct != null) {
            pct = 35 + Math.round(gradlePct * 0.55);
            phase = 'Kompilasi Gradle (' + gradlePct + '%)';
        }

        if (text.indexOf('tree-shaken') !== -1 || text.indexOf('Font asset') !== -1) {
            pct = Math.max(pct, 92);
            phase = 'Optimasi aset aplikasi';
        }
        if (text.indexOf('Built build/app/outputs') !== -1 || text.indexOf('✓ Built') !== -1) {
            pct = 97;
            phase = 'APK berhasil dikompilasi';
        }
        if (text.indexOf('Selesai. APK:') !== -1 || text.indexOf('OTA APK:') !== -1) {
            pct = 100;
            phase = 'Menyalin APK & memperbarui manifest OTA';
        }

        return { pct: Math.min(99, pct), phase: phase };
    }

    function calcEta(status, pct) {
        var totalEst = getStoredBuildDuration();
        if (!status || !status.started_at) {
            return 'Estimasi total: ~' + formatDuration(totalEst);
        }
        var elapsed = Date.now() - new Date(status.started_at).getTime();
        if (pct >= 98) return 'Hampir selesai…';
        if (pct <= 3) return 'Estimasi total: ~' + formatDuration(totalEst);
        var remaining = elapsed * (100 - pct) / Math.max(pct, 1);
        return 'Estimasi sisa: ~' + formatDuration(remaining);
    }

    function setBuildControls(status) {
        var s = (status || 'idle').toLowerCase();
        el('btnCancelBuild').disabled = s !== 'running';
        el('btnBuildApk').disabled = s === 'running';
    }

    function updateBuildProgress(status) {
        var data = status || {};
        var s = (data.status || 'idle').toLowerCase();
        var logs = data.logs || [];
        var headline = el('buildStatusHeadline');
        var statusText = el('buildStatusText');
        var bar = el('buildProgressBar');
        var phaseEl = el('buildProgressPhase');
        var etaEl = el('buildProgressEta');
        var pct = 0;
        var phase = 'Menunggu perintah build';
        var eta = '—';
        var barClass = 'progress-bar bg-secondary';
        var downloadRow = el('buildDownloadRow');

        if (s === 'success' && (data.apk_download_url || data.apk_url)) {
            var dlUrl = data.apk_download_url || data.apk_url;
            downloadRow.classList.remove('d-none');
            el('btnDownloadLatestApk').href = dlUrl;
            el('btnDownloadLatestApk').setAttribute('download', (dlUrl.split('/').pop() || 'kalimasada-mobile.apk'));
            el('buildDownloadSize').textContent = data.apk_size_mb
                ? ('(' + data.apk_size_mb + ' MB · universal arm/arm64/x86_64)')
                : '';
        } else {
            downloadRow.classList.add('d-none');
        }

        headline.className = 'build-status-headline is-' + (s === 'running' ? 'running' : s === 'success' ? 'success' : s === 'failed' ? 'failed' : 'idle');

        if (s === 'running') {
            var prog = calcProgressFromLogs(logs);
            pct = Math.max(lastProgressPct, prog.pct);
            lastProgressPct = pct;
            phase = prog.phase;
            eta = calcEta(data, pct);
            headline.innerHTML = '<span class="build-spinner"></span><span id="buildStatusText">Sedang build aplikasi…</span>';
            barClass = 'progress-bar progress-bar-striped progress-bar-animated bg-primary';
        } else if (s === 'success') {
            pct = 100;
            lastProgressPct = 0;
            storeBuildDuration(data.started_at, data.finished_at);
            var ver = (data.version || '') + (data.build_number ? '+' + data.build_number : '');
            var doneMsg = 'Build aplikasi selesai';
            if (ver) doneMsg += ' — versi ' + ver;
            headline.innerHTML = '<i class="bi bi-check-circle-fill"></i><span id="buildStatusText">' + doneMsg + '</span>';
            if (data.ota_apk_url) {
                phase = 'OTA aktif — pengguna dapat update dari aplikasi';
                eta = (data.finished_at ? new Date(data.finished_at).toLocaleString('id-ID') : 'Selesai') +
                    (data.ota_apk_url ? ' · APK siap' : '');
            } else {
                phase = 'APK siap diunduh';
                eta = data.finished_at ? new Date(data.finished_at).toLocaleString('id-ID') : 'Selesai';
            }
            barClass = 'progress-bar bg-success';
        } else if (s === 'failed') {
            pct = Math.max(lastProgressPct, 5);
            headline.innerHTML = '<i class="bi bi-x-circle-fill"></i><span id="buildStatusText">Build aplikasi gagal</span>';
            phase = data.error || 'Terjadi kesalahan saat build';
            eta = data.finished_at ? 'Gagal ' + new Date(data.finished_at).toLocaleString('id-ID') : 'Gagal';
            barClass = 'progress-bar bg-danger';
            lastProgressPct = 0;
        } else if (s === 'cancelled') {
            pct = lastProgressPct || 0;
            headline.innerHTML = '<i class="bi bi-slash-circle"></i><span id="buildStatusText">Build dibatalkan</span>';
            phase = 'Proses build dihentikan';
            eta = '—';
            barClass = 'progress-bar bg-warning';
            lastProgressPct = 0;
        } else {
            lastProgressPct = 0;
            headline.innerHTML = '<i class="bi bi-hourglass-split"></i><span id="buildStatusText">Siap build aplikasi</span>';
            phase = 'Menunggu perintah build';
            eta = 'Estimasi total: ~' + formatDuration(getStoredBuildDuration());
            barClass = 'progress-bar bg-secondary';
        }

        bar.className = barClass;
        bar.style.width = pct + '%';
        bar.textContent = pct + '%';
        bar.setAttribute('aria-valuenow', String(pct));
        phaseEl.textContent = phase;
        etaEl.textContent = eta;
        setBuildControls(s);
    }

    function startEtaTicker() {
        stopEtaTicker();
        tickTimer = setInterval(function () {
            if (lastStatusRef && lastStatusRef.status === 'running') {
                updateBuildProgress(lastStatusRef);
            }
        }, 1000);
    }

    function stopEtaTicker() {
        if (tickTimer) { clearInterval(tickTimer); tickTimer = null; }
    }

    var lastStatusRef = null;

    function renderLogs(logs) {
        var box = el('buildLog');
        if (!logs || !logs.length) {
            box.textContent = 'Belum ada log build.';
            box.classList.add('text-muted');
            return;
        }
        box.classList.remove('text-muted');
        box.textContent = logs.map(function (e) {
            var t = '';
            try { t = new Date(e.at).toLocaleTimeString('id-ID'); } catch (_) {}
            return '[' + t + '] ' + (e.line || '');
        }).join('\n');
        box.scrollTop = box.scrollHeight;
    }

    function renderApkList(files) {
        var ul = el('apkList');
        if (!files || !files.length) {
            ul.innerHTML = '<li class="text-muted">Belum ada APK di public/mobile-app/</li>';
            return;
        }
        ul.innerHTML = files.map(function (f) {
            var href = '/mobile-app/' + encodeURIComponent(f.name);
            return '<li>' +
                '<span class="apk-meta">' +
                '<strong>' + f.name + '</strong> — ' + f.size_mb + ' MB ' +
                '<span class="text-muted">(' + f.mtime + ')</span>' +
                '</span>' +
                '<a class="btn btn-sm btn-outline-success" href="' + href + '" download="' + f.name + '">' +
                '<i class="bi bi-download me-1"></i>Unduh</a>' +
                '</li>';
        }).join('');
    }

    function renderKeystoreStatus(ks) {
        var box = el('keystoreAlert');
        var okHint = el('keystoreOkHint');
        if (!ks || (ks.ready && ks.matches_production)) {
            box.classList.add('d-none');
            if (okHint) okHint.classList.toggle('d-none', !(ks && ks.ready && ks.matches_production));
            return;
        }
        if (okHint) okHint.classList.add('d-none');
        box.className = 'alert mb-3 ' + (ks.ready ? 'alert-warning' : 'alert-danger');
        box.textContent = ks.message || 'Keystore belum siap.';
        box.classList.remove('d-none');
    }

    function fillForm(data) {
        el('apiUrl').value = data.api_url || '';
        el('appName').value = data.app_name || '';
        el('versionName').value = data.version_name || '';
        el('versionCode').value = data.version_code || 1;
        el('releaseNotes').value = data.release_notes || '';
        el('forceUpdate').checked = !!data.force_update;
        el('flutterPath').value = data.flutter_path || data.flutter_path_default || '';
        if (data.flutter_path_default) {
            el('defaultFlutterPathHint').textContent = data.flutter_path_default.replace(/^.*public\//, 'public/');
        }
        if (data.apk_publish_dir) {
            el('apkPublishDirHint').textContent = data.apk_publish_dir.replace(/^.*public\//, 'public/') + '/';
        }
        var det = data.flutter_detected || {};
        var hint = det.exists
            ? 'Flutter terdeteksi: ' + det.path
            : 'Flutter belum terdeteksi di folder OTA — pasang SDK ke path default di atas atau isi path lain.';
        el('flutterDetectHint').textContent = hint;
        if (data.min_build_number) {
            el('versionCode').min = data.min_build_number;
            el('versionCodeHint').textContent = 'Minimal ' + data.min_build_number + ' untuk update dari app 5.9.2+91';
            if (parseInt(el('versionCode').value, 10) < data.min_build_number) {
                el('versionCode').value = data.min_build_number;
            }
        }
        renderKeystoreStatus(data.keystore);
        renderApkList(data.latest_apk_files);
    }

    function formPayload() {
        return {
            api_url: el('apiUrl').value.trim(),
            app_name: el('appName').value.trim(),
            version_name: el('versionName').value.trim(),
            version_code: parseInt(el('versionCode').value, 10) || 1,
            release_notes: el('releaseNotes').value.trim(),
            force_update: el('forceUpdate').checked,
            flutter_path: el('flutterPath').value.trim()
        };
    }

    async function loadConfig() {
        var r = await fetch('/admin/settings/api/android-tool/config');
        var j = await r.json();
        if (!j.success) throw new Error(j.message || 'Gagal memuat');
        fillForm(j.data || {});
    }

    async function pollStatus() {
        try {
            var r = await fetch('/admin/settings/api/android-tool/build-status');
            var j = await r.json();
            if (j.success && j.data) {
                lastStatusRef = j.data;
                updateBuildProgress(j.data);
                renderLogs(j.data.logs);
                if (j.data.status === 'running') {
                    startEtaTicker();
                    if (!pollTimer) pollTimer = setInterval(pollStatus, 2500);
                } else {
                    stopEtaTicker();
                    if (pollTimer) {
                        clearInterval(pollTimer);
                        pollTimer = null;
                        loadConfig();
                    }
                }
            }
        } catch (_) {}
    }

    el('androidToolForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        try {
            var r = await fetch('/admin/settings/api/android-tool/config', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formPayload())
            });
            var j = await r.json();
            alert(j.message || (j.success ? 'Tersimpan' : 'Gagal'));
            if (j.success) loadConfig();
        } catch (err) {
            alert('Error: ' + err.message);
        }
    });

    el('btnBuildApk').addEventListener('click', async function () {
        if (!confirm('Mulai build APK release? Proses bisa memakan beberapa menit.')) return;
        try {
            var r = await fetch('/admin/settings/api/android-tool/build', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formPayload())
            });
            var j = await r.json();
            if (!j.success) {
                alert(j.message || 'Gagal memulai build');
                return;
            }
            lastProgressPct = 0;
            updateBuildProgress({ status: 'running', started_at: new Date().toISOString(), logs: [] });
            pollStatus();
            if (!pollTimer) pollTimer = setInterval(pollStatus, 2500);
        } catch (err) {
            alert('Error: ' + err.message);
        }
    });

    el('btnCancelBuild').addEventListener('click', async function () {
        await fetch('/admin/settings/api/android-tool/build-cancel', { method: 'POST' });
        pollStatus();
    });

    el('btnClearLogView').addEventListener('click', function () {
        el('buildLog').textContent = '';
        el('buildLog').classList.add('text-muted');
    });

    loadConfig().then(pollStatus).catch(function (e) { alert(e.message); });
})();
</script>
</body>
</html>
