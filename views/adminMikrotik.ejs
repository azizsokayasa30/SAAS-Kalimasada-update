<!-- Halaman Tab Mikrotik: List User PPPoE -->
<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/hard-reload') %>
    <meta charset="UTF-8">
    <title>Admin PPPoE</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    
    <link href="/css/theme.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/responsive/2.5.0/css/dataTables.responsive.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        body { background: #f5f6fa; }
        .form-label { font-weight: 600; }

        .main-content {
            padding: 32px 24px;
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }
        .dataTables_wrapper .dataTables_filter input {
            border-radius: 6px;
            border: 1px solid #ccc;
            padding: 4px 10px;
        }
        .pppoe-toolbar-filters {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.5rem;
            justify-content: flex-end;
        }
        .pppoe-toolbar-filters .form-select {
            min-width: 180px;
            max-width: 260px;
        }
        @media (max-width: 767.98px) {
            .pppoe-toolbar-filters {
                justify-content: flex-start;
                margin-top: 0.75rem;
            }
            .pppoe-toolbar-filters .form-select {
                max-width: 100%;
                width: 100%;
            }
        }
        /* Mobile responsive table styles */
        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
        @media (max-width: 768px) {
            .table td, .table th {
                white-space: nowrap;
                min-width: 100px;
            }
            .table .btn {
                padding: 0.25rem 0.5rem;
                font-size: 0.75rem;
            }
        }
        /* Modern Metric Cards Styling - Like Image 2 */
        .metric-card {
            border-radius: 12px;
            padding: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.06);
            transition: all 0.3s ease;
            border: none;
            position: relative;
            overflow: hidden;
            background: var(--card-bg-color);
            color: #ffffff;
            min-height: auto;
        }
        .metric-card.stat-filter-card {
            cursor: pointer;
        }
        .metric-card.stat-filter-card.is-selected {
            outline: 2px solid rgba(255, 255, 255, 0.85);
            outline-offset: -2px;
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.25), 0 10px 15px rgba(0, 0, 0, 0.2);
        }
        
        .metric-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.2), 0 4px 6px rgba(0, 0, 0, 0.15);
        }
        
        .metric-card-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 8px;
            background: rgba(255, 255, 255, 0.2);
            color: #ffffff;
            font-size: 20px;
            backdrop-filter: blur(10px);
        }
        
        .metric-card-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: #ffffff;
            margin: 6px 0;
            line-height: 1.2;
        }
        
        .metric-card-label {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.9);
            font-weight: 500;
            margin-top: 2px;
        }
        
        .metric-card-subtext {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.8);
            margin-top: 4px;
        }
        
        /* Card Colors - Solid Backgrounds like Image 2 */
        .metric-card-primary {
            --card-bg-color: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        }
        
        .metric-card-success {
            --card-bg-color: linear-gradient(135deg, #10b981 0%, #34d399 100%);
            background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
        }
        
        .metric-card-danger {
            --card-bg-color: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
            background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
        }
        
        .metric-card-info {
            --card-bg-color: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
            background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
        }
        
        .metric-card-warning {
            --card-bg-color: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
            background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        }
        
        .metric-card-pink {
            --card-bg-color: linear-gradient(135deg, #ec4899 0%, #f472b6 100%);
            background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%);
        }
        
        .metric-card-teal {
            --card-bg-color: linear-gradient(135deg, #14b8a6 0%, #5eead4 100%);
            background: linear-gradient(135deg, #14b8a6 0%, #5eead4 100%);
        }
        .spin {
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        /* Mobile responsive fixes */
        @media (max-width: 767.98px) {
            .main-content {
                margin-top: 70px !important; /* Extra space for mobile navbar */
                padding-top: 10px !important;
                z-index: 1;
            }
            .card {
                z-index: 1;
            }
            /* Pastikan cards tidak overlap dengan mobile navbar */
            .row.mb-4:first-of-type {
                margin-top: 10px;
            }
            /* Responsive notification positioning */
            #restartNotif {
                top: 80px !important; /* Below mobile navbar */
                right: 10px !important;
                left: 10px !important;
                width: auto !important;
            }
        }

        /* Fix light theme: modal tambah/edit PPPoE user tidak transparan */
        [data-theme="light"] #userModal .modal-content,
        [data-theme="light"] #userModal .modal-body,
        [data-theme="light"] #userModal .modal-header,
        [data-theme="light"] #userModal .modal-footer,
        [data-theme="light"] #restartMikrotikModal .modal-content,
        [data-theme="light"] #restartMikrotikModal .modal-body,
        [data-theme="light"] #restartMikrotikModal .modal-header,
        [data-theme="light"] #restartMikrotikModal .modal-footer {
            background-color: #ffffff !important;
            color: #0f172a !important;
        }
        [data-theme="light"] #userModal .modal-content,
        [data-theme="light"] #restartMikrotikModal .modal-content {
            border: 1px solid #dee2e6 !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
        }
    </style>

    <%- include('partials/theme-head') %>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <!-- Include Responsive Admin Sidebar -->
        <%- include('partials/admin-responsive-sidebar', { page: 'mikrotik', settings: settings }) %>
        
        <main class="col-md-10 main-content ms-sm-auto">

            <h3 class="mb-4">Daftar User PPPoE Mikrotik</h3>
            <% const _stats = typeof userStats !== 'undefined' ? userStats : { totalUsers: 0, activeUsers: 0, offlineUsers: 0, profileCount: 0 }; %>
            <!-- Statistik User PPPoE -->
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="metric-card metric-card-primary stat-filter-card" data-filter="all" title="Klik untuk tampilkan semua user">
                        <div class="metric-card-icon">
                            <i class="bi bi-people"></i>
                        </div>
                        <div class="metric-card-value" id="totalUsers"><%= _stats.totalUsers %></div>
                        <div class="metric-card-label">Total User PPPoE</div>
                        <div class="metric-card-subtext">Klik untuk tampilkan semua</div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="metric-card metric-card-success stat-filter-card" data-filter="active" title="Klik untuk filter user aktif">
                        <div class="metric-card-icon">
                            <i class="bi bi-person-check"></i>
                        </div>
                        <div class="metric-card-value" id="activeUsers"><%= _stats.activeUsers %></div>
                        <div class="metric-card-label">User Aktif</div>
                        <div class="metric-card-subtext">Klik untuk filter user aktif</div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="metric-card metric-card-danger stat-filter-card" data-filter="offline" title="Klik untuk filter user offline">
                        <div class="metric-card-icon">
                            <i class="bi bi-person-x"></i>
                        </div>
                        <div class="metric-card-value" id="offlineUsers"><%= _stats.offlineUsers %></div>
                        <div class="metric-card-label">User Offline</div>
                        <div class="metric-card-subtext">Klik untuk filter user offline</div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="metric-card metric-card-info stat-filter-card" data-filter="profiles" title="Klik untuk buka menu profile PPPoE">
                        <div class="metric-card-icon">
                            <i class="bi bi-sliders"></i>
                        </div>
                        <div class="metric-card-value" id="profileCount"><%= _stats.profileCount %></div>
                        <div class="metric-card-label">Total Profile</div>
                        <div class="metric-card-subtext">Klik untuk buka list profile</div>
                    </div>
                </div>
            </div>
            
            <div class="row mb-3 align-items-center">
                <div class="col-md-6">
                    <button class="btn btn-primary" id="btnTambahUser">Tambah User PPPoE</button>
                    <a class="btn btn-outline-success ms-2" id="btnExportUsers" href="/admin/mikrotik/export-pppoe-users">
                        <i class="bi bi-file-earmark-excel"></i> Export Excel
                    </a>
                    <button class="btn btn-outline-primary ms-2" id="btnImportUsers" type="button">
                        <i class="bi bi-upload"></i> Import Excel
                    </button>
                    <button class="btn btn-outline-secondary ms-2" id="btnRefreshStats">
                        <i class="bi bi-arrow-clockwise"></i> Refresh Stats
                    </button>
                    <button class="btn btn-outline-warning ms-2" id="fixPppoeProfilesFromPackagesBtn" type="button" title="Remap paket tenant + update billing + assign profil RADIUS">
                        <i class="bi bi-tools"></i> Perbaiki Profil dari Paket
                    </button>
                </div>
                <div class="col-md-6">
                    <div class="pppoe-toolbar-filters">
                        <label for="filterProfile" class="form-label mb-0 text-nowrap">
                            <i class="bi bi-funnel me-1"></i>Filter Profile
                        </label>
                        <select id="filterProfile" class="form-select form-select-sm" aria-label="Filter Profile">
                            <option value="">Semua Profile</option>
                        </select>
                    </div>
                </div>
            </div>
  <div class="table-responsive">
    <table class="table table-bordered table-hover" id="pppoeTable" style="width:100%">
      <thead class="table-light">
        <tr>
          <th>No</th>
          <th>Username</th>
          <th>Password</th>
          <th>Profile</th>
          <th>Status</th>
          <% if (typeof authMode === 'undefined' || authMode !== 'radius') { %>
          <th>NAS</th>
          <% } %>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(user, i) { %>
        <tr>
          <td><%= i+1 %></td>
          <td>
            <%= user.name %>
            <% if (user.missing_radius) { %>
              <div class="small text-warning">Belum ada di RADIUS</div>
            <% } %>
          </td>
          <td><%= user.password %></td>
          <td><%= user.profile_display || user.profile %></td>
          <td>
            <% if (user.active) { %>
              <span class="badge rounded-pill bg-success">Aktif</span>
            <% } else { %>
              <span class="badge rounded-pill bg-danger">Offline</span>
            <% } %>
          </td>
          <% if (typeof authMode === 'undefined' || authMode !== 'radius') { %>
          <td><%= (user.nas_name || '') %> <small class="text-muted"><%= user.nas_ip || '' %></small></td>
          <% } %>
          <td>
            <button class="btn btn-sm btn-warning edit-user-btn me-1 mb-1" data-id="<%= user.id %>" data-username="<%= user.name %>" data-password="<%= user.password %>" data-profile="<%= user.profile %>"><i class="bi bi-pencil"></i> Edit</button>
            <button class="btn btn-sm btn-danger delete-user-btn me-1 mb-1" data-id="<%= user.id %>" data-username="<%= user.name %>"><i class="bi bi-trash"></i> Hapus</button>
            <% if (user.active) { %>
            <button class="btn btn-sm btn-info disconnect-session-btn mb-1" data-username="<%= user.name %>"><i class="bi bi-x-circle"></i> Putuskan Sesi</button>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal Tambah/Edit User PPPoE -->
<div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <form id="userForm">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="userModalLabel">Tambah/Edit User PPPoE</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="userId" name="id">
          
          <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
          <div class="alert alert-info mb-3">
            <i class="bi bi-info-circle me-2"></i>
            <strong>Mode RADIUS Aktif:</strong> User akan disimpan ke database RADIUS di tabel <code>radcheck</code> dan <code>radusergroup</code>.
          </div>
          <% } else { %>
          <div class="mb-3">
            <label for="router_id" class="form-label"><i class="bi bi-router me-1"></i>NAS (Router) *</label>
            <select class="form-select" id="router_id" name="router_id" required>
              <option value="">Pilih NAS</option>
              <% (routers||[]).forEach(function(r){ %>
                <option value="<%= r.id %>"><%= r.name %> (<%= r.nas_ip %>)</option>
              <% }) %>
            </select>
            <small class="text-muted">Pilih NAS (router) tempat user akan dibuat</small>
          </div>
          <% } %>
          
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" class="form-control" id="username" name="username" required>
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input type="text" class="form-control" id="password" name="password" required>
          </div>
          <div class="mb-3">
            <label for="profile" class="form-label">Profile</label>
            <select class="form-select" id="profile" name="profile" required>
              <option value="">Pilih Profile</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Modal Import User PPPoE -->
<div class="modal fade" id="importUsersModal" tabindex="-1" aria-labelledby="importUsersModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="importUsersModalLabel">
          <i class="bi bi-upload me-1"></i> Import User PPPoE dari Excel
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <a href="/admin/mikrotik/import-pppoe-users/template" class="btn btn-outline-success btn-sm">
            <i class="bi bi-download me-1"></i> Unduh Template Excel
          </a>
          <small class="text-muted d-block mt-2">
            Kolom wajib: <strong>Username</strong>, <strong>Password</strong>. Opsional: <strong>Profile</strong>.
            User yang sudah ada akan diperbarui (password/profile).
          </small>
        </div>
        <% if (typeof authMode === 'undefined' || authMode !== 'radius') { %>
        <div class="mb-3">
          <label for="importRouterId" class="form-label">NAS (Router) *</label>
          <select class="form-select" id="importRouterId">
            <option value="">Pilih NAS</option>
            <% (routers||[]).forEach(function(r){ %>
              <option value="<%= r.id %>"><%= r.name %> (<%= r.nas_ip %>)</option>
            <% }) %>
          </select>
        </div>
        <% } %>
        <div class="mb-0">
          <label for="importUsersFile" class="form-label">File Excel (.xlsx)</label>
          <input type="file" class="form-control" id="importUsersFile"
            accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet">
        </div>
        <div id="importUsersResult" class="alert mt-3 d-none" role="alert"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="button" class="btn btn-primary" id="btnSubmitImportUsers">
          <i class="bi bi-upload me-1"></i> Import
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Konfirmasi Restart Mikrotik -->
<div class="modal fade" id="restartMikrotikModal" tabindex="-1" aria-labelledby="restartMikrotikModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="restartMikrotikModalLabel"><i class="bi bi-arrow-repeat"></i> Konfirmasi Restart Mikrotik</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Apakah Anda yakin ingin <b>restart Mikrotik</b>?<br>Router akan reboot dan koneksi internet pelanggan akan terputus sementara.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="button" class="btn btn-danger" id="confirmRestartMikrotik">Restart</button>
      </div>
    </div>
  </div>
</div>
<!-- Notifikasi -->
<div id="restartNotif" class="alert d-none position-fixed top-0 end-0 m-4" style="z-index:1055; min-width:300px;"></div>
<!-- Wajib: jQuery & Bootstrap JS agar fitur tombol aktif -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/sweetalert-helper.js"></script>
<script src="/js/adminMikrotikTable.js"></script>
<script>
// Helper function untuk show toast notification
function showToast(type, message, duration) {
  duration = duration || 3000;
  let toastClass = 'bg-success';
  if (type === 'error') {
    toastClass = 'bg-danger';
  } else if (type === 'warning') {
    toastClass = 'bg-warning';
  } else if (type === 'info') {
    toastClass = 'bg-info';
  }
  const toast = `
    <div class="toast align-items-center text-white ${toastClass} border-0" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;">
      <div class="d-flex">
        <div class="toast-body">${message}</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  `;
  const $toast = $(toast);
  $('body').append($toast);
  const bsToast = new bootstrap.Toast($toast[0], { delay: duration });
  bsToast.show();
  $toast.on('hidden.bs.toast', function() {
    $(this).remove();
  });
}

$(function() {
  const PROFILE_COL = 3;
  const STATUS_COL = 4;

  function getPppoeTable() {
    const $table = $('#pppoeTable');
    if (!$table.length || !$.fn.DataTable || !$.fn.DataTable.isDataTable('#pppoeTable')) return null;
    return $table.DataTable();
  }

  function setActiveFilterCard(filterKey) {
    $('.stat-filter-card').removeClass('is-selected');
    $(`.stat-filter-card[data-filter="${filterKey}"]`).addClass('is-selected');
  }

  function applyProfileFilter(table, profileValue) {
    if (!table) return;
    if (profileValue) {
      const escaped = $.fn.dataTable.util.escapeRegex(profileValue);
      table.column(PROFILE_COL).search('^' + escaped + '$', true, false);
    } else {
      table.column(PROFILE_COL).search('');
    }
  }

  function populateProfileFilter(table) {
    const $select = $('#filterProfile');
    if (!$select.length || !table) return;

    const profiles = new Set();
    table.column(PROFILE_COL, { search: 'none' }).data().each(function(value) {
      const name = String(value || '').trim();
      if (name) profiles.add(name);
    });

    const current = $select.val() || '';
    $select.find('option:not(:first)').remove();
    Array.from(profiles).sort(function(a, b) {
      return a.localeCompare(b, 'id', { sensitivity: 'base' });
    }).forEach(function(name) {
      $select.append($('<option></option>').attr('value', name).text(name));
    });

    if (current && profiles.has(current)) {
      $select.val(current);
    } else {
      $select.val('');
    }
  }

  function filterUsersByCard(filterKey) {
    if (filterKey === 'profiles') {
      window.location.href = '/admin/mikrotik/profiles';
      return;
    }

    const table = getPppoeTable();
    if (!table) return;

    // Hanya ubah filter status; biarkan pencarian username & filter profile tetap
    if (filterKey === 'active') {
      table.column(STATUS_COL).search('^Aktif$', true, false).draw();
    } else if (filterKey === 'offline') {
      table.column(STATUS_COL).search('^Offline$', true, false).draw();
    } else {
      table.column(STATUS_COL).search('').draw();
    }

    setActiveFilterCard(filterKey);
  }

  $(document).on('click', '.stat-filter-card', function() {
    const filterKey = $(this).data('filter') || 'all';
    filterUsersByCard(filterKey);
  });

  $('#filterProfile').on('change', function() {
    const table = getPppoeTable();
    if (!table) return;
    applyProfileFilter(table, $(this).val());
    table.draw();
  });

  // Default state: tampilkan semua user + isi opsi filter profile
  setActiveFilterCard('all');
  const pppoeTable = getPppoeTable();
  if (pppoeTable) {
    populateProfileFilter(pppoeTable);
  }

  // Load profiles ke select
  function loadProfiles(selectedProfile) {
    const isRadiusMode = <%= typeof authMode !== 'undefined' && authMode === 'radius' ? 'true' : 'false' %>;
    
    $.get('/admin/mikrotik/profiles/api?include_assigned=1', function(res) {
      if(res.success) {
        var $profile = $('#profile');
        $profile.empty();
        $profile.append('<option value="">Pilih Profile</option>');
        
        if (res.profiles && res.profiles.length > 0) {
          res.profiles.forEach(function(p) {
            // Value = groupname RADIUS (radusergroup), bukan label/metadata — agar cocok dengan kolom Profile di tabel.
            var val = (p.groupname || p['.id'] || '').toString().trim();
            if (!val) return;
            var display = (p.name || val).toString();
            if (p.name && val && String(p.name).trim() !== val) {
              display = String(p.name).trim() + ' — ' + val;
            }
            $profile.append($('<option></option>').attr('value', val).text(display));
          });
          if (selectedProfile) {
            var sp = String(selectedProfile).trim();
            $profile.val(sp);
            if ($profile.val() !== sp && sp) {
              $profile.append(
                $('<option></option>')
                  .attr('value', sp)
                  .text(sp + ' (sinkronkan radgroupreply / paket)')
              );
              $profile.val(sp);
            }
          }
          
          // Update profile count in statistics card
          $('#profileCount').text(res.profiles.length);
        } else {
          // No profiles found, show message
          if (res.message) {
            console.warn('Profile API warning:', res.message);
            // Show toast notification instead of blocking alert
            showToast('warning', res.message, 5000);
          }
          $('#profileCount').text('0');
        }
      } else {
        // Legacy error handling (should not happen with new API)
        console.error('Profile API error:', res.message || 'Unknown error');
        showToast('error', 'Gagal ambil daftar profile PPPoE: ' + (res.message || 'Unknown error'), 5000);
      }
    }).fail(function(xhr, status, error) {
      console.error('Profile API request failed:', error);
      showToast('error', 'Gagal mengambil daftar profile PPPoE. Pastikan router dapat diakses.', 5000);
      $('#profileCount').text('0');
    });
  }
  
  // Tambah User
  $('#btnTambahUser').on('click', function() {
    const isRadiusMode = <%= typeof authMode !== 'undefined' && authMode === 'radius' ? 'true' : 'false' %>;
    
    $('#userId').val('');
    $('#username').val('');
    $('#password').val('');
    $('#profile').val(''); // Reset profile selection
    
    // Load profiles fresh when opening modal
    loadProfiles();
    
    $('#userModalLabel').text('Tambah User PPPoE');
    $('#userModal').modal('show');
    
    // Hide router selection in RADIUS mode
    if (isRadiusMode) {
      $('#router_id').closest('.mb-3').hide();
      $('#router_id').removeAttr('required'); // Remove required attribute
    } else {
      $('#router_id').closest('.mb-3').show();
      $('#router_id').attr('required', 'required'); // Add required attribute
    }
  });

  // Import User PPPoE dari Excel
  $('#btnImportUsers').on('click', function() {
    $('#importUsersFile').val('');
    $('#importUsersResult').addClass('d-none').removeClass('alert-success alert-danger alert-warning').empty();
    $('#importUsersModal').modal('show');
  });

  // Perbaiki profil billing + assign grup RADIUS dari paket tenant
  $('#fixPppoeProfilesFromPackagesBtn').on('click', function() {
    const msg = 'Perbaiki profil PPPoE dari paket tenant?\n\n' +
      '- Seragamkan nama profil ke format t{tenant}_profil_*\n' +
      '- Remap paket ke paket milik tenant ini\n' +
      '- Update profil di billing\n' +
      '- Assign grup di RADIUS agar pelanggan siap konek\n\n' +
      'Pelanggan isolir/suspend dilewati.';
    if (!confirm(msg)) return;

    const $btn = $(this);
    const original = $btn.html();
    $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Memperbaiki...');

    fetch('/admin/billing/customers/fix-pppoe-profiles-from-packages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({})
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        const updated = data.updated || 0;
        const radiusUpdated = data.radius_updated || 0;
        if (updated > 0 || radiusUpdated > 0) {
          showToast('success', data.message || `Berhasil memperbaiki ${updated} data`, 6000);
          setTimeout(() => {
            window.location.href = '/admin/mikrotik?refresh=1';
          }, 1500);
        } else {
          showToast('info', data.message || 'Tidak ada pelanggan yang perlu diperbaiki.', 5000);
        }
      } else {
        showToast('error', data.message || 'Gagal memperbaiki profil dari paket', 6000);
      }
    })
    .catch(err => {
      console.error(err);
      showToast('error', 'Terjadi kesalahan saat memperbaiki profil dari paket', 5000);
    })
    .finally(() => {
      $btn.prop('disabled', false).html(original);
    });
  });

  $('#btnSubmitImportUsers').on('click', function() {
    const $btn = $(this);
    if ($btn.prop('disabled')) return;

    const fileInput = document.getElementById('importUsersFile');
    if (!fileInput || !fileInput.files || !fileInput.files[0]) {
      showToast('warning', 'Pilih file Excel (.xlsx) terlebih dahulu');
      return;
    }

    const isRadiusMode = <%= typeof authMode !== 'undefined' && authMode === 'radius' ? 'true' : 'false' %>;
    const formData = new FormData();
    formData.append('file', fileInput.files[0]);

    if (!isRadiusMode) {
      const routerId = $('#importRouterId').val();
      if (!routerId) {
        showToast('warning', 'Pilih NAS (router) untuk import');
        return;
      }
      formData.append('router_id', routerId);
    }

    $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Mengimpor...');
    const $result = $('#importUsersResult');
    $result.addClass('d-none').removeClass('alert-success alert-danger alert-warning').empty();

    $.ajax({
      url: '/admin/mikrotik/import-pppoe-users',
      method: 'POST',
      data: formData,
      processData: false,
      contentType: false,
      success: function(res) {
        const created = res.created || 0;
        const updated = res.updated || 0;
        const failed = res.failed || 0;
        const skipped = res.skipped || 0;
        const errors = Array.isArray(res.errors) ? res.errors : [];
        let html = `<div><strong>${res.message || 'Import selesai'}</strong></div>` +
          `<div class="small mt-1">Baru: ${created} · Diperbarui: ${updated} · Gagal: ${failed} · Dilewati: ${skipped}</div>`;
        if (errors.length) {
          html += '<ul class="small mb-0 mt-2">' + errors.slice(0, 20).map(function(e) {
            return '<li>' + $('<div>').text(e).html() + '</li>';
          }).join('') + '</ul>';
        }
        $result
          .removeClass('d-none alert-success alert-danger alert-warning')
          .addClass(failed > 0 ? 'alert-warning' : 'alert-success')
          .html(html);

        if (created + updated > 0) {
          showToast('success', res.message || 'Import berhasil');
          setTimeout(function() { location.reload(); }, failed > 0 ? 2500 : 1200);
        } else if (failed > 0) {
          showToast('error', res.message || 'Import gagal');
        } else {
          showToast('info', res.message || 'Tidak ada data diimpor');
        }
      },
      error: function(xhr) {
        const msg = (xhr.responseJSON && xhr.responseJSON.message) || 'Gagal import user PPPoE';
        $result.removeClass('d-none alert-success alert-warning').addClass('alert-danger').text(msg);
        showToast('error', msg);
      },
      complete: function() {
        $btn.prop('disabled', false).html('<i class="bi bi-upload me-1"></i> Import');
      }
    });
  });
  
  // Edit User PPPoE
  $(document).on('click', '.edit-user-btn', function() {
    const isRadiusMode = <%= typeof authMode !== 'undefined' && authMode === 'radius' ? 'true' : 'false' %>;
    
    $('#userId').val($(this).data('id'));
    $('#username').val($(this).data('username'));
    $('#password').val($(this).data('password'));
    
    // Load profiles and set selected profile
    const selectedProfile = $(this).data('profile');
    loadProfiles(selectedProfile);
    
    $('#userModalLabel').text('Edit User PPPoE');
    $('#userModal').modal('show');
    
    // Hide router selection in RADIUS mode
    if (isRadiusMode) {
      $('#router_id').closest('.mb-3').hide();
      $('#router_id').removeAttr('required');
    } else {
      $('#router_id').closest('.mb-3').show();
      $('#router_id').attr('required', 'required');
    }
  });
  // Submit Tambah/Edit
  $('#userForm').submit(function(e) {
    e.preventDefault();
    const $form = $(this);
    const $submitBtn = $form.find('button[type="submit"]');
    if ($submitBtn.prop('disabled')) return;

    const id = $('#userId').val();
    const username = $('#username').val();
    const password = $('#password').val();
    const profile = $('#profile').val();
    const router_id = $('#router_id').val();
    const url = id ? '/admin/mikrotik/edit-user' : '/admin/mikrotik/add-user';
    
    const isRadiusMode = <%= typeof authMode !== 'undefined' && authMode === 'radius' ? 'true' : 'false' %>;
    if (!isRadiusMode && !router_id && !id) {
      showWarningAlert('Peringatan', 'Pilih NAS (router) terlebih dahulu!');
      return;
    }

    const btnHtml = $submitBtn.html();
    $submitBtn.prop('disabled', true).html(
      '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Menyimpan...'
    );
    
    $.ajax({
      url: url,
      method: 'POST',
      data: { id, username, password, profile, router_id },
      timeout: 45000
    }).done(function(res) {
      if (res.success) {
        $('#userModal').modal('hide');
        showSuccessAlert('Berhasil', res.message || 'User berhasil disimpan.', function() {
          window.location.href = '/admin/mikrotik?refresh=1';
        });
      } else {
        showErrorAlert('Gagal Menyimpan', res.message || 'Unknown error');
      }
    }).fail(function(xhr) {
      const errorMsg = xhr.responseJSON?.message || 'Terjadi kesalahan saat menyimpan user';
      showErrorAlert('Error', errorMsg);
    }).always(function() {
      $submitBtn.prop('disabled', false).html(btnHtml);
    });
  });
  // Hapus User PPPoE
  $(document).on('click', '.delete-user-btn', function() {
    const username = $(this).data('username');
    const id = $(this).data('id');
    
    showConfirmAlert(
      'Konfirmasi Hapus',
      'Yakin ingin menghapus user PPPoE "' + username + '"?',
      'Ya, Hapus',
      'Batal',
      function() {
        $.post('/admin/mikrotik/delete-user', { id }, function(res) {
          if(res.success) {
            showSuccessAlert('Berhasil!', 'User berhasil dihapus!', function() {
              location.reload();
            });
          } else {
            showErrorAlert('Gagal Menghapus', 'Gagal menghapus user: ' + (res.message || 'Unknown error'));
          }
        }).fail(function(xhr) {
          const errorMsg = xhr.responseJSON?.message || 'Terjadi kesalahan saat menghapus user';
          showErrorAlert('Error', errorMsg);
        });
      }
    );
  });
  
  $('#btnRefreshStats').on('click', function() {
    const $btn = $(this);
    $btn.prop('disabled', true).html('<i class="bi bi-arrow-clockwise spin"></i> Memuat...');
    window.location.href = '/admin/mikrotik?refresh=1';
  });
});
</script>
<script>
// Hamburger & sidebar logic
const hamburger = document.getElementById('hamburgerBtn');
const sidebar = document.getElementById('adminSidebar');
const overlay = document.getElementById('sidebarOverlay');
if (hamburger && sidebar && overlay) {
  hamburger.addEventListener('click', function() {
    sidebar.classList.toggle('show');
    overlay.classList.toggle('show');
  });
  overlay.addEventListener('click', function() {
    sidebar.classList.remove('show');
    overlay.classList.remove('show');
  });
}
</script>
<script>
$(function() {
  // Handler tombol putuskan sesi menggunakan event delegation
  $(document).on('click', '.disconnect-session-btn', function() {
    const username = $(this).data('username');
    const $btn = $(this);
    const originalHtml = $btn.html();
    
    showConfirmAlert(
      'Konfirmasi Disconnect',
      'Yakin ingin memutuskan sesi aktif user ' + username + '?',
      'Ya, Putuskan',
      'Batal',
      function() {
        $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Memproses...');
        
        $.ajax({
          url: '/admin/mikrotik/disconnect-session',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({ username }),
          success: function(data) {
            if (data.success) {
              // Jika disconnected adalah 0, berarti user tidak sedang online
              if (data.disconnected === 0) {
                showInfoAlert('Informasi', data.message || 'User ' + username + ' tidak sedang online');
                $btn.prop('disabled', false).html(originalHtml);
              } else {
                // User berhasil diputuskan
                showSuccessAlert('Berhasil!', data.message || 'Sesi user ' + username + ' berhasil diputuskan!', function() {
                  location.reload();
                });
              }
            } else {
              showErrorAlert('Gagal', 'Gagal memutuskan sesi: ' + (data.message || 'Unknown error'));
              $btn.prop('disabled', false).html(originalHtml);
            }
          },
          error: function(xhr, status, error) {
            let errorMsg = 'Terjadi error saat memutuskan sesi';
            if (xhr.responseJSON && xhr.responseJSON.message) {
              errorMsg = xhr.responseJSON.message;
            } else if (xhr.status === 401 || xhr.status === 403) {
              errorMsg = 'Session expired atau server error. Silakan login ulang.';
            }
            showErrorAlert('Error', errorMsg);
            $btn.prop('disabled', false).html(originalHtml);
          }
        });
      }
    );
  });
});
</script>
<script>
$(function() {
  $(document).on('click', '#restartMikrotikBtn', function(e) {
    e.preventDefault();
    $('#restartMikrotikModal').modal('show');
  });
  $('#confirmRestartMikrotik').on('click', function() {
    $('#restartMikrotikModal').modal('hide');
    $.ajax({
      url: '/admin/mikrotik/restart',
      method: 'POST',
      success: function(res) {
        let notif = $('#restartNotif');
        if(res.success) {
          notif.removeClass('d-none alert-danger').addClass('alert-success').text(res.message || 'Mikrotik berhasil direstart!');
        } else {
          notif.removeClass('d-none alert-success').addClass('alert-danger').text(res.message || 'Gagal restart Mikrotik!');
        }
        setTimeout(function() { notif.addClass('d-none'); }, 4000);
      },
      error: function() {
        let notif = $('#restartNotif');
        notif.removeClass('d-none alert-success').addClass('alert-danger').text('Gagal menghubungi server!');
        setTimeout(function() { notif.addClass('d-none'); }, 4000);
      }
    });
  });
});
</script>
