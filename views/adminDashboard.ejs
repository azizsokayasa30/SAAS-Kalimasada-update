<!DOCTYPE html>
<html lang="id">
<head>
    <!-- Theme Init: Di-handle oleh theme-head.ejs -->
    <%- include('partials/hard-reload') %>
    <meta charset="UTF-8">
    <title><% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>Dashboard Teknisi<% } else { %>Dashboard Admin<% } %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/css/fonts-inter-local.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="/css/fonts-inter-local.css"></noscript>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    
    
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <link href="/css/dashboard-modern.css" rel="stylesheet">
    <% if (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) { %>
    <style>.dash-stat-loading .sc-value, .dash-stat-loading .sc-sub { opacity: 0.45; }</style>
    <script>
    window.__dashOverviewPrefetch = fetch('/admin/dashboard/api/overview', { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .catch(function () { return null; });
    </script>
    <% } %>

    <%- include('partials/theme-head') %>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <!-- Include Responsive Sidebar (Admin or Technician based on context) -->
        <% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>
        <%- include('partials/technician-responsive-sidebar', { page: page || 'dashboard', settings: settings, technician: technician }) %>
        <% } else { %>
        <%- include('partials/admin-responsive-sidebar', { page: 'dashboard', settings: settings }) %>
        <% } %>
        
        <main id="pjax-container" class="col-md-10 ms-sm-auto main-content">
            <% const _greetUser = typeof dashboardGreetingUser !== 'undefined' ? dashboardGreetingUser : (typeof technician !== 'undefined' && technician && technician.name ? technician.name : 'Admin'); %>
            <% const _greetDate = typeof dashboardGreetingDate !== 'undefined' ? dashboardGreetingDate : ''; %>
            <% if (typeof isTechnicianView === 'undefined' || !isTechnicianView) { %>
            <% const _btc = typeof adminNotifBadgeTotal === 'number' ? adminNotifBadgeTotal : 0; %>
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4 dashboard-top-bar">
                <div class="dashboard-greeting">
                    <p class="dashboard-greeting-line mb-0">
                        <span class="dashboard-greeting-title">Hallo <%= _greetUser %>,</span>
                        <span class="dashboard-greeting-subtitle"><%= _greetDate %></span>
                    </p>
                </div>
                <div class="dropdown ms-auto">
                    <button class="btn btn-success d-flex align-items-center gap-2 rounded-pill px-3 py-2 border-0 position-relative shadow text-start text-white fw-semibold"
                            type="button" id="adminNotifBellBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="Pusat notifikasi">
                        <span class="fw-bold text-white lh-sm d-none d-sm-inline" style="font-size:0.95rem; letter-spacing:0.02em;">Pusat notifikasi</span>
                        <span class="fw-bold text-white lh-sm d-sm-none" style="font-size:0.78rem;">Notifikasi</span>
                        <i class="bi bi-bell-fill text-white align-middle" style="font-size:2.15rem; line-height:1;"></i>
                        <span id="adminNotifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger <%= _btc > 0 ? '' : 'd-none' %>"><%= _btc > 99 ? '99+' : _btc %></span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end shadow-lg border mt-2 p-0 rounded-3 overflow-hidden" style="width:min(440px, 96vw);">
                        <div class="px-3 py-2 bg-primary bg-opacity-10 border-bottom small fw-bold text-primary d-flex justify-content-between align-items-center flex-wrap gap-1">
                            <span><i class="bi bi-inboxes me-1"></i>Pratinjau</span>
                            <span class="text-muted fw-normal" style="font-size:0.72rem;">Teknisi · Lunas/isolir · Portal</span>
                        </div>
                        <div id="adminNotifList" class="bg-white" style="max-height:min(380px, 58vh); overflow-y: auto;">
                            <div class="px-3 py-4 text-muted small text-center">Buka menu untuk memuat…</div>
                        </div>
                        <div class="border-top bg-light py-2 px-3 d-grid gap-2">
                            <a href="/admin/dashboard/notifications" class="btn btn-sm btn-primary w-100">Buka halaman lengkap</a>
                            <button type="button" class="btn btn-sm btn-outline-secondary w-100" onclick="clearAdminNotificationsShell(event)">Bersihkan notifikasi</button>
                        </div>
                    </div>
                </div>
            </div>
            <% } else { %>
            <div class="dashboard-greeting mb-4">
                <p class="dashboard-greeting-line mb-0">
                    <span class="dashboard-greeting-title">Hallo <%= _greetUser %>,</span>
                    <span class="dashboard-greeting-subtitle"><%= _greetDate %></span>
                </p>
            </div>
            <% } %>

            <div id="baileysDisconnectAlert" class="alert alert-warning border-0 shadow-sm d-none mb-4" role="alert">
                <div class="d-flex flex-wrap align-items-start gap-2 justify-content-between">
                    <div class="d-flex align-items-start gap-2">
                        <i class="bi bi-whatsapp fs-4 mt-1" id="baileysAlertIcon"></i>
                        <div>
                            <div class="fw-semibold" id="baileysAlertTitle">Status WhatsApp (Baileys)</div>
                            <div class="small mb-0" id="baileysAlertMessage"></div>
                        </div>
                    </div>
                    <a href="/admin/billing/whatsapp-settings" class="btn btn-sm btn-danger text-white" id="baileysAlertCta">
                        Buka WhatsApp Settings
                    </a>
                </div>
            </div>

            <!-- LICENSE STATUS CARD REMOVED -->

            <!-- ====== QUICK ACTION ====== -->
            <% const bs = typeof billingStats !== 'undefined' ? billingStats : {}; %>
            <div class="db-section-label"><i class="bi bi-lightning-charge-fill me-2"></i>Akses Cepat Operasional</div>
            <div class="quick-action-grid mb-4">
                <a href="/admin/billing/customers?quickAction=add-pppoe-customer" class="qa-card qa-indigo" id="qa-add-customer">
                    <div class="qa-icon"><i class="bi bi-person-plus-fill"></i></div>
                    <div class="qa-label">Tambah Pelanggan</div>
                </a>
                <a href="/admin/installations/create" class="qa-card qa-green" id="qa-add-job">
                    <div class="qa-icon"><i class="bi bi-tools"></i></div>
                    <div class="qa-label">Tambah Job Teknisi</div>
                </a>
                <a href="/admin/trouble?quickAction=create-ticket" class="qa-card qa-orange" id="qa-add-ticket">
                    <div class="qa-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div class="qa-label">Tambah Tiket Gangguan</div>
                </a>
                <a href="/admin/billing/payments?quickAction=input-pembayaran" class="qa-card qa-blue" id="qa-payment">
                    <div class="qa-icon"><i class="bi bi-cash-coin"></i></div>
                    <div class="qa-label">Input Pembayaran</div>
                </a>
                <a href="/admin/billing/collector-remittance" class="qa-card qa-purple" id="qa-setoran">
                    <div class="qa-icon"><i class="bi bi-wallet2"></i></div>
                    <div class="qa-label">Terima Setoran</div>
                </a>
                <a href="/admin/billing/expenses" class="qa-card qa-red" id="qa-expense">
                    <div class="qa-icon"><i class="bi bi-box-arrow-up-right"></i></div>
                    <div class="qa-label">Tambah Pengeluaran</div>
                </a>
            </div>

            <% const pkgReqs = typeof portalPackageRequests !== 'undefined' && portalPackageRequests ? portalPackageRequests : []; %>
            <% if (pkgReqs.length > 0) { %>
            <div id="adminPortalPackageRequestsBlock">
            <div class="alert alert-primary d-flex align-items-center gap-2 mb-3 py-3 shadow-sm" role="alert">
                <i class="bi bi-arrow-left-right fs-4"></i>
                <div>
                    <strong>Portal pelanggan:</strong> Ada <strong><%= pkgReqs.length %></strong> permintaan ubah paket (upgrade/downgrade) menunggu tindakan.
                </div>
            </div>
            <div class="card border-primary border-opacity-25 shadow-sm mb-4">
                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="fw-bold"><i class="bi bi-box-seam me-2"></i>Permintaan ubah paket (portal)</span>
                    <span class="badge bg-light text-primary rounded-pill"><%= pkgReqs.length %> pending</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Waktu</th>
                                    <th>Pelanggan</th>
                                    <th>Paket sekarang</th>
                                    <th>Paket diminta</th>
                                    <th class="pe-3 text-end">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% pkgReqs.forEach(function(r) { %>
                                <tr>
                                    <td class="ps-3 text-nowrap text-muted"><%= r.created_at ? new Date(r.created_at).toLocaleString('id-ID', { dateStyle: 'short', timeStyle: 'short' }) : '-' %></td>
                                    <td>
                                        <div class="fw-semibold"><%= r.customer_name || r.customer_username || '—' %></div>
                                        <div class="text-muted" style="font-size:0.75rem;"><%= r.customer_phone || '' %></div>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary-subtle text-secondary"><%= r.current_package_name || '—' %></span>
                                        <% if (r.current_speed) { %><div class="text-muted mt-1" style="font-size:0.75rem;"><%= r.current_speed %></div><% } %>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary"><%= r.target_package_name %></span>
                                        <div class="mt-1" style="font-size:0.75rem;">
                                            <%= r.target_speed || '' %>
                                            <% if (r.target_price_rupiah != null) { %> · <span class="dash-amount" data-amount="Rp <%= Number(r.target_price_rupiah).toLocaleString('id-ID') %>">Rp <%= Number(r.target_price_rupiah).toLocaleString('id-ID') %></span><% } %>
                                        </div>
                                        <% if (r.note) { %><div class="text-muted mt-1 fst-italic" style="font-size:0.72rem;">“<%= r.note %>”</div><% } %>
                                    </td>
                                    <td class="pe-3 text-end text-nowrap">
                                        <% if (r.customer_phone) { %>
                                        <a href="/admin/billing/customers?editPhone=<%= encodeURIComponent(r.customer_phone) %>" class="btn btn-sm btn-primary">Edit pelanggan</a>
                                        <% } else { %>
                                        <a href="/admin/billing/customers" class="btn btn-sm btn-outline-primary">Daftar pelanggan</a>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            </div>
            <% } %>

            <!-- ====== STAT CARDS ====== -->
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <div class="db-section-label m-0"><i class="bi bi-bar-chart-fill me-2"></i>Statistik Pelanggan & Tagihan</div>
                <button type="button" id="dashAmountToggle" class="btn btn-sm btn-outline-secondary dash-amount-toggle-btn" title="Tampilkan nominal" aria-label="Tampilkan nominal" aria-pressed="false">
                    <i class="bi bi-eye" id="dashAmountToggleIcon"></i>
                </button>
            </div>
            <div class="stat-grid-6 mb-4<%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? ' dash-stat-loading' : '' %>" id="dashStatsGrid">
                <a href="/admin/billing/customers" class="stat-card-big stat-indigo" id="sc-total-customer">
                    <div class="sc-header">
                        <span class="sc-label">Total Pelanggan</span>
                        <span class="sc-badge"><i class="bi bi-people-fill me-1"></i> Database</span>
                    </div>
                    <div class="sc-value"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : (bs.total_customers || 0) %></div>
                    <div class="sc-sub">Pelanggan terdaftar total</div>
                </a>
                <a href="/admin/billing/customers?status=active" class="stat-card-big stat-emerald" id="sc-active">
                    <div class="sc-header">
                        <span class="sc-label">Pelanggan Aktif</span>
                        <span class="sc-badge"><i class="bi bi-check-circle-fill me-1"></i> Aktif</span>
                    </div>
                    <div class="sc-value"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : (bs.active_customers || 0) %></div>
                    <div class="sc-sub">Status terkoneksi saat ini</div>
                </a>
                <a href="/admin/billing/customers?status=inactive" class="stat-card-big stat-rose" id="sc-inactive">
                    <div class="sc-header">
                        <span class="sc-label">Pelanggan Nonaktif</span>
                        <span class="sc-badge"><i class="bi bi-x-circle-fill me-1"></i> Isolir</span>
                    </div>
                    <div class="sc-value"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : ((bs.total_customers || 0) - (bs.active_customers || 0)) %></div>
                    <div class="sc-sub">Isolir / Berhenti berlangganan</div>
                </a>
                <% 
                  var tagihanBln = bs.monthly_total_tagihan != null ? bs.monthly_total_tagihan : ((bs.monthly_revenue || 0) + (bs.monthly_unpaid || 0));
                  var lunasBln = bs.monthly_lunas_canonical != null ? bs.monthly_lunas_canonical : (bs.monthly_revenue || 0);
                  var blmBln = bs.monthly_belum_lunas_canonical != null ? bs.monthly_belum_lunas_canonical : (bs.monthly_unpaid || 0);
                  var invBln = bs.monthly_invoice_count_canonical != null ? bs.monthly_invoice_count_canonical : (bs.monthly_invoices || 0);
                  var invBlmBln = bs.monthly_belum_lunas_count_canonical != null ? bs.monthly_belum_lunas_count_canonical : (bs.unpaid_monthly_invoices || 0);
                  var piutangAll = bs.outstanding_unpaid_total != null ? bs.outstanding_unpaid_total : 0;
                  var piutangCnt = bs.outstanding_unpaid_count != null ? bs.outstanding_unpaid_count : 0;
                %>
                <a href="/admin/billing/invoices" class="stat-card-big stat-blue" id="sc-total-invoice">
                    <div class="sc-header">
                        <span class="sc-label">Total Tagihan</span>
                        <span class="sc-badge"><i class="bi bi-receipt me-1"></i> <%= invBln %> Inv</span>
                    </div>
                    <div class="sc-value dash-amount" data-amount="Rp <%= tagihanBln.toLocaleString('id-ID') %>"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : ('Rp ' + tagihanBln.toLocaleString('id-ID')) %></div>
                    <div class="sc-sub"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? 'Memuat…' : ('Lunas Rp ' + lunasBln.toLocaleString('id-ID') + ' · Blm Rp ' + blmBln.toLocaleString('id-ID')) %></div>
                </a>
                <a href="/admin/billing/invoices?status=unpaid" class="stat-card-big stat-amber" id="sc-unpaid">
                    <div class="sc-header">
                        <span class="sc-label">Belum Lunas</span>
                        <span class="sc-badge"><%= invBlmBln %> Inv · Bln Ini</span>
                    </div>
                    <div class="sc-value dash-amount" data-amount="Rp <%= blmBln.toLocaleString('id-ID') %>"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : ('Rp ' + blmBln.toLocaleString('id-ID')) %></div>
                    <div class="sc-sub">Dari tagihan terbit bulan ini</div>
                </a>
                <a href="/admin/billing/invoices?status=unpaid" class="stat-card-big stat-rose" id="sc-piutang-all" title="Semua invoice belum lunas (termasuk bulan lalu)">
                    <div class="sc-header">
                        <span class="sc-label">Piutang Aktif</span>
                        <span class="sc-badge"><%= piutangCnt %> Inv</span>
                    </div>
                    <div class="sc-value dash-amount" data-amount="Rp <%= piutangAll.toLocaleString('id-ID') %>"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : ('Rp ' + piutangAll.toLocaleString('id-ID')) %></div>
                    <div class="sc-sub">Total belum lunas (semua periode)</div>
                </a>
                <a href="/admin/billing/customers" class="stat-card-big stat-teal" id="sc-new-customer">
                    <div class="sc-header">
                        <span class="sc-label">Pelanggan Baru</span>
                        <span class="sc-badge"><i class="bi bi-graph-up-arrow me-1"></i> Plus</span>
                    </div>
                    <div class="sc-value"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : (typeof newCustomersThisMonth !== 'undefined' ? newCustomersThisMonth : 0) %></div>
                    <div class="sc-sub">Bulan berjalan</div>
                </a>
            </div>

            <!-- ====== OPERASIONAL HARI INI ====== -->
            <% const ops = (typeof operationalStats !== 'undefined' && operationalStats) ? operationalStats : {}; %>
            <% 
                const pendingInstallations = Number(ops.pendingInstallations || 0);
                const pendingTroubleTickets = Number(ops.pendingTroubleTickets || 0);
                const employeesAttendedToday = Number(ops.employeesAttendedToday || 0);

                const clsPendingInstallations = pendingInstallations === 0 ? 'stat-emerald' : (pendingInstallations <= 5 ? 'stat-amber' : 'stat-rose');
                const clsPendingTrouble = pendingTroubleTickets === 0 ? 'stat-emerald' : (pendingTroubleTickets <= 10 ? 'stat-amber' : 'stat-rose');
                const clsAttendanceToday = employeesAttendedToday >= 5 ? 'stat-emerald' : (employeesAttendedToday >= 1 ? 'stat-amber' : 'stat-rose');
            %>
            <div class="db-section-label"><i class="bi bi-clipboard2-data-fill me-2"></i>Operasional Hari Ini</div>
            <div class="row mb-4">
                <div class="col-lg-4 mb-3">
                    <a href="/admin/installations" class="stat-card-big <%= clsPendingInstallations %> h-100 d-block text-decoration-none" id="sc-pending-installations">
                        <div class="sc-header">
                            <span class="sc-label">Pending Job Instalasi</span>
                            <span class="sc-badge"><i class="bi bi-tools me-1"></i> Teknisi</span>
                        </div>
                        <div class="sc-value"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : pendingInstallations %></div>
                        <div class="sc-sub">Status scheduled / assigned / in progress</div>
                    </a>
                </div>
                <div class="col-lg-4 mb-3">
                    <a href="/admin/trouble" class="stat-card-big <%= clsPendingTrouble %> h-100 d-block text-decoration-none" id="sc-pending-trouble">
                        <div class="sc-header">
                            <span class="sc-label">Pending Tiket Gangguan</span>
                            <span class="sc-badge"><i class="bi bi-exclamation-triangle-fill me-1"></i> Trouble</span>
                        </div>
                        <div class="sc-value"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : pendingTroubleTickets %></div>
                        <div class="sc-sub">Tiket open / pending / in progress</div>
                    </a>
                </div>
                <div class="col-lg-4 mb-3">
                    <a href="/admin/employees/attendance" class="stat-card-big <%= clsAttendanceToday %> h-100 d-block text-decoration-none" id="sc-attendance-today">
                        <div class="sc-header">
                            <span class="sc-label">Karyawan Sudah Absen</span>
                            <span class="sc-badge"><i class="bi bi-calendar-check-fill me-1"></i> Hari Ini</span>
                        </div>
                        <div class="sc-value"><%= (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) ? '…' : employeesAttendedToday %></div>
                        <div class="sc-sub">Jumlah karyawan unik yang tercatat absen hari ini</div>
                    </a>
                </div>
            </div>

            <!-- ====== NAS MONITORING ====== -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="db-section-label m-0"><i class="bi bi-router-fill me-2"></i>Monitoring NAS & Traffic</div>
                <div class="d-flex align-items-center gap-2">
                    <div id="nasSelect1Container" class="d-flex align-items-center gap-1">
                        <select id="nasSelect1" class="form-select form-select-sm" style="width:180px;font-size:0.85rem; border-color:var(--border);">
                            <option value="">-- Pilih NAS 1 --</option>
                        </select>
                    </div>
                    <div id="nasSelect2Container" class="d-flex align-items-center gap-1">
                        <select id="nasSelect2" class="form-select form-select-sm" style="width:180px;font-size:0.85rem; border-color:var(--border);">
                            <option value="">-- Pilih NAS 2 --</option>
                        </select>
                    </div>
                    <button id="refreshMonitoring" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-clockwise"></i></button>
                    <span id="lastUpdate" class="text-muted" style="font-size:0.75rem;"></span>
                </div>
            </div>
            
            <div id="monitoringContainer" class="row mb-4">
                <div class="col-12 text-center text-muted py-5" style="background: var(--bg-card); border-radius: 12px; border: 1px solid var(--border);">
                    <i class="bi bi-router" style="font-size:3rem;opacity:0.3;"></i>
                    <p class="mt-3">Pilih NAS untuk memulai monitoring</p>
                </div>
            </div>

            <!-- ====== 3 RECENT CARDS ====== -->
            <div class="db-section-label"><i class="bi bi-clock-history me-2"></i>Aktivitas Terbaru</div>
            <div class="row mb-5">
                <!-- Pelanggan Terbaru -->
                <div class="col-lg-4 mb-3">
                    <div class="card recent-card h-100">
                        <div class="card-header recent-card-header d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-person-lines-fill me-2"></i>Pelanggan Terbaru</span>
                            <a href="/admin/billing/customers" class="btn btn-xs btn-outline-primary">Lihat Semua</a>
                        </div>
                        <div class="card-body p-0" id="dashRecentCustomers">
                            <% if (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) { %>
                            <div class="text-center py-4 text-muted small">Memuat data…</div>
                            <% } else if (typeof recentCustomers !== 'undefined' && recentCustomers && recentCustomers.length > 0) { %>
                            <ul class="recent-list">
                                <% recentCustomers.forEach(function(c) { %>
                                <li class="recent-item">
                                    <div class="ri-avatar ri-avatar-blue"><i class="bi bi-person-fill"></i></div>
                                    <div class="ri-info">
                                        <div class="ri-name"><%= c.name %></div>
                                        <div class="ri-sub"><%= c.area || 'Tanpa Area' %></div>
                                    </div>
                                    <div class="ri-right">
                                        <% if (c.status === 'aktif' || c.status === 'active') { %>
                                        <span class="badge-status green">Aktif</span>
                                        <% } else { %>
                                        <span class="badge-status brown">Non-Aktif</span>
                                        <% } %>
                                    </div>
                                </li>
                                <% }); %>
                            </ul>
                            <% } else { %>
                            <div class="text-center py-4 text-muted small"><i class="bi bi-inbox d-block fs-3 mb-2 opacity-25"></i>Belum ada data</div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <!-- Tagihan Lunas Terbaru -->
                <div class="col-lg-4 mb-3">
                    <div class="card recent-card h-100">
                        <div class="card-header recent-card-header d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-receipt-check me-2"></i>Tagihan Lunas Terbaru</span>
                            <a href="/admin/billing/invoices?status=paid" class="btn btn-xs btn-outline-success">Lihat Semua</a>
                        </div>
                        <div class="card-body p-0" id="dashRecentInvoices">
                            <% if (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) { %>
                            <div class="text-center py-4 text-muted small">Memuat data…</div>
                            <% } else if (typeof recentPaidInvoices !== 'undefined' && recentPaidInvoices && recentPaidInvoices.length > 0) { %>
                            <ul class="recent-list">
                                <% recentPaidInvoices.forEach(function(inv) { %>
                                <li class="recent-item">
                                    <div class="ri-avatar ri-avatar-green"><i class="bi bi-check-lg"></i></div>
                                    <div class="ri-info">
                                        <div class="ri-name"><%= inv.customer_name || 'N/A' %></div>
                                        <div class="ri-sub"><%= inv.invoice_number || '-' %></div>
                                    </div>
                                    <div class="ri-right ri-amount dash-amount" data-amount="Rp <%= parseFloat(inv.amount || 0).toLocaleString('id-ID') %>">Rp <%= parseFloat(inv.amount || 0).toLocaleString('id-ID') %></div>
                                </li>
                                <% }); %>
                            </ul>
                            <% } else { %>
                            <div class="text-center py-4 text-muted small"><i class="bi bi-inbox d-block fs-3 mb-2 opacity-25"></i>Belum ada data</div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <!-- Tiket Gangguan Terbaru -->
                <div class="col-lg-4 mb-3">
                    <div class="card recent-card h-100">
                        <div class="card-header recent-card-header d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-bug-fill me-2"></i>Tiket Gangguan Terbaru</span>
                            <a href="/admin/trouble" class="btn btn-xs btn-outline-danger">Lihat Semua</a>
                        </div>
                        <div class="card-body p-0" id="dashRecentTickets">
                            <% if (typeof deferStatsLoad !== 'undefined' && deferStatsLoad) { %>
                            <div class="text-center py-4 text-muted small">Memuat data…</div>
                            <% } else if (typeof recentTickets !== 'undefined' && recentTickets && recentTickets.length > 0) { %>
                            <ul class="recent-list">
                                <% recentTickets.forEach(function(t) { %>
                                <li class="recent-item">
                                    <div class="ri-avatar ri-avatar-red"><i class="bi bi-exclamation-triangle-fill"></i></div>
                                    <div class="ri-info">
                                        <div class="ri-name"><%= t.name || t.customer_name || 'Pelanggan' %></div>
                                        <div class="ri-sub"><%= t.category || t.description && t.description.substring(0,30) || '-' %></div>
                                    </div>
                                    <div class="ri-right">
                                        <% if (t.status === 'open') { %>
                                        <span class="badge-status yellow">Pending</span>
                                        <% } else if (t.status === 'in_progress') { %>
                                        <span class="badge-status blue">Proses</span>
                                        <% } else if (t.status === 'resolved' || t.status === 'closed') { %>
                                        <span class="badge-status green">Selesai</span>
                                        <% } else { %>
                                        <span class="badge-status brown"><%= t.status %></span>
                                        <% } %>
                                    </div>
                                </li>
                                <% }); %>
                            </ul>
                            <% } else { %>
                            <div class="text-center py-4 text-muted small"><i class="bi bi-inbox d-block fs-3 mb-2 opacity-25"></i>Belum ada tiket</div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            </main>
    </div>
</div>
<!-- Modal Konfirmasi Restart Mikrotik -->
<div class="modal fade" id="restartMikrotikModal" tabindex="-1" aria-labelledby="restartMikrotikModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="restartMikrotikModalLabel"><i class="bi bi-arrow-repeat"></i> Konfirmasi Restart Mikrotik</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Apakah Anda yakin ingin <b>restart Mikrotik</b>?<br>Router akan reboot dan koneksi internet pelanggan akan terputus sementara.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
        <button type="button" class="btn btn-danger" id="confirmRestartMikrotik">Restart</button>
      </div>
    </div>
  </div>
</div>
<!-- Toast Container -->
<div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>
<script src="/vendor/jquery/jquery.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
// Fungsi toast notification
function showToast(type, title, message, duration = 5000) {
    const toastId = 'toast-' + Date.now();
    const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-info-circle';
    const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';
    
    const toastHtml = `
        <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true" style="min-width: 300px;">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi ${iconClass} me-2"></i>
                    <strong>${title}</strong><br>
                    <small>${message}</small>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    `;
    
    $('#toast-container').append(toastHtml);
    const toastElement = document.getElementById(toastId);
    const toast = new bootstrap.Toast(toastElement, { delay: duration });
    toast.show();
    
    // Auto remove after hide
    toastElement.addEventListener('hidden.bs.toast', () => {
        toastElement.remove();
    });
}

async function clearAdminNotificationsShell(ev) {
    if (ev && ev.preventDefault) ev.preventDefault();
    if (!confirm('Tandai semua notifikasi teknisi & kolektor sudah dibaca, dan tiadakan permintaan ubah paket portal yang masih pending? Tiket laporan gangguan tidak ditutup dari sini.')) return;
    try {
        const res = await fetch('/admin/dashboard/api/notifications/clear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ dismissPortal: true })
        });
        const data = await res.json();
        if (!data.success) {
            alert(data.message || 'Gagal membersihkan notifikasi');
            return;
        }
        if (typeof showToast === 'function') {
            showToast('success', 'Selesai', 'Notifikasi telah dibersihkan.');
        }
        window.location.reload();
    } catch (e) {
        alert('Gagal: ' + (e && e.message ? e.message : e));
    }
}

$(function() {
  $(document).on('click', '#restartMikrotikBtn', function(e) {
    e.preventDefault();
    $('#restartMikrotikModal').modal('show');
  });
  
  $('#confirmRestartMikrotik').on('click', function() {
    const $btn = $(this);
    const originalText = $btn.html();
    
    // Loading state
    $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Restarting...');
    $('#restartMikrotikModal').modal('hide');
    
    $.ajax({
      url: '/admin/mikrotik/restart',
      method: 'POST',
      success: function(res) {
        if(res.success) {
          showToast('success', 'Restart Berhasil', res.message || 'Mikrotik berhasil direstart!');
        } else {
          showToast('error', 'Restart Gagal', res.message || 'Gagal restart Mikrotik!');
        }
      },
      error: function() {
        showToast('error', 'Error', 'Gagal menghubungi server!');
      },
      complete: function() {
        // Reset button
        $btn.prop('disabled', false).html(originalText);
      }
    });
  });
  
  // Auto-refresh dashboard data jika ada loading indicators
  function checkAndRefreshDashboard() {
    const loadingElements = $('.fs-3:contains("Loading...")');
    if (loadingElements.length > 0) {
      console.log('[Dashboard] Detected loading indicators, refreshing in 10 seconds...');
      setTimeout(() => {
        window.location.reload();
      }, 10000);
    }
  }
  
  // Check untuk loading indicators setiap 30 detik - dioptimasi untuk mengurangi beban (dari 5 detik)
  setInterval(checkAndRefreshDashboard, 30000);

  <% if (typeof isTechnicianView === 'undefined' || !isTechnicianView) { %>
  (function initAdminNotificationCenter() {
    const bellBtn = document.getElementById('adminNotifBellBtn');
    const listEl = document.getElementById('adminNotifList');
    const badgeEl = document.getElementById('adminNotifBadge');
    if (!bellBtn || !listEl) return;

    function escapeHtml(s) {
      const d = document.createElement('div');
      d.textContent = (s == null || s === undefined) ? '' : String(s);
      return d.innerHTML;
    }

    function srcLabel(source) {
      if (source === 'portal') return 'Portal · paket';
      if (source === 'portal_report') return 'Portal · laporan';
      if (source === 'collector') return 'Billing';
      return 'Teknisi';
    }

    function renderList(items) {
      if (!items.length) {
        listEl.innerHTML = '<div class="px-3 py-4 text-muted small text-center">Tidak ada notifikasi baru.</div>';
        return;
      }
      listEl.innerHTML = items.map(function (it) {
        var when = '';
        try {
          if (it.created_at) when = new Date(it.created_at).toLocaleString('id-ID', { dateStyle: 'short', timeStyle: 'short' });
        } catch (e) { when = ''; }
        return (
          '<a class="d-block text-decoration-none px-3 py-2 border-bottom text-dark admin-notif-item" href="' + escapeHtml(it.href) + '">' +
          '<div class="d-flex justify-content-between gap-2">' +
          '<span class="badge bg-secondary bg-opacity-25 text-dark">' + escapeHtml(srcLabel(it.source)) + '</span>' +
          '<small class="text-muted text-nowrap">' + escapeHtml(when) + '</small></div>' +
          '<div class="fw-semibold small mt-1">' + escapeHtml(it.title) + '</div>' +
          '<div class="text-muted mt-0" style="font-size:0.8rem;">' + escapeHtml(it.body) + '</div>' +
          '<div class="text-primary small mt-1">' + escapeHtml(it.actor_label || '') + '</div></a>'
        );
      }).join('');
    }

    async function refreshAdminNotifications() {
      try {
        var res = await fetch('/admin/dashboard/api/notifications?limit=80', { credentials: 'same-origin' });
        var data = await res.json();
        if (!data.success) return;
        var n = parseInt(data.badge, 10) || 0;
        var portalP = parseInt(data.portalPending, 10);
        if (!Number.isNaN(portalP) && portalP === 0) {
          var blk = document.getElementById('adminPortalPackageRequestsBlock');
          if (blk) blk.remove();
        }
        if (badgeEl) {
          badgeEl.textContent = n > 99 ? '99+' : String(n);
          badgeEl.classList.toggle('d-none', n === 0);
        }
        renderList(data.items || []);
      } catch (e) {
        console.warn('[Admin notif]', e);
      }
    }

    var ddRoot = bellBtn.closest('.dropdown');
    if (ddRoot) {
      ddRoot.addEventListener('shown.bs.dropdown', function () { refreshAdminNotifications(); });
    } else {
      bellBtn.addEventListener('click', function () { setTimeout(refreshAdminNotifications, 200); });
    }
    setInterval(refreshAdminNotifications, 120000);
    setTimeout(refreshAdminNotifications, 5000);
  })();
  <% } %>
});

// ===== BILLING ACTION FUNCTIONS =====
async function suspendCustomer(username) {
    const reason = prompt('Masukkan alasan isolir (opsional):', 'Telat bayar');
    if (reason === null) return;
    try {
        const res = await fetch(`/admin/billing/service-suspension/suspend/${encodeURIComponent(username)}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        });
        const data = await res.json();
        if (data.success) {
            showToast('success', 'Isolir Berhasil', `Pelanggan ${username} diisolir.${reason ? ' Alasan: ' + reason : ''}`);
        } else {
            showToast('error', 'Isolir Gagal', data.message || 'Gagal melakukan isolir');
        }
    } catch (e) {
        showToast('error', 'Error', e.message || 'Terjadi kesalahan');
    }
}

async function restoreCustomer(username) {
    const reason = prompt('Masukkan alasan pemulihan (opsional):', 'Manual restore');
    if (reason === null) return;
    try {
        const res = await fetch(`/admin/billing/service-suspension/restore/${encodeURIComponent(username)}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        });
        const data = await res.json();
        if (data.success) {
            showToast('success', 'Restore Berhasil', `Pelanggan ${username} dipulihkan.`);
        } else {
            showToast('error', 'Restore Gagal', data.message || 'Gagal melakukan restore');
        }
    } catch (e) {
        showToast('error', 'Error', e.message || 'Terjadi kesalahan');
    }
}

function sendWaReminder(phone, name, invoiceNumber, amount) {
    if (!phone) { showToast('error', 'Nomor tidak tersedia', 'Nomor WhatsApp pelanggan kosong.'); return; }
    const rupiah = parseFloat(amount || 0).toLocaleString('id-ID');
    const text = `Halo ${name}, ini pengingat tagihan Anda${invoiceNumber ? ' #' + invoiceNumber : ''} sebesar Rp ${rupiah}. Mohon segera melakukan pembayaran. Terima kasih.`;
    window.open(`https://wa.me/${encodeURIComponent(phone)}?text=${encodeURIComponent(text)}`, '_blank');
}

function sendWaReminderFromBtn(btn) {
    sendWaReminder(
        btn.getAttribute('data-phone') || '',
        btn.getAttribute('data-name') || '',
        btn.getAttribute('data-invoicenumber') || '',
        btn.getAttribute('data-amount') || 0
    );
}

</script>

