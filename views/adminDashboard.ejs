<script>
(function () {
  var alertEl = document.getElementById('baileysDisconnectAlert');
  if (!alertEl) return;
  var titleEl = document.getElementById('baileysAlertTitle');
  var msgEl = document.getElementById('baileysAlertMessage');
  var iconEl = document.getElementById('baileysAlertIcon');

  function renderBaileysAlert(payload) {
    var alert = payload && payload.alert;
    if (!payload || !payload.applicable || !alert || alert.connected || !alert.message) {
      alertEl.classList.add('d-none');
      return;
    }
    alertEl.classList.remove('d-none', 'alert-warning', 'alert-danger', 'alert-success');
    alertEl.classList.add(alert.level === 'danger' ? 'alert-danger' : 'alert-warning');
    if (titleEl) {
      titleEl.textContent = alert.needsScan
        ? 'WhatsApp Baileys terputus — perlu scan QR'
        : 'WhatsApp Baileys terputus';
    }
    if (msgEl) msgEl.textContent = alert.message;
    if (iconEl) {
      iconEl.className = 'bi bi-whatsapp fs-4 mt-1 ' + (alert.level === 'danger' ? 'text-danger' : 'text-warning');
    }
  }

  function refreshBaileysAlert() {
    fetch('/admin/dashboard/api/baileys-status', { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(renderBaileysAlert)
      .catch(function () { /* silent */ });
  }

  refreshBaileysAlert();
  setInterval(refreshBaileysAlert, 60000);
})();
</script>
<script>
(function () {
  function loadScript(src) {
    return new Promise(function (resolve, reject) {
      var s = document.createElement('script');
      s.src = src;
      s.async = true;
      s.onload = resolve;
      s.onerror = reject;
      document.body.appendChild(s);
    });
  }
  function loadCharts() {
    loadScript('https://cdn.jsdelivr.net/npm/chart.js')
      .then(function () { return loadScript('/js/dashboard-charts.js'); })
      .catch(function (e) { console.warn('[dashboard] deferred charts:', e); });
  }
  if ('requestIdleCallback' in window) {
    requestIdleCallback(loadCharts, { timeout: 5000 });
  } else {
    window.addEventListener('load', function () { setTimeout(loadCharts, 800); });
  }
})();
</script>
