<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>ISOLIR - <%= companyHeader %></title>
  <meta name="robots" content="noindex, nofollow">
  <meta name="theme-color" content="#0f766e">
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --bg: #ecfdf5;
      --card: #fff;
      --ink: #102a2a;
      --muted: #64748b;
      --line: #e2e8f0;
      --primary: #0f766e;
      --primary-dark: #115e59;
      --wa: #25d366;
      --shadow: 0 18px 50px rgba(15, 118, 110, .16);
    }

    * { box-sizing: border-box; }
    body {
      min-height: 100vh;
      margin: 0;
      color: var(--ink);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      background: radial-gradient(circle at 0 0, rgba(20, 184, 166, .22), transparent 19rem), linear-gradient(180deg, #f8fffd 0%, var(--bg) 100%);
    }

    .page {
      width: min(100%, 720px);
      margin: 0 auto;
      padding: max(12px, env(safe-area-inset-top)) 12px max(18px, env(safe-area-inset-bottom));
    }

    .shell {
      overflow: hidden;
      border: 1px solid rgba(15, 118, 110, .14);
      border-radius: 26px;
      background: rgba(255,255,255,.92);
      box-shadow: var(--shadow);
    }

    .hero {
      padding: 20px;
      color: #fff;
      background: linear-gradient(135deg, #0f766e, #14b8a6);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 18px;
    }

    .brand img {
      width: 42px;
      height: 42px;
      object-fit: contain;
      border-radius: 13px;
      padding: 5px;
      background: rgba(255,255,255,.92);
    }

    .brand-title {
      font-weight: 850;
      line-height: 1.1;
      letter-spacing: -.02em;
    }

    .brand-sub {
      color: rgba(255,255,255,.76);
      font-size: .82rem;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.24);
      font-size: .82rem;
      font-weight: 800;
      margin-bottom: 12px;
    }

    h1 {
      display: inline-flex;
      width: fit-content;
      max-width: 100%;
      align-items: center;
      gap: 9px;
      margin: 0 0 10px;
      padding: 10px 14px;
      border-radius: 18px;
      background: #fff;
      color: #dc2626;
      font-size: clamp(1.8rem, 9vw, 3.2rem);
      line-height: 1;
      letter-spacing: -.045em;
      font-weight: 950;
      box-shadow: 0 12px 28px rgba(15, 118, 110, .18);
    }

    .hero p {
      margin: 0;
      color: rgba(255,255,255,.88);
      line-height: 1.55;
      font-size: .96rem;
    }

    .summary {
      margin-top: 16px;
      border-radius: 20px;
      padding: 15px;
      color: var(--ink);
      background: rgba(255,255,255,.95);
    }

    .label {
      color: var(--muted);
      font-size: .78rem;
      font-weight: 800;
      letter-spacing: .05em;
      text-transform: uppercase;
    }

    .amount {
      margin: 3px 0 10px;
      color: var(--primary-dark);
      font-size: clamp(1.65rem, 9vw, 2.5rem);
      line-height: 1;
      font-weight: 950;
      letter-spacing: -.05em;
    }

    .amount.is-empty {
      font-size: clamp(1.25rem, 6vw, 1.75rem);
      letter-spacing: -.03em;
    }

    .content {
      display: grid;
      gap: 12px;
      padding: 12px;
    }

    .panel {
      border: 1px solid rgba(15, 118, 110, .1);
      border-radius: 20px;
      padding: 15px;
      background: var(--card);
    }

    .title {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 0 0 12px;
      font-size: .98rem;
      font-weight: 900;
      letter-spacing: -.02em;
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .btn-action {
      min-height: 46px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 0;
      border-radius: 15px;
      padding: 11px 14px;
      font-weight: 900;
      text-decoration: none;
    }

    .btn-main { background: var(--primary); color: #fff; }
    .btn-main:hover { background: var(--primary-dark); color: #fff; }
    .btn-wa { background: var(--wa); color: #062b16; }
    .btn-wa:hover { background: #1fbd5c; color: #062b16; }
    .btn-light-action {
      border: 1px solid rgba(15, 118, 110, .22);
      background: #f0fdfa;
      color: var(--primary-dark);
    }

    .step {
      display: grid;
      grid-template-columns: 28px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
      padding: 9px 0;
      border-top: 1px solid #eef2f7;
    }

    .step:first-of-type { border-top: 0; padding-top: 0; }
    .step-no {
      width: 28px;
      height: 28px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--primary-dark);
      background: #ccfbf1;
      font-weight: 950;
      font-size: .85rem;
    }

    .step strong { display: block; font-size: .94rem; }
    .step span { color: var(--muted); font-size: .88rem; }

    .invoice {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      padding: 11px 0;
      border-top: 1px solid #eef2f7;
    }

    .invoice:first-of-type { border-top: 0; padding-top: 0; }
    .invoice-no { font-weight: 900; font-size: .92rem; }
    .invoice-meta { color: var(--muted); font-size: .82rem; }
    .invoice-amount { font-weight: 950; text-align: right; white-space: nowrap; }

    .pay-box {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 12px;
      background: #f8fafc;
      margin-bottom: 10px;
    }

    .copy-value {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 9px 10px;
      border: 1px solid var(--line);
      border-radius: 13px;
      background: #fff;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-weight: 900;
      word-break: break-word;
    }

    .copy-btn {
      flex: 0 0 auto;
      border: 1px solid #99f6e4;
      border-radius: 10px;
      background: #ecfdf5;
      color: var(--primary-dark);
      padding: 6px 9px;
    }

    .qr {
      max-width: 170px;
      width: 70%;
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 8px;
      background: #fff;
    }

    .note {
      border: 1px solid #fde68a;
      border-radius: 16px;
      padding: 12px;
      color: #713f12;
      background: #fffbeb;
      font-size: .9rem;
    }

    .help {
      color: var(--muted);
      text-align: center;
      font-size: .84rem;
      padding: 12px 4px 2px;
    }

    @media (min-width: 680px) {
      .page { padding-block: 28px; }
      .hero { padding: 26px; }
      .content {
        grid-template-columns: 1fr 320px;
        gap: 16px;
        padding: 16px;
      }
      .actions { grid-template-columns: 1fr 1fr; }
      .summary { max-width: 420px; }
    }

    @media (max-width: 380px) {
      .page { padding-inline: 7px; }
      .shell { border-radius: 20px; }
      .hero, .panel { padding: 13px; }
      .content { padding: 9px; }
      .invoice { grid-template-columns: 1fr; }
      .invoice-amount { text-align: left; }
    }
  </style>
</head>
<body>
  <%
    const formatCurrency = (value) => `Rp ${(Number(value) || 0).toLocaleString('id-ID')}`;
    const formatDate = (value) => {
      if (!value) return '-';
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return value;
      return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });
    };
    const hasInvoices = Array.isArray(unpaidInvoices) && unpaidInvoices.length > 0;
    const waCheckText = `Halo Admin ${companyHeader}, saya ${customerName}. Internet saya terisolir karena belum pembayaran. Mohon bantu cek tagihan dan pembayaran.`;
    const waProofText = `Halo Admin ${companyHeader}, saya mau kirim bukti pembayaran, mohon buka isolir setelah pembayaran terkonfirmasi ya`;
    const waCheckEncoded = encodeURIComponent(waCheckText);
    const waProofEncoded = encodeURIComponent(waProofText);
    const waCheckAppUrl = `whatsapp://send?phone=${adminWA}&text=${waCheckEncoded}`;
    const waProofAppUrl = `whatsapp://send?phone=${adminWA}&text=${waProofEncoded}`;
    const waCheckIntentUrl = `intent://send?phone=${adminWA}&text=${waCheckEncoded}#Intent;scheme=whatsapp;package=com.whatsapp;end`;
    const waProofIntentUrl = `intent://send?phone=${adminWA}&text=${waProofEncoded}#Intent;scheme=whatsapp;package=com.whatsapp;end`;
  %>

  <main class="page">
    <section class="shell">
      <header class="hero">
        <div class="brand">
          <% if (logoPath) { %>
            <img src="<%= logoPath %>" alt="Logo <%= companyHeader %>">
          <% } %>
          <div>
            <div class="brand-title"><%= companyHeader %></div>
            <div class="brand-sub">Info pembayaran pelanggan</div>
          </div>
        </div>

        <div class="pill"><i class="bi bi-exclamation-triangle-fill"></i> Pembayaran belum selesai</div>
        <h1><i class="bi bi-exclamation-triangle-fill"></i> Internet Terisolir</h1>
        <p>Halo <strong><%= customerName %></strong>, akses internet sementara dibatasi karena tagihan belum dibayar. Selesaikan pembayaran agar layanan aktif kembali.</p>

        <div class="summary">
          <div class="label">Tagihan belum dibayar</div>
          <div class="amount <%= hasInvoices ? '' : 'is-empty' %>"><%= hasInvoices ? formatCurrency(totalUnpaid) : 'Cek portal' %></div>
          <div class="actions">
            <a class="btn-action btn-main" href="<%= invoiceUrl %>">
              <i class="bi bi-receipt"></i> Cek Tagihan
            </a>
            <a class="btn-action btn-wa" href="<%= waProofIntentUrl %>" data-wa-app="<%= waProofAppUrl %>" data-wa-text="<%= waProofText %>" onclick="openWhatsApp(event, this)">
              <i class="bi bi-whatsapp"></i> Kirim Bukti
            </a>
          </div>
        </div>
      </header>

      <div class="content">
        <div class="d-grid gap-3">
          <section class="panel">
            <h2 class="title"><i class="bi bi-exclamation-circle-fill text-danger"></i> Agar aktif kembali</h2>
            <div class="step">
              <span class="step-no">1</span>
              <div><strong>Cek tagihan</strong><span>Buka customer app untuk melihat nominal.</span></div>
            </div>
            <div class="step">
              <span class="step-no">2</span>
              <div><strong>Bayar</strong><span>Transfer/scan QR sesuai tagihan.</span></div>
            </div>
            <div class="step">
              <span class="step-no">3</span>
              <div><strong>Kirim bukti</strong><span>Kirim bukti via WhatsApp.</span></div>
            </div>
          </section>

          <section class="panel">
            <h2 class="title"><i class="bi bi-receipt-cutoff text-warning"></i> Invoice</h2>
            <% if (hasInvoices) { %>
              <% unpaidInvoices.slice(0, 4).forEach((invoice) => { %>
                <div class="invoice">
                  <div>
                    <div class="invoice-no"><%= invoice.invoice_number || `Invoice #${invoice.id}` %></div>
                    <div class="invoice-meta">
                      Tempo <%= formatDate(invoice.due_date) %>
                      <% if (invoice.package_name) { %> · <%= invoice.package_name %><% } %>
                    </div>
                  </div>
                  <div class="invoice-amount"><%= formatCurrency(invoice.amount) %></div>
                </div>
              <% }) %>
              <% if (unpaidInvoices.length > 4) { %>
                <div class="invoice-meta mt-2">+<%= unpaidInvoices.length - 4 %> invoice lain di portal billing.</div>
              <% } %>
            <% } else { %>
              <div class="note">Invoice belum terbaca otomatis. Buka customer app atau chat admin.</div>
            <% } %>
          </section>
        </div>

        <aside class="d-grid gap-3">
          <section class="panel">
            <h2 class="title"><i class="bi bi-credit-card text-primary"></i> Bayar</h2>

            <% if (qrFile) { %>
              <div class="text-center mb-3">
                <img class="qr" src="/img/<%= qrFile %>" alt="QR pembayaran <%= companyHeader %>">
                <div class="invoice-meta mt-1">Scan QR pembayaran.</div>
              </div>
            <% } %>

            <% if (paymentAccounts && paymentAccounts.bank_transfer) { %>
              <div class="pay-box">
                <div class="fw-bold"><i class="bi bi-bank me-1"></i> Transfer Bank</div>
                <div class="invoice-meta mt-1"><%= paymentAccounts.bank_transfer.bank_name || '-' %> · <%= paymentAccounts.bank_transfer.account_name || '-' %></div>
                <div class="copy-value mt-2">
                  <span id="bankAccount"><%= paymentAccounts.bank_transfer.account_number || '-' %></span>
                  <button class="copy-btn" type="button" onclick="copyText('bankAccount', this)" aria-label="Salin nomor rekening">
                    <i class="bi bi-copy"></i>
                  </button>
                </div>
              </div>
            <% } %>

            <% if (paymentAccounts && paymentAccounts.cash) { %>
              <div class="pay-box">
                <div class="fw-bold"><i class="bi bi-cash-coin me-1"></i> Bayar Tunai</div>
                <div class="invoice-meta mt-1"><%= paymentAccounts.cash.office_address || '-' %></div>
                <div class="fw-bold small mt-1"><%= paymentAccounts.cash.office_hours || '-' %></div>
              </div>
            <% } %>

            <div class="actions">
              <a class="btn-action btn-light-action" href="<%= billingPortalUrl %>">
                <i class="bi bi-phone"></i> Customer App
              </a>
              <a class="btn-action btn-wa" href="<%= waCheckIntentUrl %>" data-wa-app="<%= waCheckAppUrl %>" data-wa-text="<%= waCheckText %>" onclick="openWhatsApp(event, this)">
                <i class="bi bi-whatsapp"></i> WhatsApp
              </a>
            </div>
          </section>

          <section class="panel">
            <h2 class="title"><i class="bi bi-headset text-success"></i> Bantuan</h2>
            <div class="label">Admin</div>
            <div class="fw-bold fs-5"><%= adminDisplay %></div>
            <div class="note mt-2">Setelah pembayaran terverifikasi, internet akan dibuka kembali.</div>
          </section>
        </aside>
      </div>
    </section>

    <div class="help"><%= companyHeader %> · halaman isolir pelanggan</div>
  </main>

  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    function copyText(elementId, button) {
      var el = document.getElementById(elementId);
      if (!el) return;
      var value = el.textContent.trim();
      var done = function() {
        if (!button) return;
        var old = button.innerHTML;
        button.innerHTML = '<i class="bi bi-check-lg"></i>';
        setTimeout(function() { button.innerHTML = old; }, 1200);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(value).then(done).catch(function() {});
        return;
      }
      var ta = document.createElement('textarea');
      ta.value = value;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      done();
    }

    function copyPlainText(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).catch(function() {});
        return;
      }
      var ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }

    function openWhatsApp(event, link) {
      var intentUrl = link.getAttribute('href');
      var appUrl = link.getAttribute('data-wa-app');
      var message = link.getAttribute('data-wa-text') || '';
      copyPlainText(message);

      if (/Android/i.test(navigator.userAgent || '')) {
        event.preventDefault();
        window.location.href = intentUrl;
        setTimeout(function() {
          window.location.href = appUrl;
        }, 900);
      }
    }
  </script>
</body>
</html>
